@model MyStoryTold.Models.ViewModels.RelativeListViewModel
@{
    ViewData["Title"] = "Relatives";
}

<div class="row g-3">
    <div class="col-md-3">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-6">

<h2 class="mb-4">👨‍👩‍👧‍👦 Relatives</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Add Relative -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h5>Add a Relative</h5>
        <div class="row g-2">
            <div class="col-md-5">
                <input type="text" id="relativeSearch" class="form-control" placeholder="Search by name or email..." />
                <div id="relativeSearchResults" class="mt-2"></div>
            </div>
            <div class="col-md-4">
                <select id="relationshipType" class="form-select">
                    <option value="Spouse">Spouse</option>
                    <option value="Parent">Parent</option>
                    <option value="Child">Child</option>
                    <option value="Sibling">Sibling</option>
                    <option value="Aunt">Aunt</option>
                    <option value="Uncle">Uncle</option>
                    <option value="Cousin">Cousin</option>
                    <option value="Grandparent">Grandparent</option>
                    <option value="Grandchild">Grandchild</option>
                    <option value="InLaw">In-Law</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="col-md-3">
                <button id="relativeSearchBtn" class="btn btn-primary w-100">Search</button>
            </div>
        </div>
    </div>
</div>

<!-- Pending Received -->
@if (Model.PendingReceived.Any())
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">🔔 Pending Requests</h5>
            @foreach (var item in Model.PendingReceived)
            {
                <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                    <div>
                        <strong>@(item.User.DisplayName ?? item.User.UserName)</strong>
                        <span class="badge bg-info ms-1">@item.RelationshipType</span>
                    </div>
                    <div class="d-flex gap-1">
                        <form asp-action="Accept" asp-route-id="@item.ConnectionId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-success">Accept</button>
                        </form>
                        <form asp-action="Decline" asp-route-id="@item.ConnectionId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger">Decline</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Pending Sent -->
@if (Model.PendingSent.Any())
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">⏳ Sent Requests</h5>
            @foreach (var item in Model.PendingSent)
            {
                <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                    <div>
                        <span>@(item.User.DisplayName ?? item.User.UserName)</span>
                        <span class="badge bg-info ms-1">@item.RelationshipType</span>
                    </div>
                    <span class="badge bg-warning text-dark">Pending</span>
                </div>
            }
        </div>
    </div>
}

<!-- Accepted Relatives -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">My Relatives (@Model.Relatives.Count)</h5>

        @if (!Model.Relatives.Any())
        {
            <p class="text-muted">No relatives added yet.</p>
        }

        @foreach (var rel in Model.Relatives)
        {
            <div class="d-flex align-items-center justify-content-between border-bottom py-3">
                <div>
                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@rel.User.Id" class="fw-semibold text-decoration-none">
                        @(rel.User.DisplayName ?? rel.User.UserName)
                    </a>
                    <span class="badge bg-info ms-1">@rel.RelationshipType</span>
                </div>
                <form asp-action="Remove" asp-route-id="@rel.ConnectionId" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove this relative?')">✕</button>
                </form>
            </div>
        }
    </div>
</div>

    </div>
    <div class="col-md-3">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>
</div>

@section Scripts {
<script>
document.getElementById('relativeSearchBtn').addEventListener('click', function() {
    var q = document.getElementById('relativeSearch').value;
    if (q.length < 2) return;
    fetch('/Relatives/SearchUsers?q=' + encodeURIComponent(q))
        .then(r => r.json())
        .then(users => {
            var type = document.getElementById('relationshipType').value;
            var html = '';
            users.forEach(function(u) {
                html += '<div class="d-flex align-items-center justify-content-between border-bottom py-2">';
                html += '<span>' + (u.displayName || u.userName) + '</span>';
                html += '<form action="/Relatives/SendRequest" method="post" class="d-inline">';
                html += '<input type="hidden" name="__RequestVerificationToken" value="' + document.querySelector('input[name=__RequestVerificationToken]').value + '" />';
                html += '<input type="hidden" name="userBId" value="' + u.userId + '" />';
                html += '<input type="hidden" name="relationshipType" value="' + type + '" />';
                html += '<button class="btn btn-sm btn-primary">+ Add as ' + type + '</button></form></div>';
            });
            if (users.length === 0) html = '<p class="text-muted">No users found.</p>';
            document.getElementById('relativeSearchResults').innerHTML = html;
        });
});
</script>
}
