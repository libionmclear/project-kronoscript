@model MyStoryTold.Models.ApplicationUser?
@inject MyStoryTold.Services.ILocalizer _t
@{
    var navName = !string.IsNullOrWhiteSpace(Model?.FirstName) ? Model!.FirstName : User.Identity?.Name;
}
<li class="nav-item dropdown" data-tour="user-menu">
    <a class="nav-link dropdown-toggle nav-link-gold" href="#" role="button" data-bs-toggle="dropdown">
        @navName
    </a>
    <ul class="dropdown-menu dropdown-menu-end">
        <!-- Personal: profile + settings (which holds privacy controls) -->
        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index" asp-route-id="">@_t["My Profile"]</a></li>
        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Edit" asp-route-id="">⚙️ @_t["Settings"]</a></li>

        <li><hr class="dropdown-divider" /></li>

        <!-- Content: drafts, working index, export, deleted archive -->
        <li><a class="dropdown-item" asp-controller="Posts" asp-action="Drafts" asp-route-id="">@_t["My Drafts"]</a></li>
        <li><a class="dropdown-item" asp-controller="WorkingIndex" asp-action="Index" asp-route-id="">@_t["Working Index"]</a></li>
        <li><a class="dropdown-item" asp-controller="PersonProfiles" asp-action="Index" asp-route-id="">@_t["People profiles"]</a></li>
        <li><a class="dropdown-item" asp-controller="FamilyTree" asp-action="Index" asp-route-id="">@_t["Family tree"]</a></li>
        <li><a class="dropdown-item" asp-controller="Export" asp-action="Index" asp-route-id="">@_t["Export"]</a></li>
        <li><a class="dropdown-item" asp-controller="Posts" asp-action="Deleted">@_t["Deleted Stories"]</a></li>

        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        {
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item fw-semibold" asp-controller="Admin" asp-action="Index" asp-route-id="" style="color:var(--mst-primary);">⚙️ @_t["Admin Panel"]</a></li>
        }

        <li><hr class="dropdown-divider" /></li>

        <!-- Footer: legal, info, sign out -->
        <li><a class="dropdown-item" asp-controller="Home" asp-action="About">@_t["About"]</a></li>
        <li><a class="dropdown-item" asp-controller="Home" asp-action="Privacy">@_t["Privacy"]</a></li>
        <li><a class="dropdown-item" asp-controller="Home" asp-action="Agreement">@_t["User Agreement"]</a></li>
        <li><a class="dropdown-item" asp-controller="Home" asp-action="AcceptableUse">@_t["Acceptable Use"]</a></li>

        <li><hr class="dropdown-divider" /></li>
        <li>
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="dropdown-item">@_t["Sign out"]</button>
            </form>
        </li>
    </ul>
</li>
