@model MyStoryTold.Models.ApplicationUser?
@inject MyStoryTold.Services.ILocalizer _t
@inject MyStoryTold.Services.IPremiumService _premium
@{
    var navName = !string.IsNullOrWhiteSpace(Model?.FirstName) ? Model!.FirstName : User.Identity?.Name;

    // Premium-section visibility — hide menu items the current user
    // can't reach (Off mode for non-admins). Admins always see every
    // entry, mode notwithstanding, so they can keep testing.
    var showProfiles = await _premium.IsAvailableAsync(Model, MyStoryTold.Models.PremiumFeature.PeopleProfiles);
    var showTree     = await _premium.IsAvailableAsync(Model, MyStoryTold.Models.PremiumFeature.FamilyTree);
    var showGroups   = await _premium.IsAvailableAsync(Model, MyStoryTold.Models.PremiumFeature.FamilyGroups);
    var anyPremium   = showProfiles || showTree || showGroups;
}
<li class="nav-item dropdown" data-tour="user-menu">
    <a class="nav-link dropdown-toggle nav-link-gold" href="#" role="button" data-bs-toggle="dropdown">
        @navName
    </a>
    <ul class="dropdown-menu dropdown-menu-end">
        <!-- Personal: profile + settings (which holds privacy controls) -->
        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index" asp-route-id="">@_t["My Profile"]</a></li>
        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Edit" asp-route-id="">⚙️ @_t["Settings"]</a></li>

        <li><hr class="dropdown-divider" /></li>

        <!-- Content: book, drafts, working index, export, deleted archive -->
        <li><a class="dropdown-item" asp-controller="Book" asp-action="Index" asp-route-id="">📖 @_t["My memoir"]</a></li>
        <li><a class="dropdown-item" asp-controller="Posts" asp-action="Drafts" asp-route-id="">@_t["My Drafts"]</a></li>
        <li><a class="dropdown-item" asp-controller="WorkingIndex" asp-action="Index" asp-route-id="">@_t["Working Index"]</a></li>
        <li><a class="dropdown-item" asp-controller="Export" asp-action="Index" asp-route-id="">@_t["Export"]</a></li>
        <li><a class="dropdown-item" asp-controller="Posts" asp-action="Deleted">@_t["Deleted Stories"]</a></li>

        @* Premium subsection — gathers everything tagged premium in the
           catalog so members can find them in one place. Each row is
           hidden when its FeatureMode is Off for the current viewer.
           The whole header disappears when nothing is visible. *@
        @if (anyPremium)
        {
            <li><hr class="dropdown-divider" /></li>
            <li><h6 class="dropdown-header" style="color:var(--mst-primary);font-weight:600;">⭐ @_t["Premium"]</h6></li>
            @if (showProfiles)
            {
                <li><a class="dropdown-item" asp-controller="Connections" asp-action="Index" asp-route-id="">@_t["Connections"]</a></li>
            }
            @if (showTree)
            {
                <li><a class="dropdown-item" asp-controller="FamilyTree" asp-action="Index" asp-route-id="">@_t["Family tree"]</a></li>
            }
            @if (showGroups)
            {
                <li><a class="dropdown-item" asp-controller="FamilyGroups" asp-action="Index" asp-route-id="">@_t["Family Groups"]</a></li>
            }
        }

        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        {
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item fw-semibold" asp-controller="Admin" asp-action="Index" asp-route-id="" style="color:var(--mst-primary);">⚙️ @_t["Admin Panel"]</a></li>
        }

        <li><hr class="dropdown-divider" /></li>

        @* Premium Services section — ad-hoc paid deliverables (hardcover
           prints, editing, audio books, etc.). Lives in its own section
           above the Footer so it doesn't get confused with the legal /
           Sign out group below. *@
        <li><h6 class="dropdown-header" style="color:var(--mst-accent-2);font-weight:600;">✨ @_t["Premium Services"]</h6></li>
        <li><a class="dropdown-item" asp-controller="PremiumServices" asp-action="Index" asp-route-id="">@_t["Browse services"]</a></li>

        <li><hr class="dropdown-divider" /></li>

        <!-- Footer: legal, info, sign out -->
        <li><a class="dropdown-item" asp-controller="Home" asp-action="About">@_t["About"]</a></li>
        <li><a class="dropdown-item" asp-controller="Home" asp-action="Privacy">@_t["Privacy"]</a></li>
        <li><a class="dropdown-item" asp-controller="Home" asp-action="Agreement">@_t["User Agreement"]</a></li>
        <li><a class="dropdown-item" asp-controller="Home" asp-action="AcceptableUse">@_t["Acceptable Use"]</a></li>

        <li><hr class="dropdown-divider" /></li>
        <li>
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="dropdown-item">@_t["Sign out"]</button>
            </form>
        </li>
    </ul>
</li>
