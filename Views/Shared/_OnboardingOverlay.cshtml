@*
    Onboarding overlay — six-panel Cleopatra & Caesar narrative.
    Shown once per browser session (sessionStorage) on Home/Index for authed users,
    permanently dismissed via localStorage when the user ticks "Don't show again".
*@
<div id="kronOnboard" class="kron-onboard-backdrop" style="display:none;" aria-hidden="true">
    <div class="kron-onboard-modal" role="dialog" aria-modal="true" aria-labelledby="kronOnboardTitle">
        <button type="button" class="kron-onboard-close" id="kronOnboardClose" aria-label="Close">&times;</button>
        <button type="button" class="kron-onboard-arrow left" id="kronOnboardPrev" aria-label="Previous">&#10094;</button>
        <button type="button" class="kron-onboard-arrow right" id="kronOnboardNext" aria-label="Next">&#10095;</button>

        <div class="kron-onboard-slide active" data-step="1">
            <div class="kron-onboard-illustration">
                <img src="~/images/001.webp" alt="Cleopatra holding the linen bed-sack, remembering"
                     onerror="this.style.display='none';this.parentElement.classList.add('kron-onboard-illustration--placeholder');this.parentElement.textContent='📜';" />
            </div>
            <div class="kron-onboard-title" id="kronOnboardTitle">The Spark</div>
            <div class="kron-onboard-tagline">A memory finds you in an ordinary moment.</div>
            <div class="kron-onboard-body">
                Memories come and go — catch them. Kronoscript is on your phone, ready
                the second one arrives. One tap on <strong>Quick Story</strong> and you're writing.
            </div>
        </div>

        <div class="kron-onboard-slide" data-step="2">
            <div class="kron-onboard-illustration">
                <img src="~/images/002.webp" alt="Cleopatra writing the memory of meeting Julius"
                     onerror="this.style.display='none';this.parentElement.classList.add('kron-onboard-illustration--placeholder');this.parentElement.textContent='✍';" />
            </div>
            <div class="kron-onboard-title">The Capture</div>
            <div class="kron-onboard-tagline">A thought is all it takes.</div>
            <div class="kron-onboard-body">
                A thought is enough. Add a year, a song, a photo, the people who were there.
                Beautifully kept, dated, yours forever.
            </div>
        </div>

        <div class="kron-onboard-slide" data-step="3">
            <div class="kron-onboard-illustration">
                <img src="~/images/003.webp" alt="Julius writing his version of the same meeting from Rome"
                     onerror="this.style.display='none';this.parentElement.classList.add('kron-onboard-illustration--placeholder');this.parentElement.textContent='🤝';" />
            </div>
            <div class="kron-onboard-title">The Other Side</div>
            <div class="kron-onboard-tagline">Your circle makes every story richer.</div>
            <div class="kron-onboard-body">
                Tag the friends who were there — they add what they remember, the detail
                you forgot, the photo from their pocket. Your story grows with every voice.
            </div>
        </div>

        <div class="kron-onboard-slide" data-step="4">
            <div class="kron-onboard-illustration">
                <img src="~/images/004.webp" alt="Cleopatra weaving Julius's version into her own record"
                     onerror="this.style.display='none';this.parentElement.classList.add('kron-onboard-illustration--placeholder');this.parentElement.textContent='💬';" />
            </div>
            <div class="kron-onboard-title">The Enrichment</div>
            <div class="kron-onboard-tagline">One memory, many voices — the fuller it becomes.</div>
            <div class="kron-onboard-body">
                Their replies, photos, and clips attach right to your story. What started
                as a thought becomes a chorus — shared, true, and kept for good.
            </div>
        </div>

        <div class="kron-onboard-slide" data-step="5">
            <div class="kron-onboard-illustration">
                <img src="~/images/005.webp" alt="Cleopatra writing as Caesarion grows"
                     onerror="this.style.display='none';this.parentElement.classList.add('kron-onboard-illustration--placeholder');this.parentElement.textContent='🌳';" />
            </div>
            <div class="kron-onboard-title">Time Passing</div>
            <div class="kron-onboard-tagline">Your story writes itself, a little every day.</div>
            <div class="kron-onboard-body">
                Daily prompts spark a sentence. <em>"On this day, eight years ago…"</em>
                memories return on cue. Your <strong>Working Index</strong> fills, year by
                year — without effort.
            </div>
        </div>

        <div class="kron-onboard-slide" data-step="6">
            <div class="kron-onboard-illustration">
                <img src="~/images/006.webp" alt="Caesarion in the Library of Alexandria, ordering the chronicle"
                     onerror="this.style.display='none';this.parentElement.classList.add('kron-onboard-illustration--placeholder');this.parentElement.textContent='📖';" />
            </div>
            <div class="kron-onboard-title">The Chronicle</div>
            <div class="kron-onboard-tagline">Hold your life in your hands.</div>
            <div class="kron-onboard-body">
                Reorder. Polish. <strong>Export</strong>. A beautiful, illustrated book of
                your story — yours to keep, yours to pass on.
            </div>
        </div>

        <div class="kron-onboard-dots">
            <button type="button" class="kron-onboard-dot active" data-dot="1" aria-label="Step 1"></button>
            <button type="button" class="kron-onboard-dot" data-dot="2" aria-label="Step 2"></button>
            <button type="button" class="kron-onboard-dot" data-dot="3" aria-label="Step 3"></button>
            <button type="button" class="kron-onboard-dot" data-dot="4" aria-label="Step 4"></button>
            <button type="button" class="kron-onboard-dot" data-dot="5" aria-label="Step 5"></button>
            <button type="button" class="kron-onboard-dot" data-dot="6" aria-label="Step 6"></button>
        </div>

        <div class="kron-onboard-nav">
            <label class="dont-show">
                <input type="checkbox" id="kronOnboardDontShow" />
                Don't show this again
            </label>
            <button type="button" class="btn btn-sm btn-quick-story text-white px-3" id="kronOnboardDone" style="display:none;">Got it!</button>
        </div>
    </div>
</div>

<script>
(function () {
    // v4 keys for the 6-panel narrative — resets prior dismissals so users see the refresh once.
    var PERMANENT_KEY = 'kronOnboardDismissed_v4';
    var SESSION_KEY   = 'kronOnboardSeenThisSession_v4';
    try { if (localStorage.getItem(PERMANENT_KEY) === '1') return; } catch (e) {}
    try { if (sessionStorage.getItem(SESSION_KEY) === '1') return; } catch (e) {}

    var backdrop = document.getElementById('kronOnboard');
    if (!backdrop) return;
    backdrop.style.display = 'flex';
    backdrop.setAttribute('aria-hidden', 'false');
    try { sessionStorage.setItem(SESSION_KEY, '1'); } catch (e) {}

    var slides = backdrop.querySelectorAll('.kron-onboard-slide');
    var dots   = backdrop.querySelectorAll('.kron-onboard-dot');
    var prevBtn = document.getElementById('kronOnboardPrev');
    var nextBtn = document.getElementById('kronOnboardNext');
    var doneBtn = document.getElementById('kronOnboardDone');
    var closeBtn = document.getElementById('kronOnboardClose');
    var dontShow = document.getElementById('kronOnboardDontShow');
    var current = 0;

    function render() {
        slides.forEach(function (s, i) { s.classList.toggle('active', i === current); });
        dots.forEach(function (d, i) { d.classList.toggle('active', i === current); });
        prevBtn.style.visibility = (current === 0) ? 'hidden' : 'visible';
        var atEnd = current === slides.length - 1;
        nextBtn.style.visibility = atEnd ? 'hidden' : 'visible';
        doneBtn.style.display = atEnd ? 'inline-block' : 'none';
    }

    function dismiss() {
        if (dontShow && dontShow.checked) {
            try { localStorage.setItem(PERMANENT_KEY, '1'); } catch (e) {}
        }
        backdrop.style.display = 'none';
        backdrop.setAttribute('aria-hidden', 'true');
    }

    nextBtn.addEventListener('click', function () {
        if (current < slides.length - 1) { current++; render(); }
    });
    prevBtn.addEventListener('click', function () {
        if (current > 0) { current--; render(); }
    });
    doneBtn.addEventListener('click', dismiss);
    closeBtn.addEventListener('click', dismiss);
    dots.forEach(function (d, i) {
        d.addEventListener('click', function () { current = i; render(); });
    });
    backdrop.addEventListener('click', function (e) {
        if (e.target === backdrop) dismiss();
    });
    document.addEventListener('keydown', function (e) {
        if (backdrop.getAttribute('aria-hidden') === 'true') return;
        if (e.key === 'ArrowRight' && current < slides.length - 1) { current++; render(); }
        else if (e.key === 'ArrowLeft' && current > 0) { current--; render(); }
        else if (e.key === 'Escape') dismiss();
    });

    render();
})();
</script>
