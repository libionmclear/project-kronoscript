@model MyStoryTold.Models.ViewModels.DashboardViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration _config
@inject MyStoryTold.Services.ILocalizer _t
@inject Microsoft.AspNetCore.Identity.UserManager<MyStoryTold.Models.ApplicationUser> _userManager
@using MyStoryTold.Helpers
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var act  = ViewContext.RouteData.Values["action"]?.ToString();
    var onHome = ctrl == "Home" && act == "Index";
    var todayPrompt = Context.Items["SidebarPromptText"] as string;
    var onThisDay = Context.Items["SidebarOnThisDay"] as List<MyStoryTold.Models.LifeEventPost>;
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await _userManager.GetUserAsync(User)
        : null;
    var isPremium = currentUser.HasPremium();
}

<!-- Quick actions: just the Premium CTA. The theme toggle + new-story
     "+" live in the top navbar next to the tips lightbulb, so the
     left rail can stay focused on the Premium upsell. -->
<div class="rail-section rail-compose">
    @if (isPremium)
    {
        <div class="rail-premium-badge" title="You're a Premium member. Thank you!">
            <span class="rail-premium-icon">⭐</span>
            <span class="rail-premium-text">@_t["Premium Member"]</span>
        </div>
    }
    else
    {
        <a asp-controller="Premium" asp-action="Index" class="rail-premium-cta" title="See what Premium unlocks">
            <span class="rail-premium-icon">⭐</span>
            <span class="rail-premium-text">@_t["Become Premium"]</span>
        </a>
    }
</div>

@{
    var rotation = Context.Items["SidebarRotation"] as System.Collections.IList;
}
@if (rotation != null && rotation.Count > 0)
{
    var rotationJson = System.Text.Json.JsonSerializer.Serialize(rotation);
    <!-- Rotating: Today's Prompt + Tips & Announcements (cycles every 5s) -->
    <div class="rail-section rail-rotator" data-items='@Html.Raw(rotationJson)'>
        <span class="tips-badge rail-rotator-badge">…</span>
        <div class="rail-rotator-text rail-prompt-text mt-2"></div>
        <a class="rail-prompt-btn rail-rotator-btn" style="display:none;">Write about it &rarr;</a>
    </div>
}

@* Ko-fi "Support the project" block removed — the Premium CTA above
   serves the same role for monetisation, more elegantly. *@

<!-- My Network -->
<details class="rail-section rail-collapsible" open>
    <summary class="rail-head">@_t["My Network"]</summary>
    <ul class="rail-list">
        <li>
            <a asp-controller="Friends" asp-action="Index" asp-route-tier="Acquaintance" class="rail-link">
                <span><span class="tier-dot" style="background-color:var(--tier-acquaintances);"></span>@_t["Acquaintances"]</span>
                <span class="d-inline-flex align-items-center gap-1">
                    @if (Model.NewAcquaintancesThisWeek > 0) { <span class="rail-week-pill">+@Model.NewAcquaintancesThisWeek</span> }
                    <span class="badge rounded-pill" style="background-color:var(--tier-acquaintances);color:#fff;">@Model.AcquaintancesCount</span>
                </span>
            </a>
        </li>
        <li>
            <a asp-controller="Friends" asp-action="Index" asp-route-tier="Friend" class="rail-link">
                <span><span class="tier-dot" style="background-color:var(--tier-friends);"></span>@_t["Friends"]</span>
                <span class="d-inline-flex align-items-center gap-1">
                    @if (Model.NewFriendsThisWeek > 0) { <span class="rail-week-pill">+@Model.NewFriendsThisWeek</span> }
                    <span class="badge rounded-pill" style="background-color:var(--tier-friends);color:#fff;">@Model.FriendsCount</span>
                </span>
            </a>
        </li>
        <li>
            <a asp-controller="Friends" asp-action="Index" asp-route-tier="Family" class="rail-link">
                <span><span class="tier-dot" style="background-color:var(--tier-family);"></span>@_t["Family"]</span>
                <span class="d-inline-flex align-items-center gap-1">
                    @if (Model.NewFamilyThisWeek > 0) { <span class="rail-week-pill">+@Model.NewFamilyThisWeek</span> }
                    <span class="badge rounded-pill" style="background-color:var(--tier-family);color:#000;">@Model.FamilyCount</span>
                </span>
            </a>
        </li>
        <li class="rail-list-divider">
            <a asp-controller="Posts" asp-action="Tagged" class="rail-link">
                <span>@_t["Tagged"]</span>
                <span class="badge rounded-pill @(Model.TaggedCount > 0 ? "bg-warning text-dark" : "bg-light text-muted")">@Model.TaggedCount</span>
            </a>
        </li>
        <li>
            <a asp-controller="Friends" asp-action="Index" class="rail-link">
                <span>@_t["Requests"]</span>
                <span class="badge rounded-pill @(Model.PendingRequestsCount > 0 ? "bg-danger" : "bg-light text-muted")">@Model.PendingRequestsCount</span>
            </a>
        </li>
    </ul>
</details>

<!-- Recently Active -->
<details class="rail-section rail-collapsible" open>
    <summary class="rail-head">@_t["Recently active"]</summary>
    @if (Model.ActiveFriends.Any())
    {
        <ul class="rail-list">
            @foreach (var friend in Model.ActiveFriends.Take(8))
            {
                string tag;
                string tagClass = "rail-tag";
                if (friend.IsOnline)
                {
                    tag = "online";
                    tagClass += " rail-tag-online";
                }
                else if (friend.LastPostedAt.HasValue)
                {
                    var ago = DateTime.UtcNow - friend.LastPostedAt.Value;
                    if (ago.TotalMinutes < 60) tag = "just now";
                    else if (ago.TotalHours < 24) tag = $"{(int)ago.TotalHours}h ago";
                    else if (ago.TotalDays < 7) tag = $"{(int)ago.TotalDays}d ago";
                    else if (ago.TotalDays < 30) tag = $"{(int)(ago.TotalDays / 7)}w ago";
                    else tag = friend.LastPostedAt.Value.ToString("MMM yyyy");
                }
                else
                {
                    tag = "";
                }

                <li>
                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@friend.User.Id"
                       class="rail-link rail-friend-link">
                        @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = friend.User, Size = 26 })
                        <span class="rail-friend-name">@(friend.User.DisplayName ?? friend.User.UserName)</span>
                        @if (!string.IsNullOrEmpty(tag))
                        {
                            <span class="@tagClass">@tag</span>
                        }
                    </a>
                </li>
            }
        </ul>
        <a asp-controller="Friends" asp-action="Index" class="rail-footer-link">See everyone &rarr;</a>
    }
    else
    {
        <p class="rail-empty">No recent activity yet.</p>
    }
</details>

@if (onThisDay != null && onThisDay.Any())
{
    <!-- On This Day -->
    <div class="rail-section rail-on-this-day">
        <div class="rail-head">On This Day</div>
        @foreach (var p in onThisDay.Take(2))
        {
            var years = DateTime.UtcNow.Year - p.EventYear;
            <div class="rail-otd-row">
                <span class="rail-otd-year">@years yr@(years == 1 ? "" : "s") ago</span>
                <a asp-controller="Posts" asp-action="Detail" asp-route-id="@p.Id" class="rail-otd-link">
                    @(string.IsNullOrWhiteSpace(p.Title) ? MyStoryTold.Helpers.BodyRenderer.TextPreview(p.Body, 60) : p.Title)
                </a>
            </div>
        }
    </div>
}


@* "Coming Soon" section removed — most of those features either
   shipped or live in the Premium benefits page now. *@
