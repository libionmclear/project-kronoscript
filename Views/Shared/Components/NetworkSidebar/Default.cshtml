@model MyStoryTold.Models.ViewModels.DashboardViewModel

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h6 class="fw-bold mb-3" style="color: var(--mst-primary);">My Network</h6>
        <ul class="list-unstyled mb-0">
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                    <span>👋 Acquaintances</span>
                    <span class="badge rounded-pill" style="background-color:#ffc107;color:#000;">@Model.AcquaintancesCount</span>
                </a>
            </li>
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                    <span>👥 Friends</span>
                    <span class="badge rounded-pill" style="background-color:#198754;">@Model.FriendsCount</span>
                </a>
            </li>
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" asp-fragment="family" class="text-decoration-none d-flex justify-content-between">
                    <span>👨‍👩‍👧 Family</span>
                    <span class="badge rounded-pill" style="background-color:#87ceeb;color:#000;">@Model.FamilyCount</span>
                </a>
            </li>
            <li class="py-1 border-top mt-2 pt-2">
                <a asp-controller="Posts" asp-action="Tagged" class="text-decoration-none d-flex justify-content-between">
                    <span>🏷️ Tagged</span>
                    @if (Model.TaggedCount > 0)
                    {
                        <span class="badge rounded-pill bg-warning text-dark">@Model.TaggedCount</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-light text-muted">0</span>
                    }
                </a>
            </li>
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                    <span>🔔 Requests</span>
                    @if (Model.PendingRequestsCount > 0)
                    {
                        <span class="badge rounded-pill bg-danger">@Model.PendingRequestsCount</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-light text-muted">0</span>
                    }
                </a>
            </li>
        </ul>
    </div>
</div>

@if (Model.NewMembers.Any())
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <h6 class="fw-bold mb-3" style="color: var(--mst-primary);">New Members</h6>
            <ul class="list-unstyled mb-0">
                @foreach (var member in Model.NewMembers)
                {
                    <li class="py-1">
                        <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@member.Id"
                           class="text-decoration-none d-flex align-items-center gap-2">
                            @if (!string.IsNullOrEmpty(member.ProfilePhotoUrl))
                            {
                                <img src="@member.ProfilePhotoUrl" class="rounded-circle" width="24" height="24" style="object-fit:cover;" />
                            }
                            else
                            {
                                <span class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:24px;height:24px;font-size:12px;">👤</span>
                            }
                            <span class="small">@(member.DisplayName ?? member.UserName)</span>
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-3">
        <h6 class="fw-bold mb-3" style="color: var(--mst-primary);">Tips &amp; Announcements</h6>
        <ul class="list-unstyled mb-0">
            <li class="py-1 border-bottom">
                <span class="badge rounded-pill me-1" style="background-color: var(--mst-accent); color:#000; font-size:10px;">NEW</span>
                <span class="small">You can now tag friends in your life events!</span>
            </li>
            <li class="py-1 border-bottom">
                <span class="badge rounded-pill me-1 bg-secondary" style="font-size:10px;">TIP</span>
                <span class="small">Use <strong>Export My Story</strong> to save your timeline as a document.</span>
            </li>
            <li class="py-1 border-bottom">
                <span class="badge rounded-pill me-1 bg-secondary" style="font-size:10px;">TIP</span>
                <span class="small">Set post visibility to control who sees each memory.</span>
            </li>
            <li class="py-1">
                <span class="badge rounded-pill me-1" style="background-color: var(--mst-primary); color:#fff; font-size:10px;">INFO</span>
                <span class="small">Invite relatives to co-author your family story.</span>
            </li>
        </ul>
    </div>
</div>
