@model MyStoryTold.Models.ViewModels.DashboardViewModel
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var act  = ViewContext.RouteData.Values["action"]?.ToString();
    var onHome = ctrl == "Home" && act == "Index";
    var newStoryHref = onHome ? "#quickStoryFormHome" : "/#quickStoryFormHome";
    var todayPrompt = Context.Items["SidebarPromptText"] as string;
    var onThisDay = Context.Items["SidebarOnThisDay"] as List<MyStoryTold.Models.LifeEventPost>;
}

<!-- Compose -->
<div class="rail-section rail-compose">
    <div class="d-flex gap-2">
        <a href="@newStoryHref" class="btn btn-sm btn-primary flex-grow-1 fw-semibold rail-compose-primary d-inline-flex align-items-center justify-content-center gap-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0.8" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
                <path d="M17 2 Q20.5 8.5 17.5 13.5 Q14.5 16.5 9 18 L11 15.5 Q14.5 14.8 16 12 Q17.2 9.2 16.8 5.5 Q16.6 3.5 17 2 Z"/>
                <line x1="16.5" y1="3" x2="7.5" y2="18.5" stroke-width="1.2"/>
                <path d="M7.5 18.5 L5 22 L8.5 19.5 Z"/>
            </svg>
            New Story
        </a>
        <a asp-controller="Home" asp-action="Invite" asp-route-id="" class="btn btn-sm btn-outline-secondary flex-grow-1 fw-semibold">
            ✉️ Invite
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(todayPrompt))
{
    <!-- Today's Prompt (gold accent) -->
    <div class="rail-section rail-prompt rail-prompt-gold">
        <div class="rail-head">Today's Prompt</div>
        <div class="rail-prompt-text">"@todayPrompt"</div>
        <a href="@(onHome ? "#quickStoryFormHome" : "/?prompt=" + Uri.EscapeDataString(todayPrompt) + "#quickStoryFormHome")"
           class="rail-prompt-btn"
           data-prompt="@todayPrompt">Write about it &rarr;</a>
    </div>
}

<!-- My Network -->
<details class="rail-section rail-collapsible" open>
    <summary class="rail-head">My Network</summary>
    <ul class="rail-list">
        <li>
            <a asp-controller="Friends" asp-action="Index" asp-route-tier="Acquaintance" class="rail-link">
                <span><span class="tier-dot" style="background-color:var(--tier-acquaintances);"></span>Acquaintances</span>
                <span class="d-inline-flex align-items-center gap-1">
                    @if (Model.NewAcquaintancesThisWeek > 0) { <span class="rail-week-pill">+@Model.NewAcquaintancesThisWeek</span> }
                    <span class="badge rounded-pill" style="background-color:var(--tier-acquaintances);color:#000;">@Model.AcquaintancesCount</span>
                </span>
            </a>
        </li>
        <li>
            <a asp-controller="Friends" asp-action="Index" asp-route-tier="Friend" class="rail-link">
                <span><span class="tier-dot" style="background-color:var(--tier-friends);"></span>Friends</span>
                <span class="d-inline-flex align-items-center gap-1">
                    @if (Model.NewFriendsThisWeek > 0) { <span class="rail-week-pill">+@Model.NewFriendsThisWeek</span> }
                    <span class="badge rounded-pill" style="background-color:var(--tier-friends);color:#fff;">@Model.FriendsCount</span>
                </span>
            </a>
        </li>
        <li>
            <a asp-controller="Friends" asp-action="Index" asp-route-tier="Family" class="rail-link">
                <span><span class="tier-dot" style="background-color:var(--tier-family);"></span>Family</span>
                <span class="d-inline-flex align-items-center gap-1">
                    @if (Model.NewFamilyThisWeek > 0) { <span class="rail-week-pill">+@Model.NewFamilyThisWeek</span> }
                    <span class="badge rounded-pill" style="background-color:var(--tier-family);color:#fff;">@Model.FamilyCount</span>
                </span>
            </a>
        </li>
        <li class="rail-list-divider">
            <a asp-controller="Posts" asp-action="Tagged" class="rail-link">
                <span>Tagged</span>
                <span class="badge rounded-pill @(Model.TaggedCount > 0 ? "bg-warning text-dark" : "bg-light text-muted")">@Model.TaggedCount</span>
            </a>
        </li>
        <li>
            <a asp-controller="Friends" asp-action="Index" class="rail-link">
                <span>Requests</span>
                <span class="badge rounded-pill @(Model.PendingRequestsCount > 0 ? "bg-danger" : "bg-light text-muted")">@Model.PendingRequestsCount</span>
            </a>
        </li>
    </ul>
</details>

<!-- Recently Active -->
<details class="rail-section rail-collapsible" open>
    <summary class="rail-head">Recently Active</summary>
    @if (Model.ActiveFriends.Any())
    {
        <ul class="rail-list">
            @foreach (var friend in Model.ActiveFriends.Take(8))
            {
                string tag;
                string tagClass = "rail-tag";
                if (friend.IsOnline)
                {
                    tag = "online";
                    tagClass += " rail-tag-online";
                }
                else if (friend.LastPostedAt.HasValue)
                {
                    var ago = DateTime.UtcNow - friend.LastPostedAt.Value;
                    if (ago.TotalMinutes < 60) tag = "just now";
                    else if (ago.TotalHours < 24) tag = $"{(int)ago.TotalHours}h ago";
                    else if (ago.TotalDays < 7) tag = $"{(int)ago.TotalDays}d ago";
                    else if (ago.TotalDays < 30) tag = $"{(int)(ago.TotalDays / 7)}w ago";
                    else tag = friend.LastPostedAt.Value.ToString("MMM yyyy");
                }
                else
                {
                    tag = "";
                }

                <li>
                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@friend.User.Id"
                       class="rail-link rail-friend-link">
                        @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = friend.User, Size = 26 })
                        <span class="rail-friend-name">@(friend.User.DisplayName ?? friend.User.UserName)</span>
                        @if (!string.IsNullOrEmpty(tag))
                        {
                            <span class="@tagClass">@tag</span>
                        }
                    </a>
                </li>
            }
        </ul>
        <a asp-controller="Friends" asp-action="Index" class="rail-footer-link">See everyone &rarr;</a>
    }
    else
    {
        <p class="rail-empty">No recent activity yet.</p>
    }
</details>

@if (onThisDay != null && onThisDay.Any())
{
    <!-- On This Day -->
    <div class="rail-section rail-on-this-day">
        <div class="rail-head">On This Day</div>
        @foreach (var p in onThisDay.Take(2))
        {
            var years = DateTime.UtcNow.Year - p.EventYear;
            <div class="rail-otd-row">
                <span class="rail-otd-year">@years yr@(years == 1 ? "" : "s") ago</span>
                <a asp-controller="Posts" asp-action="Detail" asp-route-id="@p.Id" class="rail-otd-link">
                    @(string.IsNullOrWhiteSpace(p.Title) ? MyStoryTold.Helpers.BodyRenderer.TextPreview(p.Body, 60) : p.Title)
                </a>
            </div>
        }
    </div>
}

@{
    var sidebarTips = Context.Items["SidebarTips"] as List<MyStoryTold.Models.Tip>;
    var latestTip = sidebarTips?
        .OrderByDescending(t => t.CreatedAt)
        .FirstOrDefault();
}
@if (latestTip != null)
{
    var label = latestTip.Type switch
    {
        MyStoryTold.Models.TipType.New => "NEW",
        MyStoryTold.Models.TipType.Info => "INFO",
        MyStoryTold.Models.TipType.Warning => "WARN",
        _ => "TIP"
    };
    var cls = latestTip.Type.ToString().ToLower();
    <!-- Tips & Announcements (latest only, teal accent) -->
    <div class="rail-section rail-prompt rail-prompt-teal">
        <div class="rail-head d-flex align-items-center justify-content-between">
            <span>Announcement</span>
            <span class="tips-badge tips-badge-@cls">@label</span>
        </div>
        <div class="rail-prompt-text">@latestTip.Text</div>
    </div>
}

<!-- Coming Soon (collapsed) -->
<details class="rail-section rail-coming">
    <summary class="rail-head">Coming Soon</summary>
    <div class="rail-coming-body">
        <p class="rail-coming-sub">⭐ Premium</p>
        <ul class="rail-coming-list">
            <li>Editing &amp; Ghost Writing</li>
            <li>Book Binding &amp; Printing</li>
            <li>Family Groups</li>
        </ul>
        <p class="rail-coming-sub mt-2">🆓 Free Features</p>
        <ul class="rail-coming-list">
            <li>Memory Prompts</li>
            <li>Chats <span class="badge rounded-pill ms-1" style="background:var(--mst-accent);color:#000;font-size:9px;">Beta</span></li>
            <li>Historical Context</li>
            <li>Family Tree</li>
            <li>Ancestor's Story</li>
            <li>Getting Started Guide</li>
        </ul>
    </div>
</details>
