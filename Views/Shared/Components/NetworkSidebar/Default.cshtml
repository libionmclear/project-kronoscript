@model MyStoryTold.Models.ViewModels.DashboardViewModel

<!-- Quick Links (top of left sidebar) -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h6 class="fw-bold mb-2" style="color: var(--mst-primary);">Quick Links</h6>
        <ul class="list-unstyled mb-0 small">
            <li class="py-1">
                <a asp-controller="Posts" asp-action="Timeline"
                   asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
                   class="text-decoration-none">📖 My Timeline</a>
            </li>
            <li class="py-1"><a asp-controller="Profile" asp-action="Index" class="text-decoration-none">👤 My Profile</a></li>
            <li class="py-1"><a asp-controller="Profile" asp-action="Edit" class="text-decoration-none">✏️ Edit Profile</a></li>
            <li class="py-1"><a asp-controller="Export" asp-action="Index" class="text-decoration-none">📥 Export My Story</a></li>
            <li class="py-1 border-top mt-1 pt-1">
                <a asp-controller="Home" asp-action="Invite" class="text-decoration-none" style="color: var(--mst-accent);">✉️ Invite a Friend</a>
            </li>
            @if (User.IsInRole("Admin"))
            {
                <li class="py-1 border-top mt-1 pt-1">
                    <a asp-controller="Admin" asp-action="Index" class="text-decoration-none fw-semibold" style="color: var(--mst-primary);">⚙️ Admin Panel</a>
                </li>
            }
        </ul>
    </div>
</div>

<!-- My Network -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h6 class="fw-bold mb-2" style="color: var(--mst-primary);">My Network</h6>
        <ul class="list-unstyled mb-0 small">
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                    <span>👋 Acquaintances</span>
                    <span class="badge rounded-pill" style="background-color:#ffc107;color:#000;">@Model.AcquaintancesCount</span>
                </a>
            </li>
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                    <span>👥 Friends</span>
                    <span class="badge rounded-pill" style="background-color:#198754;">@Model.FriendsCount</span>
                </a>
            </li>
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                    <span>👨‍👩‍👧 Family</span>
                    <span class="badge rounded-pill" style="background-color:#87ceeb;color:#000;">@Model.FamilyCount</span>
                </a>
            </li>
            <li class="py-1 border-top mt-1 pt-1">
                <a asp-controller="Posts" asp-action="Tagged" class="text-decoration-none d-flex justify-content-between">
                    <span>🏷️ Tagged</span>
                    <span class="badge rounded-pill @(Model.TaggedCount > 0 ? "bg-warning text-dark" : "bg-light text-muted")">@Model.TaggedCount</span>
                </a>
            </li>
            <li class="py-1">
                <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                    <span>🔔 Requests</span>
                    <span class="badge rounded-pill @(Model.PendingRequestsCount > 0 ? "bg-danger" : "bg-light text-muted")">@Model.PendingRequestsCount</span>
                </a>
            </li>
        </ul>
    </div>
</div>

<!-- Recently Active -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <h6 class="fw-bold mb-2" style="color: var(--mst-primary);">Recently Active</h6>
        <ul class="list-unstyled mb-0">
            @foreach (var friend in Model.ActiveFriends)
            {
                <li class="py-1">
                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@friend.User.Id"
                       class="text-decoration-none d-flex align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(friend.User.ProfilePhotoUrl))
                        {
                            <img src="@friend.User.ProfilePhotoUrl" class="rounded-circle flex-shrink-0" width="24" height="24" style="object-fit:cover;" />
                        }
                        else
                        {
                            <span class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-bold"
                                  style="width:24px;height:24px;font-size:9px;
                                  background:@(friend.User.Gender == "Male" ? "#4a90d9" : friend.User.Gender == "Female" ? "#d96a9d" : "var(--mst-light)");
                                  color:@((friend.User.Gender == "Male" || friend.User.Gender == "Female") ? "#fff" : "var(--mst-primary)");">
                                @((!string.IsNullOrEmpty(friend.User.FirstName) && !string.IsNullOrEmpty(friend.User.LastName))
                                    ? $"{friend.User.FirstName[0]}{friend.User.LastName[0]}".ToUpper()
                                    : ((friend.User.UserName ?? "??").Length >= 2
                                        ? (friend.User.UserName ?? "??")[..2].ToUpper()
                                        : (friend.User.UserName ?? "??").ToUpper()))
                            </span>
                        }
                        <span class="small">@(friend.User.DisplayName ?? friend.User.UserName)</span>
                    </a>
                </li>
            }
        </ul>
        @if (!Model.ActiveFriends.Any())
        {
            <p class="small text-muted mb-0">No recent activity yet.</p>
        }
    </div>
</div>

<!-- Coming Soon -->
<div class="card border-0 shadow-sm mb-3" style="border-left:3px solid var(--mst-gold) !important;">
    <div class="card-body p-3">
        <h6 class="fw-bold mb-2" style="color:var(--mst-accent);font-size:0.78rem;letter-spacing:0.04em;text-transform:uppercase;">Coming Soon</h6>

        <p class="fw-semibold mb-1" style="font-size:0.72rem;color:var(--mst-primary);text-transform:uppercase;letter-spacing:0.05em;">⭐ Premium</p>
        <ul class="list-unstyled mb-2" style="font-size:0.75rem;color:var(--mst-text);">
            <li class="py-1 border-bottom">✍️ Editing &amp; Ghost Writing</li>
            <li class="py-1 border-bottom">📖 Book Binding &amp; Printing</li>
            <li class="py-1">👨‍👩‍👧 Family Groups</li>
        </ul>

        <p class="fw-semibold mb-1" style="font-size:0.72rem;color:var(--mst-primary);text-transform:uppercase;letter-spacing:0.05em;">🆓 Free Features</p>
        <ul class="list-unstyled mb-0" style="font-size:0.75rem;color:var(--mst-text);">
            <li class="py-1 border-bottom">💡 Memory Prompts</li>
            <li class="py-1 border-bottom">💬 Chats <span class="badge rounded-pill ms-1" style="background:var(--mst-accent);color:#000;font-size:9px;">Beta</span></li>
            <li class="py-1 border-bottom">🏛️ Historical Context</li>
            <li class="py-1">📚 Getting Started Guide</li>
        </ul>
    </div>
</div>
