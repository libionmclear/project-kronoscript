@model int
@{
    var postId = Model;
}
<div class="btn-group translate-group">
    <button type="button" class="icon-action btn-translate-post"
            data-post-id="@postId"
            data-bs-toggle="tooltip"
            data-bs-title="Translate (Change default in Settings)">
        @await Html.PartialAsync("_Icon", "translate")
    </button>
    <button type="button" class="icon-action dropdown-toggle dropdown-toggle-split translate-lang-toggle"
            data-bs-toggle="dropdown" data-bs-auto-close="true" aria-expanded="false"
            aria-label="Choose language to translate to">
        <span class="visually-hidden">Choose language</span>
    </button>
    <ul class="dropdown-menu dropdown-menu-end translate-menu" data-post-id="@postId">
        <li><h6 class="dropdown-header">Translate to</h6></li>
        @foreach (var lang in MyStoryTold.Helpers.LanguageNames.Supported)
        {
            <li>
                <a href="#" class="dropdown-item translate-lang-pick" data-post-id="@postId" data-to="@lang.Code">
                    @lang.Name
                </a>
            </li>
        }
        <li><hr class="dropdown-divider" /></li>
        <li>
            <a href="#" class="dropdown-item translate-show-original" data-post-id="@postId">Show original</a>
        </li>
    </ul>
</div>
