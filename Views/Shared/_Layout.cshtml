<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kronoscript</title>
    <link rel="icon" type="image/png" href="~/images/kronoscript-logo-green.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyStoryTold.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="@(ViewData["BodyClass"])">
    <header>
        <nav class="navbar navbar-expand-md shadow-sm" style="background: linear-gradient(135deg, #2e6b3d 0%, #419954 100%);">
            <div class="container">
                <!-- Logo: always left -->
                <a class="navbar-brand navbar-brand-ks fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img src="~/images/kronoscript-logo-gold.png" alt="" height="38" style="filter: drop-shadow(0 1px 4px rgba(0,0,0,0.35));" onerror="this.style.display='none'" />
                    KRONOSCRIPT
                </a>

                <button class="navbar-toggler border-light" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <!-- Centered nav items: icon on top, label below -->
                        <ul class="navbar-nav mx-auto align-items-center">
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Home" asp-action="Index"
                                   data-bs-toggle="tooltip" data-bs-title="Your home feed">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                        <path d="M12 3L3 9.5V21h6v-6h6v6h6V9.5L12 3z"/>
                                    </svg>
                                    <span class="nav-icon-label">Home</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Posts" asp-action="Timeline"
                                   asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
                                   data-bs-toggle="tooltip" data-bs-title="Your personal chronological life story">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                        <path d="M6 2c-1.1 0-2 .9-2 2v1c-1.1 0-2 .9-2 2v13c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-1c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2V4c0-1.1-.9-2-2-2H6zm0 2h10v1H6V4zM4 7h12v12H4V7zm2 2v2h8V9H6zm0 4v2h6v-2H6z"/>
                                    </svg>
                                    <span class="nav-icon-label">My Story</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Friends" asp-action="Index"
                                   data-bs-toggle="tooltip" data-bs-title="Manage friends, family and connections">
                                    <svg width="24" height="18" viewBox="0 0 36 22" fill="currentColor" aria-hidden="true">
                                        <circle cx="6" cy="6" r="4"/>
                                        <path d="M0 22c0-4 2.5-7 6-7s6 3 6 7"/>
                                        <circle cx="18" cy="5" r="4.5"/>
                                        <path d="M11.5 22c0-4.5 3-8 6.5-8s6.5 3.5 6.5 8"/>
                                        <circle cx="30" cy="6" r="4"/>
                                        <path d="M24 22c0-4 2.5-7 6-7s6 3 6 7"/>
                                    </svg>
                                    <span class="nav-icon-label">Network</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Inbox" asp-action="Index" id="inboxNavLink"
                                   data-bs-toggle="tooltip" data-bs-title="Private messages with your connections">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                        <path d="M17 3c-.5 0-1 .2-1.4.6L7 12.2V17h4.8l8.6-8.6c.8-.8.8-2 0-2.8L18.4 3.6C18 3.2 17.5 3 17 3zm0 2l1.4 1.4-8 8-1.4-1.4 8-8zM5 19v2h14v-2H5z"/>
                                    </svg>
                                    <span class="nav-icon-label">Messages <span id="inboxBadge" class="badge bg-danger ms-1" style="display:none;font-size:0.6rem;vertical-align:middle;"></span></span>
                                </a>
                            </li>
                        </ul>

                        <!-- Start Here! -->
                        <ul class="navbar-nav me-2">
                            <li class="nav-item">
                                <a class="btn btn-sm fw-semibold" asp-controller="Home" asp-action="GettingStarted"
                                   style="background:var(--mst-gold);color:var(--mst-dark);border:none;"
                                   data-bs-toggle="tooltip" data-bs-title="New here? Read our fun guide to get started!">★ Start Here!</a>
                            </li>
                        </ul>

                        <!-- Right: user dropdown -->
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle nav-link-gold" href="#" role="button" data-bs-toggle="dropdown">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index">My Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Edit">Edit Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Export" asp-action="Index">Export My Story</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">Sign Out</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm ms-2 mt-1" asp-controller="Account" asp-action="Register">Get Started</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="@(ViewData["ContainerClass"] ?? "container mt-4")">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer @(ViewData["BodyClass"] != null ? "footer-landing" : "") mt-auto">
        <div class="container text-center py-3">
            <small>&copy; 2026 Kronoscript &mdash; Tell your life story. Share it over time.</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltipEls.forEach(function (el) {
            new bootstrap.Tooltip(el, { trigger: 'hover', delay: { show: 300, hide: 100 } });
        });
    });
    </script>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
        (function pollInbox() {
            fetch('/Inbox/UnreadCount')
                .then(r => r.json())
                .then(function(count) {
                    var badge = document.getElementById('inboxBadge');
                    if (badge) {
                        badge.textContent = count;
                        badge.style.display = count > 0 ? 'inline' : 'none';
                    }
                })
                .catch(function(){});
            setTimeout(pollInbox, 60000);
        })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
