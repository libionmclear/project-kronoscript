<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kronoscript</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyStoryTold.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md shadow-sm" style="background: linear-gradient(135deg, var(--mst-primary), var(--mst-secondary));">
            <div class="container">
                <a class="navbar-brand navbar-brand-ks fw-bold fs-4 d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img src="~/images/kronoscript-logo.png" alt="" height="36" style="filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));" onerror="this.style.display='none'" />
                    Kronoscript
                </a>
                <button class="navbar-toggler border-light" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link text-white-50" asp-controller="Posts" asp-action="Feed">Feed</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white-50" asp-controller="Posts" asp-action="Timeline"
                                   asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">My Timeline</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white-50" asp-controller="Friends" asp-action="Index">Friends</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white-50" asp-controller="Relatives" asp-action="Index">Relatives</a>
                            </li>
                        </ul>
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index">My Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Edit">Edit Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Export" asp-action="Index">Export My Story</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">Sign Out</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm ms-2 mt-1" asp-controller="Account" asp-action="Register">Get Started</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-5">
        <div class="container text-center py-3">
            <small>&copy; 2026 Kronoscript &mdash; Tell your life story. Share it over time.</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
