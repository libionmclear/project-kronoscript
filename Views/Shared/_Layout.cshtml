@inject Microsoft.AspNetCore.Identity.UserManager<MyStoryTold.Models.ApplicationUser> _userManager
@inject Microsoft.Extensions.Configuration.IConfiguration _layoutConfig
@inject MyStoryTold.Services.ISiteSettings _layoutSiteSettings
@inject MyStoryTold.Services.ILocalizer _t
@{
    var currentUiCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@currentUiCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (User.Identity?.IsAuthenticated == true)
    {
        <meta name="current-user-id" content="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />
    }
    @{ var layoutKofi = _layoutConfig["KoFi:Handle"]; }
    @if (!string.IsNullOrWhiteSpace(layoutKofi))
    {
        <meta name="kofi-handle" content="@layoutKofi" />
    }
    <title>@ViewData["Title"] - Kronoscript</title>
    <link rel="icon" type="image/png" href="~/images/New%20Logo%20White.png" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <meta name="theme-color" content="#0f6466" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Kronoscript" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="~/images/New%20Logo%20White.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyStoryTold.styles.css" asp-append-version="true" />
    <script>
        // Apply saved theme before paint to avoid FOUC
        (function () {
            try {
                var t = localStorage.getItem('kronTheme');
                if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
            } catch (e) {}
        })();
        // Register the PWA service worker (enables "Add to Home Screen").
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/sw.js').catch(function () {});
            });
        }
    </script>
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="@(ViewData["BodyClass"])"
      data-current-user-id="@(User.Identity != null && User.Identity.IsAuthenticated ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : "")">
    <header>
        @{
            MyStoryTold.Models.ApplicationUser? navUser = null;
            if (User.Identity?.IsAuthenticated == true)
            {
                navUser = await _userManager.GetUserAsync(User);
            }
        }
        <nav class="navbar navbar-expand-md">
            <div class="container">
                <!-- Logo: always left -->
                <a class="navbar-brand navbar-brand-ks fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img src="~/images/New%20Logo%20White.png" alt="Kronoscript" height="44" onerror="this.style.display='none'" />
                    Kronoscript
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <!-- Mobile-only: user dropdown always visible on the top bar, next to the hamburger -->
                    <ul class="navbar-nav d-md-none navbar-mobile-user flex-row align-items-center ms-auto me-2">
                        <partial name="_UserDropdown" model="navUser" />
                    </ul>
                }

                @* Mobile: hamburger opens a side drawer (kron-drawer)
                   instead of the bootstrap collapse so the menu doesn't
                   bleed teal across the full width with badly-styled
                   dropdowns. Desktop keeps the inline navbar (collapse
                   stays mounted but is `d-md-flex` so the drawer JS
                   never runs there). *@
                <button class="navbar-toggler border-light d-md-none" type="button"
                        id="kronDrawerToggle"
                        aria-controls="kronDrawer" aria-expanded="false" aria-label="Open menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse d-none d-md-flex" id="mainNav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <!-- Centered nav items: icon on top, label below -->
                        <ul class="navbar-nav mx-auto align-items-center nav-main-icons">
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Home" asp-action="Index"
                                   data-bs-toggle="tooltip" data-bs-title="Your home feed">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                        <path d="M12 3L3 9.5V21h6v-6h6v6h6V9.5L12 3z"/>
                                    </svg>
                                    <span class="nav-icon-label">@_t["Home"]</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Posts" asp-action="Timeline"
                                   asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
                                   data-bs-toggle="tooltip" data-bs-title="Your personal chronological life story">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <!-- Top roller -->
                                        <rect x="3" y="3.5" width="18" height="3" rx="1.5" fill="currentColor"/>
                                        <!-- Parchment body with curled edges -->
                                        <path d="M5 6.5 Q5 8 6 8.5 L6 15 Q5 15.5 5 17 L19 17 Q19 15.5 18 15 L18 8.5 Q19 8 19 6.5"/>
                                        <!-- Text lines on the parchment -->
                                        <line x1="8.5" y1="10" x2="15.5" y2="10"/>
                                        <line x1="8.5" y1="12.3" x2="15.5" y2="12.3"/>
                                        <line x1="8.5" y1="14.6" x2="13" y2="14.6"/>
                                        <!-- Bottom roller -->
                                        <rect x="3" y="16.5" width="18" height="3" rx="1.5" fill="currentColor"/>
                                    </svg>
                                    <span class="nav-icon-label">@_t["My Story"]</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Friends" asp-action="Index"
                                   data-bs-toggle="tooltip" data-bs-title="Manage friends, family and connections">
                                    <svg width="24" height="18" viewBox="0 0 36 22" fill="currentColor" aria-hidden="true">
                                        <circle cx="6" cy="6" r="4"/>
                                        <path d="M0 22c0-4 2.5-7 6-7s6 3 6 7"/>
                                        <circle cx="18" cy="5" r="4.5"/>
                                        <path d="M11.5 22c0-4.5 3-8 6.5-8s6.5 3.5 6.5 8"/>
                                        <circle cx="30" cy="6" r="4"/>
                                        <path d="M24 22c0-4 2.5-7 6-7s6 3 6 7"/>
                                    </svg>
                                    <span class="nav-icon-label">@_t["Network"]</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Inbox" asp-action="Index" id="inboxNavLink"
                                   data-bs-toggle="tooltip" data-bs-title="Private messages with your connections">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0.8" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
                                        <!-- Feather blade: wide top tapering to a point near the nib -->
                                        <path d="M17 2 Q20.5 8.5 17.5 13.5 Q14.5 16.5 9 18 L11 15.5 Q14.5 14.8 16 12 Q17.2 9.2 16.8 5.5 Q16.6 3.5 17 2 Z"/>
                                        <!-- Central rachis / spine from feather base down to nib -->
                                        <line x1="16.5" y1="3" x2="7.5" y2="18.5" stroke-width="1.2"/>
                                        <!-- Nib: narrow triangle pointing down-left -->
                                        <path d="M7.5 18.5 L5 22 L8.5 19.5 Z"/>
                                    </svg>
                                    <span class="nav-icon-label">@_t["Messages"] <span id="inboxBadge" class="badge bg-danger ms-1" style="display:none;font-size:0.6rem;vertical-align:middle;"></span></span>
                                </a>
                            </li>
                            <li class="nav-item">
                                @* Notifications used to open as a dropdown.
                                   Now it links to a full page so longer
                                   threads are easier to read; the badge is
                                   still updated by the same poller. *@
                                <a class="nav-link nav-link-gold d-flex flex-column align-items-center px-3"
                                   asp-controller="Notifications" asp-action="Index" id="notifNavLink"
                                   data-bs-toggle="tooltip" data-bs-title="@(_t["Notifications"])">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
                                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                    </svg>
                                    <span class="nav-icon-label">@_t["Notifications"] <span id="notifBellBadge" class="badge bg-danger ms-1" style="display:none;font-size:0.6rem;vertical-align:middle;"></span></span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <button type="button" class="nav-link nav-link-gold d-flex flex-column align-items-center px-3 nav-search-toggle" id="navSearchToggle"
                                        data-bs-toggle="tooltip" data-bs-title="Search people, posts, features"
                                        style="background:none;border:none;">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <circle cx="11" cy="11" r="7"/>
                                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                    </svg>
                                    <span class="nav-icon-label">@_t["Search"]</span>
                                </button>
                            </li>
                        </ul>

                        <!-- Utility trio (in order): + new story, tips bulb, theme toggle -->
                        <ul class="navbar-nav me-2 align-items-center gap-2 nav-utility">
                            <li class="nav-item">
                                @* "+" quick-write — leads the trio so the
                                   most active action is read first. *@
                                <a asp-controller="Posts" asp-action="Create" asp-route-id=""
                                   class="btn btn-sm btn-outline-secondary"
                                   data-bs-toggle="tooltip" data-bs-title="@_t["New full story"]"
                                   aria-label="@_t["New full story"]">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <line x1="12" y1="5" x2="12" y2="19"/>
                                        <line x1="5"  y1="12" x2="19" y2="12"/>
                                    </svg>
                                </a>
                            </li>
                            <li class="nav-item">
                                @await Component.InvokeAsync("NavTips")
                            </li>
                            <li class="nav-item">
                                <button type="button" class="btn btn-sm btn-outline-secondary theme-toggle" id="themeToggle"
                                        data-bs-toggle="tooltip" data-bs-title="Toggle dark mode" aria-label="Toggle dark mode">
                                    <svg class="theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
                                    <svg class="theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                                </button>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-primary fw-semibold" asp-controller="Home" asp-action="GettingStarted"
                                   data-bs-toggle="tooltip" data-bs-title="New here? Read our fun guide to get started!">@_t["Start Here"]</a>
                            </li>
                        </ul>

                        <!-- Right: user dropdown (desktop only; mobile copy lives outside the collapse) -->
                        <ul class="navbar-nav d-none d-md-flex">
                            <partial name="_UserDropdown" model="navUser" />
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link nav-link-gold" asp-controller="Account" asp-action="Login">@_t["Sign In"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm ms-2 mt-1" asp-controller="Account" asp-action="Register">@_t["Get Started"]</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>

        @* Mobile-only side drawer. Slides in from the right; backdrop
           catches outside-clicks; visible-only on small screens via the
           CSS class .kron-drawer (display:none on md+). *@
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            var meIdForDrawer = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            <div class="kron-drawer-backdrop" id="kronDrawerBackdrop" hidden></div>
            <aside class="kron-drawer" id="kronDrawer" hidden aria-label="Menu">
                <header class="kron-drawer-header">
                    <span class="kron-drawer-title">Kronoscript</span>
                    <button type="button" class="kron-drawer-close" id="kronDrawerClose" aria-label="@(_t["Close"])">×</button>
                </header>
                <nav class="kron-drawer-body">
                    <a class="kron-drawer-link" asp-controller="Home" asp-action="Index">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3L3 9.5V21h6v-6h6v6h6V9.5L12 3z"/></svg>
                        <span>@_t["Home"]</span>
                    </a>
                    <a class="kron-drawer-link" asp-controller="Posts" asp-action="Timeline" asp-route-id="@meIdForDrawer">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="3.5" width="18" height="3" rx="1.5" fill="currentColor"/>
                            <path d="M5 6.5 Q5 8 6 8.5 L6 15 Q5 15.5 5 17 L19 17 Q19 15.5 18 15 L18 8.5 Q19 8 19 6.5"/>
                            <line x1="8.5" y1="10" x2="15.5" y2="10"/>
                            <line x1="8.5" y1="12.3" x2="15.5" y2="12.3"/>
                            <line x1="8.5" y1="14.6" x2="13" y2="14.6"/>
                            <rect x="3" y="16.5" width="18" height="3" rx="1.5" fill="currentColor"/>
                        </svg>
                        <span>@_t["My Story"]</span>
                    </a>
                    <a class="kron-drawer-link" asp-controller="Friends" asp-action="Index">
                        <svg width="22" height="22" viewBox="0 0 36 22" fill="currentColor" aria-hidden="true">
                            <circle cx="6" cy="6" r="4"/><path d="M0 22c0-4 2.5-7 6-7s6 3 6 7"/>
                            <circle cx="18" cy="5" r="4.5"/><path d="M11.5 22c0-4.5 3-8 6.5-8s6.5 3.5 6.5 8"/>
                            <circle cx="30" cy="6" r="4"/><path d="M24 22c0-4 2.5-7 6-7s6 3 6 7"/>
                        </svg>
                        <span>@_t["Network"]</span>
                    </a>
                    <a class="kron-drawer-link" asp-controller="Inbox" asp-action="Index">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0.8" aria-hidden="true">
                            <path d="M17 2 Q20.5 8.5 17.5 13.5 Q14.5 16.5 9 18 L11 15.5 Q14.5 14.8 16 12 Q17.2 9.2 16.8 5.5 Q16.6 3.5 17 2 Z"/>
                            <line x1="16.5" y1="3" x2="7.5" y2="18.5" stroke-width="1.2"/>
                            <path d="M7.5 18.5 L5 22 L8.5 19.5 Z"/>
                        </svg>
                        <span>@_t["Messages"]</span>
                    </a>
                    <a class="kron-drawer-link" asp-controller="Notifications" asp-action="Index">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span>@_t["Notifications"]</span>
                    </a>
                    <p class="kron-drawer-section">@_t["You"]</p>
                    <a class="kron-drawer-link kron-drawer-link-text" asp-controller="Profile" asp-action="Index" asp-route-id="">
                        <span>@_t["My Profile"]</span>
                    </a>
                    <a class="kron-drawer-link kron-drawer-link-text" asp-controller="Profile" asp-action="Edit" asp-route-id="">
                        <span>@_t["Settings"]</span>
                    </a>
                    <a class="kron-drawer-link kron-drawer-link-text" asp-controller="Posts" asp-action="Drafts" asp-route-id="">
                        <span>@_t["My Drafts"]</span>
                    </a>
                    <a class="kron-drawer-link kron-drawer-link-text" asp-controller="Export" asp-action="Index" asp-route-id="">
                        <span>@_t["Export"]</span>
                    </a>
                    <a class="kron-drawer-link kron-drawer-link-text" asp-controller="Home" asp-action="GettingStarted">
                        <span>@_t["Start Here"]</span>
                    </a>
                    <hr class="kron-drawer-divider" />
                    <button type="button" class="kron-drawer-link kron-drawer-theme" id="kronDrawerThemeToggle">
                        <svg class="theme-icon-sun" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
                        <svg class="theme-icon-moon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                        <span>Dark mode</span>
                    </button>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="kron-drawer-logout-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="kron-drawer-link kron-drawer-link-text kron-drawer-logout">
                            <span>@_t["Sign out"]</span>
                        </button>
                    </form>
                </nav>
            </aside>
        }
    </header>

    @{
        // Site banner — shown at the top of every page until the user
        // dismisses the current version. Editing it bumps the version so
        // the same user sees the new copy even if they dismissed the
        // previous one.
        var bannerOn = await _layoutSiteSettings.GetBoolAsync(MyStoryTold.Services.ISiteSettings.BannerEnabled, false);
        var bannerVersion = await _layoutSiteSettings.GetIntAsync(MyStoryTold.Services.ISiteSettings.BannerVersion, 0);
        var bannerText = await _layoutSiteSettings.GetStringAsync(MyStoryTold.Services.ISiteSettings.BannerText);
        var bannerSeverity = (await _layoutSiteSettings.GetStringAsync(MyStoryTold.Services.ISiteSettings.BannerSeverity, "info")) ?? "info";
        var bannerLinkUrl = await _layoutSiteSettings.GetStringAsync(MyStoryTold.Services.ISiteSettings.BannerLinkUrl);
        var bannerLinkText = await _layoutSiteSettings.GetStringAsync(MyStoryTold.Services.ISiteSettings.BannerLinkText);
        int userBannerDismissed = 0;
        if (User.Identity?.IsAuthenticated == true)
        {
            var u = await _userManager.GetUserAsync(User);
            if (u != null) userBannerDismissed = u.LastDismissedBannerVersion;
        }
        var showBanner = bannerOn
            && !string.IsNullOrWhiteSpace(bannerText)
            && bannerVersion > userBannerDismissed;
        var bannerReturn = Context.Request.Path + Context.Request.QueryString;
    }
    @if (showBanner)
    {
        <div class="site-banner site-banner-@bannerSeverity" role="status">
            <div class="container site-banner-inner">
                <span class="site-banner-text">@bannerText</span>
                @if (!string.IsNullOrWhiteSpace(bannerLinkUrl))
                {
                    <a class="site-banner-link" href="@bannerLinkUrl" target="_blank" rel="noopener">@(string.IsNullOrWhiteSpace(bannerLinkText) ? "Read more" : bannerLinkText) →</a>
                }
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Profile" asp-action="DismissBanner" method="post" class="m-0 ms-auto">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="version" value="@bannerVersion" />
                        <input type="hidden" name="returnUrl" value="@bannerReturn" />
                        <button type="submit" class="site-banner-close" aria-label="Dismiss">×</button>
                    </form>
                }
            </div>
        </div>
    }

    <div class="@(ViewData["ContainerClass"] ?? "container mt-4")">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer @(ViewData["BodyClass"] != null ? "footer-landing" : "") mt-auto">
        <div class="container py-3 footer-fine">
            <div class="footer-row">
                <span class="footer-brand">Kronoscript</span>
                <span class="footer-sep">·</span>
                <a asp-controller="Home" asp-action="About">@_t["About"]</a>
                <a asp-controller="Home" asp-action="GettingStarted">Start here</a>
                <a asp-controller="Home" asp-action="Faq">FAQ</a>
                <span class="footer-sep">·</span>
                <a asp-controller="Home" asp-action="Privacy">@_t["Privacy"]</a>
                <a asp-controller="Home" asp-action="Agreement">@_t["Terms"]</a>
                <a asp-controller="Home" asp-action="AcceptableUse">@_t["Acceptable use"]</a>
                <span class="footer-sep">·</span>
                <a href="mailto:info@kronoscript.net">info@kronoscript.net</a>
                <a href="https://ko-fi.com/kronoscript" target="_blank" rel="noopener">@_t["Support the Project"]</a>
            </div>
            <div class="footer-bottom text-center">
                <span>&copy; 2026 Kronoscript</span>
                <span class="footer-sep">·</span>
                <span>@_t["An independent passion project, in beta."]</span>
                <span class="footer-sep">·</span>
                <span class="text-muted small" title="Active interface language">@_t.Culture.ToUpper()</span>
            </div>
        </div>
    </footer>

    @* Localized strings exposed to client-side scripts. JS files read
       window.kronStrings.X with a fallback to the English literal so the
       page still works if a key is missing from a translation. *@
    <script>
        window.kronStrings = {
            readMore: @Json.Serialize(_t["Read more"]),
            readLess: @Json.Serialize(_t["Read less"]),
            loadingConversations: @Json.Serialize(_t["Loading conversations…"]),
            loadingMessages: @Json.Serialize(_t["Loading messages…"]),
            noMessagesYet: @Json.Serialize(_t["No messages yet"]),
            useNewMessage: @Json.Serialize((currentUiCulture == "it" ? "Usa Nuovo messaggio qui sotto per iniziare." : "Use New message below to start one.")),
            saySomething: @Json.Serialize((currentUiCulture == "it" ? "Saluta " : "Say hi to ")),
            sendingFeedback: @Json.Serialize(_t["Sending…"]),
            feedbackThanks: @Json.Serialize(_t["Thanks! Sent to Kronoadmin."]),
            failedToSend: @Json.Serialize(_t["Failed to send."]),
            couldNotSend: @Json.Serialize(_t["Could not send."]),
            couldNotLoadMessages: @Json.Serialize(_t["Could not load messages."]),
            networkError: @Json.Serialize(_t["Network error. Please try again."]),
            unitMinute: 'm',
            unitHour: 'h',
            now: @Json.Serialize((currentUiCulture == "it" ? "ora" : "now")),
            tour: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
            {
                stepCounter = currentUiCulture == "it" ? "Passo {0} di {1}" : "Step {0} of {1}",
                next        = currentUiCulture == "it" ? "Avanti" : "Next",
                finish      = currentUiCulture == "it" ? "Fine" : "Finish",
                skip        = currentUiCulture == "it" ? "Salta il tour" : "Skip tour",
                maybeLater  = currentUiCulture == "it" ? "Magari più tardi" : "Maybe later",
                tipCreator  = currentUiCulture == "it" ? "Sostieni il progetto ☕" : "Support the Project ☕",
                steps = currentUiCulture == "it" ? new[]
                {
                    new { id = 1, title = "Benvenuto su Kronoscript",   body = "Storie ordinate per quando sono successe — non per quando le hai scritte. Due minuti." },
                    new { id = 2, title = "Storia rapida",              body = "Scrivi un ricordo, aggiungi l'anno, pubblica. Per quelli più lunghi con foto e musica, usa \"Nuova storia completa\" in alto." },
                    new { id = 3, title = "Scegli chi la vede",         body = "Pubblico, Amici, Famiglia, o Solo io — per storia, non per account." },
                    new { id = 4, title = "La tua rete, in livelli",    body = "Smista le persone in Conoscenti, Amici, Famiglia. Sono i livelli che scegli quando imposti la visibilità." },
                    new { id = 5, title = "La tua linea del tempo",     body = "Ogni storia pubblicata si dispone qui in ordine cronologico. La tua vita come un libro." },
                    new { id = 6, title = "Tutto il resto",             body = "Impostazioni, bozze, esportazione, e Rivedi il tour vivono dietro il tuo nome qui in alto." },
                    new { id = 7, title = "Sostieni il progetto",       body = "Kronoscript è gratuito e senza pubblicità. Un piccolo contributo lo mantiene così. ☕" }
                } : new[]
                {
                    new { id = 1, title = "Welcome to Kronoscript",     body = "Stories kept by when they happened — not when you posted them. Two minutes." },
                    new { id = 2, title = "Quick Story",                body = "Type a memory, add the year, post. For longer ones with photos and music, use \"New full story\" up top." },
                    new { id = 3, title = "Choose who sees it",         body = "Public, Friends, Family, or Only Me — per story, not per account." },
                    new { id = 4, title = "Your network, in tiers",     body = "Sort people into Acquaintances, Friends, Family. These are what you pick from when you set visibility." },
                    new { id = 5, title = "Your timeline",              body = "Every story you publish lines up here in chronological order. Your life as a book." },
                    new { id = 6, title = "Everything else",            body = "Settings, drafts, export, and Replay tour all live behind your name up here." },
                    new { id = 7, title = "Support the project",        body = "Kronoscript is free and ad-free. A small contribution keeps it that way. ☕" }
                }
            }))
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    }
    <!-- Cookie consent — only essential cookies are used (auth, antiforgery, theme),
         so the banner is informational rather than a blocking consent gate. -->
    <div id="cookieBanner" class="cookie-banner" style="display:none;" role="region" aria-label="@(_t["Cookie notice"])">
        <div>
            @if (currentUiCulture == "it")
            {
                <span>Usiamo solo <strong>cookie essenziali</strong> — per tenerti connesso, proteggere i moduli e ricordare il tuo tema. Niente tracciamento, niente pubblicità. Usando Kronoscript li accetti. <a asp-controller="Home" asp-action="Privacy">@_t["Read more"]</a>.</span>
            }
            else
            {
                <span>We only use <strong>essential cookies</strong> — to keep you signed in, protect form submissions, and remember your theme. No tracking, no advertising. By using Kronoscript you accept these. <a asp-controller="Home" asp-action="Privacy">Read more</a>.</span>
            }
        </div>
        <button type="button" class="btn btn-sm btn-light" id="cookieBannerOk">OK</button>
    </div>
    <script>
        (function () {
            try {
                if (localStorage.getItem('kronCookieAck_v1') === '1') return;
                var b = document.getElementById('cookieBanner');
                if (!b) return;
                b.style.display = 'flex';
                document.getElementById('cookieBannerOk').addEventListener('click', function () {
                    try { localStorage.setItem('kronCookieAck_v1', '1'); } catch (e) {}
                    b.style.display = 'none';
                });
            } catch (e) {}
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script src="~/js/tour.js" asp-append-version="true"></script>
    }
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.replay-onboarding').forEach(function (replayLink) {
            replayLink.addEventListener('click', function (e) {
                e.preventDefault();
                try {
                    localStorage.removeItem('kronOnboardDismissed_v2');
                    sessionStorage.removeItem('kronOnboardSeenThisSession_v2');
                    localStorage.removeItem('kronOnboardDismissed_v3');
                    sessionStorage.removeItem('kronOnboardSeenThisSession_v3');
                    localStorage.removeItem('kronOnboardDismissed_v4');
                    sessionStorage.removeItem('kronOnboardSeenThisSession_v4');
                } catch (err) {}
                window.location.href = '/';
            });
        });
        var tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltipEls.forEach(function (el) {
            new bootstrap.Tooltip(el, {
                trigger: 'hover',
                delay: { show: 300, hide: 100 },
                placement: 'bottom',
                fallbackPlacements: ['top']
            });
        });

        // ── Mobile side drawer ─────────────────────────────────────────
        // Replaces the bootstrap navbar collapse on small screens — the
        // collapse stays mounted for desktop (d-md-flex) but the
        // hamburger only fires the drawer on mobile (d-md-none).
        (function initDrawer() {
            var toggle   = document.getElementById('kronDrawerToggle');
            var drawer   = document.getElementById('kronDrawer');
            var backdrop = document.getElementById('kronDrawerBackdrop');
            var closeBtn = document.getElementById('kronDrawerClose');
            if (!toggle || !drawer || !backdrop) return;

            function open() {
                drawer.hidden = false;
                backdrop.hidden = false;
                // Force reflow so the CSS transform transition runs.
                drawer.offsetWidth;
                drawer.classList.add('is-open');
                backdrop.classList.add('is-open');
                document.body.classList.add('kron-drawer-open');
                toggle.setAttribute('aria-expanded', 'true');
            }
            function close() {
                drawer.classList.remove('is-open');
                backdrop.classList.remove('is-open');
                document.body.classList.remove('kron-drawer-open');
                toggle.setAttribute('aria-expanded', 'false');
                // Wait for the slide-out, then hide so it's not in the
                // tab-order while closed.
                setTimeout(function () {
                    if (!drawer.classList.contains('is-open')) {
                        drawer.hidden = true;
                        backdrop.hidden = true;
                    }
                }, 250);
            }
            toggle.addEventListener('click', open);
            backdrop.addEventListener('click', close);
            if (closeBtn) closeBtn.addEventListener('click', close);
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && drawer.classList.contains('is-open')) close();
            });
            // Close after navigating to a link inside the drawer.
            drawer.querySelectorAll('a').forEach(function (a) {
                a.addEventListener('click', function () { close(); });
            });
            // Theme toggle inside the drawer mirrors the desktop one.
            var drawerTheme = document.getElementById('kronDrawerThemeToggle');
            if (drawerTheme) {
                drawerTheme.addEventListener('click', function () {
                    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
                    if (dark) {
                        document.documentElement.removeAttribute('data-theme');
                        try { localStorage.setItem('kronTheme', 'light'); } catch (e) {}
                    } else {
                        document.documentElement.setAttribute('data-theme', 'dark');
                        try { localStorage.setItem('kronTheme', 'dark'); } catch (e) {}
                    }
                    // Refresh icon state inside the drawer.
                    var sun  = drawerTheme.querySelector('.theme-icon-sun');
                    var moon = drawerTheme.querySelector('.theme-icon-moon');
                    var nowDark = document.documentElement.getAttribute('data-theme') === 'dark';
                    if (sun)  sun.style.display  = nowDark ? 'none' : '';
                    if (moon) moon.style.display = nowDark ? '' : 'none';
                });
                // Initial sync
                var nowDark = document.documentElement.getAttribute('data-theme') === 'dark';
                var sun  = drawerTheme.querySelector('.theme-icon-sun');
                var moon = drawerTheme.querySelector('.theme-icon-moon');
                if (sun)  sun.style.display  = nowDark ? 'none' : '';
                if (moon) moon.style.display = nowDark ? '' : 'none';
            }
        })();

        // ── Floating chat dock ─────────────────────────────────────────
        // Two modes: "list" (recent conversations + feedback row) and
        // "thread" (inline conversation with a back button + composer).
        // The dock owns one SignalR connection and either appends to the
        // open thread or refreshes the list, depending on which mode is
        // active when a message lands.
        (function initChatDock() {
            var fab           = document.getElementById('chatFab');
            var dock          = document.getElementById('chatDock');
            if (!fab || !dock) return;

            var listPanel     = document.getElementById('chatDockListPanel');
            var threadPanel   = document.getElementById('chatDockThreadPanel');
            var headerList    = dock.querySelector('.chat-dock-header-list');
            var headerThread  = dock.querySelector('.chat-dock-header-thread');
            var listEl        = document.getElementById('chatDockList');
            var threadEl      = document.getElementById('chatDockThread');
            var badge         = document.getElementById('chatFabBadge');

            var closeBtn      = document.getElementById('chatDockClose');
            var closeBtnT     = document.getElementById('chatDockCloseThread');
            var backBtn       = document.getElementById('chatDockBack');
            var threadName    = document.getElementById('chatDockThreadName');
            var threadAvatar  = document.getElementById('chatDockThreadAvatar');
            var threadExpand  = document.getElementById('chatDockThreadExpand');

            var msgBody       = document.getElementById('chatDockMsgBody');
            var sendBtn       = document.getElementById('chatDockSendBtn');
            var sendError     = document.getElementById('chatDockSendError');

            var fbToggle      = document.getElementById('chatDockFeedbackToggle');
            var fbForm        = document.getElementById('chatDockFeedbackForm');
            var fbText        = document.getElementById('chatDockFeedbackText');
            var fbSend        = document.getElementById('chatDockFeedbackSend');
            var fbStatus      = document.getElementById('chatDockFeedbackStatus');

            // "Look offline" toggle in the dock footer. Flipping it POSTs
            // to /Profile/SetVisibility (persists ShowOnlineStatus) AND
            // tells the live presence hub via window.kronosPresence so
            // every connected viewer's dot updates without a page refresh.
            var lookOfflineEl = document.getElementById('chatDockLookOffline');
            if (lookOfflineEl) {
                lookOfflineEl.addEventListener('change', function () {
                    var lookingOffline = lookOfflineEl.checked;
                    var fd = new FormData();
                    fd.append('show', lookingOffline ? 'false' : 'true');
                    var token = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (token) fd.append('__RequestVerificationToken', token.value);
                    fetch('/Profile/SetVisibility', {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin'
                    }).then(function (r) {
                        if (!r.ok) lookOfflineEl.checked = !lookingOffline;
                    }).catch(function () { lookOfflineEl.checked = !lookingOffline; });
                    if (window.kronosPresence && window.kronosPresence.setVisibility) {
                        window.kronosPresence.setVisibility(!lookingOffline);
                    }
                });
            }

            // Identity of the current viewer — pulled from the navbar's
            // data-user-id if present; otherwise inferred from the first
            // outgoing message we render. Used to decide bubble alignment.
            var currentUserId = (document.body.dataset.currentUserId || '').trim();
            if (!currentUserId) {
                var meEl = document.querySelector('[data-current-user-id]');
                if (meEl) currentUserId = meEl.dataset.currentUserId || '';
            }

            // ── helpers ────────────────────────────────────────────────
            function escapeHtml(s) {
                return String(s == null ? '' : s)
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }
            function timeAgo(iso) {
                if (!iso) return '';
                var d = new Date(iso);
                var s = (Date.now() - d.getTime()) / 1000;
                var L = window.kronStrings || {};
                if (s < 60) return L.now || 'now';
                if (s < 3600) return Math.floor(s / 60) + (L.unitMinute || 'm');
                if (s < 86400) return Math.floor(s / 3600) + (L.unitHour || 'h');
                if (s < 604800) return d.toLocaleDateString(undefined, { weekday: 'short' });
                return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
            }
            function fmtTime(d) {
                var h = d.getHours(); var m = d.getMinutes();
                var ampm = h >= 12 ? 'pm' : 'am';
                h = h % 12; if (h === 0) h = 12;
                return h + ':' + (m < 10 ? '0' + m : m) + ' ' + ampm;
            }
            function initialsFor(name) {
                var n = (name || '?').trim();
                return (n.length >= 2 ? n[0] + n[1] : (n[0] || '?')).toUpperCase();
            }
            function setBadge(count) {
                if (!badge) return;
                if (!count || count <= 0) {
                    badge.hidden = true;
                    badge.textContent = '0';
                } else {
                    badge.hidden = false;
                    badge.textContent = count > 99 ? '99+' : String(count);
                }
            }

            // ── List rendering ────────────────────────────────────────
            function renderList(data) {
                if (!data || !data.conversations || data.conversations.length === 0) {
                    var L = window.kronStrings || {};
                    listEl.innerHTML =
                        '<div class="chat-dock-empty">' +
                            '<div class="chat-dock-empty-icon">💬</div>' +
                            '<div class="chat-dock-empty-title">' + escapeHtml(L.noMessagesYet || 'No messages yet') + '</div>' +
                            '<div class="chat-dock-empty-sub">' + escapeHtml(L.useNewMessage || 'Use New message below to start one.') + '</div>' +
                        '</div>';
                    return;
                }
                var html = '';
                data.conversations.forEach(function (c) {
                    var name = c.otherName || c.otherUsername || '?';
                    // Wrap the avatar in a .presence-dot span so the
                    // SignalR presence wiring (site.js) toggles green/away
                    // dots as people come online or go idle. hidePresence
                    // marks users who chose "Look offline" — their dot
                    // stays grey regardless of connection state.
                    var avatarInner = c.otherPhoto
                        ? '<img src="' + escapeHtml(c.otherPhoto) + '" alt="" />'
                        : '<span class="chat-dock-avatar-fallback">' + escapeHtml(initialsFor(name)) + '</span>';
                    var hideAttr = c.hidePresence ? ' data-presence-hidden="true"' : '';
                    var avatar = '<span class="presence-dot size-sm" data-presence-user="' + escapeHtml(c.otherId) + '"' + hideAttr + '>' + avatarInner + '</span>';
                    var preview = (c.lastFromMe ? 'You: ' : '') + (c.lastBody || '');
                    html += '<button type="button" class="chat-dock-conv ' + (c.unread > 0 ? 'is-unread' : '') + '"'
                          + ' data-other-id="' + escapeHtml(c.otherId) + '"'
                          + ' data-other-name="' + escapeHtml(name) + '"'
                          + ' data-other-photo="' + escapeHtml(c.otherPhoto || '') + '"'
                          + ' data-other-initials="' + escapeHtml(initialsFor(name)) + '">'
                          + '  <span class="chat-dock-avatar">' + avatar + '</span>'
                          + '  <span class="chat-dock-conv-body">'
                          + '    <span class="chat-dock-conv-row1">'
                          + '      <span class="chat-dock-conv-name">' + escapeHtml(name) + '</span>'
                          + '      <span class="chat-dock-conv-time">' + escapeHtml(timeAgo(c.sentAt)) + '</span>'
                          + '    </span>'
                          + '    <span class="chat-dock-conv-preview">' + escapeHtml(preview) + '</span>'
                          + '  </span>'
                          + (c.unread > 0 ? '<span class="chat-dock-conv-unread">' + c.unread + '</span>' : '')
                          + '</button>';
                });
                listEl.innerHTML = html;
                // Newly-injected .presence-dot wrappers need the global
                // presence wiring to compute their initial colour. The
                // rescan picks up data-presence-hidden + applies the
                // online/away class from the current state map.
                if (window.kronosPresence && window.kronosPresence.rescan) {
                    window.kronosPresence.rescan();
                }
                listEl.querySelectorAll('.chat-dock-conv').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        openThread({
                            otherId: btn.dataset.otherId,
                            otherName: btn.dataset.otherName,
                            otherPhoto: btn.dataset.otherPhoto,
                            otherInitials: btn.dataset.otherInitials
                        });
                    });
                });
            }

            var lastLoadedAt = 0;
            function loadDockData(force) {
                // Throttle: if we just loaded within 1.5s and there's nothing
                // forcing a refresh, skip — SignalR will catch us up anyway.
                var now = Date.now();
                if (!force && (now - lastLoadedAt) < 1500) return Promise.resolve();
                lastLoadedAt = now;
                return fetch('/Inbox/DockData', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (data) {
                        if (!data) return;
                        renderList(data);
                        setBadge(data.totalUnread || 0);
                    })
                    .catch(function () { /* network blip — leave the existing UI */ });
            }

            // ── Mode switching ────────────────────────────────────────
            function setMode(mode) {
                dock.dataset.mode = mode;
                if (mode === 'thread') {
                    listPanel.hidden = true;
                    threadPanel.hidden = false;
                    headerList.hidden = true;
                    headerThread.hidden = false;
                    setTimeout(function () { if (msgBody) msgBody.focus(); }, 30);
                } else {
                    threadPanel.hidden = true;
                    listPanel.hidden = false;
                    headerList.hidden = false;
                    headerThread.hidden = true;
                    threadEl.dataset.otherId = '';
                }
            }

            function openDock() {
                dock.hidden = false;
                fab.setAttribute('aria-expanded', 'true');
                loadDockData(true);
                document.body.classList.add('chat-dock-open');
            }
            function closeDock() {
                dock.hidden = true;
                fab.setAttribute('aria-expanded', 'false');
                if (fbForm) { fbForm.hidden = true; fbToggle.setAttribute('aria-expanded', 'false'); }
                document.body.classList.remove('chat-dock-open');
                setMode('list');
            }
            function toggleDock() { dock.hidden ? openDock() : closeDock(); }

            // ── Inline thread ─────────────────────────────────────────
            function avatarHtmlFor(other, isMe) {
                if (isMe) {
                    // We don't render our own avatar in the thread bubbles —
                    // alignment is enough to tell who said what.
                    return '';
                }
                if (other.photo) {
                    return '<img src="' + escapeHtml(other.photo) + '" alt="" />';
                }
                return '<span class="chat-dock-thread-avatar-fallback">' + escapeHtml(other.initials || '?') + '</span>';
            }

            function renderThreadMessages(messages, other) {
                if (!messages || messages.length === 0) {
                    var L = window.kronStrings || {};
                    var prefix = (L.noMessagesYet || 'No messages yet') + ' — ' + (L.saySomething || 'say hi to ');
                    threadEl.innerHTML =
                        '<div class="chat-dock-thread-empty">' +
                            '<div>💬</div>' +
                            '<div class="small">' + escapeHtml(prefix) + escapeHtml(other.name) + '.</div>' +
                        '</div>';
                    return;
                }
                threadEl.innerHTML = '';
                var lastSenderId = null;
                messages.forEach(function (m) {
                    appendThreadMessage(m, other, /*scroll*/ false, lastSenderId);
                    lastSenderId = m.senderId;
                });
                threadEl.scrollTop = threadEl.scrollHeight;
            }

            function appendThreadMessage(m, other, scroll, prevSenderId) {
                if (!threadEl) return;
                // De-dupe: if the message id already rendered, skip.
                if (m.id != null && threadEl.querySelector('[data-msg-id="' + m.id + '"]')) return;

                // Drop the empty state once we have a real message.
                var empty = threadEl.querySelector('.chat-dock-thread-empty');
                if (empty) empty.remove();

                var isMe = m.senderId === currentUserId
                          || (currentUserId === '' && m.recipientId === other.otherId);
                if (!currentUserId && isMe) {
                    // Infer current user id once we see one of our own messages
                    currentUserId = m.senderId;
                }

                var rows = threadEl.querySelectorAll('.chat-dock-row');
                var lastRow = rows.length ? rows[rows.length - 1] : null;
                var continuation = lastRow && (
                    (isMe && lastRow.classList.contains('is-me')) ||
                    (!isMe && lastRow.classList.contains('is-them'))
                );

                var row = document.createElement('div');
                row.className = 'chat-dock-row ' + (isMe ? 'is-me' : 'is-them') + (continuation ? ' is-continuation' : '');
                if (m.id != null) row.dataset.msgId = m.id;

                var sentAt = m.sentAt ? new Date(m.sentAt) : new Date();
                var avatarSlot = '';
                if (!isMe) {
                    avatarSlot = '<span class="chat-dock-row-avatar">' +
                        (continuation ? '' : avatarHtmlFor(other, false)) +
                        '</span>';
                }
                row.innerHTML = avatarSlot
                    + '<span class="chat-dock-row-bubblegroup">'
                    +   '<span class="chat-dock-bubble">' + escapeHtml(m.body).replace(/\n/g, '<br />') + '</span>'
                    +   '<span class="chat-dock-row-time">' + escapeHtml(fmtTime(sentAt)) + '</span>'
                    + '</span>';
                threadEl.appendChild(row);
                if (scroll !== false) threadEl.scrollTop = threadEl.scrollHeight;
            }

            function openThread(other) {
                if (!other || !other.otherId) return;
                threadEl.dataset.otherId       = other.otherId;
                threadEl.dataset.otherName     = other.otherName || '';
                threadEl.dataset.otherPhoto    = other.otherPhoto || '';
                threadEl.dataset.otherInitials = other.otherInitials || initialsFor(other.otherName || '?');

                threadName.textContent = other.otherName || 'Conversation';
                threadName.href = '/Profile/Index/' + encodeURIComponent(other.otherId);
                threadExpand.href = '/Inbox/Conversation/' + encodeURIComponent(other.otherId);

                threadAvatar.innerHTML = other.otherPhoto
                    ? '<img src="' + escapeHtml(other.otherPhoto) + '" alt="" />'
                    : '<span class="chat-dock-thread-avatar-fallback">' + escapeHtml(other.otherInitials || initialsFor(other.otherName || '?')) + '</span>';

                var L = window.kronStrings || {};
                threadEl.innerHTML = '<div class="chat-dock-loading">' + escapeHtml(L.loadingMessages || 'Loading messages…') + '</div>';
                setMode('thread');

                fetch('/Inbox/Thread/' + encodeURIComponent(other.otherId), {
                    credentials: 'same-origin',
                    headers: { 'Accept': 'application/json' }
                })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (data) {
                    if (!data) {
                        threadEl.innerHTML = '<div class="chat-dock-empty"><div class="small">' + escapeHtml(L.couldNotLoadMessages || 'Could not load messages.') + '</div></div>';
                        return;
                    }
                    threadEl.dataset.otherId       = data.otherId;
                    threadEl.dataset.otherName     = data.otherName || '';
                    threadEl.dataset.otherPhoto    = data.otherPhoto || '';
                    threadEl.dataset.otherInitials = data.otherInitials || initialsFor(data.otherName || '?');
                    renderThreadMessages(data.messages, {
                        otherId: data.otherId,
                        name: data.otherName,
                        photo: data.otherPhoto,
                        initials: data.otherInitials
                    });
                    // After opening a thread, server marked unread as read —
                    // refresh the badge so it drops.
                    loadDockData(true);
                })
                .catch(function () {
                    threadEl.innerHTML = '<div class="chat-dock-empty"><div class="small">' + escapeHtml(L.networkError || 'Network error. Please try again.') + '</div></div>';
                });
            }

            // ── Composer (inside the inline thread) ───────────────────
            function sendThreadMessage() {
                if (!msgBody) return;
                var rid = threadEl.dataset.otherId;
                if (!rid) return;
                var body = (msgBody.value || '').trim();
                if (!body) return;

                sendBtn.disabled = true;
                sendError.hidden = true;
                sendError.textContent = '';

                var token = (document.querySelector('#chatDockThreadPanel input[name="__RequestVerificationToken"]') || {}).value;
                var fd = new FormData();
                fd.append('recipientId', rid);
                fd.append('body', body);
                if (token) fd.append('__RequestVerificationToken', token);

                fetch('/Inbox/Send', {
                    method: 'POST', body: fd, credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
                })
                .then(function (r) {
                    if (r.status === 429) {
                        var ra = parseInt(r.headers.get('Retry-After') || '0', 10);
                        if (window.kronShowSlowDown) window.kronShowSlowDown(ra);
                        throw new Error('Rate limited.');
                    }
                    if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || 'Could not send.'); });
                    return r.json();
                })
                .then(function (saved) {
                    appendThreadMessage({
                        id: saved.id,
                        body: saved.body,
                        sentAt: saved.sentAt,
                        senderId: saved.senderId,
                        recipientId: saved.recipientId
                    }, {
                        otherId: threadEl.dataset.otherId,
                        name: threadEl.dataset.otherName,
                        photo: threadEl.dataset.otherPhoto,
                        initials: threadEl.dataset.otherInitials
                    });
                    msgBody.value = '';
                    msgBody.style.height = 'auto';
                    msgBody.focus();
                })
                .catch(function (err) {
                    var L2 = window.kronStrings || {};
                    sendError.textContent = err.message || (L2.couldNotSend || 'Could not send.');
                    sendError.hidden = false;
                })
                .finally(function () { sendBtn.disabled = false; });
            }

            if (msgBody) {
                msgBody.addEventListener('input', function () {
                    this.style.height = 'auto';
                    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
                });
                msgBody.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' && !e.shiftKey && !e.isComposing) {
                        e.preventDefault();
                        sendThreadMessage();
                    }
                });
            }
            if (sendBtn) sendBtn.addEventListener('click', sendThreadMessage);
            if (backBtn) backBtn.addEventListener('click', function () { setMode('list'); loadDockData(true); });

            // ── Wire-up ──────────────────────────────────────────────
            fab.addEventListener('click', toggleDock);
            if (closeBtn)  closeBtn.addEventListener('click', closeDock);
            if (closeBtnT) closeBtnT.addEventListener('click', closeDock);

            // Click outside the dock closes it; FAB click is excluded
            // because it'd toggle twice otherwise.
            document.addEventListener('click', function (e) {
                if (dock.hidden) return;
                if (dock.contains(e.target) || fab.contains(e.target)) return;
                closeDock();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && !dock.hidden) {
                    if (dock.dataset.mode === 'thread') { setMode('list'); }
                    else { closeDock(); }
                }
            });

            // Feedback expander
            if (fbToggle && fbForm) {
                fbToggle.addEventListener('click', function () {
                    var open = !fbForm.hidden;
                    fbForm.hidden = open;
                    fbToggle.setAttribute('aria-expanded', open ? 'false' : 'true');
                    if (!open && fbText) { fbText.focus(); }
                });
            }
            if (fbSend && fbText) {
                function sendFeedback() {
                    var body = (fbText.value || '').trim();
                    if (!body) return;
                    var L = window.kronStrings || {};
                    fbSend.disabled = true;
                    fbStatus.textContent = L.sendingFeedback || 'Sending…';
                    fbStatus.style.color = '';
                    var token = (document.querySelector('#chatDockFeedback input[name="__RequestVerificationToken"]') || {}).value;
                    var fd = new FormData();
                    fd.append('body', body);
                    if (token) fd.append('__RequestVerificationToken', token);
                    fetch('/Home/Feedback', {
                        method: 'POST', body: fd, credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
                    })
                    .then(function (r) {
                        if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || (L.couldNotSend || 'Could not send.')); });
                        return r.json();
                    })
                    .then(function () {
                        fbText.value = '';
                        fbStatus.textContent = L.feedbackThanks || 'Thanks! Sent to Kronoadmin.';
                        fbStatus.style.color = 'var(--mst-primary)';
                        setTimeout(function () { fbStatus.textContent = ''; fbForm.hidden = true; fbToggle.setAttribute('aria-expanded', 'false'); }, 1500);
                    })
                    .catch(function (err) {
                        fbStatus.textContent = err.message || (L.failedToSend || 'Failed to send.');
                        fbStatus.style.color = '#b34141';
                    })
                    .finally(function () { fbSend.disabled = false; });
                }
                fbSend.addEventListener('click', sendFeedback);
                fbText.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); sendFeedback(); }
                });
            }

            // Initial badge load (so the FAB shows unread count even when
            // the dock is closed).
            loadDockData(true);

            // SignalR — if the message belongs to the open thread, append
            // it inline; otherwise refresh the list + badge.
            if (typeof signalR !== 'undefined') {
                try {
                    var conn = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/messages')
                        .withAutomaticReconnect()
                        .build();
                    conn.on('messageReceived', function (msg) {
                        if (!msg) return;
                        var openOtherId = threadEl.dataset.otherId;
                        var inThread = dock.dataset.mode === 'thread' && openOtherId &&
                            ((msg.senderId === openOtherId) || (msg.recipientId === openOtherId));
                        if (inThread && !threadPanel.hidden) {
                            appendThreadMessage(msg, {
                                otherId: openOtherId,
                                name: threadEl.dataset.otherName,
                                photo: threadEl.dataset.otherPhoto,
                                initials: threadEl.dataset.otherInitials
                            });
                        }
                        // Always refresh the list + badge; cheap, throttled.
                        loadDockData(true);
                    });
                    conn.start().catch(function () { /* hub unreachable — manual refresh still works */ });
                } catch (e) { /* no SignalR — dock still functional */ }
            }
        })();

        // Theme toggle
        var toggle = document.getElementById('themeToggle');
        if (toggle) {
            function syncIcons() {
                var dark = document.documentElement.getAttribute('data-theme') === 'dark';
                var sun  = toggle.querySelector('.theme-icon-sun');
                var moon = toggle.querySelector('.theme-icon-moon');
                if (sun)  sun.style.display  = dark ? 'none' : '';
                if (moon) moon.style.display = dark ? '' : 'none';
            }
            syncIcons();
            toggle.addEventListener('click', function () {
                var dark = document.documentElement.getAttribute('data-theme') === 'dark';
                if (dark) {
                    document.documentElement.removeAttribute('data-theme');
                    try { localStorage.setItem('kronTheme', 'light'); } catch (e) {}
                } else {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    try { localStorage.setItem('kronTheme', 'dark'); } catch (e) {}
                }
                syncIcons();
            });
        }
    });
    </script>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
        var act  = ViewContext.RouteData.Values["action"]?.ToString();
        if (ctrl == "Home" && act == "Index")
        {
            // Cleopatra & Caesar story is admin-gated. Defaults OFF so
            // most users never see it; admins can flip it on in
            // Site Settings if they want to A/B with a cohort.
            var onboardOverlayOn = await _layoutSiteSettings.GetBoolAsync(
                MyStoryTold.Services.ISiteSettings.OnboardingOverlayEnabled, false);
            if (onboardOverlayOn)
            {
                @await Html.PartialAsync("_OnboardingOverlay")
            }
        }

        @* Floating chat dock — bubble in the corner that opens an overlay
           with the user's recent conversations + a pinned "feedback to
           admin" entry at the top. Replaces the previous one-shot
           feedback modal: feedback is now part of the same dock, and
           every conversation is one click away from any page. Hidden
           on the Inbox / Conversation routes themselves so we don't
           double up. *@
        var hideDock = ctrl == "Inbox";
        if (!hideDock)
        {
            <button type="button" class="chat-fab" id="chatFab" aria-label="@(_t["Open messages"])" aria-expanded="false">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span class="chat-fab-badge" id="chatFabBadge" hidden>0</span>
            </button>

            <aside class="chat-dock" id="chatDock" hidden aria-label="@(_t["Messages"])" data-mode="list">
                @* List-mode header: title + Open-all + close. Thread-mode
                   header (back + avatar + name + close) lives inside the
                   thread panel so its layout doesn't fight with this one. *@
                <header class="chat-dock-header chat-dock-header-list">
                    <div class="chat-dock-title">💬 @_t["Messages"]</div>
                    <a asp-controller="Inbox" asp-action="Index" class="chat-dock-open-all" title="@(_t["Open the full inbox"])">@_t["Open all →"]</a>
                    <button type="button" class="chat-dock-close" id="chatDockClose" aria-label="@(_t["Close"])">×</button>
                </header>

                @* ── List panel (recent conversations) ─────────────────── *@
                <div class="chat-dock-panel chat-dock-panel-list" id="chatDockListPanel">
                    <section class="chat-dock-feedback" id="chatDockFeedback">
                        <button type="button" class="chat-dock-feedback-row" id="chatDockFeedbackToggle" aria-expanded="false">
                            <span class="chat-dock-feedback-icon">🛟</span>
                            <span class="chat-dock-feedback-label">
                                <span class="chat-dock-feedback-title">@_t["Send feedback to admin"]</span>
                                <span class="chat-dock-feedback-sub">@_t["Bugs, ideas, wishes — goes straight to Kronoadmin."]</span>
                            </span>
                            <span class="chat-dock-chevron" aria-hidden="true">▾</span>
                        </button>
                        <div class="chat-dock-feedback-form" id="chatDockFeedbackForm" hidden>
                            @Html.AntiForgeryToken()
                            <textarea id="chatDockFeedbackText" placeholder="@(_t["What would you like us to know?"])" rows="3"></textarea>
                            <div class="chat-dock-feedback-actions">
                                <span class="chat-dock-feedback-status" id="chatDockFeedbackStatus" aria-live="polite"></span>
                                <button type="button" class="chat-dock-feedback-send" id="chatDockFeedbackSend">@_t["Send"]</button>
                            </div>
                        </div>
                    </section>

                    <section class="chat-dock-list" id="chatDockList">
                        <div class="chat-dock-loading">@_t["Loading conversations…"]</div>
                    </section>

                    <footer class="chat-dock-footer">
                        <a asp-controller="Inbox" asp-action="Compose" class="chat-dock-new">＋ @_t["New message"]</a>
                        @{
                            // Initial state for the toggle — when the user
                            // is hidden, the checkbox renders ON. Live JS
                            // flips both the server state and the dot
                            // broadcasts via /Profile/SetVisibility.
                            var isHiddenNow = navUser != null && !navUser.ShowOnlineStatus;
                        }
                        <label class="chat-dock-look-offline" title="@(_t["Look offline to other members. Your dot will appear grey."])">
                            <input type="checkbox" id="chatDockLookOffline" @(isHiddenNow ? "checked" : "") />
                            <span>@_t["Look offline"]</span>
                        </label>
                    </footer>
                </div>

                @* ── Thread panel (inline conversation) ────────────────── *@
                <div class="chat-dock-panel chat-dock-panel-thread" id="chatDockThreadPanel" hidden>
                    <header class="chat-dock-header chat-dock-header-thread">
                        <button type="button" class="chat-dock-back" id="chatDockBack" aria-label="@(_t["Back to messages"])">←</button>
                        <span class="chat-dock-thread-avatar" id="chatDockThreadAvatar"></span>
                        <a class="chat-dock-thread-name" id="chatDockThreadName" href="#"></a>
                        <a class="chat-dock-thread-expand" id="chatDockThreadExpand" href="#" title="@(_t["Open full chat"])">⤢</a>
                        <button type="button" class="chat-dock-close" id="chatDockCloseThread" aria-label="@(_t["Close"])">×</button>
                    </header>
                    <div class="chat-dock-thread" id="chatDockThread"
                         data-other-id=""
                         data-other-name=""
                         data-other-photo=""
                         data-other-initials="?">
                        <div class="chat-dock-loading">@_t["Loading messages…"]</div>
                    </div>
                    <div class="chat-dock-composer">
                        @Html.AntiForgeryToken()
                        <textarea id="chatDockMsgBody" rows="1" placeholder="@(_t["Message…"])"></textarea>
                        <button type="button" class="chat-dock-send-btn" id="chatDockSendBtn" aria-label="@(_t["Send"])" title="@(_t["Send"])">➤</button>
                    </div>
                    <div class="chat-dock-send-error" id="chatDockSendError" hidden></div>
                </div>
            </aside>
        }

        <!-- Global search popover (small bubble anchored to navbar) -->
        <div id="navSearchPopover" class="nav-search-popover" style="display:none;">
            <div class="nav-search-input-wrap">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="navSearchInput" placeholder="Search people, posts, features…" autocomplete="off" />
                <button type="button" class="nav-search-clear" id="navSearchClear" aria-label="Clear">&times;</button>
            </div>
        </div>

        <!-- Media lightbox -->
        <div id="kronLightbox" class="kron-lightbox" style="display:none;" aria-hidden="true">
            <button type="button" class="kron-lightbox-close" id="kronLightboxClose" aria-label="Close">&times;</button>
            <button type="button" class="kron-lightbox-arrow left" id="kronLightboxPrev" aria-label="Previous">&#10094;</button>
            <button type="button" class="kron-lightbox-arrow right" id="kronLightboxNext" aria-label="Next">&#10095;</button>
            <div class="kron-lightbox-stage">
                <div class="kron-lightbox-bubbles left" id="kronLightboxBubblesLeft"></div>
                <div class="kron-lightbox-content">
                    <img id="kronLightboxImg" alt="" style="display:none;" />
                    <video id="kronLightboxVideo" controls style="display:none;"></video>
                </div>
                <div class="kron-lightbox-bubbles right" id="kronLightboxBubblesRight"></div>
            </div>
            <div class="kron-lightbox-footer">
                <form id="kronLightboxCommentForm" class="kron-lightbox-comment-form" autocomplete="off">
                    <input type="text" id="kronLightboxCommentInput" placeholder="Add a comment to this picture…" maxlength="1000" />
                    <button type="submit">Send</button>
                </form>
                <div class="kron-lightbox-counter" id="kronLightboxCounter"></div>
            </div>
        </div>

        <!-- Guided product tour: hidden until triggered from .start-product-tour -->
        <div id="kronTourOverlay" class="kron-tour-overlay" style="display:none;"></div>
        <div id="kronTourPopup" class="kron-tour-popup" style="display:none;" role="dialog" aria-live="polite">
            <div class="kron-tour-counter"></div>
            <h5 class="kron-tour-title"></h5>
            <div class="kron-tour-body"></div>
            <div class="kron-tour-actions">
                <button type="button" class="kron-tour-skip btn btn-link btn-sm p-0">Skip tour</button>
                <button type="button" class="kron-tour-next btn btn-primary btn-sm">Next</button>
            </div>
        </div>

        <script>
        (function pollInbox() {
            fetch('/Inbox/UnreadCount')
                .then(r => r.json())
                .then(function(count) {
                    var badge = document.getElementById('inboxBadge');
                    if (badge) {
                        badge.textContent = count;
                        badge.style.display = count > 0 ? 'inline' : 'none';
                    }
                })
                .catch(function(){});
            setTimeout(pollInbox, 60000);
        })();

        // Notification bell — poll unread count, load full list on dropdown open,
        // mark all read on open, and on click of an item navigate (read state already
        // updated from the open).
        (function () {
            var bell = document.getElementById('notifBellToggle');
            var badge = document.getElementById('notifBellBadge');
            var menu = document.getElementById('notifBellMenu');
            var list = document.getElementById('notifBellList');
            var markAll = document.getElementById('notifMarkAllRead');
            if (!bell || !badge || !list) return;

            function timeAgo(iso) {
                var d = new Date(iso);
                var s = Math.floor((Date.now() - d.getTime()) / 1000);
                if (s < 60) return 'just now';
                if (s < 3600) return Math.floor(s / 60) + 'm ago';
                if (s < 86400) return Math.floor(s / 3600) + 'h ago';
                if (s < 604800) return Math.floor(s / 86400) + 'd ago';
                return d.toLocaleDateString();
            }
            function escape(s) { return (s || '').replace(/[&<>"']/g, function (c) {
                return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
            function avatarHtml(item) {
                if (item.actorPhoto) return '<span class="notif-avatar"><img src="' + escape(item.actorPhoto) + '" alt="" /></span>';
                var letter = (item.actorName || '?').trim().charAt(0).toUpperCase();
                return '<span class="notif-avatar">' + escape(letter) + '</span>';
            }

            function pollCount() {
                fetch('/Notifications/UnreadCount')
                    .then(function (r) { return r.ok ? r.json() : 0; })
                    .then(function (count) {
                        badge.textContent = count;
                        badge.style.display = count > 0 ? 'inline' : 'none';
                    })
                    .catch(function () {});
                setTimeout(pollCount, 60000);
            }
            pollCount();

            function loadList() {
                list.innerHTML = '<div class="notif-empty p-3 text-center text-muted small">Loading…</div>';
                fetch('/Notifications/Recent')
                    .then(function (r) { return r.ok ? r.json() : []; })
                    .then(function (items) {
                        if (!items || !items.length) {
                            list.innerHTML = '<div class="notif-empty text-center text-muted small">Nothing new yet.</div>';
                            return;
                        }
                        list.innerHTML = items.map(function (i) {
                            var typeClass = 'notif-' + (i.type || 'comment').toLowerCase();
                            return '<a href="' + escape(i.link) + '" class="notif-item ' + typeClass + (i.unread ? ' unread' : '') + '">'
                                + avatarHtml(i)
                                + '<span class="flex-grow-1"><span class="notif-text">' + escape(i.text) + '</span>'
                                + '<div class="notif-time">' + timeAgo(i.createdAt) + '</div></span>'
                                + '</a>';
                        }).join('');
                    })
                    .catch(function () {
                        list.innerHTML = '<div class="notif-empty text-center text-muted small">Couldn’t load.</div>';
                    });
            }
            function markAllRead() {
                var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                var fd = new FormData();
                if (token) fd.append('__RequestVerificationToken', token);
                fetch('/Notifications/MarkAllRead', { method: 'POST', body: fd })
                    .then(function () {
                        badge.textContent = '0';
                        badge.style.display = 'none';
                    })
                    .catch(function () {});
            }

            bell.addEventListener('shown.bs.dropdown', function () {
                loadList();
                markAllRead();
            });
            if (markAll) {
                markAll.addEventListener('click', function (e) {
                    e.preventDefault();
                    markAllRead();
                    // Refresh visible items so the unread highlight clears
                    list.querySelectorAll('.notif-item.unread').forEach(function (n) { n.classList.remove('unread'); });
                });
            }
        })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
