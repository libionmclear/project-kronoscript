@model MyStoryTold.Models.PostVisibility
@{
    var (icon, color, label) = Model switch
    {
        MyStoryTold.Models.PostVisibility.Public        => ("&#9679;", "var(--tier-public)",        "Public"),
        MyStoryTold.Models.PostVisibility.Acquaintances => ("&#9679;", "var(--tier-acquaintances)", "Acquaintances only"),
        MyStoryTold.Models.PostVisibility.Friends       => ("&#9679;", "var(--tier-friends)",       "Friends only"),
        MyStoryTold.Models.PostVisibility.Family        => ("&#9679;", "var(--tier-family)",        "Family only"),
        MyStoryTold.Models.PostVisibility.Private       => ("&#128274;", "var(--tier-private)",     "Private"),
        _                                               => ("&#9679;", "var(--tier-private)", "")
    };
}
<span title="@label"
      style="font-size:14px;line-height:1;vertical-align:middle;cursor:default;flex-shrink:0;@(color != "" ? $"color:{color};" : "opacity:0.8;")"
      aria-label="@label">@Html.Raw(icon)</span>
