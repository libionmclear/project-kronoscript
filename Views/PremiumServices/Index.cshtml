@using MyStoryTold.Models
@{
    ViewData["Title"] = "Premium Services";
    var services = (IReadOnlyList<PremiumServiceInfo>)ViewBag.Services;
    var byCategory = services.GroupBy(s => s.Category).OrderBy(g => g.Key).ToList();
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <header class="ps-hero">
            <p class="ps-hero-eyebrow">Premium Services</p>
            <h1 class="ps-hero-title">When your story needs<br class="d-none d-md-inline" /> to leave the screen.</h1>
            <p class="ps-hero-lead">
                One-off projects, not subscription features. A hardcover bound from your timeline.
                An editor reading every page. An audiobook in your voice. Photos lifted out of a
                shoebox and restored. Order what you want, when you want it.
            </p>
        </header>

        @foreach (var grp in byCategory)
        {
            <section class="ps-section">
                <h3 class="ps-section-name">@grp.Key</h3>
                <div class="ps-grid">
                    @foreach (var svc in grp.OrderBy(s => s.Name))
                    {
                        <a asp-action="Details" asp-route-id="@svc.Slug" class="ps-card-link">
                            <div class="ps-card">
                                <div class="ps-card-eyebrow">@svc.IconEmoji</div>
                                <h4 class="ps-card-name">@svc.Name</h4>
                                <p class="ps-card-desc">@svc.ShortDescription</p>
                                <span class="ps-card-arrow">Read more →</span>
                            </div>
                        </a>
                    }
                </div>
            </section>
        }

        <section class="ps-closing">
            <h3>Ready to order?</h3>
            <p>
                Pricing depends on scope. Send us a note with what you have in mind and we'll come back
                with a quote and a timeline. No commitment, no upsell.
            </p>
            <a asp-controller="Inbox" asp-action="Compose" asp-route-id="kronoadmin" class="btn btn-primary btn-lg">
                Send us a note
            </a>
        </section>
    </div>
</div>
