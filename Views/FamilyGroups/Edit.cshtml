@model MyStoryTold.Models.FamilyGroup
@{
    ViewData["Title"] = "Edit group";
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <header class="page-header">
            <div class="page-header-titles">
                <p class="page-header-eyebrow">Group settings</p>
                <h2 class="page-header-title">Edit group</h2>
            </div>
        </header>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="card border-0 shadow-sm p-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" maxlength="120" autocomplete="off" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Kind" class="form-label">Kind</label>
                <div class="kind-choice">
                    <label class="kind-choice-option">
                        <input type="radio" asp-for="Kind" value="0" />
                        <span class="kind-choice-label">
                            <span class="kind-choice-title">Family</span>
                            <span class="kind-choice-sub">Relatives. Can pin a shared family tree.</span>
                        </span>
                    </label>
                    <label class="kind-choice-option">
                        <input type="radio" asp-for="Kind" value="1" />
                        <span class="kind-choice-label">
                            <span class="kind-choice-title">Friends</span>
                            <span class="kind-choice-sub">A circle from school, work, or somewhere in between.</span>
                        </span>
                    </label>
                    <label class="kind-choice-option">
                        <input type="radio" asp-for="Kind" value="2" />
                        <span class="kind-choice-label">
                            <span class="kind-choice-title">Mixed</span>
                            <span class="kind-choice-sub">Family + friends in the same group.</span>
                        </span>
                    </label>
                </div>
                <span asp-validation-for="Kind" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description <span class="text-muted small">(optional)</span></label>
                <textarea asp-for="Description" class="form-control" rows="3" maxlength="500"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
