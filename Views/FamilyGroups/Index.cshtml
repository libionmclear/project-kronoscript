@model List<MyStoryTold.Models.FamilyGroupMember>
@{
    ViewData["Title"] = "Groups";
    var canCreate    = (bool)(ViewBag.CanCreate ?? false);
    var memberCounts = ViewBag.MemberCounts as Dictionary<int, int> ?? new();

    string RoleLabel(MyStoryTold.Models.FamilyGroupRole role) => role switch
    {
        MyStoryTold.Models.FamilyGroupRole.Admin   => "Admin",
        MyStoryTold.Models.FamilyGroupRole.CoAdmin => "Co-admin",
        _ => "Member"
    };

    string KindLabel(MyStoryTold.Models.GroupKind k) => k switch
    {
        MyStoryTold.Models.GroupKind.Friends => "Friends",
        MyStoryTold.Models.GroupKind.Mixed   => "Mixed",
        _ => "Family"
    };
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <header class="page-header">
            <div class="page-header-titles">
                <p class="page-header-eyebrow">Groups
                    <partial name="_PremiumBadge" model="@MyStoryTold.Models.PremiumFeature.FamilyGroups" />
                </p>
                <h2 class="page-header-title">A private corner for the people who share a story with you.</h2>
                <p class="page-header-lead">
                    Build a small, private space — your siblings, your old roommates, your in-laws. Share
                    stories, photos, and a thread of memory inside it. You can belong to many.
                </p>
            </div>
            @if (canCreate)
            {
                <a asp-action="Create" class="btn btn-primary">+ New group</a>
            }
        </header>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show py-2">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show py-2">@TempData["Info"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        @if (!Model.Any())
        {
            @if (canCreate)
            {
                <div class="empty-state card border-0 shadow-sm text-center p-5">
                    <h4 class="mt-3 mb-2">No groups yet</h4>
                    <p class="text-muted mb-3">Start with the slice of people you most want to share memories with — your siblings, your high-school friends, your in-laws.</p>
                    <div><a asp-action="Create" class="btn btn-primary">+ Create your first group</a></div>
                </div>
            }
            else
            {
                <partial name="_PremiumGate" model="@MyStoryTold.Models.PremiumFeature.FamilyGroups" />
            }
        }
        else
        {
            <div class="group-list">
                @foreach (var m in Model)
                {
                    var g = m.FamilyGroup!;
                    var count = memberCounts.TryGetValue(g.Id, out var c) ? c : 0;
                    <a asp-action="Details" asp-route-id="@g.Id" class="group-card">
                        <div class="group-card-head">
                            <div class="group-card-title-group">
                                <div class="group-card-name">@g.Name</div>
                                <span class="group-kind-tag" data-kind="@g.Kind">@KindLabel(g.Kind)</span>
                            </div>
                            <span class="group-card-role">@RoleLabel(m.Role)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(g.Description))
                        {
                            <p class="group-card-desc text-muted small mt-2 mb-1">@g.Description</p>
                        }
                        <div class="group-card-count text-muted small">@count @(count == 1 ? "member" : "members")</div>
                    </a>
                }
            </div>
        }
    </div>
</div>
