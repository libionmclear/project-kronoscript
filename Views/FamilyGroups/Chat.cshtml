@using MyStoryTold.Models
@{
    var group = ViewBag.Group as FamilyGroup;
    var messages = ViewBag.Messages as List<GroupMessage> ?? new();
    var meId = ViewBag.MyUserId as string ?? "";
    ViewData["Title"] = (group?.Name ?? "Group") + " — chat";

    string MsgInitials(ApplicationUser? u)
    {
        if (u == null) return "?";
        if (!string.IsNullOrEmpty(u.FirstName) && !string.IsNullOrEmpty(u.LastName))
            return $"{u.FirstName[0]}{u.LastName[0]}".ToUpper();
        var un = u.DisplayName ?? u.UserName ?? "??";
        return (un.Length >= 2 ? un[..2] : un).ToUpper();
    }
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h3 class="mb-1">@group?.Name — chat
                    <partial name="_PremiumBadge" model="@PremiumFeature.FamilyChat" />
                </h3>
                <div class="text-muted small">
                    Live chat for group members. New messages appear instantly for everyone.
                    <a asp-action="Details" asp-route-id="@group?.Id">← Back to @group?.Name</a>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm fg-chat-card">
            <div class="fg-chat-stream" id="fgChatStream">
                @if (!messages.Any())
                {
                    <div class="text-center text-muted py-5">
                        <div style="font-size:2rem;opacity:0.4;">💬</div>
                        <div class="small mt-2">No messages yet — be the first.</div>
                    </div>
                }
                @foreach (var m in messages)
                {
                    var fromMe = m.SenderUserId == meId;
                    var rowClass = fromMe ? "fg-chat-row from-me" : "fg-chat-row";
                    <div class="@rowClass" data-msg-id="@m.Id">
                        <div class="fg-chat-avatar">
                            @if (!string.IsNullOrEmpty(m.Sender?.ProfilePhotoUrl))
                            {
                                <img src="@m.Sender.ProfilePhotoUrl" alt="" />
                            }
                            else
                            {
                                <span class="fg-chat-avatar-fallback">@MsgInitials(m.Sender)</span>
                            }
                        </div>
                        <div class="fg-chat-bubble">
                            <div class="fg-chat-meta">
                                <strong>@(m.Sender?.DisplayName ?? m.Sender?.UserName ?? "—")</strong>
                                <span>@m.SentAt.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                            </div>
                            <div class="fg-chat-body">@m.Body</div>
                        </div>
                    </div>
                }
            </div>
            <form id="fgChatForm" class="fg-chat-composer">
                @Html.AntiForgeryToken()
                <input type="hidden" id="fgChatGroupId" value="@group?.Id" />
                <textarea id="fgChatBody" class="form-control" rows="2" maxlength="2000"
                          placeholder="Write a message and press Enter…" required></textarea>
                <button type="submit" class="btn btn-primary">Send</button>
            </form>
        </div>
    </div>
</div>

<style>
    .fg-chat-card { padding: 0; overflow: hidden; }
    .fg-chat-stream {
        height: 540px; overflow-y: auto;
        padding: 16px; background: #fafaf6;
        display: flex; flex-direction: column; gap: 10px;
    }
    [data-theme="dark"] .fg-chat-stream { background: rgba(255,255,255,0.02); }
    .fg-chat-row { display: flex; gap: 10px; align-items: flex-end; }
    .fg-chat-row.from-me { flex-direction: row-reverse; }
    .fg-chat-avatar { width: 32px; height: 32px; flex-shrink: 0; }
    .fg-chat-avatar img,
    .fg-chat-avatar-fallback {
        width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
        display: flex; align-items: center; justify-content: center;
        background: var(--mst-light); color: var(--mst-primary);
        font-weight: 600; font-size: 0.8rem;
    }
    .fg-chat-bubble {
        max-width: 70%;
        background: #fff;
        border: 1px solid var(--mst-border);
        border-radius: 10px;
        padding: 8px 12px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }
    .fg-chat-row.from-me .fg-chat-bubble { background: var(--mst-light); }
    .fg-chat-meta { font-size: 0.72rem; color: var(--mst-muted); display: flex; gap: 8px; }
    .fg-chat-body { font-size: 0.95rem; white-space: pre-wrap; }
    .fg-chat-composer {
        display: flex; gap: 8px; padding: 12px;
        border-top: 1px solid var(--mst-border); background: #fff;
    }
    .fg-chat-composer textarea { resize: vertical; flex-grow: 1; }
</style>

@section Scripts {
<script src="~/lib/microsoft-signalr/signalr.min.js"></script>
<script>
(function () {
    var streamEl  = document.getElementById('fgChatStream');
    var formEl    = document.getElementById('fgChatForm');
    var bodyEl    = document.getElementById('fgChatBody');
    var groupId   = parseInt(document.getElementById('fgChatGroupId').value, 10);
    var meId      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(meId));

    function scrollToBottom() { streamEl.scrollTop = streamEl.scrollHeight; }
    scrollToBottom();

    function escapeHtml(s) {
        return (s == null ? '' : String(s))
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function fmtTime(iso) {
        try { return new Date(iso).toLocaleString(undefined, { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }); }
        catch (e) { return ''; }
    }
    function initials(name) {
        if (!name) return '?';
        var parts = name.trim().split(/\s+/);
        if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
        return (name.length >= 2 ? name.slice(0, 2) : name).toUpperCase();
    }
    function appendMessage(m) {
        var fromMe = m.senderId === meId;
        var avatarHtml = m.senderPhoto
            ? '<img src="' + escapeHtml(m.senderPhoto) + '" alt="" />'
            : '<span class="fg-chat-avatar-fallback">' + escapeHtml(initials(m.senderName)) + '</span>';
        var html =
            '<div class="fg-chat-row ' + (fromMe ? 'from-me' : '') + '" data-msg-id="' + m.id + '">' +
            '  <div class="fg-chat-avatar">' + avatarHtml + '</div>' +
            '  <div class="fg-chat-bubble">' +
            '    <div class="fg-chat-meta"><strong>' + escapeHtml(m.senderName) + '</strong><span>' + escapeHtml(fmtTime(m.sentAt)) + '</span></div>' +
            '    <div class="fg-chat-body">' + escapeHtml(m.body) + '</div>' +
            '  </div>' +
            '</div>';
        // Drop the empty-state placeholder on first message.
        var empty = streamEl.querySelector('.text-muted.py-5');
        if (empty) empty.remove();
        streamEl.insertAdjacentHTML('beforeend', html);
        scrollToBottom();
    }

    var conn = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/groupchat')
        .withAutomaticReconnect()
        .build();
    conn.on('MessageReceived', function (m) {
        // De-dupe: if we already rendered this id (sender just sent it
        // and the hub echoed back), skip.
        if (streamEl.querySelector('[data-msg-id="' + m.id + '"]')) return;
        appendMessage(m);
    });
    conn.start()
        .then(function () { return conn.invoke('JoinGroup', groupId); })
        .catch(function () { /* swallow — page still works without realtime, refresh shows messages */ });

    formEl.addEventListener('submit', function (e) {
        e.preventDefault();
        var body = (bodyEl.value || '').trim();
        if (!body) return;
        conn.invoke('SendMessage', groupId, body)
            .then(function () { bodyEl.value = ''; bodyEl.focus(); })
            .catch(function () { /* swallow; user can retry */ });
    });
    bodyEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            formEl.requestSubmit();
        }
    });
})();
</script>
}
