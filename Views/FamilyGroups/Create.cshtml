@model MyStoryTold.Models.FamilyGroup
@{
    ViewData["Title"] = "New family group";
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <h3 class="mb-1">New family group</h3>
        <p class="text-muted mb-3" style="font-size:0.92rem;">
            Pick a name that says who's in. "Descendants of Grandpa Joe", "My kids and wife", "In-laws".
            You can add members and stories after.
        </p>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show py-2">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <form asp-action="Create" method="post" class="card border-0 shadow-sm p-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" maxlength="120" autocomplete="off" autofocus />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description <span class="text-muted small">(optional)</span></label>
                <textarea asp-for="Description" class="form-control" rows="3" maxlength="500"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create group</button>
                <a asp-action="Index" class="btn btn-link">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
