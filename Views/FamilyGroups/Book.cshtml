@using MyStoryTold.Models
@{
    var group    = ViewBag.Group as FamilyGroup;
    var posts    = ViewBag.Posts as List<FamilyGroupPost> ?? new();
    var profiles = ViewBag.Profiles as List<PersonProfile> ?? new();
    var photos   = ViewBag.Photos as List<FamilyGroupMedia> ?? new();
    ViewData["Title"] = (group?.Name ?? "Group") + " — family book";

    string Place(MyStoryTold.Models.LifeEventPost p)
    {
        if (!string.IsNullOrWhiteSpace(p.Location)) return " · " + p.Location;
        return "";
    }
    string ByLine(MyStoryTold.Models.LifeEventPost p)
    {
        return (p.Owner?.DisplayName ?? p.Owner?.UserName ?? "—");
    }
    string DateLine(MyStoryTold.Models.LifeEventPost p)
    {
        var y = p.EventYear;
        if (p.EventMonth.HasValue && p.EventDay.HasValue)
            return $"{new DateTime(2000, p.EventMonth.Value, p.EventDay.Value):MMMM d}, {y}";
        if (p.EventMonth.HasValue)
            return $"{new DateTime(2000, p.EventMonth.Value, 1):MMMM} {y}";
        return $"{y}";
    }
}
@{
    var anyContent = profiles.Any() || posts.Any() || photos.Any();
}
<div class="fg-book-shell">
    <div class="fg-book-controls d-print-none">
        <a asp-action="Details" asp-route-id="@group?.Id" class="fg-book-back">‹ Back to @group?.Name</a>
        @if (anyContent)
        {
            <button type="button" class="btn btn-primary btn-sm" onclick="window.print();">Print / Save as PDF</button>
            <span class="text-muted small">Tip: use your browser's print dialog → Save as PDF.</span>
        }
    </div>

    <article class="fg-book-page fg-book-cover">
        <div class="fg-book-cover-eyebrow">A family book</div>
        <h1 class="fg-book-cover-title">@group?.Name</h1>
        @if (!string.IsNullOrWhiteSpace(group?.Description))
        {
            <div class="fg-book-cover-tagline">@group.Description</div>
        }
        <div class="fg-book-cover-meta">
            Founded by @(group?.Creator?.DisplayName ?? group?.Creator?.UserName) · @group?.CreatedAt.ToString("MMMM yyyy")
        </div>
    </article>

    @if (!anyContent)
    {
        <article class="fg-book-page fg-book-empty">
            <h2 class="fg-book-empty-title">This book is still blank.</h2>
            <p class="fg-book-empty-body">
                Stories that members write into <strong>@group?.Name</strong> appear here as chapters.
                People profiles and the group's shared photo archive show up too.
                Add a first story or two from the group's page and come back — the book fills itself.
            </p>
            <div class="fg-book-empty-cta">
                <a asp-action="Details" asp-route-id="@group?.Id" class="btn btn-primary btn-sm">‹ Back to @group?.Name</a>
            </div>
        </article>
    }

    @if (profiles.Any())
    {
        <article class="fg-book-page">
            <h2 class="fg-book-section-title">People in this family</h2>
            <div class="fg-book-profiles">
                @foreach (var p in profiles)
                {
                    <div class="fg-book-profile">
                        <h3>@p.DisplayName @(!string.IsNullOrWhiteSpace(p.Nickname) && p.Nickname != p.DisplayName ? $"\"{p.Nickname}\"" : "")</h3>
                        <div class="fg-book-profile-meta">
                            @p.LifeRange@(string.IsNullOrEmpty(p.BirthPlace) ? "" : " · " + p.BirthPlace)
                        </div>
                        @if (!string.IsNullOrWhiteSpace(p.Bio))
                        {
                            <p>@p.Bio</p>
                        }
                    </div>
                }
            </div>
        </article>
    }

    @if (posts.Any())
    {
        <h2 class="fg-book-section-divider">Stories</h2>
        @foreach (var gp in posts)
        {
            var post = gp.LifeEventPost!;
            <article class="fg-book-page fg-book-story">
                <h2>@(string.IsNullOrWhiteSpace(post.Title) ? "(untitled)" : post.Title)</h2>
                <div class="fg-book-story-meta">
                    @ByLine(post) · @DateLine(post)@Place(post)
                </div>
                @if (post.Media != null && post.Media.Any())
                {
                    var firstImage = post.Media.FirstOrDefault(m => m.MediaType == MediaType.Image && !string.IsNullOrEmpty(m.Url));
                    if (firstImage != null)
                    {
                        <img src="@firstImage.Url" class="fg-book-story-photo" alt="" />
                    }
                }
                <div class="fg-book-story-body">@Html.Raw(MyStoryTold.Helpers.BodyRenderer.RenderBody(post.Body ?? ""))</div>
            </article>
        }
    }

    @if (photos.Any())
    {
        <h2 class="fg-book-section-divider">Photo archive</h2>
        <article class="fg-book-page">
            <div class="fg-book-photo-grid">
                @foreach (var p in photos)
                {
                    <figure class="fg-book-photo">
                        <img src="@p.Url" alt="@p.Caption" />
                        @if (!string.IsNullOrWhiteSpace(p.Caption))
                        {
                            <figcaption>@p.Caption</figcaption>
                        }
                    </figure>
                }
            </div>
        </article>
    }
</div>

<style>
    /* Family-group book — unique prefix so we don't collide with the
       personal "book reader" classes in site.css (which use flex to
       lay out a horizontal page-turn carousel; that flex was mashing
       the H1, tagline, and meta line inline on the cover). */
    .fg-book-shell {
        max-width: 800px;
        margin: 0 auto;
        padding: 24px;
        background: #fbf9f3;
        color: #2b241c;
    }
    .fg-book-controls {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }
    .fg-book-back {
        color: var(--mst-primary, #0f6466);
        text-decoration: none;
        font-weight: 600;
    }
    .fg-book-back:hover { text-decoration: underline; }
    .fg-book-page {
        background: #fff;
        border: 1px solid var(--mst-border, #e7d8b0);
        padding: 36px 44px;
        margin-bottom: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border-radius: 6px;
        page-break-after: always;
    }
    .fg-book-cover {
        text-align: center;
        padding: 72px 32px 64px;
        background: linear-gradient(160deg, #f5e8c8, #fff);
    }
    .fg-book-cover-eyebrow {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #8a7355;
        margin-bottom: 12px;
    }
    .fg-book-cover-title {
        font-family: 'Fraunces', 'Cormorant Garamond', Georgia, serif;
        font-size: 2.8rem;
        line-height: 1.1;
        margin: 0 0 14px;
    }
    .fg-book-cover-tagline {
        font-family: 'Fraunces', Georgia, serif;
        font-style: italic;
        font-size: 1.1rem;
        color: #5a4520;
        margin: 0 auto 28px;
        max-width: 520px;
    }
    .fg-book-cover-meta {
        color: var(--mst-muted, #6b6258);
        font-size: 0.9rem;
        font-family: 'Inter', system-ui, sans-serif;
    }
    .fg-book-empty {
        text-align: center;
        padding: 56px 40px;
    }
    .fg-book-empty-title {
        font-family: 'Fraunces', Georgia, serif;
        font-size: 1.6rem;
        margin: 0 0 12px;
        color: #2b241c;
    }
    .fg-book-empty-body {
        font-family: 'Fraunces', Georgia, serif;
        color: #5a4520;
        line-height: 1.6;
        max-width: 540px;
        margin: 0 auto 24px;
    }
    .fg-book-section-title {
        font-family: 'Fraunces', Georgia, serif;
        font-size: 1.7rem;
        margin: 0 0 18px;
    }
    .fg-book-section-divider {
        text-align: center;
        font-family: 'Fraunces', Georgia, serif;
        font-size: 1.6rem;
        margin: 32px 0 16px;
        color: var(--mst-primary, #0f6466);
        page-break-before: always;
    }
    .fg-book-profiles { display: grid; gap: 20px; grid-template-columns: 1fr 1fr; }
    .fg-book-profile h3 { margin-bottom: 4px; font-family: 'Fraunces', Georgia, serif; }
    .fg-book-profile-meta { color: var(--mst-muted, #6b6258); font-size: 0.88rem; margin-bottom: 6px; }
    .fg-book-story h2 { font-family: 'Fraunces', Georgia, serif; margin-bottom: 4px; }
    .fg-book-story-meta { color: var(--mst-muted, #6b6258); font-size: 0.88rem; margin-bottom: 16px; }
    .fg-book-story-photo { width: 100%; max-height: 360px; object-fit: cover; border-radius: 4px; margin-bottom: 16px; }
    .fg-book-story-body { line-height: 1.65; font-family: 'Fraunces', Georgia, serif; font-size: 1.02rem; }
    .fg-book-photo-grid { display: grid; gap: 12px; grid-template-columns: 1fr 1fr 1fr; }
    .fg-book-photo img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 4px; }
    .fg-book-photo figcaption { font-size: 0.78rem; color: var(--mst-muted, #6b6258); margin-top: 4px; }

    @@media print {
        body, .fg-book-shell { background: #fff !important; padding: 0 !important; }
        .fg-book-page { border: 0 !important; box-shadow: none !important; padding: 16px !important; }
        .d-print-none { display: none !important; }
    }
</style>
