@{
    ViewData["Title"] = "Verification link is invalid";
}

<div class="container" style="max-width: 520px;">
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-body p-4 text-center">
            <div style="font-size:2.4rem;">⚠️</div>
            <h3 class="mt-2">This verification link didn't work</h3>
            <p class="text-muted">
                Either it expired, was already used, or got mangled by your email client. No problem —
                send a new one and try again.
            </p>
            <form asp-action="ResendConfirmation" method="post" class="d-flex gap-2 justify-content-center mt-3">
                @Html.AntiForgeryToken()
                <input type="email" name="email" class="form-control form-control-sm" style="max-width:280px;" placeholder="you@example.com" required />
                <button type="submit" class="btn btn-sm btn-outline-primary">Resend link</button>
            </form>
            <p class="small mt-3 mb-0">
                <a asp-action="Login">Back to sign in</a>
            </p>
        </div>
    </div>
</div>
