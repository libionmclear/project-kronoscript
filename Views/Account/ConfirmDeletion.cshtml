@{
    ViewData["Title"] = "Confirm account deletion";
}

<div class="container" style="max-width: 520px;">
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-body p-4">
            <h3 class="text-danger mb-2">Confirm account deletion</h3>
            <p>We've emailed a 6-digit code to your address on file. Enter it below to permanently delete
            your account and everything you've posted. This action is <strong>irreversible</strong>.</p>

            <form asp-action="ConfirmDeletion" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label class="form-label">6-digit code from your email</label>
                    <input type="text" name="code" maxlength="6" minlength="6" pattern="[0-9]{6}" inputmode="numeric"
                           class="form-control text-center" style="font-size:1.4rem;letter-spacing:0.4em;"
                           placeholder="123456" autocomplete="one-time-code" required />
                </div>

                <div class="form-check mb-3">
                    <input type="checkbox" name="confirm" value="true" class="form-check-input" id="confirmDelete" required />
                    <label for="confirmDelete" class="form-check-label">
                        Yes, I understand this is permanent. Delete my account, all my stories, comments,
                        connections, and uploads.
                    </label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete my account</button>
                    <a asp-controller="Profile" asp-action="Edit" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
