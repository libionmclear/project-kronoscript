@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                <h2 class="mb-4" style="color: var(--mst-primary);">Check Your Email</h2>
                <p class="text-muted">If an account exists with that email address, we've sent a password reset link.</p>

                @if (TempData["ResetLink"] != null)
                {
                    <div class="alert alert-info mt-3">
                        <strong>Dev Mode:</strong> <a href="@TempData["ResetLink"]">Click here to reset password</a>
                    </div>
                }

                <a asp-action="Login" class="btn btn-outline-primary mt-3">Return to Sign In</a>
            </div>
        </div>
    </div>
</div>
