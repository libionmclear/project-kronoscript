@{
    ViewData["Title"] = "Password Reset Complete";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5 text-center">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="mb-4" style="color: var(--mst-primary);">Password Reset</h2>
                <p class="text-muted">Your password has been reset successfully.</p>
                <a asp-action="Login" class="btn btn-primary mt-3">Sign In</a>
            </div>
        </div>
    </div>
</div>
