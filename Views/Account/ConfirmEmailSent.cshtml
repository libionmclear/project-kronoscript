@{
    ViewData["Title"] = "Check your email";
}

<div class="container" style="max-width: 520px;">
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-body p-4 text-center">
            <div style="font-size:2.4rem;">📨</div>
            <h3 class="mt-2">Check your email</h3>
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info">@TempData["Info"]</div>
            }
            else
            {
                <p class="text-muted">We sent a verification link to your inbox. Click it to activate your account.</p>
            }
            <p class="small text-muted">
                Can't find it? Check spam, or paste the email below to send a fresh link.
            </p>
            <form asp-action="ResendConfirmation" method="post" class="d-flex gap-2 justify-content-center mt-3">
                @Html.AntiForgeryToken()
                <input type="email" name="email" class="form-control form-control-sm" style="max-width:280px;" placeholder="you@example.com" required />
                <button type="submit" class="btn btn-sm btn-outline-primary">Resend</button>
            </form>
            <p class="small mt-3 mb-0">
                <a asp-action="Login">Back to sign in</a>
            </p>
        </div>
    </div>
</div>
