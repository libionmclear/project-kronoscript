@model MyStoryTold.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="text-center mb-4" style="color: var(--mst-primary);">Create Account</h2>
                <p class="text-center text-muted mb-4">Start telling your story</p>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" placeholder="Choose a username" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="your@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" id="regPwd" placeholder="Min. 8 characters" />
                            <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('regPwd',this)" tabindex="-1">👁</button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" class="form-control" id="regConfirm" placeholder="Repeat password" />
                            <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('regConfirm',this)" tabindex="-1">👁</button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    @* Agreement copy + links live OUTSIDE the label so clicking
                       a link to read the agreement doesn't silently toggle
                       the checkbox (label clicks toggle the bound input). The
                       label is the short statement; clicking it is intentional. *@
                    <div class="mb-2 small text-muted">
                        Please read the
                        <a asp-controller="Home" asp-action="Agreement" target="_blank" rel="noopener">User Agreement</a>,
                        <a asp-controller="Home" asp-action="Privacy" target="_blank" rel="noopener">Privacy Policy</a>, and
                        <a asp-controller="Home" asp-action="AcceptableUse" target="_blank" rel="noopener">Acceptable Use Policy</a>.
                        Kronoscript is in beta — may be unavailable or change without notice. No confidential, illegal, sexual, or harassing content.
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="AgreedToTerms" class="form-check-input" />
                        <label asp-for="AgreedToTerms" class="form-check-label small">
                            I have read and agree to the terms above.
                        </label>
                        <span asp-validation-for="AgreedToTerms" class="text-danger d-block"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3">Register</button>
                    <p class="text-center mb-0">
                        Already have an account? <a asp-action="Login">Sign in</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    function togglePwd(id, btn) {
        var inp = document.getElementById(id);
        if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
        else { inp.type = 'password'; btn.textContent = '👁'; }
    }

    // Clear the "you must agree" message the moment the box becomes
    // checked, so a stale server-side error doesn't read as if the
    // form is still broken after the user already fixed it.
    (function () {
        var box = document.querySelector('input[name="AgreedToTerms"][type="checkbox"]');
        var msg = document.querySelector('[data-valmsg-for="AgreedToTerms"]');
        if (!box || !msg) return;
        function sync() {
            if (box.checked) {
                msg.textContent = '';
                msg.classList.remove('field-validation-error');
            }
        }
        box.addEventListener('change', sync);
        sync();
    })();
    </script>
}
