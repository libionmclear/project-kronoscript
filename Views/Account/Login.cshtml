@model MyStoryTold.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    ViewData["BodyClass"] = "auth-body";
    ViewData["ContainerClass"] = "container py-5";
}

<div class="row justify-content-center auth-wrap">
    <div class="col-md-6 col-lg-5">
        <div class="auth-card">
            <div class="card-body p-4 p-md-5">
                <h2 class="text-center mb-2 auth-title">Welcome back</h2>
                <p class="text-center auth-sub mb-4">Sign in to continue your story</p>

                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="your@email.com or username" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" id="loginPassword" />
                            <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('loginPassword',this)" tabindex="-1">👁</button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3">Sign In</button>

                    <div class="text-center">
                        <a asp-action="ForgotPassword">Forgot your password?</a>
                    </div>
                    <hr />
                    <p class="text-center mb-0">
                        Don't have an account? <a asp-action="Register">Create one</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    function togglePwd(id, btn) {
        var inp = document.getElementById(id);
        if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
        else { inp.type = 'password'; btn.textContent = '👁'; }
    }
    </script>
}
