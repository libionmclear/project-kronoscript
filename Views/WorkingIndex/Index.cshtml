@model List<MyStoryTold.Models.WorkingIndexEntry>
@{
    ViewData["Title"] = "Working Index";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Family removed; "MainEvent" stays as the field name but renders as "Main Life Event"
    var fields = new (string Field, string Label, string Emoji)[] {
        ("MainEvent",    "Main Life Event", "✨"),
        ("Residence",    "Residence",       "🏠"),
        ("SchoolJob",    "School / Job",    "💼"),
        ("Relationship", "Relationship",    "❤"),
        ("Vacation",     "Vacation",        "🌴"),
        ("Other",        "Other",           "✏")
    };
}
@Html.AntiForgeryToken()

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">

        <div class="working-hero mb-4">
            <h2 class="mb-1">Working Index</h2>
            <p class="text-muted mb-0" style="font-size:0.95rem;">
                Your private year-by-year scaffold. Only you can see this — it stays here as a memory map
                we'll later use to surface prompts ("you mentioned moving to Madrid in 2014 — write about that?").
            </p>
        </div>

        <div class="working-table-wrap">
            <div class="working-table">
                <!-- Header row -->
                <div class="wt-row wt-head">
                    <div class="wt-year-col">Year</div>
                    @foreach (var f in fields)
                    {
                        <div class="wt-cell-col" data-field="@f.Field">
                            <span class="wt-emoji">@f.Emoji</span> @f.Label
                        </div>
                    }
                    <div class="wt-mood-col">Mood</div>
                </div>

                @foreach (var e in Model)
                {
                    <div class="wt-row" data-year="@e.Year" data-id="@e.Id">
                        <div class="wt-year-col">
                            <span class="wt-year-pill mood-@e.Mood.ToString().ToLower()">@e.Year</span>
                        </div>
                        @foreach (var f in fields)
                        {
                            var value = (string?)typeof(MyStoryTold.Models.WorkingIndexEntry).GetProperty(f.Field)!.GetValue(e);
                            <div class="wt-cell-col wt-cell" data-field="@f.Field">
                                <div class="wt-cell-value" contenteditable="true"
                                     data-placeholder="@f.Label">@value</div>
                            </div>
                        }
                        <div class="wt-mood-col">
                            <div class="working-mood-picker">
                                @foreach (var mood in new[] {
                                    ("Great", "Great year", "#22c55e"),
                                    ("Good",  "Good year",  "#84cc16"),
                                    ("Neutral","Neutral",   "#9ca3af"),
                                    ("Tough", "Tough",      "#f59e0b"),
                                    ("Heavy", "Heavy",      "#ef4444")
                                })
                                {
                                    <button type="button" class="mood-dot @(e.Mood.ToString() == mood.Item1 ? "active" : "")"
                                            title="@mood.Item2" data-mood="@mood.Item1"
                                            style="background:@mood.Item3;"></button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <p class="text-muted small mt-3">
            Years are scaffolded from your birth year (set in <a asp-controller="Profile" asp-action="Edit">Settings</a>) up to today.
            Click any cell to start typing — it saves automatically.
        </p>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    function upsert(year, field, value) {
        var fd = new FormData();
        fd.append('year', String(year));
        fd.append('field', field);
        fd.append('value', value || '');
        return fetch('/WorkingIndex/Upsert', { method: 'POST', headers: { 'X-CSRF-TOKEN': token }, body: fd })
            .then(function (r) { return r.ok ? r.json() : null; });
    }

    document.querySelectorAll('.wt-row[data-year]').forEach(function (row) {
        var year = parseInt(row.dataset.year, 10);

        // Cells
        row.querySelectorAll('.wt-cell').forEach(function (cell) {
            var field = cell.dataset.field;
            var input = cell.querySelector('.wt-cell-value');
            var lastSaved = input.textContent;
            input.addEventListener('blur', function () {
                var v = input.textContent.trim();
                if (v === lastSaved) return;
                lastSaved = v;
                upsert(year, field, v).then(function (data) {
                    if (data && data.id) row.dataset.id = data.id;
                    cell.classList.add('cell-saved');
                    setTimeout(function () { cell.classList.remove('cell-saved'); }, 600);
                });
            });
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); input.blur(); }
                if (e.key === 'Tab') { /* let default tab go to next cell */ }
            });
        });

        // Mood
        row.querySelectorAll('.mood-dot').forEach(function (dot) {
            dot.addEventListener('click', function () {
                var m = dot.dataset.mood;
                row.querySelectorAll('.mood-dot').forEach(function (d) { d.classList.toggle('active', d === dot); });
                var pill = row.querySelector('.wt-year-pill');
                if (pill) pill.className = 'wt-year-pill mood-' + m.toLowerCase();
                upsert(year, 'Mood', m);
            });
        });
    });
})();
</script>
}
