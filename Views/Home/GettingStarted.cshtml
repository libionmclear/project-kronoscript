@{
    ViewData["Title"] = "Start Here";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="gs-page">

    <!-- Hero -->
    <section class="gs-hero">
        <p class="gs-hero-kicker">Start here</p>
        <h1 class="gs-hero-title">Your life, written down.</h1>
        <p class="gs-hero-sub">
            Kronoscript is a quiet place for the memories that made you — the moments worth writing
            down and the people who were there. Pick the door that fits you right now.
        </p>
    </section>

    <!-- Two paths -->
    <section class="gs-paths">
        <button type="button" class="gs-path-card gs-path-why replay-onboarding" aria-label="Replay the welcome story">
            <div class="gs-path-kicker">Why bother</div>
            <h2 class="gs-path-title">The story behind Kronoscript</h2>
            <p class="gs-path-body">
                A short narrative — a few panels — about why this exists and what it's really for. Start
                here if you want the heart before the how.
            </p>
            <div class="gs-path-meta">
                <span class="gs-path-length">~2 minutes</span>
                <span class="gs-path-cta">Watch the welcome story →</span>
            </div>
        </button>

        <button type="button" class="gs-path-card gs-path-how start-product-tour" aria-label="Take the guided product tour">
            <div class="gs-path-kicker">How to use it</div>
            <h2 class="gs-path-title">A guided tour of the app</h2>
            <p class="gs-path-body">
                A 7-step walkthrough of the actual UI: Quick Story, Full Story, visibility tiers, your
                network, the timeline, reactions &amp; share, your profile.
            </p>
            <div class="gs-path-meta">
                <span class="gs-path-length">~3 minutes</span>
                <span class="gs-path-cta">Take the product tour →</span>
            </div>
        </button>
    </section>

    <!-- What's inside -->
    <section class="gs-features">
        <h3 class="gs-section-title">What's in here</h3>
        <div class="gs-feature-grid">
            <div class="gs-feature">
                <div class="gs-feature-icon">📝</div>
                <div>
                    <h4>Quick Story &amp; Full Story</h4>
                    <p>Jot a sentence and a photo, or sit down and write a long memory with a title, date, and music.</p>
                </div>
            </div>
            <div class="gs-feature">
                <div class="gs-feature-icon">👥</div>
                <div>
                    <h4>Tiers, not followers</h4>
                    <p>Acquaintances, Friends, Family. Every post has an audience — you choose who sees each one.</p>
                </div>
            </div>
            <div class="gs-feature">
                <div class="gs-feature-icon">🗓️</div>
                <div>
                    <h4>Your life as a timeline</h4>
                    <p>Published stories line up chronologically. Zoom by decade, year, or month.</p>
                </div>
            </div>
            <div class="gs-feature">
                <div class="gs-feature-icon">🏷️</div>
                <div>
                    <h4>Tag the people who were there</h4>
                    <p>A shared moment can live on someone else's timeline too. Tag them and they'll see it.</p>
                </div>
            </div>
            <div class="gs-feature">
                <div class="gs-feature-icon">💬</div>
                <div>
                    <h4>React, reply, share</h4>
                    <p>Reactions beyond the like button. Inline comments. A one-tap link you can send anywhere.</p>
                </div>
            </div>
            <div class="gs-feature">
                <div class="gs-feature-icon">📦</div>
                <div>
                    <h4>Export anytime</h4>
                    <p>Your story is yours. Export the whole thing to a document whenever you want it in hand.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="gs-final">
        <h3 class="gs-section-title">Ready to start writing?</h3>
        <p class="text-muted mb-3">You don't need a plan. Pick one memory you're afraid you'll forget, and start there.</p>
        <div class="d-flex justify-content-center gap-2 flex-wrap">
            <a asp-controller="Posts" asp-action="Create" class="btn btn-primary btn-lg px-4">Write a Full Story</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">Go to my feed</a>
        </div>
    </section>

</div>
