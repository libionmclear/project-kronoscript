@inject MyStoryTold.Services.ILocalizer _t
@{
    var isItalian = _t.Culture == "it";
    ViewData["Title"] = isItalian ? "Inizia qui" : "Start Here";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="gs-page">
    @* ── Hero with a rotating headline ─────────────────────────────── *@
    <section class="gs-hero gs-hero-v2">
        <p class="gs-hero-kicker">@(isItalian ? "Inizia qui" : "Start here")</p>
        <h1 class="gs-hero-title gs-rotator" aria-live="polite">
            @if (isItalian)
            {
                <span class="gs-rot active">La tua vita, scritta.</span>
                <span class="gs-rot">Le tue persone, ricordate.</span>
                <span class="gs-rot">Quello che i tuoi nipoti leggeranno.</span>
                <span class="gs-rot">Storie. Tue. Per sempre.</span>
            }
            else
            {
                <span class="gs-rot active">Your life, written down.</span>
                <span class="gs-rot">The people you loved, remembered.</span>
                <span class="gs-rot">What your grandkids will read.</span>
                <span class="gs-rot">Stories. Yours. Forever.</span>
            }
        </h1>
        <p class="gs-hero-sub">
            @(isItalian
                ? "Un posto tranquillo per i ricordi che ti hanno reso quello che sei — i momenti che vale la pena scrivere e le persone che c'erano."
                : "A quiet place for the memories that made you — the moments worth writing down and the people who were there.")
        </p>

        @* Three big CTAs. "Start writing" is the primary action; the
           other two are framed as ways to learn before doing. *@
        <div class="gs-cta-row mt-4">
            <a asp-controller="Posts" asp-action="Create" class="btn btn-primary btn-lg px-4 gs-cta-primary">
                ✍️ @(isItalian ? "Scrivi il primo ricordo" : "Write your first memory")
            </a>
            <button type="button" class="btn btn-outline-secondary btn-lg px-4 start-product-tour">
                🧭 @(isItalian ? "Tour guidato — 3 min" : "Take the 3-min tour")
            </button>
            <button type="button" class="btn btn-link btn-lg replay-onboarding">
                @(isItalian ? "↻ Rivedi la storia di benvenuto" : "↻ Watch the welcome story")
            </button>
        </div>
    </section>

    @* ── Live sample of what a memory looks like ───────────────────── *@
    <section class="gs-sample-wrap">
        <p class="gs-sample-label">@(isItalian ? "Ecco com'è un ricordo qui dentro" : "Here's what a memory looks like inside")</p>
        <article class="gs-sample-card">
            <div class="gs-sample-strip">
                <span class="gs-sample-strip-icon">📜</span>
                <span class="gs-sample-strip-label">@(isItalian ? "Biografico" : "Memoir")</span>
                <span class="gs-sample-strip-era">@(isItalian ? "Anni '80" : "1980s")</span>
            </div>
            <header class="gs-sample-head">
                <div class="gs-sample-avatar" aria-hidden="true">G</div>
                <div>
                    <div class="gs-sample-author">Grandpa Joe</div>
                    <div class="gs-sample-date">@(isItalian ? "Ottobre 1987 · Firenze, Italia" : "October 1987 · Florence, Italy")</div>
                </div>
            </header>
            <h2 class="gs-sample-title">@(isItalian ? "La prima volta che ho visto il mare" : "The first time I saw the sea")</h2>
            <p class="gs-sample-body">
                @(isItalian
                    ? "Avevo sette anni. Mio padre mi disse di chiudere gli occhi, e li tenne chiusi con la mano grande sui miei finché non sentimmo il rumore. Poi tolse la mano e c'era tutta l'acqua del mondo davanti a me. Non sapevo che il mondo potesse essere così grande."
                    : "I was seven. My father told me to close my eyes, and he kept them closed with his big hand over mine until we could hear the sound. Then he took his hand away and there was all the water in the world in front of me. I didn't know the world could be that big.")
            </p>
            <div class="gs-sample-footer">
                <span class="gs-sample-tag">@(isItalian ? "con il Papà" : "with Dad")</span>
                <span class="gs-sample-tag gs-sample-tag-profile">🕊 @(isItalian ? "Giuseppe Rossi" : "Joseph Smith")</span>
                <span class="gs-sample-react">❤️ 12</span>
                <span class="gs-sample-react">💬 3</span>
            </div>
        </article>
        <p class="gs-sample-caption">
            @(isItalian
                ? "Niente algoritmi. Niente pubblicità. Solo i tuoi ricordi, le tue persone, il tuo ritmo."
                : "No algorithm. No ads. Just your memories, your people, at your own pace.")
        </p>
    </section>

    @* ── What people make in here ──────────────────────────────────── *@
    <section class="gs-uses">
        <h3 class="gs-section-title">@(isItalian ? "Cosa puoi farci dentro" : "What people make in here")</h3>
        <div class="gs-uses-grid">
            <div class="gs-use">
                <div class="gs-use-icon">📖</div>
                <h4>@(isItalian ? "Un memoir personale" : "A personal memoir")</h4>
                <p>@(isItalian
                    ? "La tua vita, raccontata un ricordo alla volta. Le storie pubblicate si dispongono in ordine cronologico — naviga per decennio, anno, mese."
                    : "Your life, one memory at a time. Published stories line up chronologically — zoom by decade, year, or month.")</p>
            </div>
            <div class="gs-use">
                <div class="gs-use-icon">🌳</div>
                <h4>@(isItalian ? "Un albero di famiglia" : "A family tree")</h4>
                <p>@(isItalian
                    ? "Persone tue, parenti che non sono qui, foto delle persone giuste collegate alle storie giuste."
                    : "Your people, your relatives who aren't on the site, photos with the right faces tied to the right stories.")</p>
            </div>
            <div class="gs-use">
                <div class="gs-use-icon">📰</div>
                <h4>@(isItalian ? "Una rubrica curata" : "A curated channel")</h4>
                <p>@(isItalian
                    ? "Articoli a tema su qualcosa che ti sta a cuore — la storia di un quartiere, una passione, un mestiere — letti come un giornale."
                    : "Themed articles about something you care about — a neighbourhood's history, a passion, a craft — laid out like a newspaper.")</p>
            </div>
        </div>
    </section>

    @* ── Quiet promises ────────────────────────────────────────────── *@
    <section class="gs-promises">
        <ul class="gs-promise-list">
            <li><span class="gs-promise-check">✓</span> <strong>@(isItalian ? "I tuoi ricordi sono tuoi, sempre." : "Your stories are yours, always.")</strong> @(isItalian ? "Esporta tutto in un documento ogni volta che vuoi averli in mano." : "Export everything to a document whenever you want it in hand.")</li>
            <li><span class="gs-promise-check">✓</span> <strong>@(isItalian ? "Livelli, non follower." : "Tiers, not followers.")</strong> @(isItalian ? "Conoscenti, Amici, Famiglia. Decidi tu chi vede ogni cosa." : "Acquaintances, Friends, Family. You choose who sees each one.")</li>
            <li><span class="gs-promise-check">✓</span> <strong>@(isItalian ? "Niente pubblicità. Niente tracciamento." : "No ads. No tracking.")</strong> @(isItalian ? "Niente che ti rimette su un feed che non hai chiesto." : "Nothing that pushes you back to a feed you didn't ask for.")</li>
            <li><span class="gs-promise-check">✓</span> <strong>@(isItalian ? "Le persone che c'erano possono esserci." : "The people who were there can be there.")</strong> @(isItalian ? "Aggiungi chi vuoi a una storia o a una foto — anche chi non è ancora sul sito." : "Tag anyone in a story or on a photo — even people who aren't on the site yet.")</li>
        </ul>
    </section>

    @* ── Final CTA ─────────────────────────────────────────────────── *@
    <section class="gs-final">
        <h3 class="gs-final-title">@(isItalian ? "Pronto a iniziare?" : "Ready to begin?")</h3>
        <p class="gs-final-sub text-muted">
            @(isItalian
                ? "Non serve un piano. Scegli un ricordo che hai paura di dimenticare e parti da lì."
                : "You don't need a plan. Pick one memory you're afraid you'll forget, and start there.")
        </p>
        <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
            <a asp-controller="Posts" asp-action="Create" class="btn btn-primary btn-lg px-4">
                ✍️ @(isItalian ? "Scrivi una storia" : "Write a story")
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">
                @(isItalian ? "Vai al feed" : "Go to my feed")
            </a>
        </div>
    </section>
</div>

@section Scripts {
<script>
// Hero headline rotator — soft cross-fade every ~4.5 s. Pauses when the
// tab is hidden so the page doesn't churn in the background.
(function () {
    var slots = document.querySelectorAll('.gs-rotator .gs-rot');
    if (slots.length < 2) return;
    var ix = 0;
    function advance() {
        if (document.hidden) return;
        slots[ix].classList.remove('active');
        ix = (ix + 1) % slots.length;
        slots[ix].classList.add('active');
    }
    setInterval(advance, 4500);
})();
</script>
}
