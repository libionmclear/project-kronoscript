@using MyStoryTold.Models.ViewModels
@model DashboardViewModel
@{
    ViewData["Title"] = "Home";
}

@if (User.Identity != null && User.Identity.IsAuthenticated && Model != null)
{
    <!-- Authenticated Dashboard -->
    <div class="row g-3">

        <!-- LEFT: Friends Panel -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-3" style="color: var(--mst-primary);">My Network</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="py-1">
                            <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                                <span>👥 Friends</span>
                                <span class="badge rounded-pill" style="background-color: var(--mst-primary);">@Model.FriendsCount</span>
                            </a>
                        </li>
                        <li class="py-1">
                            <a asp-controller="Friends" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                                <span>👋 Acquaintances</span>
                                <span class="badge rounded-pill bg-secondary">@Model.AcquaintancesCount</span>
                            </a>
                        </li>
                        <li class="py-1">
                            <a asp-controller="Relatives" asp-action="Index" class="text-decoration-none d-flex justify-content-between">
                                <span>👨‍👩‍👧 Family</span>
                                <span class="badge rounded-pill" style="background-color: var(--mst-accent);">@Model.FamilyCount</span>
                            </a>
                        </li>
                        <li class="py-1 border-top mt-2 pt-2">
                            <a asp-controller="Posts" asp-action="Tagged" class="text-decoration-none d-flex justify-content-between">
                                <span>🏷️ Tagged</span>
                                @if (Model.TaggedCount > 0)
                                {
                                    <span class="badge rounded-pill bg-warning text-dark">@Model.TaggedCount</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-light text-muted">0</span>
                                }
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            @if (Model.ActiveFriends.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-3" style="color: var(--mst-primary);">Recently Active</h6>
                        <ul class="list-unstyled mb-0">
                            @foreach (var friend in Model.ActiveFriends)
                            {
                                <li class="py-1">
                                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@friend.User.Id"
                                       class="text-decoration-none d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(friend.User.ProfilePhotoUrl))
                                        {
                                            <img src="@friend.User.ProfilePhotoUrl" class="rounded-circle" width="24" height="24" style="object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <span class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:24px;height:24px;font-size:12px;">👤</span>
                                        }
                                        <span class="small">@(friend.User.DisplayName ?? friend.User.UserName)</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>

        <!-- CENTER: Feed -->
        <div class="col-md-6">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="mb-0">Welcome back, @User.Identity.Name!</h5>
                <a asp-controller="Posts" asp-action="Create" class="btn btn-sm btn-primary">✏️ New Event</a>
            </div>

            <!-- Invite Card -->
            <div class="card border-0 shadow-sm mb-3" style="border-left: 4px solid var(--mst-accent) !important;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">✉️ Invite a Friend</h6>
                            <small class="text-muted">Share your story with someone who was there</small>
                        </div>
                        <a asp-action="Invite" class="btn btn-sm btn-outline-primary">Invite</a>
                    </div>
                </div>
            </div>

            @if (!Model.RecentPosts.Any())
            {
                <div class="card border-0 bg-light text-center p-4">
                    <p class="text-muted mb-2">Your story starts here.</p>
                    <a asp-controller="Posts" asp-action="Create" class="btn btn-primary btn-sm">Write your first life event</a>
                </div>
            }
            else
            {
                @foreach (var item in Model.RecentPosts)
                {
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@item.Post.OwnerUserId"
                                       class="fw-semibold text-decoration-none">
                                        @(item.Post.Owner.DisplayName ?? item.Post.Owner.UserName)
                                    </a>
                                    <span class="badge bg-success-subtle text-success ms-2 small">@item.Post.EventDateDisplay</span>
                                    @if (!string.IsNullOrEmpty(item.Post.Location))
                                    {
                                        <span class="text-muted small ms-1">📍 @item.Post.Location</span>
                                    }
                                </div>
                                <span class="small text-muted d-inline-flex align-items-center gap-1">@await Html.PartialAsync("_VisibilityDot", item.Post.Visibility) @item.Post.CreatedAt.ToString("MMM d")</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Post.Title))
                            {
                                <h6 class="mb-1">@item.Post.Title</h6>
                            }
                            <p class="mb-2 text-truncate" style="max-height:3em;overflow:hidden;">@item.Post.Body</p>
                            <div class="d-flex gap-3">
                                <a asp-controller="Posts" asp-action="Detail" asp-route-id="@item.Post.Id"
                                   class="small text-decoration-none">Read more</a>
                                <span class="small text-muted">❤ @item.LikeCount</span>
                                <span class="small text-muted">💬 @item.Post.Comments.Count</span>
                            </div>
                        </div>
                    </div>
                }
                <div class="text-center mt-2">
                    <a asp-controller="Posts" asp-action="Feed" class="btn btn-outline-secondary btn-sm">See full feed</a>
                </div>
            }
        </div>

        <!-- RIGHT: Quick Links -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-3" style="color: var(--mst-primary);">Quick Links</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="py-1">
                            <a asp-controller="Posts" asp-action="Timeline"
                               asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">
                               📖 My Timeline
                            </a>
                        </li>
                        <li class="py-1"><a asp-controller="Profile" asp-action="Index">👤 My Profile</a></li>
                        <li class="py-1"><a asp-controller="Profile" asp-action="Edit">✏️ Edit Profile</a></li>
                        <li class="py-1"><a asp-controller="Export" asp-action="Index">📥 Export My Story</a></li>
                        <li class="py-1 border-top mt-2 pt-2">
                            <a asp-action="Invite" style="color: var(--mst-accent);">✉️ Invite a Friend</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

    </div>
}
else
{
    <!-- Public Landing Page -->
    <div class="hero-section text-center mb-5">
        <img src="~/images/kronoscript-logo.png" alt="Kronoscript" height="100" class="mb-3" style="filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));" onerror="this.style.display='none'" />
        <h1>Kronoscript</h1>
        <p class="tagline mt-2">Tell Your Life Story. Share It Over Time.</p>
        <p class="lead mt-3 text-white-50" style="max-width: 600px; margin: 0 auto;">
            A private place to document your life story and invite the people who were there to enrich it with their memories.
        </p>
        <div class="mt-4 d-flex justify-content-center gap-3">
            <a asp-controller="Account" asp-action="Register" class="btn btn-lg fw-semibold px-4" style="background-color: var(--mst-gold); color: var(--mst-dark); border-color: var(--mst-gold);">Get Started Free</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-lg btn-outline-light px-4">Sign In</a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">📝</div>
                    <h5>Document Your Life</h5>
                    <p class="text-muted">Create life events with the date they actually happened &mdash; not just when you wrote them.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">👥</div>
                    <h5>Invite Friends & Family</h5>
                    <p class="text-muted">People who were there can add their memories as comments. Set permission tiers to control who sees and contributes.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">📖</div>
                    <h5>Export Your Story</h5>
                    <p class="text-muted">Download your entire life story as a printable document, sorted chronologically.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center text-muted mb-5">
        <p><em>This is not a social network. It's your personal history, enriched by the people who lived it with you.</em></p>
    </div>
}
