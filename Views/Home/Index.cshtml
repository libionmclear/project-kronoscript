@using MyStoryTold.Models.ViewModels
@model DashboardViewModel
@{
    ViewData["Title"] = "Home";
    var taggableFriends = ViewBag.TaggableFriends as List<TaggableFriendViewModel> ?? new List<TaggableFriendViewModel>();
}

@if (User.Identity != null && User.Identity.IsAuthenticated && Model != null)
{
    <!-- Authenticated Dashboard -->
    <div class="row g-3">

        <!-- LEFT: My Network -->
        <div class="col-md-2 col-sidebar">
            @await Component.InvokeAsync("NetworkSidebar")
        </div>

        <!-- CENTER: Feed -->
        <div class="col-md-8 col-main">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="mb-0">Welcome, @User.Identity.Name!</h5>
                <a asp-controller="Posts" asp-action="Create" class="btn btn-sm btn-primary">New Full Story</a>
            </div>

            <!-- Invite Card -->
            <div class="card border-0 shadow-sm mb-3" style="border-left: 4px solid var(--mst-accent) !important;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">✉️ Invite a Friend</h6>
                            <small class="text-muted">Share your story with someone who was there</small>
                        </div>
                        <a asp-action="Invite" class="btn btn-sm btn-outline-primary">Invite</a>
                    </div>
                </div>
            </div>

            <!-- Quick Story Box -->
            <div class="card quick-story-card mb-3 mt-3">
                <div class="card-body">
                    <form asp-controller="Posts" asp-action="QuickPost" method="post">
                        @Html.AntiForgeryToken()
                        <textarea name="body" class="form-control border-0 bg-light mb-2 quick-story-textarea"
                                  rows="1" placeholder="Share a life story or memory..."
                                  required></textarea>
                        @await Html.PartialAsync("_TagWidgetInline", new TagWidgetViewModel
                        {
                            Friends = taggableFriends,
                            Selected = new List<TaggableFriendViewModel>()
                        })
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <input type="number" name="eventYear" class="form-control form-control-sm"
                                   style="width:80px;" placeholder="Year" max="2100" required />
                            <input type="number" name="eventMonth" class="form-control form-control-sm"
                                   style="width:70px;" placeholder="Mo" min="1" max="12" />
                            <input type="number" name="eventDay" class="form-control form-control-sm"
                                   style="width:65px;" placeholder="Day" min="1" max="31" />
                            <input type="text" name="location" class="form-control form-control-sm"
                                   style="width:120px;" placeholder="📍 Location" />
                            <select name="visibility" class="form-select form-select-sm" style="width:auto;">
                                <option value="Public">🔴 Public</option>
                                <option value="Acquaintances">🟡 Acquaintances</option>
                                <option value="Friends" selected>🟢 Friends</option>
                                <option value="Family">🔵 Family</option>
                                <option value="Private">🔒 Only Me</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-quick-story ms-auto">
                                Quick Story
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (!Model.RecentPosts.Any())
            {
                <div class="card border-0 bg-light text-center p-4">
                    <p class="text-muted mb-2">Your story starts here.</p>
                    <a asp-controller="Posts" asp-action="Create" class="btn btn-primary btn-sm">Write your first life event</a>
                </div>
            }
            else
            {
                @foreach (var item in Model.RecentPosts)
                {
                    <div class="card border-0 shadow-sm mb-3" style="position:relative;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = item.Post.Owner, Size = 32 })
                                    <div>
                                        <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@item.Post.OwnerUserId"
                                           class="fw-semibold text-decoration-none" style="position:relative;z-index:2;">
                                            @(item.Post.Owner.DisplayName ?? item.Post.Owner.UserName)
                                        </a>
                                        <span class="badge bg-success-subtle text-success ms-2 small">@item.Post.EventDateDisplay</span>
                                        @if (!string.IsNullOrEmpty(item.Post.Location))
                                        {
                                            <span class="text-muted small ms-1">📍 @item.Post.Location</span>
                                        }
                                    </div>
                                </div>
                                <span class="small text-muted d-inline-flex align-items-center gap-1">@await Html.PartialAsync("_VisibilityDot", item.Post.Visibility) @item.Post.CreatedAt.ToString("MMM d")</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Post.Title))
                            {
                                <h6 class="mb-1">@item.Post.Title</h6>
                            }
                            <div class="mb-2 small text-truncate">@MyStoryTold.Helpers.BodyRenderer.TextPreview(item.Post.Body, 200)</div>
                            <div class="d-flex align-items-center gap-3 border-top pt-2" style="position:relative;z-index:3;">
                                <button type="button"
                                        class="icon-action like-btn @(item.CurrentUserLiked ? "liked" : "")"
                                        data-post-id="@item.Post.Id"
                                        data-liked="@item.CurrentUserLiked.ToString().ToLower()"
                                        style="position:relative;z-index:4;">
                                    <span class="icon-heart">❤</span> <span class="like-count">@item.LikeCount</span>
                                </button>
                                <a asp-controller="Posts" asp-action="Detail" asp-route-id="@item.Post.Id"
                                   class="icon-action" style="position:relative;z-index:4;">
                                    💬 @item.Post.Comments.Count
                                </a>
                            </div>
                            <a asp-controller="Posts" asp-action="Detail" asp-route-id="@item.Post.Id"
                               class="stretched-link" aria-label="Read post"></a>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- RIGHT: Quick Links -->
        <div class="col-md-2 col-sidebar">
            @await Html.PartialAsync("_QuickLinksSidebar")
        </div>

    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        document.querySelectorAll('.like-btn').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var postId = btn.dataset.postId;
                var countEl = btn.querySelector('.like-count');
                // Optimistic UI: flip immediately, reconcile with server after
                var wasLiked = btn.classList.contains('liked');
                var newCount = parseInt(countEl.textContent, 10) + (wasLiked ? -1 : 1);
                btn.classList.toggle('liked');
                countEl.textContent = newCount;
                fetch('/Posts/ToggleLikeAjax/' + postId, {
                    method: 'POST',
                    headers: { 'X-CSRF-TOKEN': token }
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    countEl.textContent = data.count;
                    btn.classList.toggle('liked', !!data.liked);
                })
                .catch(function () {
                    // rollback on error
                    btn.classList.toggle('liked', wasLiked);
                    countEl.textContent = wasLiked ? newCount + 1 : newCount - 1;
                });
            });
        });
    });
    </script>
}
else
{
    ViewData["BodyClass"] = "landing-body";
    ViewData["ContainerClass"] = "container-fluid px-0";

    <!-- Public Landing Page -->
    <div class="landing-page-wrap">

        <!-- Hero -->
        <div class="text-center landing-hero">
            <img src="~/images/kronoscript-logo-gold.png" alt="Kronoscript"
                 class="hero-logo mb-2" onerror="this.style.display='none'" />
            <h1 class="hero-title">KRONOSCRIPT</h1>
            <p class="tagline mt-1">Tell Your Life Story. Share It Over Time.</p>
            <p class="hero-lead mt-4">
                A private place to document your life story and invite<br class="d-none d-md-inline" />
                the people who were there to enrich it with their memories.
            </p>
            <div class="mt-5 d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Account" asp-action="Register"
                   class="btn btn-hero-gold btn-lg fw-semibold px-5">Get Started</a>
                <a asp-controller="Account" asp-action="Login"
                   class="btn btn-hero-outline btn-lg px-5">Sign In</a>
            </div>
        </div>

        <!-- Quill Script Section -->
        <div class="quill-section text-center">
            <div class="quill-stage" id="quillStage">
                <span id="quillText" class="quill-text"></span>
            </div>
        </div>

        <!-- Footer text inline -->
        <div class="text-center landing-inline-footer">
            <small>&copy; 2026 Kronoscript &mdash; Tell your life story. Share it over time.</small>
        </div>

    </div>

@section Head {
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
}

@section Scripts {
<script>
(function () {
    // ── Quill typewriter (no cursor, no delete — fade between messages) ──
    var messages = [
        "A place for shared Memories",
        "A Story Told",
        "Enrich your Story with insights from friends and family",
        "Relive great moments",
        "Keepsake and safeguard your life",
        "Share moments as they happen, or as they come back to you",
        "Easily reorganize your memories",
        "When you are satisfied, organize and download them",
        "It\u2019s privacy proof, free and ad-free",
        "Document your life",
        "Join the Social Lifestory Network",
        "Organize friends by acquaintances, friends, and family\u2026 or write in private",
        "Because our loved ones remember what we have forgotten",
        "Export whenever you want",
        "Enriched by the People that lived it with you"
    ];

    var el = document.getElementById('quillText');
    var stage = document.getElementById('quillStage');
    var msgIdx = 0, charIdx = 0;

    function tick() {
        var msg = messages[msgIdx];
        charIdx++;
        el.textContent = msg.substring(0, charIdx);
        if (charIdx === msg.length) {
            // Full message shown — pause then fade out, jump to next
            setTimeout(function () {
                stage.classList.add('quill-fade-out');
                setTimeout(function () {
                    msgIdx = (msgIdx + 1) % messages.length;
                    charIdx = 0;
                    el.textContent = '';
                    stage.classList.remove('quill-fade-out');
                    setTimeout(tick, 300);
                }, 600);
            }, 3000);
            return;
        }
        setTimeout(tick, 55 + Math.random() * 35);
    }

    setTimeout(tick, 800);
})();
</script>
}
}
