@{
    ViewData["Title"] = "Invite Sent";
    var token = ViewBag.Token as string;
    var email = ViewBag.Email as string;
    var message = ViewBag.Message as string;
    var inviteUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Account/Register?invite={token}";
}

<div class="row g-3">
    <div class="col-md-2">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-6 text-center">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-5">
                <div class="fs-1 mb-3">✅</div>
                <h4 class="fw-bold mb-2" style="color: var(--mst-primary);">Invite Created!</h4>
                <p class="text-muted mb-4">
                    Share this link with <strong>@email</strong> so they can join Kronoscript and connect with you.
                </p>

                <div class="input-group mb-3">
                    <input type="text" id="inviteLink" class="form-control" value="@inviteUrl" readonly />
                    <button class="btn btn-outline-secondary" onclick="copyLink()" type="button">📋 Copy</button>
                </div>

                <a href="mailto:@email?subject=Join me on Kronoscript&body=@Uri.EscapeDataString(message + "\n\n" + inviteUrl)"
                   class="btn btn-primary mb-3">📧 Open in Email App</a>

                <div>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Home</a>
                    <a asp-action="Invite" class="btn btn-outline-primary btn-sm ms-2">Invite Another</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>
</div>

@section Scripts {
<script>
function copyLink() {
    var el = document.getElementById('inviteLink');
    el.select();
    document.execCommand('copy');
    var btn = el.nextElementSibling;
    btn.textContent = '✅ Copied!';
    setTimeout(function() { btn.textContent = '📋 Copy'; }, 2000);
}
</script>
}
