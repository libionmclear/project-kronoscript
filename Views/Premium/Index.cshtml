@using MyStoryTold.Models
@{
    ViewData["Title"] = "Premium";
    var isPremium = (bool)(ViewBag.IsPremium ?? false);
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <header class="premium-hero">
            @if (isPremium)
            {
                <p class="premium-hero-eyebrow">You're a Premium member</p>
                <h1 class="premium-hero-title">Thank you.</h1>
                @if (ViewBag.PremiumUntil is DateTime u)
                {
                    <p class="premium-hero-meta">Your subscription runs through <strong>@u.ToLocalTime().ToString("MMMM d, yyyy")</strong>.</p>
                }
            }
            else
            {
                <p class="premium-hero-eyebrow">Premium</p>
                <h1 class="premium-hero-title">Your story, illustrated.<br class="d-none d-md-inline" />Your family's, told together.</h1>
            }
        </header>

        @* ── Two-tier comparison ──────────────────────────────────── *@
        <section class="premium-plans">
            <div class="premium-plan">
                <div class="premium-plan-eyebrow">Personal</div>
                <div class="premium-plan-price">
                    <span class="premium-plan-amount">$10</span>
                    <span class="premium-plan-period">/ month</span>
                </div>
                <p class="premium-plan-tagline">Your story, illustrated and polished.</p>
                <ul class="premium-plan-features">
                    <li><strong>Inline photos in the prose</strong> — placed where you want them, text wrapping around</li>
                    <li><strong>Premium typography</strong> — drop cap, justified text, Newspaper &amp; Book layouts</li>
                    <li><strong>Magazine-style cover</strong> on your feed cards</li>
                    <li><strong>Audio &amp; video</strong> — record or upload, both come with</li>
                    <li><strong>AI Story Assistant</strong> — when the blank page is winning, it asks the right questions</li>
                    <li><strong>AI photo restoration</strong> — bring old prints back from the box in the attic</li>
                    <li><strong>People Profiles, Family Tree, Eras</strong> — the organising layer that becomes your archive</li>
                    <li><strong>Book mode + chapters + PDF export</strong> — what your timeline becomes ten years in</li>
                </ul>
                @if (!isPremium)
                {
                    <a asp-controller="Inbox" asp-action="Compose" asp-route-id="kronoadmin" class="premium-plan-cta">
                        Start Personal
                    </a>
                }
                else
                {
                    <span class="premium-plan-current">Your current plan</span>
                }
            </div>

            <div class="premium-plan premium-plan-family">
                <div class="premium-plan-eyebrow">Family</div>
                <div class="premium-plan-price">
                    <span class="premium-plan-amount">$25</span>
                    <span class="premium-plan-period">/ month · up to 6</span>
                </div>
                <p class="premium-plan-tagline">Your family's story, told together.</p>
                <ul class="premium-plan-features">
                    <li>Everything in Personal, for <strong>up to 6 people</strong> in your family or circle</li>
                    <li><strong>Shared Family Tree</strong> — each member edits the same branches</li>
                    <li><strong>Groups</strong> — private spaces for family, friends, or both</li>
                    <li><strong>Crowdsource a memory</strong> — one event, many voices, full edit rights</li>
                    <li><strong>Family Book</strong> — everyone's life stories bound into one volume</li>
                    <li><strong>Family Chat</strong> — group conversations scoped to a Group</li>
                </ul>
                @if (!isPremium)
                {
                    <a asp-controller="Inbox" asp-action="Compose" asp-route-id="kronoadmin" class="premium-plan-cta premium-plan-cta-family">
                        Start Family
                    </a>
                }
                else
                {
                    <span class="premium-plan-current">Available — message us to upgrade</span>
                }
            </div>
        </section>

        @if (!isPremium)
        {
            @* ── Compact feature grid (replaces the verbose 'what it looks like') *@
            <section class="premium-grid">
                <p class="premium-grid-eyebrow">What you get</p>
                <div class="premium-grid-items">
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="5" width="18" height="14" rx="2"/>
                            <circle cx="9" cy="10" r="1.5"/>
                            <path d="M3 17l5-4 4 3 3-2 6 4"/>
                        </svg>
                        <h4>Photos in the prose</h4>
                        <p>Left, right, or center — text wraps around.</p>
                    </div>
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M4 6h16M4 10h16M4 14h10M4 18h13"/>
                        </svg>
                        <h4>Book-quality typography</h4>
                        <p>Drop cap, justified text, magazine layouts.</p>
                    </div>
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="4" y="3" width="16" height="18" rx="1.5"/>
                            <path d="M8 8h8M8 12h6"/>
                        </svg>
                        <h4>Cover, not card</h4>
                        <p>Full-width photo cover, title overlaid in serif.</p>
                    </div>
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="9" y="3" width="6" height="12" rx="3"/>
                            <path d="M5 11a7 7 0 0 0 14 0M12 18v3"/>
                        </svg>
                        <h4>Audio &amp; video</h4>
                        <p>Record or upload. Both come with.</p>
                    </div>
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
                            <circle cx="12" cy="12" r="3.5"/>
                        </svg>
                        <h4>AI Story Assistant</h4>
                        <p>When the blank page is winning.</p>
                    </div>
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M4 6h16v12H4z"/>
                            <path d="M9 18l-1 3M15 18l1 3"/>
                            <path d="M8 11l3 2 5-4"/>
                        </svg>
                        <h4>AI photo restoration</h4>
                        <p>Old prints brought back from the box in the attic.</p>
                    </div>
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="6" r="2.5"/>
                            <path d="M12 8.5V12M6 14a6 6 0 0 1 12 0M9 14v6M15 14v6"/>
                        </svg>
                        <h4>People &amp; family tree</h4>
                        <p>The organising layer that becomes your archive.</p>
                    </div>
                    <div class="premium-grid-card">
                        <svg class="premium-grid-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M4 4h7a3 3 0 0 1 3 3v13a3 3 0 0 0-3-3H4z"/>
                            <path d="M20 4h-7a3 3 0 0 0-3 3v13a3 3 0 0 1 3-3h7z"/>
                        </svg>
                        <h4>Book mode + PDF</h4>
                        <p>Your timeline, ten years in.</p>
                    </div>
                </div>
            </section>

            @* ── Closing CTA ──────────────────────────────────────── *@
            <section class="premium-closing">
                <h3>Ready to upgrade?</h3>
                <p>
                    Checkout is on its way — we're finalising payment details for the launch.
                    Drop us a line and we'll reach out the moment it opens.
                </p>
                <a asp-controller="Inbox" asp-action="Compose" asp-route-id="kronoadmin" class="btn btn-primary btn-lg">
                    Tell us you're interested
                </a>
            </section>
        }

        @* ── Premium Services pointer ─────────────────────────────── *@
        <div class="premium-services-pointer">
            <p>
                Looking for one-off deliverables instead? Hardcover prints, editing passes, audio books,
                family-tree research, archival scanning — those are <strong>Premium Services</strong>.
            </p>
            <a asp-controller="PremiumServices" asp-action="Index">Browse Premium Services →</a>
        </div>
    </div>
</div>
