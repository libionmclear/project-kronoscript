@model MyStoryTold.Models.ViewModels.InboxViewModel
@inject Microsoft.AspNetCore.Identity.UserManager<MyStoryTold.Models.ApplicationUser> _userManager
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string Initials(MyStoryTold.Models.ApplicationUser u)
    {
        if (!string.IsNullOrEmpty(u.FirstName) && !string.IsNullOrEmpty(u.LastName))
            return $"{u.FirstName[0]}{u.LastName[0]}".ToUpper();
        var un = u.DisplayName ?? u.UserName ?? "?";
        return (un.Length >= 2 ? un[..2] : un).ToUpper();
    }

    string Preview(MyStoryTold.Models.Message m, string currentId)
    {
        var prefix = m.SenderUserId == currentId ? "You: " : "";
        var body = (m.Body ?? "").Replace("\r", " ").Replace("\n", " ").Trim();
        if (body.Length > 90) body = body[..90].TrimEnd() + "…";
        return prefix + body;
    }

    string TimeAgo(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var span = DateTime.Now - local;
        if (span.TotalMinutes < 1) return "now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h";
        if (span.TotalDays < 7) return local.ToString("ddd");
        return local.ToString("MMM d");
    }

    var currentId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <div class="col-md-9 col-main">
        <div class="inbox-page-header">
            <h2 class="inbox-page-title">
                <span class="inbox-icon">💬</span>
                <span>Messages</span>
                @if (Model.TotalUnread > 0)
                {
                    <span class="inbox-unread-pill">@Model.TotalUnread new</span>
                }
            </h2>
            <div class="d-flex align-items-center gap-3">
                @{
                    var meUser = await _userManager.GetUserAsync(User);
                    var lookingOffline = meUser != null && !meUser.ShowOnlineStatus;
                }
                <label class="chat-dock-look-offline" title="Look offline to other members. Your dot will appear grey." style="margin:0;">
                    <input type="checkbox" id="inboxLookOffline" @(lookingOffline ? "checked" : "") />
                    <span>Look offline</span>
                </label>
                <a asp-action="Compose" class="inbox-new-btn">
                    <span aria-hidden="true">＋</span>
                    <span>New message</span>
                </a>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show py-2">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Search a connection by name to start a fresh conversation -->
        <div class="position-relative inbox-search-row">
            <input type="text" id="contactSearch" class="form-control"
                   placeholder="Search a connection to message…" autocomplete="off" />
            <div id="contactSearchResults"
                 class="list-group position-absolute w-100 shadow"
                 style="display:none;z-index:1060;max-height:240px;overflow-y:auto;top:100%;left:0;"></div>
        </div>

        @if (!Model.Conversations.Any())
        {
            <div class="inbox-empty">
                <div class="inbox-empty-icon">💬</div>
                <div class="inbox-empty-title">No messages yet</div>
                <div class="inbox-empty-sub">
                    Start a conversation by searching a connection above, or
                    @if (Model.Family.Any() || Model.Friends.Any() || Model.Acquaintances.Any())
                    {
                        <span>tap one of your contacts below.</span>
                    }
                    else
                    {
                        <a asp-controller="Friends" asp-action="Index">grow your network</a><span> first.</span>
                    }
                </div>
                <a asp-action="Compose" class="inbox-new-btn">
                    <span aria-hidden="true">＋</span>
                    <span>New message</span>
                </a>
            </div>
        }
        else
        {
            <div class="inbox-conversations" aria-label="Conversations">
                @foreach (var conv in Model.Conversations)
                {
                    var isUnread = conv.UnreadCount > 0;
                    var name = conv.OtherUser.DisplayName ?? conv.OtherUser.UserName ?? "?";
                    <a asp-action="Conversation" asp-route-id="@conv.OtherUser.Id"
                       class="inbox-conversation @(isUnread ? "is-unread" : "")">
                        <div class="inbox-conversation-avatar">
                            @* Presence-dot wrapper picks up the same SignalR
                               wiring as everywhere else: green when online,
                               amber when Away, grey otherwise. Hidden users
                               carry data-presence-hidden="true" and stay grey. *@
                            <span class="presence-dot"
                                  data-presence-user="@conv.OtherUser.Id"
                                  @(!conv.OtherUser.ShowOnlineStatus ? "data-presence-hidden=\"true\"" : "")>
                                @if (!string.IsNullOrEmpty(conv.OtherUser.ProfilePhotoUrl))
                                {
                                    <img src="@conv.OtherUser.ProfilePhotoUrl" class="rounded-circle"
                                         style="width:46px;height:46px;object-fit:cover;" alt="" />
                                }
                                else
                                {
                                    <span class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                          style="width:46px;height:46px;background:var(--mst-light);color:var(--mst-primary);font-size:0.95rem;">
                                        @Initials(conv.OtherUser)
                                    </span>
                                }
                            </span>
                        </div>
                        <div class="inbox-conversation-body">
                            <div class="inbox-conversation-row1">
                                <span class="inbox-conversation-name">@name</span>
                                <span class="inbox-conversation-time">@TimeAgo(conv.LastMessage.SentAt)</span>
                            </div>
                            <div class="inbox-conversation-preview">
                                @Preview(conv.LastMessage, currentId)
                            </div>
                        </div>
                        @if (isUnread)
                        {
                            <span class="inbox-conversation-unread">@conv.UnreadCount</span>
                        }
                    </a>
                }
            </div>
        }

        @* Connections fall-back: only relevant when there are NO conversations
           yet — gives the new user a hint of who they could message. Tucked
           below so it never overshadows the actual messages list. *@
        @if (!Model.Conversations.Any() && (Model.Family.Any() || Model.Friends.Any() || Model.Acquaintances.Any()))
        {
            <div class="mt-4">
                <div class="small fw-semibold mb-2 text-muted text-uppercase" style="letter-spacing:0.06em;font-size:0.7rem;">
                    Your connections
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var c in Model.Family.Concat(Model.Friends).Concat(Model.Acquaintances))
                    {
                        var dn = c.User.DisplayName ?? c.User.UserName ?? "";
                        var ini = Initials(c.User);
                        <a href="/Inbox/Conversation/@c.User.Id"
                           class="text-decoration-none"
                           data-bs-toggle="tooltip" data-bs-title="@dn">
                            @if (!string.IsNullOrEmpty(c.User.ProfilePhotoUrl))
                            {
                                <img src="@c.User.ProfilePhotoUrl" class="rounded-circle"
                                     style="width:40px;height:40px;object-fit:cover;border:2px solid var(--mst-border);" />
                            }
                            else
                            {
                                <span class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                      style="width:40px;height:40px;font-size:0.78rem;background:var(--mst-light);color:var(--mst-primary);flex-shrink:0;">
                                    @ini
                                </span>
                            }
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        new bootstrap.Tooltip(el);
    });

    var contactSearch  = document.getElementById('contactSearch');
    var contactResults = document.getElementById('contactSearchResults');
    if (contactSearch) {
        contactSearch.addEventListener('input', function () {
            var q = this.value.trim();
            contactResults.innerHTML = '';
            if (q.length < 2) { contactResults.style.display = 'none'; return; }
            fetch('/Friends/Search?q=' + encodeURIComponent(q))
                .then(function (r) { return r.json(); })
                .then(function (users) {
                    if (!users || !users.length) {
                        contactResults.innerHTML = '<div class="list-group-item small text-muted">No users found.</div>';
                        contactResults.style.display = 'block';
                        return;
                    }
                    users.forEach(function (u) {
                        var a = document.createElement('a');
                        a.href = '/Inbox/Conversation/' + u.userId;
                        a.className = 'list-group-item list-group-item-action d-flex align-items-center gap-2 py-2';
                        var name = u.displayName || u.userName || '';
                        var un = name.trim();
                        var initials = (un.length >= 2 ? un[0] + un[1] : un[0] || '?').toUpperCase();
                        a.innerHTML = '<span style="width:30px;height:30px;border-radius:50%;background:var(--mst-light);color:var(--mst-primary);font-weight:bold;font-size:11px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">' + initials + '</span>'
                                    + '<span class="fw-semibold small">' + name + '</span>';
                        contactResults.appendChild(a);
                    });
                    contactResults.style.display = 'block';
                })
                .catch(function () { contactResults.style.display = 'none'; });
        });
        contactSearch.addEventListener('blur', function () {
            setTimeout(function () { contactResults.style.display = 'none'; }, 200);
        });
    }

    // "Look offline" toggle in the page header — same behavior as the
    // chat-dock copy: POST to /Profile/SetVisibility AND tell the live
    // presence hub so other viewers' dots flip immediately.
    var lookOffline = document.getElementById('inboxLookOffline');
    if (lookOffline) {
        lookOffline.addEventListener('change', function () {
            var goHidden = lookOffline.checked;
            var fd = new FormData();
            fd.append('show', goHidden ? 'false' : 'true');
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) fd.append('__RequestVerificationToken', token.value);
            fetch('/Profile/SetVisibility', {
                method: 'POST',
                body: fd,
                credentials: 'same-origin'
            }).then(function (r) {
                if (!r.ok) lookOffline.checked = !goHidden;
            }).catch(function () { lookOffline.checked = !goHidden; });
            if (window.kronosPresence && window.kronosPresence.setVisibility) {
                window.kronosPresence.setVisibility(!goHidden);
            }
        });
    }
</script>
}
