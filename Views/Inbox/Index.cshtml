@model MyStoryTold.Models.ViewModels.InboxViewModel
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-3">
    <div class="col-md-3 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <div class="col-md-6">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0" style="color: var(--mst-primary);">
                Messages
                @if (Model.TotalUnread > 0)
                {
                    <span class="badge bg-danger ms-2">@Model.TotalUnread</span>
                }
            </h5>
            <a asp-action="Compose" class="btn btn-sm btn-primary"
               data-bs-toggle="tooltip" data-bs-title="Start a new conversation">✉️ New Message</a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show py-2">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Contacts browser by category -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-2">
                <strong class="small" style="color:var(--mst-primary);">Your Connections</strong>
            </div>
            <div class="card-body p-2">
                <!-- Live search box -->
                <div class="mb-2 position-relative">
                    <input type="text" id="contactSearch" class="form-control form-control-sm"
                           placeholder="Search by name or username…" autocomplete="off" />
                    <div id="contactSearchResults"
                         class="list-group position-absolute w-100 shadow"
                         style="display:none;z-index:1060;max-height:200px;overflow-y:auto;top:100%;left:0;"></div>
                </div>

                @{
                    // Helper to compute initials for a contact card
                    string ContactInitials(MyStoryTold.Models.ApplicationUser u)
                    {
                        if (!string.IsNullOrEmpty(u.FirstName) && !string.IsNullOrEmpty(u.LastName))
                            return $"{u.FirstName[0]}{u.LastName[0]}".ToUpper();
                        var dn = u.DisplayName ?? u.UserName ?? "?";
                        var pts = dn.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        return pts.Length >= 2 ? $"{pts[0][0]}{pts[^1][0]}".ToUpper() : pts[0][0].ToString().ToUpper();
                    }
                }

                @if (Model.Family.Any())
                {
                    <div class="mb-2">
                        <div class="small text-muted fw-semibold px-1 mb-1" style="font-size:0.7rem;letter-spacing:0.05em;text-transform:uppercase;">Family</div>
                        <div class="d-flex flex-wrap gap-2 px-1">
                            @foreach (var c in Model.Family)
                            {
                                var dn = c.User.DisplayName ?? c.User.UserName ?? "";
                                var ini = ContactInitials(c.User);
                                <a href="/Inbox/Conversation/@c.User.Id"
                                   class="d-flex align-items-center gap-2 text-decoration-none rounded p-1 px-2"
                                   style="background:var(--mst-light);color:var(--mst-primary);font-size:0.85rem;"
                                   data-bs-toggle="tooltip" data-bs-title="Message @dn">
                                    @if (!string.IsNullOrEmpty(c.User.ProfilePhotoUrl))
                                    {
                                        <img src="@c.User.ProfilePhotoUrl" class="rounded-circle" style="width:24px;height:24px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                              style="width:24px;height:24px;background:var(--mst-primary);color:#fff;font-weight:bold;font-size:10px;">@ini</span>
                                    }
                                    <span>@dn</span>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.Friends.Any())
                {
                    <div class="mb-2">
                        <div class="small text-muted fw-semibold px-1 mb-1" style="font-size:0.7rem;letter-spacing:0.05em;text-transform:uppercase;">Friends</div>
                        <div class="d-flex flex-wrap gap-2 px-1">
                            @foreach (var c in Model.Friends)
                            {
                                var dn = c.User.DisplayName ?? c.User.UserName ?? "";
                                var ini = ContactInitials(c.User);
                                <a href="/Inbox/Conversation/@c.User.Id"
                                   class="d-flex align-items-center gap-2 text-decoration-none rounded p-1 px-2"
                                   style="background:var(--mst-light);color:var(--mst-primary);font-size:0.85rem;"
                                   data-bs-toggle="tooltip" data-bs-title="Message @dn">
                                    @if (!string.IsNullOrEmpty(c.User.ProfilePhotoUrl))
                                    {
                                        <img src="@c.User.ProfilePhotoUrl" class="rounded-circle" style="width:24px;height:24px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                              style="width:24px;height:24px;background:var(--mst-primary);color:#fff;font-weight:bold;font-size:10px;">@ini</span>
                                    }
                                    <span>@dn</span>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.Acquaintances.Any())
                {
                    <div class="mb-2">
                        <div class="small text-muted fw-semibold px-1 mb-1" style="font-size:0.7rem;letter-spacing:0.05em;text-transform:uppercase;">Acquaintances</div>
                        <div class="d-flex flex-wrap gap-2 px-1">
                            @foreach (var c in Model.Acquaintances)
                            {
                                var dn = c.User.DisplayName ?? c.User.UserName ?? "";
                                var ini = ContactInitials(c.User);
                                <a href="/Inbox/Conversation/@c.User.Id"
                                   class="d-flex align-items-center gap-2 text-decoration-none rounded p-1 px-2"
                                   style="background:var(--mst-light);color:var(--mst-primary);font-size:0.85rem;"
                                   data-bs-toggle="tooltip" data-bs-title="Message @dn">
                                    @if (!string.IsNullOrEmpty(c.User.ProfilePhotoUrl))
                                    {
                                        <img src="@c.User.ProfilePhotoUrl" class="rounded-circle" style="width:24px;height:24px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                              style="width:24px;height:24px;background:var(--mst-primary);color:#fff;font-weight:bold;font-size:10px;">@ini</span>
                                    }
                                    <span>@dn</span>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (!Model.Family.Any() && !Model.Friends.Any() && !Model.Acquaintances.Any())
                {
                    <p class="text-muted small text-center mb-0">No connections yet. <a asp-controller="Friends" asp-action="Index">Grow your network</a> to start messaging!</p>
                }
            </div>
        </div>

        <!-- Recent conversations -->
        @if (!Model.Conversations.Any())
        {
            <div class="card border-0 shadow-sm text-center p-4 text-muted">
                <p class="mb-0">No messages yet. Pick a connection above to start a conversation!</p>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-2">
                    <strong class="small" style="color:var(--mst-primary);">Recent Conversations</strong>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var conv in Model.Conversations)
                    {
                        <a asp-action="Conversation" asp-route-id="@conv.OtherUser.Id"
                           class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 @(conv.UnreadCount > 0 ? "fw-semibold" : "")">
                            @if (!string.IsNullOrEmpty(conv.OtherUser.ProfilePhotoUrl))
                            {
                                <img src="@conv.OtherUser.ProfilePhotoUrl" class="rounded-circle" style="width:42px;height:42px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:42px;height:42px;background:var(--mst-light);color:var(--mst-primary);font-weight:bold;">
                                    @((conv.OtherUser.DisplayName ?? conv.OtherUser.UserName ?? "?")[0])
                                </div>
                            }
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="d-flex justify-content-between">
                                    <span>@(conv.OtherUser.DisplayName ?? conv.OtherUser.UserName)</span>
                                    <small class="text-muted">@conv.LastMessage.SentAt.ToLocalTime().ToString("MMM d")</small>
                                </div>
                                <div class="small text-truncate text-muted">
                                    @(conv.LastMessage.SenderUserId != conv.OtherUser.Id ? "You: " : "")@conv.LastMessage.Body
                                </div>
                            </div>
                            @if (conv.UnreadCount > 0)
                            {
                                <span class="badge bg-danger rounded-pill">@conv.UnreadCount</span>
                            }
                        </a>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-md-3 col-sidebar">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>
</div>

@section Scripts {
<script>
    var contactSearch = document.getElementById('contactSearch');
    var contactResults = document.getElementById('contactSearchResults');
    if (contactSearch) {
        contactSearch.addEventListener('input', function () {
            var q = this.value.trim();
            contactResults.innerHTML = '';
            if (q.length < 2) { contactResults.style.display = 'none'; return; }
            fetch('/Friends/Search?q=' + encodeURIComponent(q))
                .then(function (r) { return r.json(); })
                .then(function (users) {
                    if (!users || !users.length) {
                        contactResults.innerHTML = '<div class="list-group-item small text-muted">No users found.</div>';
                        contactResults.style.display = 'block';
                        return;
                    }
                    users.forEach(function (u) {
                        var a = document.createElement('a');
                        a.href = '/Inbox/Conversation/' + u.userId;
                        a.className = 'list-group-item list-group-item-action d-flex align-items-center gap-2 py-2';
                        var name = u.displayName || u.userName || '';
                        var initials = name.trim() ? name.trim()[0].toUpperCase() : '?';
                        a.innerHTML = '<span style="width:28px;height:28px;border-radius:50%;background:var(--mst-light);color:var(--mst-primary);font-weight:bold;font-size:11px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">' + initials + '</span>'
                                    + '<span class="fw-semibold small">' + name + '</span>'
                                    + '<span class="text-muted ms-1" style="font-size:0.75rem;">@@' + (u.userName || '') + '</span>';
                        contactResults.appendChild(a);
                    });
                    contactResults.style.display = 'block';
                })
                .catch(function () { contactResults.style.display = 'none'; });
        });
        contactSearch.addEventListener('blur', function () {
            setTimeout(function () { contactResults.style.display = 'none'; }, 200);
        });
    }
</script>
}
