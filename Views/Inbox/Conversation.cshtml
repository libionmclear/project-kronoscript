@model MyStoryTold.Models.ViewModels.MessageThreadViewModel
@{
    var isCompose = string.IsNullOrEmpty(Model.OtherUser?.Id);
    ViewData["Title"] = isCompose ? "New Message" : $"Chat with {Model.OtherUser.DisplayName ?? Model.OtherUser.UserName}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="row g-3">
    <div class="col-md-3 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <div class="col-md-6 d-flex flex-column">

        <!-- Header -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body py-2 px-3 d-flex align-items-center gap-2">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-1">← Inbox</a>

                @if (!isCompose)
                {
                    @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.OtherUser, Size = 38 })
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@(Model.OtherUser.DisplayName ?? Model.OtherUser.UserName)</div>
                        <div class="small text-muted">@@@Model.OtherUser.UserName</div>
                    </div>
                }
                else
                {
                    <span class="fw-semibold text-muted">New Message</span>
                }
            </div>
        </div>

        @if (isCompose)
        {
            <!-- Compose: pick recipient first -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-3">
                    <div class="mb-2">
                        <label class="form-label fw-semibold small">To:</label>
                        <div class="input-group">
                            <input type="text" id="recipientSearch" class="form-control"
                                   placeholder="Search by name or username..." autocomplete="off" />
                        </div>
                        <div id="recipientResults" class="mt-1"></div>
                    </div>
                    <form asp-action="Send" method="post" id="composeForm" style="display:none;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="recipientId" id="recipientId" />
                        <div id="toLabel" class="mb-2 d-flex align-items-center gap-2">
                            <span class="badge" style="background-color:var(--mst-primary);color:#fff;" id="toName"></span>
                            <button type="button" class="btn btn-sm btn-link text-muted p-0" id="clearRecipient">Change</button>
                        </div>
                        <textarea name="body" class="form-control mb-2" rows="4"
                                  placeholder="Write your message..." required style="resize:none;"></textarea>
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary">Send Message</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <!-- Thread -->
            <div class="card border-0 shadow-sm mb-3 flex-grow-1">
                <div class="card-body p-3" id="messageThread" style="max-height:52vh;overflow-y:auto;">
                    @if (!Model.Messages.Any())
                    {
                        <p class="text-muted text-center py-4 mb-0">No messages yet — say hello!</p>
                    }
                    @foreach (var msg in Model.Messages)
                    {
                        var isMe = msg.SenderUserId == currentUserId;
                        <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") mb-2">
                            <div class="px-3 py-2 rounded-3 @(isMe ? "text-white" : "bg-light text-dark")"
                                 style="max-width:75%;@(isMe ? "background-color:var(--mst-primary);" : "")">
                                <div>@msg.Body</div>
                                <div class="small @(isMe ? "text-white-50" : "text-muted") text-end mt-1" style="font-size:0.72rem;">
                                    @msg.SentAt.ToLocalTime().ToString("MMM d, h:mm tt")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Reply -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <form asp-action="Send" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="recipientId" value="@Model.OtherUser.Id" />
                        <div class="input-group">
                            <textarea name="body" class="form-control" rows="2"
                                      placeholder="Write a message..." required style="resize:none;"></textarea>
                            <button type="submit" class="btn btn-primary px-3">Send</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="col-md-3 col-sidebar">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>
</div>

@section Scripts {
<script>
    // Auto-scroll thread to bottom
    var thread = document.getElementById('messageThread');
    if (thread) thread.scrollTop = thread.scrollHeight;

    // Compose: recipient search
    var recipientSearch = document.getElementById('recipientSearch');
    if (recipientSearch) {
        recipientSearch.addEventListener('input', function () {
            var q = this.value.trim();
            if (q.length < 2) { document.getElementById('recipientResults').innerHTML = ''; return; }
            fetch('/Friends/Search?q=' + encodeURIComponent(q))
                .then(function(r) { return r.json(); })
                .then(function(users) {
                    if (!users.length) {
                        document.getElementById('recipientResults').innerHTML = '<p class="text-muted small mt-1">No users found.</p>';
                        return;
                    }
                    var html = '<div class="list-group mt-1">';
                    users.forEach(function(u) {
                        html += '<button type="button" class="list-group-item list-group-item-action py-2 small recipient-pick"'
                              + ' data-id="' + u.userId + '" data-name="' + (u.displayName || u.userName) + '">'
                              + '<strong>' + (u.displayName || u.userName) + '</strong>'
                              + ' <span class="text-muted">@@' + u.userName + '</span>'
                              + '</button>';
                    });
                    html += '</div>';
                    document.getElementById('recipientResults').innerHTML = html;

                    document.querySelectorAll('.recipient-pick').forEach(function(btn) {
                        btn.addEventListener('click', function() {
                            document.getElementById('recipientId').value = this.dataset.id;
                            document.getElementById('toName').textContent = this.dataset.name;
                            recipientSearch.parentElement.parentElement.style.display = 'none';
                            document.getElementById('recipientResults').innerHTML = '';
                            document.getElementById('composeForm').style.display = 'block';
                        });
                    });
                });
        });

        document.getElementById('clearRecipient').addEventListener('click', function() {
            document.getElementById('composeForm').style.display = 'none';
            recipientSearch.parentElement.parentElement.style.display = 'block';
            recipientSearch.value = '';
            document.getElementById('recipientId').value = '';
        });
    }
</script>
}
