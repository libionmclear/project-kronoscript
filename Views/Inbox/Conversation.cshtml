@model MyStoryTold.Models.ViewModels.MessageThreadViewModel
@{
    var isCompose = string.IsNullOrEmpty(Model.OtherUser?.Id);
    var otherName = isCompose ? "" : (Model.OtherUser!.DisplayName ?? Model.OtherUser.UserName ?? "");
    ViewData["Title"] = isCompose ? "New Message" : $"Chat with {otherName}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentDisplay = Model.CurrentUser?.DisplayName ?? Model.CurrentUser?.UserName ?? "";
    var currentPhoto = Model.CurrentUser?.ProfilePhotoUrl;
    var otherPhoto = Model.OtherUser?.ProfilePhotoUrl;

    string Initials(MyStoryTold.Models.ApplicationUser? u)
    {
        if (u == null) return "?";
        if (!string.IsNullOrEmpty(u.FirstName) && !string.IsNullOrEmpty(u.LastName))
            return $"{u.FirstName[0]}{u.LastName[0]}".ToUpper();
        var un = u.DisplayName ?? u.UserName ?? "?";
        return (un.Length >= 2 ? un[..2] : un).ToUpper();
    }
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <div class="col-md-9 col-main">
        @if (TempData["ChatError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show py-2 mb-2">
                @TempData["ChatError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="chat-card"
             data-current-user-id="@currentUserId"
             data-other-user-id="@(Model.OtherUser?.Id ?? "")"
             data-current-display="@currentDisplay"
             data-current-photo="@(currentPhoto ?? "")"
             data-other-display="@otherName"
             data-other-photo="@(otherPhoto ?? "")"
             data-current-initials="@Initials(Model.CurrentUser)"
             data-other-initials="@Initials(Model.OtherUser)">

            <!-- ── Header ── -->
            <div class="chat-header">
                <a asp-action="Index" class="chat-back-btn" title="Back to inbox" aria-label="Back to inbox">←</a>

                @if (!isCompose)
                {
                    <div class="chat-header-user">
                        @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.OtherUser!, Size = 40 })
                        <div class="chat-header-text">
                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@Model.OtherUser!.Id"
                               class="chat-header-name text-decoration-none">@otherName</a>
                            <span class="chat-header-username">@@@Model.OtherUser!.UserName</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="chat-header-compose flex-grow-1 d-flex align-items-center gap-2">
                        <span class="text-muted small">To:</span>
                        <div id="toChip" class="d-none align-items-center gap-1">
                            <span class="badge rounded-pill d-flex align-items-center gap-1 px-2 py-1"
                                  style="background:var(--mst-light);color:var(--mst-primary);font-size:0.85rem;">
                                <span id="toChipName"></span>
                                <button type="button" id="clearTo" class="btn-close btn-close-sm ms-1"
                                        style="font-size:0.6rem;" aria-label="Clear"></button>
                            </span>
                        </div>
                        <div id="toSearch" class="position-relative flex-grow-1">
                            <input type="text" id="recipientInput" class="form-control form-control-sm border-0 shadow-none"
                                   placeholder="Search name or username…" autocomplete="off" />
                            <div id="recipientDropdown"
                                 class="list-group position-absolute w-100 shadow"
                                 style="display:none;z-index:1060;max-height:220px;overflow-y:auto;top:100%;left:0;"></div>
                        </div>
                    </div>
                }
            </div>

            <!-- ── Message thread ── -->
            <div id="chatThread" class="chat-thread">
                @if (!isCompose)
                {
                    @if (!Model.Messages.Any())
                    {
                        <div class="chat-empty" id="chatEmpty">
                            <div class="chat-empty-icon">💬</div>
                            <div class="chat-empty-title">No messages yet</div>
                            <div class="chat-empty-sub">Say hello to @otherName.</div>
                        </div>
                    }
                    else
                    {
                        @* Day-divider grouping was being computed against the
                           SERVER's local timezone (UTC in production). When
                           the viewer is in a different zone, both the day
                           breaks and the bubble timestamps were off — sometimes
                           by a whole calendar day. We now emit the raw UTC
                           ISO timestamp on each element and let a small JS
                           pass at the bottom of the page format it in the
                           browser's timezone, matching the popup dock. *@
                        string? lastSenderId = null;
                        for (int i = 0; i < Model.Messages.Count; i++)
                        {
                            var msg = Model.Messages[i];
                            var sentAtIso = msg.SentAt.ToUniversalTime().ToString("o");
                            var isMe = msg.SenderUserId == currentUserId;
                            // Server-side day-grouping fallback: emit a
                            // divider whenever the UTC date changes. The JS
                            // pass de-duplicates if local-tz makes two
                            // consecutive UTC days collapse into one.
                            var utcDay = msg.SentAt.ToUniversalTime().Date;
                            bool emitDivider = i == 0
                                || msg.SentAt.ToUniversalTime().Date
                                    != Model.Messages[i - 1].SentAt.ToUniversalTime().Date;
                            if (emitDivider)
                            {
                                <div class="chat-day-divider" data-utc-day="@sentAtIso"><span>@utcDay.ToString("MMMM d, yyyy")</span></div>
                                lastSenderId = null;
                            }
                            var isContinuation = lastSenderId == msg.SenderUserId;
                            <div class="chat-row @(isMe ? "is-me" : "is-them") @(isContinuation ? "is-continuation" : "")"
                                 data-message-id="@msg.Id">
                                @if (!isMe)
                                {
                                    <div class="chat-avatar-slot">
                                        @if (!isContinuation)
                                        {
                                            @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.OtherUser!, Size = 32 })
                                        }
                                    </div>
                                }
                                <div class="chat-bubble-group">
                                    <div class="chat-bubble">@msg.Body</div>
                                    <div class="chat-time" data-utc="@sentAtIso">@msg.SentAt.ToUniversalTime().ToString("HH:mm")</div>
                                </div>
                            </div>
                            lastSenderId = msg.SenderUserId;
                        }
                    }
                }
                else
                {
                    <div class="chat-empty">
                        <div class="chat-empty-icon">💬</div>
                        <div class="chat-empty-title">Start a new conversation</div>
                        <div class="chat-empty-sub">Search for someone above and start typing.</div>
                    </div>
                }
            </div>

            <!-- ── Send bar ── -->
            <div class="chat-composer">
                <form asp-action="Send" method="post" id="sendForm" class="chat-composer-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="recipientId" id="recipientId"
                           value="@(isCompose ? "" : Model.OtherUser?.Id)" />
                    <textarea name="body" id="msgBody" class="chat-composer-input" rows="1"
                              placeholder="@(isCompose ? "Select a recipient above first…" : "Message " + otherName + "…  (Enter to send, Shift+Enter for newline)")"
                              @(isCompose ? "disabled" : "") required></textarea>
                    <button type="submit" id="sendBtn" class="chat-composer-send" @(isCompose ? "disabled" : "")
                            title="Send (Enter)" aria-label="Send">
                        ➤
                    </button>
                </form>
                <div id="sendError" class="chat-composer-error d-none"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var card = document.querySelector('.chat-card');
    if (!card) return;

    var thread       = document.getElementById('chatThread');
    var msgBody      = document.getElementById('msgBody');
    var sendForm     = document.getElementById('sendForm');
    var sendBtn      = document.getElementById('sendBtn');
    var sendError    = document.getElementById('sendError');
    var recipientId  = document.getElementById('recipientId');
    var chatEmpty    = document.getElementById('chatEmpty');

    var currentUserId   = card.dataset.currentUserId || '';
    var otherUserId     = card.dataset.otherUserId || '';
    var currentDisplay  = card.dataset.currentDisplay || '';
    var currentPhoto    = card.dataset.currentPhoto || '';
    var otherDisplay    = card.dataset.otherDisplay || '';
    var otherPhoto      = card.dataset.otherPhoto || '';
    var currentInitials = card.dataset.currentInitials || '?';
    var otherInitials   = card.dataset.otherInitials || '?';

    function escapeHtml(s) {
        return String(s == null ? '' : s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function formatTime(d) {
        var h = d.getHours(); var m = d.getMinutes();
        var ampm = h >= 12 ? 'pm' : 'am';
        h = h % 12; if (h === 0) h = 12;
        return h + ':' + (m < 10 ? '0' + m : m) + ' ' + ampm;
    }

    function formatDay(d) {
        return d.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });
    }

    function avatarHtml(isMe) {
        var photo = isMe ? currentPhoto : otherPhoto;
        var initials = isMe ? currentInitials : otherInitials;
        if (photo) {
            return '<img src="' + escapeHtml(photo) + '" class="rounded-circle" style="width:32px;height:32px;object-fit:cover;" alt="" />';
        }
        return '<span class="chat-avatar-fallback">' + escapeHtml(initials) + '</span>';
    }

    // Append a message bubble to the thread, grouping consecutive messages
    // from the same sender and dropping a date divider when the day changes.
    function appendMessage(msg) {
        if (!thread) return;
        if (chatEmpty) { chatEmpty.remove(); chatEmpty = null; }

        // De-dupe — server-pushed messages can arrive at the sender right
        // after we've optimistically appended them locally.
        if (msg.id != null && thread.querySelector('[data-message-id="' + msg.id + '"]')) return;

        var sentAt = msg.sentAt ? new Date(msg.sentAt) : new Date();
        var isMe = msg.senderId === currentUserId;

        // Day divider?
        var lastRow = thread.querySelector('.chat-row:last-of-type');
        var lastDayStr = thread.dataset.lastDay || '';
        var thisDayStr = sentAt.toDateString();
        if (thisDayStr !== lastDayStr) {
            var div = document.createElement('div');
            div.className = 'chat-day-divider';
            div.innerHTML = '<span>' + escapeHtml(formatDay(sentAt)) + '</span>';
            thread.appendChild(div);
            thread.dataset.lastDay = thisDayStr;
        }

        // Continuation = same sender as previous row, same day.
        var isContinuation = false;
        if (lastRow && thisDayStr === lastDayStr) {
            isContinuation = (isMe && lastRow.classList.contains('is-me'))
                || (!isMe && lastRow.classList.contains('is-them'));
        }

        var row = document.createElement('div');
        row.className = 'chat-row ' + (isMe ? 'is-me' : 'is-them') + (isContinuation ? ' is-continuation' : '');
        if (msg.id != null) row.dataset.messageId = msg.id;

        var avatarHtmlStr = '';
        if (!isMe) {
            avatarHtmlStr = '<div class="chat-avatar-slot">'
                + (isContinuation ? '' : avatarHtml(false))
                + '</div>';
        }
        row.innerHTML = avatarHtmlStr
            + '<div class="chat-bubble-group">'
            +   '<div class="chat-bubble">' + escapeHtml(msg.body).replace(/\n/g, '<br />') + '</div>'
            +   '<div class="chat-time">' + formatTime(sentAt) + '</div>'
            + '</div>';
        thread.appendChild(row);
        thread.dataset.lastDay = thisDayStr;
        thread.scrollTop = thread.scrollHeight;
    }

    // Initialise dataset.lastDay from the last existing row so newly-appended
    // messages know whether to insert a divider or not.
    // Server-rendered timestamps are emitted in UTC ISO format
    // (data-utc / data-utc-day attributes); convert each to the
    // browser's local time so the times match what the popup dock
    // shows. Without this, server-side .ToLocalTime() would render
    // in the *server's* timezone (UTC in production), which is wrong
    // for everyone outside that zone.
    if (thread) {
        thread.querySelectorAll('.chat-time[data-utc]').forEach(function (el) {
            var d = new Date(el.dataset.utc);
            if (!isNaN(d)) el.textContent = formatTime(d);
        });
        // De-dupe day dividers when consecutive UTC days collapse into
        // the same local day for the viewer (the server emitted one per
        // UTC day; some of those may now be the same local day).
        var lastLocalDay = null;
        thread.querySelectorAll('.chat-day-divider[data-utc-day]').forEach(function (div) {
            var d = new Date(div.dataset.utcDay);
            if (isNaN(d)) return;
            var localDay = d.toDateString();
            if (localDay === lastLocalDay) {
                div.remove();
            } else {
                var span = div.querySelector('span');
                if (span) span.textContent = formatDay(d);
                lastLocalDay = localDay;
            }
        });
        // Mark the last existing local day so the appendMessage path
        // uses the same key when deciding whether to emit a new divider.
        thread.dataset.lastDay = lastLocalDay || new Date().toDateString();
    }

    if (thread) thread.scrollTop = thread.scrollHeight;

    // ── Composer: auto-grow + Enter-to-send ─────────────────────────────
    if (msgBody) {
        msgBody.addEventListener('input', function () {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 140) + 'px';
        });
        msgBody.addEventListener('keydown', function (e) {
            // Enter sends; Shift+Enter inserts newline. Avoids the "where
            // did my message go?" feel — Ctrl+Enter was an unusual gate.
            if (e.key === 'Enter' && !e.shiftKey && !e.isComposing) {
                e.preventDefault();
                sendForm.requestSubmit();
            }
        });
    }

    // ── AJAX send ───────────────────────────────────────────────────────
    if (sendForm) {
        sendForm.addEventListener('submit', function (e) {
            e.preventDefault();
            if (sendBtn.disabled) return;
            var body = (msgBody.value || '').trim();
            if (!body) return;
            var rid = recipientId.value;
            if (!rid) return;

            sendBtn.disabled = true;
            sendError.classList.add('d-none');
            sendError.textContent = '';

            var token = (sendForm.querySelector('input[name="__RequestVerificationToken"]') || {}).value;
            var fd = new FormData();
            fd.append('recipientId', rid);
            fd.append('body', body);
            if (token) fd.append('__RequestVerificationToken', token);

            fetch('/Inbox/Send', {
                method: 'POST',
                body: fd,
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
            })
            .then(function (r) {
                if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || 'Failed to send.'); });
                return r.json();
            })
            .then(function (saved) {
                // Optimistic: append locally; the hub will also push it to
                // our other tabs (de-duped by message id).
                appendMessage({
                    id: saved.id,
                    body: saved.body,
                    sentAt: saved.sentAt,
                    senderId: saved.senderId,
                    recipientId: saved.recipientId
                });
                msgBody.value = '';
                msgBody.style.height = 'auto';
                msgBody.focus();
            })
            .catch(function (err) {
                sendError.textContent = err.message || 'Could not send. Please try again.';
                sendError.classList.remove('d-none');
            })
            .finally(function () {
                sendBtn.disabled = false;
            });
        });
    }

    // ── SignalR: real-time receive ──────────────────────────────────────
    if (typeof signalR !== 'undefined') {
        try {
            var conn = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/messages')
                .withAutomaticReconnect()
                .build();

            conn.on('messageReceived', function (msg) {
                if (!msg) return;
                // Only append if this message belongs to the open conversation.
                var belongsHere = (msg.senderId === otherUserId && msg.recipientId === currentUserId)
                                 || (msg.senderId === currentUserId && msg.recipientId === otherUserId);
                if (!belongsHere) return;
                appendMessage(msg);
            });

            conn.start().catch(function () { /* hub unavailable — view still works without push */ });
        } catch (e) { /* SignalR not loaded — fall through */ }
    }

    // ── Compose: To: recipient search (only when in compose mode) ──────
    var recipientInput = document.getElementById('recipientInput');
    if (recipientInput) {
        var recipientDropdown = document.getElementById('recipientDropdown');
        var toChip            = document.getElementById('toChip');
        var toChipName        = document.getElementById('toChipName');
        var toSearch          = document.getElementById('toSearch');
        var clearTo           = document.getElementById('clearTo');

        recipientInput.addEventListener('input', function () {
            var q = this.value.trim();
            recipientDropdown.innerHTML = '';
            if (q.length < 2) { recipientDropdown.style.display = 'none'; return; }

            fetch('/Friends/Search?q=' + encodeURIComponent(q))
                .then(function (r) { return r.json(); })
                .then(function (users) {
                    if (!users || !users.length) {
                        recipientDropdown.innerHTML = '<div class="list-group-item small text-muted">No users found.</div>';
                        recipientDropdown.style.display = 'block';
                        return;
                    }
                    recipientDropdown.innerHTML = '';
                    users.forEach(function (u) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action d-flex align-items-center gap-2 py-2';

                        var name  = u.displayName || u.userName || '';
                        var uname = u.userName || '';

                        var av = document.createElement('span');
                        av.style.cssText = 'width:30px;height:30px;border-radius:50%;background:var(--mst-light);color:var(--mst-primary);font-weight:bold;font-size:12px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;';
                        av.textContent = (name.trim()[0] || '?').toUpperCase();
                        btn.appendChild(av);

                        var label = document.createElement('div');
                        label.innerHTML = '<div class="fw-semibold small">' + escapeHtml(name) + '</div>'
                                        + '<div class="text-muted" style="font-size:0.75rem;">@@' + escapeHtml(uname) + '</div>';
                        btn.appendChild(label);

                        btn.addEventListener('mousedown', function (e) {
                            e.preventDefault();
                            selectRecipient(u.userId, name);
                        });
                        recipientDropdown.appendChild(btn);
                    });
                    recipientDropdown.style.display = 'block';
                })
                .catch(function () { recipientDropdown.style.display = 'none'; });
        });

        recipientInput.addEventListener('blur', function () {
            setTimeout(function () { recipientDropdown.style.display = 'none'; }, 200);
        });

        function selectRecipient(id, name) {
            recipientId.value = id;
            toChipName.textContent = name;
            toChip.classList.remove('d-none');
            toChip.classList.add('d-flex');
            toSearch.style.display = 'none';
            recipientDropdown.style.display = 'none';
            msgBody.disabled = false;
            msgBody.placeholder = 'Message ' + name + '…  (Enter to send, Shift+Enter for newline)';
            sendBtn.disabled = false;
            msgBody.focus();
        }

        clearTo.addEventListener('click', function () {
            recipientId.value = '';
            toChip.classList.add('d-none');
            toChip.classList.remove('d-flex');
            toSearch.style.display = '';
            recipientInput.value = '';
            msgBody.disabled = true;
            msgBody.placeholder = 'Select a recipient above first…';
            sendBtn.disabled = true;
            recipientInput.focus();
        });
    }
})();
</script>
}
