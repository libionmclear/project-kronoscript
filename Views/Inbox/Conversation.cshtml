@model MyStoryTold.Models.ViewModels.MessageThreadViewModel
@{
    var isCompose = string.IsNullOrEmpty(Model.OtherUser?.Id);
    var otherName = isCompose ? "" : (Model.OtherUser!.DisplayName ?? Model.OtherUser.UserName ?? "");
    ViewData["Title"] = isCompose ? "New Message" : $"Chat with {otherName}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <div class="col-md-9 col-main">
        @if (TempData["ChatError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show py-2 mb-2">
                @TempData["ChatError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Chat card -->
        <div class="card border-0 shadow-sm d-flex flex-column" style="height:78vh;">

            <!-- ── Header ── -->
            <div class="card-header bg-white border-bottom d-flex align-items-center gap-2 py-2">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Inbox</a>

                @if (!isCompose)
                {
                    @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.OtherUser!, Size = 36 })
                    <div>
                        <div class="fw-semibold lh-1">@otherName</div>
                        <div class="small text-muted">@@@Model.OtherUser!.UserName</div>
                    </div>
                }
                else
                {
                    <!-- To: selector -->
                    <div class="flex-grow-1 d-flex align-items-center gap-2">
                        <span class="fw-semibold text-muted small me-1">To:</span>
                        <div id="toChip" class="d-none align-items-center gap-1">
                            <span class="badge rounded-pill d-flex align-items-center gap-1 px-2 py-1"
                                  style="background:var(--mst-light);color:var(--mst-primary);font-size:0.85rem;">
                                <span id="toChipName"></span>
                                <button type="button" id="clearTo" class="btn-close btn-close-sm ms-1"
                                        style="font-size:0.6rem;" aria-label="Clear"></button>
                            </span>
                        </div>
                        <div id="toSearch" class="position-relative flex-grow-1">
                            <input type="text" id="recipientInput" class="form-control form-control-sm border-0 shadow-none"
                                   placeholder="Search name or username…" autocomplete="off" />
                            <div id="recipientDropdown"
                                 class="list-group position-absolute w-100 shadow"
                                 style="display:none;z-index:1060;max-height:220px;overflow-y:auto;top:100%;left:0;"></div>
                        </div>
                    </div>
                }
            </div>

            <!-- ── Message thread ── -->
            <div class="flex-grow-1 overflow-auto p-3" id="chatThread" style="background:#f8faf9;">
                @if (!isCompose)
                {
                    @if (!Model.Messages.Any())
                    {
                        <div class="text-center text-muted py-5 small">No messages yet — say hello!</div>
                    }
                    @foreach (var msg in Model.Messages)
                    {
                        var isMe = msg.SenderUserId == currentUserId;
                        <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") align-items-end gap-2 mb-3">
                            @if (!isMe)
                            {
                                @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.OtherUser!, Size = 28 })
                            }
                            <div style="max-width:70%;">
                                <div class="px-3 py-2 @(isMe ? "text-white" : "bg-white text-dark border")"
                                     style="border-radius:@(isMe ? "18px 18px 4px 18px" : "18px 18px 18px 4px");
                                            @(isMe ? "background-color:var(--mst-primary);" : "")
                                            box-shadow:0 1px 2px rgba(0,0,0,0.08);">
                                    @msg.Body
                                </div>
                                <div class="small text-muted mt-1 @(isMe ? "text-end" : "")" style="font-size:0.7rem;">
                                    @msg.SentAt.ToLocalTime().ToString("h:mm tt")
                                </div>
                            </div>
                            @if (isMe && Model.CurrentUser != null)
                            {
                                @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.CurrentUser, Size = 28 })
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-5 small">Search for someone above to start a conversation.</div>
                }
            </div>

            <!-- ── Send bar ── -->
            <div class="card-footer bg-white border-top p-2">
                <form asp-action="Send" method="post" id="sendForm" class="d-flex gap-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="recipientId" id="recipientId"
                           value="@(isCompose ? "" : Model.OtherUser?.Id)" />
                    <textarea name="body" id="msgBody" class="form-control" rows="1"
                              placeholder="@(isCompose ? "Select a recipient above first…" : "Type a message…")"
                              @(isCompose ? "disabled" : "") required
                              style="resize:none;border-radius:20px;padding:8px 16px;min-height:40px;max-height:120px;overflow-y:auto;"></textarea>
                    <button type="submit" id="sendBtn" class="btn btn-primary rounded-circle flex-shrink-0"
                            style="width:40px;height:40px;padding:0;" @(isCompose ? "disabled" : "")
                            title="Send">
                        ➤
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Auto-scroll to latest message ──────────────────────────────────
    var thread = document.getElementById('chatThread');
    if (thread) thread.scrollTop = thread.scrollHeight;

    // ── Auto-grow textarea ────────────────────────────────────────────
    var msgBody = document.getElementById('msgBody');
    if (msgBody) {
        msgBody.addEventListener('input', function () {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });
        // Send on Ctrl/Cmd+Enter
        msgBody.addEventListener('keydown', function (e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('sendForm').submit();
            }
        });
    }

    // ── Compose: To: recipient search ────────────────────────────────
    var recipientInput = document.getElementById('recipientInput');
    if (recipientInput) {
        var recipientDropdown = document.getElementById('recipientDropdown');
        var recipientId      = document.getElementById('recipientId');
        var toChip           = document.getElementById('toChip');
        var toChipName       = document.getElementById('toChipName');
        var toSearch         = document.getElementById('toSearch');
        var clearTo          = document.getElementById('clearTo');
        var sendBtn          = document.getElementById('sendBtn');
        var msgBodyEl        = document.getElementById('msgBody');

        recipientInput.addEventListener('input', function () {
            var q = this.value.trim();
            recipientDropdown.innerHTML = '';
            if (q.length < 2) { recipientDropdown.style.display = 'none'; return; }

            fetch('/Friends/Search?q=' + encodeURIComponent(q))
                .then(function (r) { return r.json(); })
                .then(function (users) {
                    if (!users || !users.length) {
                        recipientDropdown.innerHTML = '<div class="list-group-item small text-muted">No users found.</div>';
                        recipientDropdown.style.display = 'block';
                        return;
                    }
                    recipientDropdown.innerHTML = '';
                    users.forEach(function (u) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action d-flex align-items-center gap-2 py-2';

                        var name  = u.displayName || u.userName || '';
                        var uname = u.userName || '';

                        // Initials circle
                        var av = document.createElement('span');
                        av.style.cssText = 'width:30px;height:30px;border-radius:50%;background:var(--mst-light);color:var(--mst-primary);font-weight:bold;font-size:12px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;';
                        av.textContent = name.trim()[0].toUpperCase();
                        btn.appendChild(av);

                        var label = document.createElement('div');
                        label.innerHTML = '<div class="fw-semibold small">' + name + '</div>'
                                        + '<div class="text-muted" style="font-size:0.75rem;">@@' + uname + '</div>';
                        btn.appendChild(label);

                        btn.addEventListener('mousedown', function (e) {
                            e.preventDefault();
                            selectRecipient(u.userId, name);
                        });
                        recipientDropdown.appendChild(btn);
                    });
                    recipientDropdown.style.display = 'block';
                })
                .catch(function () { recipientDropdown.style.display = 'none'; });
        });

        recipientInput.addEventListener('blur', function () {
            setTimeout(function () { recipientDropdown.style.display = 'none'; }, 200);
        });

        function selectRecipient(id, name) {
            recipientId.value = id;
            toChipName.textContent = name;
            toChip.classList.remove('d-none');
            toChip.classList.add('d-flex');
            toSearch.style.display = 'none';
            recipientDropdown.style.display = 'none';
            // Enable the send bar
            msgBodyEl.disabled = false;
            msgBodyEl.placeholder = 'Type a message…';
            sendBtn.disabled = false;
            msgBodyEl.focus();
        }

        clearTo.addEventListener('click', function () {
            recipientId.value = '';
            toChip.classList.add('d-none');
            toChip.classList.remove('d-flex');
            toSearch.style.display = '';
            recipientInput.value = '';
            msgBodyEl.disabled = true;
            msgBodyEl.placeholder = 'Select a recipient above first…';
            sendBtn.disabled = true;
            recipientInput.focus();
        });
    }
</script>
}
