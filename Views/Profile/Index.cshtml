@model MyStoryTold.Models.ApplicationUser
@using MyStoryTold.Helpers
@{
    ViewData["Title"] = (bool)ViewBag.IsOwner ? "My Profile" : $"{Model.DisplayName ?? Model.UserName}'s Profile";

    string? birthDisplay = null;
    // When HideBirthYear is set, show only month/day (e.g. "March 4"). The
    // year is still stored on the user record (drives age-aware features),
    // it just doesn't render publicly.
    if (Model.HideBirthYear && Model.BirthMonth.HasValue && Model.BirthDay.HasValue)
    {
        birthDisplay = $"{new DateTime(2000, Model.BirthMonth.Value, 1).ToString("MMMM")} {Model.BirthDay.Value}";
    }
    else if (Model.HideBirthYear && Model.BirthMonth.HasValue)
    {
        birthDisplay = new DateTime(2000, Model.BirthMonth.Value, 1).ToString("MMMM");
    }
    else if (Model.BirthYear.HasValue)
    {
        var by = Model.BirthYear.Value;
        var absYear = Math.Abs(by);
        var era = by < 0 ? " BC" : "";
        if (Model.BirthMonth.HasValue && Model.BirthDay.HasValue && by > 0)
            birthDisplay = new DateTime(by, Model.BirthMonth.Value, Model.BirthDay.Value).ToString("MMMM d, yyyy");
        else if (Model.BirthMonth.HasValue && Model.BirthDay.HasValue)
            birthDisplay = $"{new DateTime(2000, Model.BirthMonth.Value, 1).ToString("MMMM")} {Model.BirthDay.Value}, {absYear}{era}";
        else if (Model.BirthMonth.HasValue)
            birthDisplay = $"{new DateTime(2000, Model.BirthMonth.Value, 1).ToString("MMMM")} {absYear}{era}";
        else
            birthDisplay = $"{absYear}{era}";
    }

    var natCodes = (Model.Nationalities ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(s => s.Trim().ToLower()).Where(s => s.Length == 2).ToList();
    var bgUrl = Model.ProfileCardBackgroundUrl;
    var isOwner = (bool)ViewBag.IsOwner;

    var postCount = (int)(ViewBag.PostCount ?? 0);
    var oldestYear = ViewBag.OldestEventYear as int?;
    var newestYear = ViewBag.NewestEventYear as int?;
    var connectionsCount = (int)(ViewBag.ConnectionsCount ?? 0);
    var recentStories = ViewBag.RecentStories as List<MyStoryTold.Models.LifeEventPost> ?? new List<MyStoryTold.Models.LifeEventPost>();

    string YearLabel(int y) => y < 0 ? $"{Math.Abs(y)} BC" : y.ToString();
    string YearSpanLabel()
    {
        if (!oldestYear.HasValue) return "—";
        if (oldestYear == newestYear) return YearLabel(oldestYear.Value);
        return $"{YearLabel(oldestYear.Value)} – {YearLabel(newestYear!.Value)}";
    }
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">

        @if (Model.IsBiographical)
        {
            <div class="profile-bio-banner mb-3">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span style="font-size:1.1rem;">📜</span>
                    <strong>Biographical profile</strong>
                    @if (!string.IsNullOrEmpty(Model.BiographicalEra))
                    {
                        <span class="text-muted">· @Model.BiographicalEra</span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.BiographicalSummary))
                {
                    <div class="small text-muted">@Model.BiographicalSummary</div>
                }
                else
                {
                    <div class="small text-muted">A fictional, historical or public-figure profile. Posts here are written by an admin on this profile's behalf.</div>
                }
            </div>
        }

        @Html.AntiForgeryToken()

        <!-- HERO BAND -->
        <div class="profile-hero @(bgUrl != null ? "has-bg" : "no-bg") mb-3">
            <div class="profile-hero-cover" @(bgUrl != null ? $"style=background-image:url('{bgUrl}');" : "")></div>
            <div class="profile-hero-body">
                <div class="profile-hero-avatar">
                    @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model, Size = 120 })
                </div>
                <div class="profile-hero-identity">
                    <h2 class="profile-hero-name mb-0">@(Model.DisplayName ?? Model.UserName)</h2>
                    <div class="profile-hero-handle">@@@Model.UserName</div>
                    <div class="profile-hero-meta">
                        @if (!string.IsNullOrEmpty(Model.CurrentLocation) && (bool)ViewBag.ShowCurrentLocation)
                        {
                            <span class="profile-hero-meta-item">📍 @Model.CurrentLocation</span>
                        }
                        @if (natCodes.Any() && (bool)ViewBag.ShowNationalities)
                        {
                            <span class="profile-hero-meta-flags">
                                @foreach (var c in natCodes)
                                {
                                    <img src="https://flagcdn.com/24x18/@(c).png"
                                         srcset="https://flagcdn.com/48x36/@(c).png 2x"
                                         width="24" height="18" alt="@c.ToUpper()" title="@c.ToUpper()" />
                                }
                            </span>
                        }
                    </div>
                </div>
                <div class="profile-hero-actions">
                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Id"
                       class="profile-hero-btn" data-bs-toggle="tooltip" data-bs-title="Timeline" aria-label="Timeline">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>
                        </svg>
                    </a>
                    @if (isOwner)
                    {
                        <a asp-action="Edit" class="profile-hero-btn" data-bs-toggle="tooltip" data-bs-title="Settings" aria-label="Settings">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="3"/>
                                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                            </svg>
                        </a>
                        <a asp-action="ChangePassword" class="profile-hero-btn" data-bs-toggle="tooltip" data-bs-title="Change password" aria-label="Change password">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Inbox" asp-action="Conversation" asp-route-id="@Model.Id"
                           class="profile-hero-btn" data-bs-toggle="tooltip" data-bs-title="Send message" aria-label="Send message">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 3 Q23 9 17 15 L9 20"/><path d="M19 3 Q13 5 9 12 L9 20"/>
                                <line x1="18.5" y1="3.5" x2="9" y2="20"/>
                                <path d="M9 20 L6 23"/><path d="M4 22 L8 21"/>
                            </svg>
                        </a>
                        <!-- Block / Report tucked into a quiet overflow menu so visitors aren't
                             primed to take destructive action on a stranger's profile. -->
                        <div class="dropdown">
                            <button type="button" class="profile-hero-btn"
                                    data-bs-toggle="dropdown" data-bs-strategy="fixed" aria-expanded="false"
                                    aria-label="More">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/>
                                </svg>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end profile-hero-more-menu">
                                <li>
                                    <form asp-action="Block" method="post" class="m-0"
                                          onsubmit="return confirm('Block @(Model.DisplayName ?? Model.UserName)? They will be hidden from your search and feed, and they won''t be able to message or comment on your posts.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="dropdown-item text-muted">Block this user</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Reports" asp-action="Create" method="post" class="m-0"
                                          onsubmit="var r = prompt('Why are you reporting this user? (Optional context for the admins.)'); if (r === null) return false; this.elements.reason.value = r || ''; return confirm('Send this report to the admins?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="targetType" value="User" />
                                        <input type="hidden" name="targetId" value="@Model.Id" />
                                        <input type="hidden" name="reason" value="" />
                                        <button type="submit" class="dropdown-item text-muted">Report to admins</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- STATS STRIP -->
        <div class="profile-stats mb-3">
            <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Id" class="profile-stat">
                <div class="profile-stat-num">@postCount</div>
                <div class="profile-stat-label">@(postCount == 1 ? "Story" : "Stories")</div>
            </a>
            <div class="profile-stat">
                <div class="profile-stat-num">@YearSpanLabel()</div>
                <div class="profile-stat-label">@(oldestYear.HasValue && oldestYear == newestYear ? "Memory year" : "Memories span")</div>
            </div>
            <a asp-controller="Friends" asp-action="Index" class="profile-stat">
                <div class="profile-stat-num">@connectionsCount</div>
                <div class="profile-stat-label">@(connectionsCount == 1 ? "Connection" : "Connections")</div>
            </a>
            <div class="profile-stat">
                <div class="profile-stat-num">@Model.CreatedAt.ToString("MMM yyyy")</div>
                <div class="profile-stat-label">Member since</div>
            </div>
        </div>

        @{
            // Visitor lands with Stories pre-opened so they see Marco's story
            // immediately, without clicking. Owner sees everything collapsed
            // and chooses what to expand.
            var aboutOpen = false;
            var storiesOpen = !isOwner;
        }

        <div class="profile-sections">

            <!-- About -->
            <section class="profile-section">
                <button class="profile-section-toggle @(aboutOpen ? "" : "collapsed")"
                        type="button"
                        data-bs-toggle="collapse" data-bs-target="#profileSecAbout"
                        aria-expanded="@(aboutOpen ? "true" : "false")" aria-controls="profileSecAbout">
                    <span class="profile-section-title">About</span>
                    <span class="profile-section-chevron" aria-hidden="true">▾</span>
                </button>
                <div class="collapse @(aboutOpen ? "show" : "")" id="profileSecAbout">
                    <div class="profile-section-body">
                <dl class="profile-about-list">
                    @if (birthDisplay != null && (bool)ViewBag.ShowBirthDate)
                    {
                        <div class="profile-about-row">
                            <dt>Birthday</dt>
                            <dd>@birthDisplay</dd>
                            @if (isOwner)
                            {
                                <div class="profile-about-vis">@await Html.PartialAsync("_FieldVisibility", ("BirthDate", Model.BirthDateVisibility))</div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Gender) && (bool)ViewBag.ShowGender)
                    {
                        <div class="profile-about-row">
                            <dt>Gender</dt>
                            <dd>@Model.Gender</dd>
                            @if (isOwner)
                            {
                                <div class="profile-about-vis">@await Html.PartialAsync("_FieldVisibility", ("Gender", Model.GenderVisibility))</div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.BirthPlace) && (bool)ViewBag.ShowBirthPlace)
                    {
                        <div class="profile-about-row">
                            <dt>Born in</dt>
                            <dd>@Model.BirthPlace</dd>
                            @if (isOwner)
                            {
                                <div class="profile-about-vis">@await Html.PartialAsync("_FieldVisibility", ("BirthPlace", Model.BirthPlaceVisibility))</div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.CurrentLocation) && (bool)ViewBag.ShowCurrentLocation)
                    {
                        <div class="profile-about-row">
                            <dt>Currently living</dt>
                            <dd>@Model.CurrentLocation</dd>
                            @if (isOwner)
                            {
                                <div class="profile-about-vis">@await Html.PartialAsync("_FieldVisibility", ("CurrentLocation", Model.CurrentLocationVisibility))</div>
                            }
                        </div>
                    }
                    @if (natCodes.Any() && (bool)ViewBag.ShowNationalities)
                    {
                        <div class="profile-about-row">
                            <dt>Nationalities</dt>
                            <dd>
                                <span class="d-inline-flex gap-1 align-items-center">
                                    @foreach (var c in natCodes)
                                    {
                                        <img src="https://flagcdn.com/24x18/@(c).png"
                                             srcset="https://flagcdn.com/48x36/@(c).png 2x"
                                             width="24" height="18" alt="@c.ToUpper()" title="@c.ToUpper()"
                                             style="border-radius:2px;box-shadow:0 0 0 1px rgba(0,0,0,0.1);" />
                                    }
                                </span>
                            </dd>
                            @if (isOwner)
                            {
                                <div class="profile-about-vis">@await Html.PartialAsync("_FieldVisibility", ("Nationalities", Model.NationalitiesVisibility))</div>
                            }
                        </div>
                    }
                    <div class="profile-about-row">
                        <dt>Member since</dt>
                        <dd>@Model.CreatedAt.ToString("MMMM yyyy")</dd>
                    </div>
                </dl>
                    </div>
                </div>
            </section>

            <!-- Stories -->
            <section class="profile-section">
                <button class="profile-section-toggle @(storiesOpen ? "" : "collapsed")"
                        type="button"
                        data-bs-toggle="collapse" data-bs-target="#profileSecStories"
                        aria-expanded="@(storiesOpen ? "true" : "false")" aria-controls="profileSecStories">
                    <span class="profile-section-title">Stories <span class="profile-section-count">@postCount</span></span>
                    <span class="profile-section-chevron" aria-hidden="true">▾</span>
                </button>
                <div class="collapse @(storiesOpen ? "show" : "")" id="profileSecStories">
                    <div class="profile-section-body">
                @if (recentStories.Any())
                {
                    <div class="profile-stories-grid">
                        @foreach (var p in recentStories)
                        {
                            var thumb = p.Media?.FirstOrDefault(m => m.MediaType == MyStoryTold.Models.MediaType.Image)?.Url;
                            var preview = BodyRenderer.TextPreview(p.Body, 90);
                            <a asp-controller="Posts" asp-action="Detail" asp-route-id="@p.Id" class="profile-story-card">
                                <div class="profile-story-thumb @(thumb == null ? "no-thumb" : "")"
                                     @(thumb != null ? $"style=background-image:url('{thumb}');" : "")>
                                    @if (thumb == null)
                                    {
                                        <span class="profile-story-thumb-year">@YearLabel(p.EventYear)</span>
                                    }
                                </div>
                                <div class="profile-story-meta">
                                    <div class="profile-story-year-line">
                                        <span class="profile-story-year">@p.EventDateDisplay</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(p.Title))
                                    {
                                        <div class="profile-story-title">@p.Title</div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(preview))
                                    {
                                        <div class="profile-story-preview">@preview</div>
                                    }
                                </div>
                            </a>
                        }
                    </div>
                    @if (postCount > recentStories.Count)
                    {
                        <div class="text-center mt-3">
                            <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                                View full timeline (@postCount stories) →
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mt-3">
                            <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                                Open full timeline →
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted text-center py-4">
                        @(isOwner ? "You haven't published any stories yet." : "No stories visible to you yet.")
                    </div>
                }
                    </div>
                </div>
            </section>

            @if (isOwner)
            {
                <!-- Badges -->
                <section class="profile-section">
                    <button class="profile-section-toggle collapsed"
                            type="button"
                            data-bs-toggle="collapse" data-bs-target="#profileSecBadges"
                            aria-expanded="false" aria-controls="profileSecBadges">
                        <span class="profile-section-title">Badges</span>
                        <span class="profile-section-chevron" aria-hidden="true">▾</span>
                    </button>
                    <div class="collapse" id="profileSecBadges">
                        <div class="profile-section-body">
                            @await Component.InvokeAsync("UserBadges")
                        </div>
                    </div>
                </section>

                <!-- Dashboard -->
                <section class="profile-section">
                    <button class="profile-section-toggle collapsed"
                            type="button"
                            data-bs-toggle="collapse" data-bs-target="#profileSecDashboard"
                            aria-expanded="false" aria-controls="profileSecDashboard">
                        <span class="profile-section-title">Dashboard</span>
                        <span class="profile-section-chevron" aria-hidden="true">▾</span>
                    </button>
                    <div class="collapse" id="profileSecDashboard">
                        <div class="profile-section-body">
                            @await Component.InvokeAsync("UserDashboard")
                        </div>
                    </div>
                </section>
            }

        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        new bootstrap.Tooltip(el);
    });

    // Per-field visibility AJAX
    (function () {
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        var LABELS = { 0: 'Public', 1: 'Friends', 2: 'Family', 3: 'Only me' };
        document.querySelectorAll('.field-vis-dropdown').forEach(function (wrap) {
            var btn = wrap.querySelector('.field-vis-btn');
            var label = wrap.querySelector('.field-vis-label');
            wrap.querySelectorAll('.field-vis-opt').forEach(function (opt) {
                opt.addEventListener('click', function (e) {
                    e.preventDefault();
                    var v = parseInt(opt.dataset.v, 10);
                    var fd = new FormData();
                    fd.append('field', wrap.dataset.field);
                    fd.append('visibility', String(v));
                    fetch('/Profile/SetFieldVisibility', {
                        method: 'POST',
                        headers: { 'X-CSRF-TOKEN': token },
                        body: fd
                    }).then(function (r) { return r.ok ? r.json() : null; })
                      .then(function (data) {
                          if (!data) return;
                          if (label) label.textContent = LABELS[v];
                          if (btn) btn.dataset.current = String(v);
                      });
                });
            });
        });
    })();

    // Remember which sections were open across navigations within the session
    // so refreshing or coming back from an edit doesn't collapse everything.
    (function () {
        var KEY = 'kron-profile-sections';
        var saved = (sessionStorage.getItem(KEY) || '').split(',').filter(Boolean);
        if (saved.length && window.bootstrap) {
            saved.forEach(function (id) {
                var el = document.getElementById(id);
                if (el) try { bootstrap.Collapse.getOrCreateInstance(el, { toggle: false }).show(); } catch (e) {}
            });
        }
        function persist() {
            var open = Array.from(document.querySelectorAll('.profile-section .collapse.show')).map(function (e) { return e.id; });
            sessionStorage.setItem(KEY, open.join(','));
        }
        document.querySelectorAll('.profile-section .collapse').forEach(function (c) {
            c.addEventListener('shown.bs.collapse', persist);
            c.addEventListener('hidden.bs.collapse', persist);
        });
    })();
</script>
}
