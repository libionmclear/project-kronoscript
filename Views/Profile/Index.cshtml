@model MyStoryTold.Models.ApplicationUser
@{
    ViewData["Title"] = (bool)ViewBag.IsOwner ? "My Profile" : $"{Model.DisplayName ?? Model.UserName}'s Profile";

    // Build birth date display with BC support
    string? birthDisplay = null;
    if (Model.BirthYear.HasValue)
    {
        var by = Model.BirthYear.Value;
        var absYear = Math.Abs(by);
        var era = by < 0 ? " BC" : "";
        if (Model.BirthMonth.HasValue && Model.BirthDay.HasValue && by > 0)
            birthDisplay = new DateTime(by, Model.BirthMonth.Value, Model.BirthDay.Value).ToString("MMMM d, yyyy");
        else if (Model.BirthMonth.HasValue && Model.BirthDay.HasValue)
            birthDisplay = $"{new DateTime(2000, Model.BirthMonth.Value, 1).ToString("MMMM")} {Model.BirthDay.Value}, {absYear}{era}";
        else if (Model.BirthMonth.HasValue)
            birthDisplay = $"{new DateTime(2000, Model.BirthMonth.Value, 1).ToString("MMMM")} {absYear}{era}";
        else
            birthDisplay = $"{absYear}{era}";
    }
}

@{
    var natCodes = (Model.Nationalities ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(s => s.Trim().ToLower()).Where(s => s.Length == 2).ToList();
    var bgUrl = Model.ProfileCardBackgroundUrl;
}
<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <div class="profile-card-shell mb-3 @(bgUrl != null ? "has-bg" : "")"
             @(bgUrl != null ? $"style=background-image:url('{bgUrl}');" : "")>
            <div class="profile-card-overlay">

                <!-- Profile Header -->
                <div class="d-flex align-items-center gap-4 mb-4">
                    @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model, Size = 96 })
                    <div>
                        <h3 class="mb-0">@(Model.DisplayName ?? Model.UserName)</h3>
                        <div class="text-muted small">@@@Model.UserName</div>
                        @if (!string.IsNullOrEmpty(Model.CurrentLocation))
                        {
                            <div class="small mt-1">📍 @Model.CurrentLocation</div>
                        }
                        @if (natCodes.Any())
                        {
                            <div class="mt-2 d-flex gap-1 align-items-center">
                                @foreach (var c in natCodes)
                                {
                                    <img src="https://flagcdn.com/24x18/@(c).png"
                                         srcset="https://flagcdn.com/48x36/@(c).png 2x, https://flagcdn.com/72x54/@(c).png 3x"
                                         width="24" height="18"
                                         alt="@c.ToUpper()" title="@c.ToUpper()"
                                         style="border-radius:2px;box-shadow:0 0 0 1px rgba(0,0,0,0.1);" />
                                }
                            </div>
                        }
                    </div>
                    <div class="ms-auto d-flex gap-3 align-items-center">
                        <!-- Timeline -->
                        <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Id"
                           class="d-flex flex-column align-items-center text-decoration-none profile-action-link"
                           style="color:var(--mst-primary);" data-bs-toggle="tooltip" data-bs-title="Timeline">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>
                            </svg>
                            <span class="nav-icon-label mt-1">Timeline</span>
                        </a>
                        @if ((bool)ViewBag.IsOwner)
                        {
                            <!-- Edit Profile -->
                            <a asp-action="Edit"
                               class="d-flex flex-column align-items-center text-decoration-none"
                               style="color:var(--mst-primary);" data-bs-toggle="tooltip" data-bs-title="Edit Profile">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                                <span class="nav-icon-label mt-1">Edit</span>
                            </a>
                            <!-- Change Password -->
                            <a asp-action="ChangePassword"
                               class="d-flex flex-column align-items-center text-decoration-none"
                               style="color:var(--mst-primary);" data-bs-toggle="tooltip" data-bs-title="Change Password">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                                <span class="nav-icon-label mt-1">Password</span>
                            </a>
                        }
                        @if (!(bool)ViewBag.IsOwner)
                        {
                            <!-- Message -->
                            <a asp-controller="Inbox" asp-action="Conversation" asp-route-id="@Model.Id"
                               class="d-flex flex-column align-items-center text-decoration-none"
                               style="color:var(--mst-primary);" data-bs-toggle="tooltip" data-bs-title="Send Message">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 3 Q23 9 17 15 L9 20"/>
                                    <path d="M19 3 Q13 5 9 12 L9 20"/>
                                    <line x1="18.5" y1="3.5" x2="9" y2="20"/>
                                    <path d="M9 20 L6 23"/><path d="M4 22 L8 21"/>
                                </svg>
                                <span class="nav-icon-label mt-1">Message</span>
                            </a>
                        }
                    </div>
                </div>

                @{
                    var isOwner = (bool)ViewBag.IsOwner;
                }
                @Html.AntiForgeryToken()

                <!-- Profile Details — 3-column grid -->
                <div class="row g-3 profile-fields">

                    @if (birthDisplay != null && (bool)ViewBag.ShowBirthDate)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card bg-light border-0 p-3 h-100 profile-field">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <small class="text-muted fw-semibold">Birthday</small>
                                    @if (isOwner)
                                    {
                                        @await Html.PartialAsync("_FieldVisibility", ("BirthDate", Model.BirthDateVisibility))
                                    }
                                </div>
                                <div class="mt-1">@birthDisplay</div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Gender) && (bool)ViewBag.ShowGender)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card bg-light border-0 p-3 h-100 profile-field">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <small class="text-muted fw-semibold">Gender</small>
                                    @if (isOwner)
                                    {
                                        @await Html.PartialAsync("_FieldVisibility", ("Gender", Model.GenderVisibility))
                                    }
                                </div>
                                <div class="mt-1">@Model.Gender</div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.BirthPlace) && (bool)ViewBag.ShowBirthPlace)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card bg-light border-0 p-3 h-100 profile-field">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <small class="text-muted fw-semibold">Born in</small>
                                    @if (isOwner)
                                    {
                                        @await Html.PartialAsync("_FieldVisibility", ("BirthPlace", Model.BirthPlaceVisibility))
                                    }
                                </div>
                                <div class="mt-1">@Model.BirthPlace</div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.CurrentLocation) && (bool)ViewBag.ShowCurrentLocation)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card bg-light border-0 p-3 h-100 profile-field">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <small class="text-muted fw-semibold">Currently living</small>
                                    @if (isOwner)
                                    {
                                        @await Html.PartialAsync("_FieldVisibility", ("CurrentLocation", Model.CurrentLocationVisibility))
                                    }
                                </div>
                                <div class="mt-1">@Model.CurrentLocation</div>
                            </div>
                        </div>
                    }

                    @if (natCodes.Any() && (bool)ViewBag.ShowNationalities)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card bg-light border-0 p-3 h-100 profile-field">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <small class="text-muted fw-semibold">Nationalities</small>
                                    @if (isOwner)
                                    {
                                        @await Html.PartialAsync("_FieldVisibility", ("Nationalities", Model.NationalitiesVisibility))
                                    }
                                </div>
                                <div class="mt-1 d-flex gap-1 flex-wrap">
                                    @foreach (var c in natCodes)
                                    {
                                        <img src="https://flagcdn.com/24x18/@(c).png"
                                             srcset="https://flagcdn.com/48x36/@(c).png 2x"
                                             width="24" height="18"
                                             alt="@c.ToUpper()" title="@c.ToUpper()"
                                             style="border-radius:2px;box-shadow:0 0 0 1px rgba(0,0,0,0.1);" />
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="col-md-4 col-sm-6">
                        <div class="card bg-light border-0 p-3 h-100">
                            <small class="text-muted fw-semibold">Member since</small>
                            <div class="mt-1">@Model.CreatedAt.ToString("MMMM yyyy")</div>
                        </div>
                    </div>

                </div>

                @if (!(bool)ViewBag.IsOwner)
                {
                    <div class="text-center mt-4">
                        <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Id"
                           class="btn btn-primary px-4">
                            Look at @(Model.FirstName ?? Model.DisplayName ?? Model.UserName)'s Story
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        new bootstrap.Tooltip(el);
    });

    // Per-field visibility AJAX
    (function () {
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        var LABELS = { 0: 'Public', 1: 'Friends', 2: 'Family', 3: 'Only me' };
        document.querySelectorAll('.field-vis-dropdown').forEach(function (wrap) {
            var btn = wrap.querySelector('.field-vis-btn');
            var label = wrap.querySelector('.field-vis-label');
            wrap.querySelectorAll('.field-vis-opt').forEach(function (opt) {
                opt.addEventListener('click', function (e) {
                    e.preventDefault();
                    var v = parseInt(opt.dataset.v, 10);
                    var fd = new FormData();
                    fd.append('field', wrap.dataset.field);
                    fd.append('visibility', String(v));
                    fetch('/Profile/SetFieldVisibility', {
                        method: 'POST',
                        headers: { 'X-CSRF-TOKEN': token },
                        body: fd
                    }).then(function (r) { return r.ok ? r.json() : null; })
                      .then(function (data) {
                          if (!data) return;
                          if (label) label.textContent = LABELS[v];
                          if (btn) btn.dataset.current = String(v);
                      });
                });
            });
        });
    })();
</script>
}
