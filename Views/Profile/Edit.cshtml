@model MyStoryTold.Models.ViewModels.ProfileEditViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="mb-4" style="color: var(--mst-primary);">Edit Profile</h2>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" placeholder="First name" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" placeholder="Last name" />
                        </div>
                    </div>

                    <!-- Photo -->
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.ExistingPhotoUrl))
                        {
                            <img src="@Model.ExistingPhotoUrl" class="rounded-circle mb-2" style="width:80px;height:80px;object-fit:cover;" />
                        }
                        <label asp-for="ProfilePhoto" class="form-label d-block"></label>
                        <input asp-for="ProfilePhoto" class="form-control" type="file" accept="image/*" />
                    </div>

                    <hr />

                    <!-- Birth Date -->
                    <h5 class="mb-3">Birth Information</h5>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label asp-for="BirthYear" class="form-label"></label>
                            <input asp-for="BirthYear" class="form-control" type="number" max="2100" placeholder="e.g. -44 BC" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BirthMonth" class="form-label"></label>
                            <select asp-for="BirthMonth" class="form-select">
                                <option value="">-- --</option>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BirthDay" class="form-label"></label>
                            <input asp-for="BirthDay" class="form-control" type="number" min="1" max="31" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Gender" class="form-label">Gender <small class="text-muted">(optional)</small></label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BirthPlace" class="form-label"></label>
                        <input asp-for="BirthPlace" class="form-control" placeholder="City, Country" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="CurrentLocation" class="form-label"></label>
                        <input asp-for="CurrentLocation" class="form-control" placeholder="City, State/Country" />
                    </div>

                    <hr />

                    <!-- Nationalities (multi-select with flags) -->
                    <div class="mb-3">
                        <label class="form-label">Nationalities <small class="text-muted">(pick one or more)</small></label>
                        <div class="nationality-picker" data-target="#nationalitiesField">
                            <input type="text" class="form-control form-control-sm nat-search" placeholder="Search countries…" autocomplete="off" />
                            <div class="nat-results list-group mt-1" style="max-height:220px;overflow-y:auto;display:none;"></div>
                            <div class="nat-bubbles d-flex flex-wrap gap-2 mt-2"></div>
                        </div>
                        <input asp-for="Nationalities" type="hidden" id="nationalitiesField" />
                    </div>

                    <hr />

                    <!-- Card Background -->
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.ExistingCardBackgroundUrl))
                        {
                            <img src="@Model.ExistingCardBackgroundUrl" class="rounded mb-2" style="width:100%;max-height:120px;object-fit:cover;" />
                        }
                        <label asp-for="ProfileCardBackground" class="form-label d-block">Profile card background image</label>
                        <input asp-for="ProfileCardBackground" class="form-control" type="file" accept="image/*" />
                        <small class="text-muted">Sits behind your profile header. Other profile boxes overlay on top.</small>
                    </div>

                    <!-- Privacy / Presence -->
                    <div class="form-check mb-3">
                        <input asp-for="ShowOnlineStatus" class="form-check-input" />
                        <label asp-for="ShowOnlineStatus" class="form-check-label">
                            Show my online status to others
                        </label>
                        <small class="text-muted d-block">If off, others will always see you as offline (grey dot).</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/nationalities.js" asp-append-version="true"></script>
}
