@model MyStoryTold.Models.PersonProfile
@{
    ViewData["Title"] = Model.DisplayName;
    var isOwner = (bool)(ViewBag.IsOwner ?? false);
    string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0][..1].ToUpper();
    }
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <a asp-action="Index" class="text-decoration-none mb-3 d-block">← People profiles</a>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show py-2">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="person-detail-head">
                    <div class="person-detail-avatar">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="" />
                        }
                        else
                        {
                            <span class="person-detail-initials">@Initials(Model.DisplayName)</span>
                        }
                    </div>
                    <div class="person-detail-meta">
                        <h2 class="person-detail-name">@Model.DisplayName</h2>
                        @if (!string.IsNullOrEmpty(Model.Relation))
                        {
                            <div class="person-detail-relation">@Model.Relation</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.LifeRange))
                        {
                            <div class="person-detail-range">@Model.LifeRange</div>
                        }
                        <div class="person-detail-places small text-muted">
                            @if (!string.IsNullOrEmpty(Model.BirthPlace))
                            {
                                <div>🏠 born @Model.BirthPlace</div>
                            }
                            @if (!string.IsNullOrEmpty(Model.DeathPlace))
                            {
                                <div>🕊 died @Model.DeathPlace</div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.LinkedUserId) && Model.LinkedUser != null)
                        {
                            var viewerUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                            var canUnlink = isOwner
                                            || Model.LinkedUserId == viewerUserId
                                            || User.IsInRole("Admin");
                            <div class="person-detail-linked mt-2 d-flex align-items-center gap-2 flex-wrap">
                                <span>✓ Claimed by
                                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@Model.LinkedUser.Id" class="fw-semibold">
                                        @(Model.LinkedUser.DisplayName ?? Model.LinkedUser.UserName)
                                    </a>
                                </span>
                                @if (canUnlink)
                                {
                                    <form asp-action="Unlink" asp-route-id="@Model.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove this link? Story tags will revert to pointing at this standalone profile page. You can re-link later by repeating the claim flow.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0">unlink</button>
                                    </form>
                                }
                            </div>
                        }
                        else if (isOwner && !string.IsNullOrEmpty(Model.ContactEmail))
                        {
                            <div class="person-detail-claim-pending mt-2 small text-muted">
                                <span style="opacity:.7;">⧗</span> A claim is pending — when a member registers with <span class="text-monospace">@Model.ContactEmail</span>, they'll see a banner offering to claim this profile.
                                @if (Model.ClaimDeclinedAt.HasValue)
                                {
                                    <span class="badge bg-light text-muted ms-1">declined</span>
                                }
                            </div>
                        }
                        @* Joiner-initiated claim — Tier 2/3 of the claim
                           authority hierarchy. Eligible visitors see a
                           "This is me" button and file a Pending claim;
                           the creator approves or denies. *@
                        @{
                            var canFileClaim = (bool)(ViewBag.CanFileClaim ?? false);
                            var myPendingClaim = ViewBag.MyPendingClaim as MyStoryTold.Models.ProfileClaim;
                            var pendingClaims = ViewBag.PendingClaims as List<MyStoryTold.Models.ProfileClaim>
                                ?? new List<MyStoryTold.Models.ProfileClaim>();
                        }
                        @if (canFileClaim)
                        {
                            <details class="person-detail-claim-self mt-2 small">
                                <summary class="text-muted" style="cursor:pointer;">
                                    Is this you? You can file a claim — the creator will review and approve.
                                </summary>
                                <form asp-action="RequestClaim" asp-route-id="@Model.Id" method="post"
                                      class="mt-2 d-flex gap-2 align-items-start flex-wrap">
                                    @Html.AntiForgeryToken()
                                    <input type="text" name="note" class="form-control form-control-sm"
                                           placeholder="Optional note (e.g. why you're sure this is you)"
                                           maxlength="500" style="min-width:280px;flex:1;" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">This is me</button>
                                </form>
                            </details>
                        }
                        @if (myPendingClaim != null)
                        {
                            <div class="person-detail-claim-mine mt-2 small text-muted">
                                <span style="opacity:.7;">⧗</span> Your claim is pending the creator's review.
                                <form asp-action="WithdrawClaim" asp-route-claimId="@myPendingClaim.Id" method="post" class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link btn-sm text-muted p-0">withdraw</button>
                                </form>
                            </div>
                        }
                        @if (isOwner && pendingClaims.Count > 0)
                        {
                            <div class="person-detail-claim-queue mt-2 small">
                                <div class="text-muted mb-1">
                                    <strong>@pendingClaims.Count</strong> pending claim@(pendingClaims.Count == 1 ? "" : "s"):
                                </div>
                                <ul class="list-unstyled mb-0">
                                    @foreach (var claim in pendingClaims)
                                    {
                                        var name = claim.Claimant?.DisplayName ?? claim.Claimant?.UserName ?? "someone";
                                        <li class="d-flex align-items-start gap-2 flex-wrap mb-1">
                                            <span class="fw-semibold">@name</span>
                                            @if (!string.IsNullOrWhiteSpace(claim.Note))
                                            {
                                                <span class="text-muted">— "@claim.Note"</span>
                                            }
                                            <form asp-action="ApproveClaim" asp-route-claimId="@claim.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-success py-0 px-2">Approve</button>
                                            </form>
                                            <form asp-action="DenyClaim" asp-route-claimId="@claim.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-secondary py-0 px-2">Deny</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }

                        @* Creator-initiated link — Tier 1 of the claim
                           authority hierarchy. The creator picks an
                           existing connection and directly marks the
                           profile as them, no joiner confirmation needed. *@
                        @if (isOwner && string.IsNullOrEmpty(Model.LinkedUserId))
                        {
                            var linkable = ViewBag.LinkableMembers as List<MyStoryTold.Models.ApplicationUser>
                                ?? new List<MyStoryTold.Models.ApplicationUser>();
                            var isClaimable = Model.BirthYear.HasValue
                                            && !string.IsNullOrWhiteSpace(Model.BirthPlace);
                            <div class="person-detail-creator-link mt-2 small">
                                @if (!isClaimable)
                                {
                                    <span class="text-muted">
                                        <span style="opacity:.7;">ⓘ</span>
                                        Add a birth year and birthplace to enable joiner claim requests.
                                        Creator links below still work without them.
                                    </span>
                                    <br />
                                }
                                @if (linkable.Count > 0)
                                {
                                    <form asp-action="CreatorLink" asp-route-id="@Model.Id" method="post"
                                          class="d-inline-flex align-items-center gap-2 mt-1 flex-wrap"
                                          onsubmit="return confirm('Link this profile to the selected member? Tags will start routing to their timeline. You can unlink later.');">
                                        @Html.AntiForgeryToken()
                                        <label class="form-label mb-0">Link to member:</label>
                                        <select name="targetUserId" class="form-select form-select-sm" style="width:auto;min-width:180px;" required>
                                            <option value="">— pick from your network —</option>
                                            @foreach (var u in linkable)
                                            {
                                                <option value="@u.Id">@(u.DisplayName ?? u.UserName)</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Link</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        No network connections yet — once a friend or family member is
                                        on your network you can directly link this profile to them.
                                    </span>
                                }
                            </div>
                        }
                    </div>
                    @if (isOwner)
                    {
                        <div class="person-detail-actions">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline ms-1"
                                  onsubmit="return confirm('Delete this profile? Any stories tagging them will lose the tag. This can't be undone.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    }
                </div>

                @* Family-tree wiring: a quick way to see this NPC on
                   the canvas if they're already placed, or to drop them
                   onto the tree right here with an anchor + relationship
                   instead of bouncing to the family-tree page first. *@
                @if (isOwner)
                {
                    var onTree = (bool)(ViewBag.OnFamilyTree ?? false);
                    <div class="person-detail-family-tree mt-3">
                        @if (onTree)
                        {
                            <a asp-controller="FamilyTree" asp-action="Index" class="btn btn-sm btn-outline-primary">
                                🌳 View on family tree
                            </a>
                        }
                        else
                        {
                            var anchors = ViewBag.TreeAnchors as System.Collections.IEnumerable;
                            <form asp-controller="FamilyTree" asp-action="AddProfile" method="post"
                                  class="d-flex align-items-center gap-2 flex-wrap">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="profileId" value="@Model.Id" />
                                <label class="form-label mb-0 fw-semibold">Add to family tree as:</label>
                                <select name="relationKind" class="form-select form-select-sm" style="width:auto;">
                                    <option value="@MyStoryTold.Controllers.FamilyTreeController.AddRelation.Parent">Parent</option>
                                    <option value="@MyStoryTold.Controllers.FamilyTreeController.AddRelation.Child">Child</option>
                                    <option value="@MyStoryTold.Controllers.FamilyTreeController.AddRelation.Spouse">Spouse</option>
                                    <option value="@MyStoryTold.Controllers.FamilyTreeController.AddRelation.Sibling">Sibling</option>
                                </select>
                                <label class="form-label mb-0">of</label>
                                <select name="relationToNodeId" class="form-select form-select-sm" style="width:auto;min-width:160px;" required>
                                    <option value="">— pick a person on the tree —</option>
                                    @if (anchors != null)
                                    {
                                        foreach (dynamic a in anchors)
                                        {
                                            <option value="@a.Id">@a.Label</option>
                                        }
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary">Add</button>
                            </form>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <div class="person-detail-bio mt-3">@Model.Bio</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <details class="mt-3">
                        <summary class="fw-semibold" style="cursor:pointer;">Notes</summary>
                        <div class="mt-2" style="white-space:pre-wrap;">@Model.Notes</div>
                    </details>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Sources))
                {
                    <div class="mt-3 small text-muted">
                        <strong>Sources:</strong> @Model.Sources
                    </div>
                }
            </div>
        </div>

        @{
            var taggedInPosts = (ViewBag.TaggedInPosts as List<MyStoryTold.Models.LifeEventPost>) ?? new();
        }
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body p-4">
                <h5 class="mb-3">Stories that mention @Model.DisplayName
                    <span class="badge bg-light text-muted ms-1">@taggedInPosts.Count</span>
                </h5>
                @if (taggedInPosts.Count == 0)
                {
                    <div class="text-center text-muted py-3">
                        <div style="font-size:1.4rem;opacity:0.5;">📜</div>
                        <div class="mt-2 small">No stories tag this profile yet. Add them from the tag picker when you write or edit a story.</div>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var p in taggedInPosts)
                        {
                            <a asp-controller="Posts" asp-action="Detail" asp-route-id="@p.Id"
                               class="list-group-item list-group-item-action d-flex align-items-start gap-3">
                                <div style="flex:0 0 auto;">
                                    @if (p.Media != null && p.Media.Any(m => m.MediaType == MyStoryTold.Models.MediaType.Image))
                                    {
                                        var thumb = p.Media.First(m => m.MediaType == MyStoryTold.Models.MediaType.Image);
                                        <img src="@thumb.Url" alt="" style="width:56px;height:56px;object-fit:cover;border-radius:6px;object-position:@(thumb.FocusX)% @(thumb.FocusY)%;" />
                                    }
                                    else
                                    {
                                        <div style="width:56px;height:56px;border-radius:6px;background:#f1efe9;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#9b9181;">📖</div>
                                    }
                                </div>
                                <div style="flex:1 1 auto;min-width:0;">
                                    <div class="fw-semibold text-truncate">
                                        @(string.IsNullOrWhiteSpace(p.Title) ? "(untitled)" : p.Title)
                                    </div>
                                    <div class="small text-muted">
                                        @p.EventDateDisplay
                                        @if (!string.IsNullOrEmpty(p.Location))
                                        {
                                            <text> · @p.Location</text>
                                        }
                                        @if (p.Channel != null)
                                        {
                                            <text> · </text><span>📚 @p.Channel.Name</span>
                                        }
                                        else if (p.Owner != null)
                                        {
                                            <text> · </text><span>@(p.Owner.DisplayName ?? p.Owner.UserName)</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        @{
            var photoGroups = ViewBag.PhotoTagPostGroups
                as List<MyStoryTold.Controllers.PersonProfilesController.MediaPersonTagGroup>
                ?? new();
            var totalPhotoTags = photoGroups.Sum(g => g.Tags.Count);
        }
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body p-4">
                <h5 class="mb-3">Photos with @Model.DisplayName
                    <span class="badge bg-light text-muted ms-1">@totalPhotoTags</span>
                </h5>
                @if (photoGroups.Count == 0)
                {
                    <div class="text-center text-muted py-3">
                        <div style="font-size:1.4rem;opacity:0.5;">📷</div>
                        <div class="mt-2 small">No photos tagged with this profile yet. Tag a face in the story Edit page (or in full-picture view on a story).</div>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var grp in photoGroups)
                        {
                            var post = grp.Post;
                            var tags = grp.Tags;
                            <a asp-controller="Posts" asp-action="Detail" asp-route-id="@post.Id"
                               class="text-decoration-none text-body">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="d-flex gap-1 flex-wrap" style="flex:0 0 auto;max-width:180px;">
                                        @foreach (var t in tags.Take(3))
                                        {
                                            if (t.Media == null) { continue; }
                                            <img src="@t.Media.Url" alt=""
                                                 style="width:56px;height:56px;border-radius:6px;object-fit:cover;object-position:@(Math.Clamp(t.X, 0, 100))% @(Math.Clamp(t.Y, 0, 100))%;" />
                                        }
                                        @if (tags.Count > 3)
                                        {
                                            <div style="width:56px;height:56px;border-radius:6px;background:#eee;color:#555;display:flex;align-items:center;justify-content:center;font-size:0.85rem;">+@(tags.Count - 3)</div>
                                        }
                                    </div>
                                    <div style="flex:1 1 auto;min-width:0;">
                                        <div class="fw-semibold text-truncate">
                                            @(string.IsNullOrWhiteSpace(post.Title) ? "(untitled story)" : post.Title)
                                        </div>
                                        <div class="small text-muted">
                                            @post.EventDateDisplay
                                            @if (!string.IsNullOrEmpty(post.Location)) { <text> · @post.Location</text> }
                                            @if (post.Channel != null) { <text> · 📚 @post.Channel.Name</text> }
                                            else if (post.Owner != null) { <text> · @(post.Owner.DisplayName ?? post.Owner.UserName)</text> }
                                        </div>
                                        <div class="small text-muted mt-1">@tags.Count photo@(tags.Count == 1 ? "" : "s") with @Model.DisplayName</div>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
