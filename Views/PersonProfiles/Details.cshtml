@model MyStoryTold.Models.PersonProfile
@{
    ViewData["Title"] = Model.DisplayName;
    var isOwner = (bool)(ViewBag.IsOwner ?? false);
    string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0][..1].ToUpper();
    }
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <a asp-action="Index" class="text-decoration-none mb-3 d-block">← People profiles</a>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show py-2">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="person-detail-head">
                    <div class="person-detail-avatar">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="" />
                        }
                        else
                        {
                            <span class="person-detail-initials">@Initials(Model.DisplayName)</span>
                        }
                    </div>
                    <div class="person-detail-meta">
                        <h2 class="person-detail-name">@Model.DisplayName</h2>
                        @if (!string.IsNullOrEmpty(Model.Relation))
                        {
                            <div class="person-detail-relation">@Model.Relation</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.LifeRange))
                        {
                            <div class="person-detail-range">@Model.LifeRange</div>
                        }
                        <div class="person-detail-places small text-muted">
                            @if (!string.IsNullOrEmpty(Model.BirthPlace))
                            {
                                <div>🏠 born @Model.BirthPlace</div>
                            }
                            @if (!string.IsNullOrEmpty(Model.DeathPlace))
                            {
                                <div>🕊 died @Model.DeathPlace</div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.LinkedUserId) && Model.LinkedUser != null)
                        {
                            var viewerUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                            var canUnlink = isOwner
                                            || Model.LinkedUserId == viewerUserId
                                            || User.IsInRole("Admin");
                            <div class="person-detail-linked mt-2 d-flex align-items-center gap-2 flex-wrap">
                                <span>✓ Claimed by
                                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@Model.LinkedUser.Id" class="fw-semibold">
                                        @(Model.LinkedUser.DisplayName ?? Model.LinkedUser.UserName)
                                    </a>
                                </span>
                                @if (canUnlink)
                                {
                                    <form asp-action="Unlink" asp-route-id="@Model.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove this link? Story tags will revert to pointing at this standalone profile page. You can re-link later by repeating the claim flow.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0">unlink</button>
                                    </form>
                                }
                            </div>
                        }
                        else if (isOwner && !string.IsNullOrEmpty(Model.ContactEmail))
                        {
                            <div class="person-detail-claim-pending mt-2 small text-muted">
                                <span style="opacity:.7;">⧗</span> A claim is pending — when a member registers with <span class="text-monospace">@Model.ContactEmail</span>, they'll see a banner offering to claim this profile.
                                @if (Model.ClaimDeclinedAt.HasValue)
                                {
                                    <span class="badge bg-light text-muted ms-1">declined</span>
                                }
                            </div>
                        }
                    </div>
                    @if (isOwner)
                    {
                        <div class="person-detail-actions">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline ms-1"
                                  onsubmit="return confirm('Delete this profile? Any stories tagging them will lose the tag. This can't be undone.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <div class="person-detail-bio mt-3">@Model.Bio</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <details class="mt-3">
                        <summary class="fw-semibold" style="cursor:pointer;">Notes</summary>
                        <div class="mt-2" style="white-space:pre-wrap;">@Model.Notes</div>
                    </details>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Sources))
                {
                    <div class="mt-3 small text-muted">
                        <strong>Sources:</strong> @Model.Sources
                    </div>
                }
            </div>
        </div>

        @{
            var taggedInPosts = (ViewBag.TaggedInPosts as List<MyStoryTold.Models.LifeEventPost>) ?? new();
        }
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body p-4">
                <h5 class="mb-3">Stories that mention @Model.DisplayName
                    <span class="badge bg-light text-muted ms-1">@taggedInPosts.Count</span>
                </h5>
                @if (taggedInPosts.Count == 0)
                {
                    <div class="text-center text-muted py-3">
                        <div style="font-size:1.4rem;opacity:0.5;">📜</div>
                        <div class="mt-2 small">No stories tag this profile yet. Add them from the tag picker when you write or edit a story.</div>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var p in taggedInPosts)
                        {
                            <a asp-controller="Posts" asp-action="Detail" asp-route-id="@p.Id"
                               class="list-group-item list-group-item-action d-flex align-items-start gap-3">
                                <div style="flex:0 0 auto;">
                                    @if (p.Media != null && p.Media.Any(m => m.MediaType == MyStoryTold.Models.MediaType.Image))
                                    {
                                        var thumb = p.Media.First(m => m.MediaType == MyStoryTold.Models.MediaType.Image);
                                        <img src="@thumb.Url" alt="" style="width:56px;height:56px;object-fit:cover;border-radius:6px;object-position:@(thumb.FocusX)% @(thumb.FocusY)%;" />
                                    }
                                    else
                                    {
                                        <div style="width:56px;height:56px;border-radius:6px;background:#f1efe9;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#9b9181;">📖</div>
                                    }
                                </div>
                                <div style="flex:1 1 auto;min-width:0;">
                                    <div class="fw-semibold text-truncate">
                                        @(string.IsNullOrWhiteSpace(p.Title) ? "(untitled)" : p.Title)
                                    </div>
                                    <div class="small text-muted">
                                        @p.EventDateDisplay
                                        @if (!string.IsNullOrEmpty(p.Location))
                                        {
                                            <text> · @p.Location</text>
                                        }
                                        @if (p.Channel != null)
                                        {
                                            <text> · </text><span>📚 @p.Channel.Name</span>
                                        }
                                        else if (p.Owner != null)
                                        {
                                            <text> · </text><span>@(p.Owner.DisplayName ?? p.Owner.UserName)</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
