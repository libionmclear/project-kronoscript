@model List<MyStoryTold.Models.PersonProfile>
@inject MyStoryTold.Services.IPremiumService _premium
@{
    ViewData["Title"] = "People profiles";
    var canCreate = (bool)(ViewBag.CanCreate ?? false);

    string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0][..1].ToUpper();
    }
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h3 class="mb-1">People profiles
                    <partial name="_PremiumBadge" model="@MyStoryTold.Models.PremiumFeature.PeopleProfiles" />
                </h3>
                <p class="text-muted mb-0" style="font-size:0.92rem;">
                    Profiles for people you write about who aren't on the site — deceased family,
                    distant relatives. Tag them in stories the same way you tag members.
                </p>
            </div>
            @if (canCreate)
            {
                <a asp-action="Create" class="btn btn-primary">+ New profile</a>
            }
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show py-2">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        @if (Model.Any())
        {
            <div class="people-search mb-3">
                <input type="search"
                       id="people-search-input"
                       class="form-control"
                       placeholder="🔍 Search profiles by name or birthplace…"
                       autocomplete="off" />
                <div id="people-search-empty" class="text-muted small mt-2"
                     style="display:none;">No profiles match.</div>
            </div>
        }

        @if (!Model.Any())
        {
            @if (canCreate)
            {
                <div class="empty-state card border-0 shadow-sm text-center p-5">
                    <div class="empty-state-mark">🕊️</div>
                    <h4 class="mt-3 mb-2">No profiles yet</h4>
                    <p class="text-muted mb-3">Start with a parent, grandparent, or anyone else you'd want to tag in your stories.</p>
                    <div><a asp-action="Create" class="btn btn-primary">+ Create your first profile</a></div>
                </div>
            }
            else
            {
                <partial name="_PremiumGate" model="@MyStoryTold.Models.PremiumFeature.PeopleProfiles" />
            }
        }
        else
        {
            @* Two sections: Family on top, everyone else below. Friend /
               Colleague / Acquaintance / Other land in the second block
               because they aren't part of the family tree and tell a
               different story (friendship arc rather than lineage). *@
            var family = Model.Where(p => p.Kind == MyStoryTold.Models.PersonProfileKind.Family).ToList();
            var others = Model.Where(p => p.Kind != MyStoryTold.Models.PersonProfileKind.Family).ToList();

            string CardData(MyStoryTold.Models.PersonProfile p) =>
                ((p.DisplayName ?? "") + " " + (p.Nickname ?? "") + " " + (p.BirthPlace ?? "")).Trim().ToLowerInvariant();

            if (family.Any())
            {
                <section class="people-section">
                    <h5 class="people-section-title">
                        <span class="people-section-dot" data-kind="Family"></span>
                        Family
                        <span class="text-muted small fw-normal">· @family.Count</span>
                    </h5>
                    <div class="people-grid">
                        @foreach (var p in family)
                        {
                            <a asp-action="Details" asp-route-id="@p.Id"
                               class="people-card"
                               data-kind="@p.Kind"
                               data-search-text="@CardData(p)">
                                <div class="people-card-avatar">
                                    @if (!string.IsNullOrEmpty(p.AvatarUrl))
                                    {
                                        <img src="@p.AvatarUrl" alt="" />
                                    }
                                    else
                                    {
                                        <span class="people-card-initials">@Initials(p.DisplayName)</span>
                                    }
                                </div>
                                <div class="people-card-body">
                                    <div class="people-card-name">@p.DisplayName</div>
                                    @if (!string.IsNullOrWhiteSpace(p.Nickname)
                                         && !string.Equals(p.Nickname, p.DisplayName, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <div class="people-card-nickname text-muted small">"@p.Nickname"</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.LifeRange))
                                    {
                                        <div class="people-card-range">@p.LifeRange</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.BirthPlace))
                                    {
                                        <div class="people-card-place text-muted small">🏠 @p.BirthPlace</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.LinkedUserId))
                                    {
                                        <div class="people-card-linked">✓ Linked to member</div>
                                    }
                                </div>
                            </a>
                        }
                    </div>
                </section>
            }

            if (others.Any())
            {
                <section class="people-section">
                    <h5 class="people-section-title mb-0">
                        <span class="people-section-dot" data-kind="Friend"></span>
                        Friends &amp; Colleagues
                        <span class="text-muted small fw-normal">· @others.Count</span>
                    </h5>
                    <div class="people-grid mt-2">
                        @foreach (var p in others)
                        {
                            <a asp-action="Details" asp-route-id="@p.Id"
                               class="people-card"
                               data-kind="@p.Kind"
                               data-search-text="@CardData(p)">
                                <div class="people-card-avatar">
                                    @if (!string.IsNullOrEmpty(p.AvatarUrl))
                                    {
                                        <img src="@p.AvatarUrl" alt="" />
                                    }
                                    else
                                    {
                                        <span class="people-card-initials">@Initials(p.DisplayName)</span>
                                    }
                                </div>
                                <div class="people-card-body">
                                    <div class="people-card-name">@p.DisplayName</div>
                                    <div class="people-card-kind-tag" data-kind="@p.Kind">@p.Kind.ToString()</div>
                                    @if (!string.IsNullOrWhiteSpace(p.Nickname)
                                         && !string.Equals(p.Nickname, p.DisplayName, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <div class="people-card-nickname text-muted small">"@p.Nickname"</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.LifeRange) || p.MetYear.HasValue)
                                    {
                                        <div class="people-card-range">
                                            @if (!string.IsNullOrEmpty(p.LifeRange))
                                            {
                                                @p.LifeRange
                                            }
                                            @if (p.MetYear.HasValue)
                                            {
                                                <span class="people-card-met text-muted small">@(string.IsNullOrEmpty(p.LifeRange) ? "" : " · ")met @p.MetYear</span>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.BirthPlace))
                                    {
                                        <div class="people-card-place text-muted small">🏠 @p.BirthPlace</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.LinkedUserId))
                                    {
                                        <div class="people-card-linked">✓ Linked to member</div>
                                    }
                                </div>
                            </a>
                        }
                    </div>
                </section>
            }
        }
    </div>
</div>

@section Scripts {
<script>
(function () {
    // Client-side filter on the profiles grid. Each card carries a
    // pre-lowercased data-search-text string (name + nickname + birth
    // place). Type → filter; clear → restore.
    var input = document.getElementById('people-search-input');
    var empty = document.getElementById('people-search-empty');
    if (!input) return;
    var cards = Array.prototype.slice.call(document.querySelectorAll('.people-card'));
    function apply() {
        var q = (input.value || '').trim().toLowerCase();
        var anyVisible = false;
        cards.forEach(function (c) {
            var text = c.getAttribute('data-search-text') || '';
            var match = (q === '' || text.indexOf(q) !== -1);
            c.style.display = match ? '' : 'none';
            if (match) anyVisible = true;
        });
        if (empty) empty.style.display = (!anyVisible && q !== '') ? 'block' : 'none';
    }
    input.addEventListener('input', apply);
})();
</script>
}
