@model MyStoryTold.Models.PersonProfile
@{
    var isEdit = Model.Id > 0;
    var action = isEdit ? "Edit" : "Create";
}
<form asp-action="@action" asp-route-id="@(isEdit ? Model.Id.ToString() : null)" method="post" enctype="multipart/form-data" class="card border-0 shadow-sm">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="mb-3">
            <label asp-for="DisplayName" class="form-label fw-semibold">Name</label>
            <input asp-for="DisplayName" class="form-control" placeholder="e.g. Lucia Bellini" autofocus />
            <span asp-validation-for="DisplayName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Nickname" class="form-label fw-semibold">Nickname <span class="text-muted small">(what the family calls them)</span></label>
            <input asp-for="Nickname" class="form-control" placeholder="e.g. Nonna, Zio Bobby, Aunt Lou" maxlength="80" />
            <div class="form-text small">Shown as the main label on the Family Tree bubble. Leave blank to use the full name.</div>
            <span asp-validation-for="Nickname" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Sex <span class="text-danger">*</span></label>
            <div class="d-flex gap-3 flex-wrap">
                <div class="form-check">
                    <input asp-for="Gender" class="form-check-input" type="radio" value="Male" id="genderMale" required />
                    <label class="form-check-label" for="genderMale">Male</label>
                </div>
                <div class="form-check">
                    <input asp-for="Gender" class="form-check-input" type="radio" value="Female" id="genderFemale" required />
                    <label class="form-check-label" for="genderFemale">Female</label>
                </div>
            </div>
            <div class="form-text small">Biological sex — needed so the kinship calculator can pick the right term (Father vs Mother, Niece vs Nephew, etc.). The tree relies on this to place husbands left and wives right inside each couple.</div>
            <span asp-validation-for="Gender" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Relation" class="form-label fw-semibold">Relation to you <span class="text-muted small">(optional)</span></label>
            <input asp-for="Relation" class="form-control" placeholder="e.g. Aunt, Grandfather, Family friend" id="relationInput" />
            <div class="mt-1 d-flex flex-wrap gap-1">
                @foreach (var chip in new[] { "Mother", "Father", "Grandmother", "Grandfather", "Aunt", "Uncle", "Sister", "Brother", "Friend", "Colleague", "Neighbour", "Self" })
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 relation-chip"
                            style="font-size:0.78rem;" data-value="@chip">@chip</button>
                }
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <label asp-for="BirthYear" class="form-label fw-semibold">Birth year</label>
                <input asp-for="BirthYear" type="number" class="form-control" min="1" max="2100" placeholder="e.g. 1932" />
            </div>
            <div class="col-md-9">
                <label asp-for="BirthPlace" class="form-label fw-semibold">Birth place</label>
                <input asp-for="BirthPlace" class="form-control" placeholder="e.g. Florence, Italy" />
            </div>
            <div class="col-md-3">
                <label asp-for="DeathYear" class="form-label fw-semibold">Death year <span class="text-muted small">(if applicable)</span></label>
                <input asp-for="DeathYear" type="number" class="form-control" min="1" max="2100" placeholder="leave blank if living" />
            </div>
            <div class="col-md-9">
                <label asp-for="DeathPlace" class="form-label fw-semibold">Death place</label>
                <input asp-for="DeathPlace" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="MarriageYear" class="form-label fw-semibold">Marriage year <span class="text-muted small">(if applicable)</span></label>
                <input asp-for="MarriageYear" type="number" class="form-control" min="1" max="2100" placeholder="e.g. 1955" />
            </div>
            <div class="col-md-9"></div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="DatesEstimated" class="form-check-input" />
                    <label asp-for="DatesEstimated" class="form-check-label small">
                        Dates are approximate (renders as "ca. 1932")
                    </label>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Bio" class="form-label fw-semibold">Short bio <span class="text-muted small">(500 chars)</span></label>
            <textarea asp-for="Bio" rows="3" class="form-control" maxlength="500"
                      placeholder="A sentence or two — who they were, what they did, what they meant to you."></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label fw-semibold">Notes <span class="text-muted small">(longer)</span></label>
            <textarea asp-for="Notes" rows="4" class="form-control" maxlength="2000"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="Sources" class="form-label fw-semibold">Sources <span class="text-muted small">(optional — where this info comes from)</span></label>
            <input asp-for="Sources" class="form-control" placeholder='e.g. "Grandma told me, 2018" / "Family records"' />
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Avatar</label>
            <div class="d-flex align-items-center gap-3 mb-2">
                <div class="person-avatar-preview" style="width:72px;height:72px;border-radius:50%;border:2px dashed #c8a572;background:#f5ecdb;display:flex;align-items:center;justify-content:center;overflow:hidden;flex:0 0 auto;">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img id="avatarPreviewImg" src="@Model.AvatarUrl" alt="" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <span id="avatarPreviewInitials" style="color:#8a6a32;font-weight:600;font-size:1.4rem;">@(string.IsNullOrWhiteSpace(Model.DisplayName) ? "?" : Model.DisplayName.Trim()[0].ToString().ToUpper())</span>
                    }
                </div>
                <div style="flex:1 1 auto;">
                    <input type="file" name="avatarFile" id="avatarFileInput" accept="image/jpeg,image/png,image/webp,image/gif" class="form-control form-control-sm" />
                    <div class="form-text small">JPG / PNG / WebP / GIF, up to ~10 MB. Square works best.</div>
                </div>
            </div>
            <input asp-for="AvatarUrl" type="hidden" id="avatarUrlField" />

            @{
                var existingPhotos = ViewBag.ExistingPhotos as List<string> ?? new();
            }
            @if (existingPhotos.Count > 0)
            {
                <details class="mt-2">
                    <summary class="small text-muted" style="cursor:pointer;">Or pick from a photo where you've already tagged @(string.IsNullOrEmpty(Model.DisplayName) ? "this person" : Model.DisplayName) (@existingPhotos.Count)</summary>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        @foreach (var url in existingPhotos)
                        {
                            <button type="button" class="avatar-pick-btn"
                                    data-url="@url"
                                    style="width:56px;height:56px;border-radius:50%;border:2px solid transparent;padding:0;overflow:hidden;background:#eee;cursor:pointer;">
                                <img src="@url" alt="" style="width:100%;height:100%;object-fit:cover;" />
                            </button>
                        }
                    </div>
                </details>
            }
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Visibility" class="form-label fw-semibold">Who can see this profile?</label>
                <select asp-for="Visibility" class="form-select">
                    <option value="@MyStoryTold.Models.PostVisibility.Family">Family only (recommended for non-consenting third parties)</option>
                    <option value="@MyStoryTold.Models.PostVisibility.Friends">Friends &amp; Family</option>
                    <option value="@MyStoryTold.Models.PostVisibility.Acquaintances">My whole network</option>
                    <option value="@MyStoryTold.Models.PostVisibility.Public">Public</option>
                    <option value="@MyStoryTold.Models.PostVisibility.Private">Only me</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="ContactEmail" class="form-label fw-semibold">Contact email <span class="text-muted small">(optional)</span></label>
                <input asp-for="ContactEmail" type="email" class="form-control" placeholder="lucia@example.com" />
                <div class="form-text small">
                    If they ever sign up with this email, they'll be offered to claim this profile.
                    We never email this address.
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">@(isEdit ? "Save changes" : "Create profile")</button>
            <a asp-action="@(isEdit ? "Details" : "Index")" asp-route-id="@(isEdit ? Model.Id.ToString() : null)" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
<script>
    // Chip taps populate the relation input.
    document.querySelectorAll('.relation-chip').forEach(function (b) {
        b.addEventListener('click', function () {
            var input = document.getElementById('relationInput');
            if (input) input.value = b.dataset.value;
        });
    });

    // Live preview when the file input changes — show the picked image
    // in the bubble so the user knows the upload registered before submit.
    var fileInput = document.getElementById('avatarFileInput');
    if (fileInput) {
        fileInput.addEventListener('change', function () {
            var f = fileInput.files && fileInput.files[0];
            if (!f) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                renderAvatarPreview(e.target.result);
            };
            reader.readAsDataURL(f);
            // The file input wins over a picked URL — clear the hidden field
            // so the server uses the upload path instead of the URL path.
            var hidden = document.getElementById('avatarUrlField');
            if (hidden) hidden.value = '';
            document.querySelectorAll('.avatar-pick-btn').forEach(function (b) { b.style.borderColor = 'transparent'; });
        });
    }

    // Pick from existing tagged photos: copy URL into the hidden AvatarUrl
    // field and update the preview. Clears any pending file upload.
    document.querySelectorAll('.avatar-pick-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var url = btn.dataset.url;
            var hidden = document.getElementById('avatarUrlField');
            if (hidden) hidden.value = url;
            renderAvatarPreview(url);
            if (fileInput) fileInput.value = '';
            document.querySelectorAll('.avatar-pick-btn').forEach(function (b) { b.style.borderColor = 'transparent'; });
            btn.style.borderColor = '#c8a572';
        });
    });

    function renderAvatarPreview(src) {
        var wrap = document.querySelector('.person-avatar-preview');
        if (!wrap) return;
        wrap.innerHTML = '';
        var img = document.createElement('img');
        img.src = src;
        img.style.width = '100%';
        img.style.height = '100%';
        img.style.objectFit = 'cover';
        wrap.appendChild(img);
    }
</script>
}
