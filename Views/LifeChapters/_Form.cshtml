@model MyStoryTold.Models.LifeChapter
@{
    var isEdit = Model.Id > 0;
    var action = isEdit ? "Edit" : "Create";
    var profileChoices = ((System.Collections.IEnumerable?)ViewBag.ProfileChoices)?.Cast<dynamic>().ToList()
                         ?? new List<dynamic>();
    var existingMemberIds = (Model.Members ?? new()).Select(m => m.PersonProfileId).ToHashSet();
}

<form asp-action="@action" asp-route-id="@(isEdit ? Model.Id.ToString() : null)" method="post"
      class="card border-0 shadow-sm">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold">Chapter name</label>
            <input asp-for="Name" class="form-control"
                   placeholder="e.g. Acme engineering team, St Mary's parish, High school"
                   autofocus />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="Category" class="form-label fw-semibold">Category</label>
                <select asp-for="Category" class="form-select">
                    @foreach (var c in Enum.GetValues<MyStoryTold.Models.LifeChapterCategory>())
                    {
                        <option value="@c">@c.ToString()</option>
                    }
                </select>
                <div class="form-text small">Sets the default bubble colour.</div>
            </div>
            <div class="col-md-4">
                <label asp-for="StartYear" class="form-label fw-semibold">Start year</label>
                <input asp-for="StartYear" type="number" class="form-control" min="1" max="2100" />
                <span asp-validation-for="StartYear" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="EndYear" class="form-label fw-semibold">End year
                    <span class="text-muted small">(blank = still active)</span>
                </label>
                <input asp-for="EndYear" type="number" class="form-control" min="1" max="2100" />
                <span asp-validation-for="EndYear" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-semibold">Description
                <span class="text-muted small">(optional)</span>
            </label>
            <textarea asp-for="Description" rows="2" maxlength="500" class="form-control"
                      placeholder="A sentence about this part of your life — what you did, where it was."></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">People who were part of this</label>
            <div class="form-text small mb-2">
                Pick from your existing profiles. Want someone who isn't on the list?
                <a asp-controller="PersonProfiles" asp-action="Create">Create a profile</a> first,
                then come back.
            </div>
            @if (!profileChoices.Any())
            {
                <div class="text-muted small">No profiles yet —
                    <a asp-controller="PersonProfiles" asp-action="Create">create one</a>
                    to attach to a chapter.
                </div>
            }
            else
            {
                <div class="chapter-member-picker">
                    @foreach (var p in profileChoices)
                    {
                        var pid = (int)p.Id;
                        var checkedAttr = existingMemberIds.Contains(pid) ? "checked" : null;
                        <label class="chapter-member-choice" data-checked="@(checkedAttr != null ? "1" : "0")">
                            <input type="checkbox" name="memberProfileIds" value="@pid" @checkedAttr />
                            <span class="chapter-member-bubble">
                                @if (!string.IsNullOrEmpty((string?)p.AvatarUrl))
                                {
                                    <img src="@p.AvatarUrl" alt="" />
                                }
                                else
                                {
                                    <span class="initials">@(((string)p.DisplayName).Trim()[0].ToString().ToUpper())</span>
                                }
                            </span>
                            <span class="chapter-member-name">@p.DisplayName</span>
                        </label>
                    }
                </div>
            }
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">@(isEdit ? "Save changes" : "Create chapter")</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</form>
