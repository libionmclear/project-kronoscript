@{
    ViewData["Title"] = "Connections";
    var profileCount = (int)(ViewBag.ProfileCount ?? 0);
    var chapterCount = (int)(ViewBag.ChapterCount ?? 0);
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <header class="connections-hero">
            <p class="connections-hero-eyebrow">Connections
                <partial name="_PremiumBadge" model="@MyStoryTold.Models.PremiumFeature.PeopleProfiles" />
            </p>
            <h2 class="connections-hero-title">The people in your story.</h2>
            <p class="connections-hero-lead">
                Three views of the same thing: who was there, when, and what you shared.
            </p>
        </header>

        <div class="connections-tiles">
            <a asp-controller="PersonProfiles" asp-action="Index" class="connections-tile" data-tile="profiles">
                <div class="connections-tile-eyebrow">I.</div>
                <div class="connections-tile-body">
                    <h3 class="connections-tile-title">Profiles</h3>
                    <p class="connections-tile-desc">
                        Cards for the people you write about — family, friends, the ones
                        who aren't on the site. Tag them in stories the way you tag members.
                    </p>
                    <div class="connections-tile-stat">
                        @profileCount @(profileCount == 1 ? "profile" : "profiles")
                    </div>
                </div>
            </a>

            <a asp-controller="LifeChapters" asp-action="Index" class="connections-tile" data-tile="chapters">
                <div class="connections-tile-eyebrow">II.</div>
                <div class="connections-tile-body">
                    <h3 class="connections-tile-title">Eras</h3>
                    <p class="connections-tile-desc">
                        Contexts you lived through. A job, a school, a parish, a hobby
                        group. Each era holds a year range and a set of people.
                    </p>
                    <div class="connections-tile-stat">
                        @chapterCount @(chapterCount == 1 ? "era" : "eras")
                    </div>
                </div>
            </a>

            <a asp-controller="LifeChapters" asp-action="Map" class="connections-tile" data-tile="lifemap">
                <div class="connections-tile-eyebrow">III.</div>
                <div class="connections-tile-body">
                    <h3 class="connections-tile-title">Era map</h3>
                    <p class="connections-tile-desc">
                        Each era as a bubble on a timeline, with the people inside it.
                        Open one to see the full roster.
                    </p>
                    <div class="connections-tile-stat">
                        @chapterCount @(chapterCount == 1 ? "bubble" : "bubbles")
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
