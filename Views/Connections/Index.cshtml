@{
    ViewData["Title"] = "Connections";
    var profileCount    = (int)(ViewBag.ProfileCount ?? 0);
    var friendKindCount = (int)(ViewBag.FriendKindCount ?? 0);
    var milestoneCount  = (int)(ViewBag.MilestoneCount ?? 0);
    var chapterCount    = (int)(ViewBag.ChapterCount ?? 0);
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <div class="mb-3">
            <h3 class="mb-1">Connections
                <partial name="_PremiumBadge" model="@MyStoryTold.Models.PremiumFeature.PeopleProfiles" />
            </h3>
            <p class="text-muted mb-0" style="font-size:0.92rem;">
                Four lenses on the people in your life and the contexts they belonged to.
                Start with profiles, then plot closeness over time and group people into
                the chapters they shared with you.
            </p>
        </div>

        <div class="connections-tiles">
            <a asp-controller="PersonProfiles" asp-action="Index" class="connections-tile" data-tile="profiles">
                <div class="connections-tile-icon">👤</div>
                <div class="connections-tile-body">
                    <div class="connections-tile-title">People profiles</div>
                    <div class="connections-tile-desc">
                        Cards for people you write about who aren't on Kronoscript — family,
                        friends, colleagues. Tag them in stories the same way you tag members.
                    </div>
                    <div class="connections-tile-stat">
                        @profileCount @(profileCount == 1 ? "profile" : "profiles")
                    </div>
                </div>
            </a>

            <a asp-controller="PersonProfiles" asp-action="Friendship" class="connections-tile" data-tile="friendship">
                <div class="connections-tile-icon">📈</div>
                <div class="connections-tile-body">
                    <div class="connections-tile-title">Friendship graph</div>
                    <div class="connections-tile-desc">
                        Closeness over time. Each friend is a line; turning points come from
                        the milestones you log on their card. Faint bars show stories per year.
                    </div>
                    <div class="connections-tile-stat">
                        @friendKindCount non-family @(friendKindCount == 1 ? "profile" : "profiles") ·
                        @milestoneCount @(milestoneCount == 1 ? "milestone" : "milestones")
                    </div>
                </div>
            </a>

            <a asp-controller="LifeChapters" asp-action="Index" class="connections-tile" data-tile="chapters">
                <div class="connections-tile-icon">📚</div>
                <div class="connections-tile-body">
                    <div class="connections-tile-title">Life chapters</div>
                    <div class="connections-tile-desc">
                        Coarse-grained contexts you lived through — a job, a school, a parish,
                        a hobby group. Each chapter wraps a year range and a set of people.
                    </div>
                    <div class="connections-tile-stat">
                        @chapterCount @(chapterCount == 1 ? "chapter" : "chapters")
                    </div>
                </div>
            </a>

            <a asp-controller="LifeChapters" asp-action="Map" class="connections-tile" data-tile="lifemap">
                <div class="connections-tile-icon">🫧</div>
                <div class="connections-tile-body">
                    <div class="connections-tile-title">Life map</div>
                    <div class="connections-tile-desc">
                        Every chapter as a bubble on a timeline, with the avatars of its
                        members tiled inside. Click a bubble to see the full roster.
                    </div>
                    <div class="connections-tile-stat">
                        @chapterCount @(chapterCount == 1 ? "bubble" : "bubbles")
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
