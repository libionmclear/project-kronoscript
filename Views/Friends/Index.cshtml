@model MyStoryTold.Models.ViewModels.FriendListViewModel
@{
    ViewData["Title"] = "Friends";
}

<h2 class="mb-4">👥 Friends & Connections</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Search & Add -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h5>Find People</h5>
        <div class="input-group">
            <input type="text" id="friendSearch" class="form-control" placeholder="Search by name or email..." />
            <button class="btn btn-primary" type="button" id="friendSearchBtn">Search</button>
        </div>
        <div id="searchResults" class="mt-2"></div>
    </div>
</div>

<!-- Pending Received -->
@if (Model.PendingReceived.Any())
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">🔔 Pending Requests (@Model.PendingReceived.Count)</h5>
            @foreach (var item in Model.PendingReceived)
            {
                <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:var(--mst-light);color:var(--mst-primary);font-weight:bold;">
                            @(item.User.DisplayName?[0] ?? item.User.UserName![0])
                        </div>
                        <div>
                            <strong>@(item.User.DisplayName ?? item.User.UserName)</strong>
                            <small class="text-muted d-block">wants to connect</small>
                        </div>
                    </div>
                    <div class="d-flex gap-1">
                        <form asp-action="Accept" asp-route-id="@item.ConnectionId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-success">Accept</button>
                        </form>
                        <form asp-action="Decline" asp-route-id="@item.ConnectionId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger">Decline</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Pending Sent -->
@if (Model.PendingSent.Any())
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">⏳ Sent Requests (@Model.PendingSent.Count)</h5>
            @foreach (var item in Model.PendingSent)
            {
                <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                    <span>@(item.User.DisplayName ?? item.User.UserName)</span>
                    <span class="badge bg-warning text-dark">Pending</span>
                </div>
            }
        </div>
    </div>
}

<!-- Accepted Friends -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">My Friends (@Model.Friends.Count)</h5>

        @if (!Model.Friends.Any())
        {
            <p class="text-muted">No friends yet. Search above to find people!</p>
        }

        @foreach (var friend in Model.Friends)
        {
            <div class="d-flex align-items-center justify-content-between border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    @if (!string.IsNullOrEmpty(friend.User.ProfilePhotoUrl))
                    {
                        <img src="@friend.User.ProfilePhotoUrl" class="rounded-circle" style="width:40px;height:40px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:var(--mst-light);color:var(--mst-primary);font-weight:bold;">
                            @(friend.User.DisplayName?[0] ?? friend.User.UserName![0])
                        </div>
                    }
                    <div>
                        <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@friend.User.Id" class="fw-semibold text-decoration-none">
                            @(friend.User.DisplayName ?? friend.User.UserName)
                        </a>
                        <span class="badge ms-2
                            @(friend.Tier == MyStoryTold.Models.FriendTier.Family ? "bg-success" :
                              friend.Tier == MyStoryTold.Models.FriendTier.Friend ? "bg-primary" : "bg-secondary")">
                            @friend.Tier
                        </span>
                    </div>
                </div>
                <div class="d-flex gap-1 align-items-center">
                    <!-- Tier Selector -->
                    <form asp-action="SetTier" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="connectionId" value="@friend.ConnectionId" />
                        <select name="tier" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                            <option value="Acquaintance" selected="@(friend.Tier == MyStoryTold.Models.FriendTier.Acquaintance)">Acquaintance</option>
                            <option value="Friend" selected="@(friend.Tier == MyStoryTold.Models.FriendTier.Friend)">Friend</option>
                            <option value="Family" selected="@(friend.Tier == MyStoryTold.Models.FriendTier.Family)">Family</option>
                        </select>
                    </form>
                    <form asp-action="Remove" asp-route-id="@friend.ConnectionId" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove this friend?')">✕</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
document.getElementById('friendSearchBtn').addEventListener('click', function() {
    var q = document.getElementById('friendSearch').value;
    if (q.length < 2) return;
    fetch('/Friends/Search?q=' + encodeURIComponent(q))
        .then(r => r.json())
        .then(users => {
            var html = '';
            users.forEach(function(u) {
                html += '<div class="d-flex align-items-center justify-content-between border-bottom py-2">';
                html += '<span>' + (u.displayName || u.userName) + ' <small class="text-muted">(' + u.userName + ')</small></span>';
                html += '<form action="/Friends/SendRequest" method="post" class="d-inline">';
                html += '<input type="hidden" name="__RequestVerificationToken" value="' + document.querySelector('input[name=__RequestVerificationToken]').value + '" />';
                html += '<input type="hidden" name="addresseeId" value="' + u.userId + '" />';
                html += '<button class="btn btn-sm btn-primary">+ Add</button></form></div>';
            });
            if (users.length === 0) html = '<p class="text-muted">No users found.</p>';
            document.getElementById('searchResults').innerHTML = html;
        });
});
document.getElementById('friendSearch').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('friendSearchBtn').click(); }
});
</script>
}
