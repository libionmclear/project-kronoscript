@model MyStoryTold.Models.ViewModels.FriendListViewModel
@using MyStoryTold.Models
@using MyStoryTold.Models.ViewModels
@{
    ViewData["Title"] = "Friends & Connections";
    var totalNetwork = Model.Friends.Count + Model.RelativeFamily.Count;
}

<div class="row g-3">
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">

        <h2 class="mb-4">👥 Friends & Connections</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <!-- Search & Add -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>Find People</h5>
                <div class="input-group">
                    <input type="text" id="friendSearch" class="form-control" placeholder="Search by name or username..." />
                    <button class="btn btn-primary" type="button" id="friendSearchBtn">Search</button>
                </div>
                <div id="searchResults" class="mt-2"></div>
            </div>
        </div>

        <!-- ── Requests ── -->
        @if (Model.PendingReceived.Any() || Model.PendingSent.Any())
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="mb-3">📬 Requests</h5>

                    @if (Model.PendingReceived.Any())
                    {
                        <p class="text-muted small fw-semibold mb-2" style="letter-spacing:.04em;">RECEIVED</p>
                        @foreach (var item in Model.PendingReceived)
                        {
                            <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                                <div class="d-flex align-items-center gap-2">
                                    @await Html.PartialAsync("_UserAvatar", new UserAvatarViewModel { User = item.User, Size = 40 })
                                    <div>
                                        <strong>@(item.User.DisplayName ?? item.User.UserName)</strong>
                                        <small class="text-muted d-block">wants to connect with you</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-1 align-items-center flex-wrap">
                                    <form asp-action="Accept" asp-route-id="@item.ConnectionId" method="post" class="d-inline-flex align-items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <select name="tier" class="form-select form-select-sm" style="width:auto;" title="Accept as...">
                                            <option value="Acquaintance">Acquaintance</option>
                                            <option value="Friend">Friend</option>
                                            <option value="Family">Family</option>
                                        </select>
                                        <button class="btn btn-sm btn-success">Accept</button>
                                    </form>
                                    <form asp-action="Decline" asp-route-id="@item.ConnectionId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger">Decline</button>
                                    </form>
                                </div>
                            </div>
                        }
                    }

                    @if (Model.PendingSent.Any())
                    {
                        <p class="text-muted small fw-semibold mb-2 @(Model.PendingReceived.Any() ? "mt-3" : "")" style="letter-spacing:.04em;">SENT</p>
                        @foreach (var item in Model.PendingSent)
                        {
                            <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                                <div class="d-flex align-items-center gap-2">
                                    @await Html.PartialAsync("_UserAvatar", new UserAvatarViewModel { User = item.User, Size = 40 })
                                    <div>
                                        <strong>@(item.User.DisplayName ?? item.User.UserName)</strong>
                                        <small class="text-muted d-block">request pending</small>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge" style="background-color:var(--mst-accent);color:#000;">Pending</span>
                                    <form asp-action="CancelRequest" asp-route-id="@item.ConnectionId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-secondary" onclick="return confirm('Cancel this request?')">✕ Cancel</button>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        <!-- ── Network ── -->
        <div class="card border-0 shadow-sm" data-tour="network-tiers" id="networkSection">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                    <h5 class="mb-0">🌐 My Network (@totalNetwork)</h5>
                    <div class="tier-filter-group" role="group" aria-label="Filter by tier">
                        <button type="button" class="tier-filter-btn" data-filter="Acquaintance" data-tier-color="acquaintances">Acquaintances</button>
                        <button type="button" class="tier-filter-btn" data-filter="Friend" data-tier-color="friends">Friends</button>
                        <button type="button" class="tier-filter-btn" data-filter="Family" data-tier-color="family">Family</button>
                    </div>
                </div>

                <!-- Banner: lights up while a tier filter is active -->
                <div id="networkFilterBanner" class="alert alert-light py-2 mb-3 d-none" role="status">
                    <span>Showing <strong id="networkFilterLabel"></strong> only.</span>
                    <button type="button" id="networkFilterClear" class="btn btn-sm btn-link p-0 ms-2">Show all</button>
                </div>

                @if (totalNetwork == 0)
                {
                    <p class="text-muted">No connections yet. Search above to find people!</p>
                }

                <div id="networkList">
                    @foreach (var friend in Model.Friends)
                    {
                        <div class="network-item d-flex align-items-center justify-content-between border-bottom py-2"
                             data-tier="@friend.Tier.ToString()">
                            <div class="d-flex align-items-center gap-2">
                                @await Html.PartialAsync("_UserAvatar", new UserAvatarViewModel { User = friend.User, Size = 40 })
                                <div>
                                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@friend.User.Id" class="fw-semibold text-decoration-none">
                                        @(friend.User.DisplayName ?? friend.User.UserName)
                                    </a>
                                    @if (friend.Tier == FriendTier.Family)
                                    {
                                        <span class="badge ms-1" style="background-color:var(--tier-family);color:#000;">Family</span>
                                    }
                                    else if (friend.Tier == FriendTier.Friend)
                                    {
                                        <span class="badge ms-1" style="background-color:var(--tier-friends);color:#fff;">Friend</span>
                                    }
                                    else
                                    {
                                        <span class="badge ms-1" style="background-color:var(--tier-acquaintances);color:#fff;">Acquaintance</span>
                                    }
                                </div>
                            </div>
                            <div class="d-flex gap-1 align-items-center">
                                <form asp-action="SetTier" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="connectionId" value="@friend.ConnectionId" />
                                    <select name="tier" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                                        <option value="Acquaintance" selected="@(friend.Tier == FriendTier.Acquaintance)">Acquaintance</option>
                                        <option value="Friend" selected="@(friend.Tier == FriendTier.Friend)">Friend</option>
                                        <option value="Family" selected="@(friend.Tier == FriendTier.Family)">Family</option>
                                    </select>
                                </form>
                                <form asp-action="Remove" asp-route-id="@friend.ConnectionId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove this connection?')">✕</button>
                                </form>
                            </div>
                        </div>
                    }

                    @foreach (var r in Model.RelativeFamily)
                    {
                        <div class="network-item d-flex align-items-center justify-content-between border-bottom py-2"
                             data-tier="RelativeFamily">
                            <div class="d-flex align-items-center gap-2">
                                @await Html.PartialAsync("_UserAvatar", new UserAvatarViewModel { User = r.User, Size = 40 })
                                <div>
                                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@r.User.Id" class="fw-semibold text-decoration-none">
                                        @(r.User.DisplayName ?? r.User.UserName)
                                    </a>
                                    <span class="badge ms-1" style="background-color:#87ceeb;color:#000;">Family</span>
                                    <span class="badge ms-1 bg-light text-dark border">@r.RelationshipType.ToString()</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    var FILTER_LABELS = { 'Acquaintance': 'Acquaintances', 'Friend': 'Friends', 'Family': 'Family' };

    // Search — guard everything with null checks so a missing element doesn't
    // bring the whole script down (which previously caused the tier filter to
    // silently no-op when search elements weren't on the page).
    var searchBtn = document.getElementById('friendSearchBtn');
    var searchInput = document.getElementById('friendSearch');
    if (searchBtn && searchInput) {
        searchBtn.addEventListener('click', function () {
            var q = searchInput.value;
            if (q.length < 2) return;
            fetch('/Friends/Search?q=' + encodeURIComponent(q))
                .then(r => r.json())
                .then(users => {
                    var token = document.querySelector('input[name=__RequestVerificationToken]').value;
                    var html = '';
                    users.forEach(function (u) {
                        html += '<div class="d-flex align-items-center justify-content-between border-bottom py-2">';
                        html += '<span>' + (u.displayName || u.userName) + ' <small class="text-muted">(' + u.userName + ')</small></span>';
                        html += '<form action="/Friends/SendRequest" method="post" class="d-inline d-flex align-items-center gap-1">';
                        html += '<input type="hidden" name="__RequestVerificationToken" value="' + token + '" />';
                        html += '<input type="hidden" name="addresseeId" value="' + u.userId + '" />';
                        html += '<select name="tier" class="form-select form-select-sm" style="width:auto;">'
                              + '<option value="Acquaintance">Acquaintance</option>'
                              + '<option value="Friend">Friend</option>'
                              + '<option value="Family">Family</option>'
                              + '</select>';
                        html += '<button class="btn btn-sm btn-primary">+ Add</button></form></div>';
                    });
                    if (users.length === 0) html = '<p class="text-muted mt-2">No users found.</p>';
                    document.getElementById('searchResults').innerHTML = html;
                });
        });
        searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); searchBtn.click(); }
        });
    }

    // Tier filter — click a button (or land on the page with ?tier=…) to
    // narrow the My Network list to one audience tier. Click again to clear.
    var activeFilter = null;
    var banner = document.getElementById('networkFilterBanner');
    var bannerLabel = document.getElementById('networkFilterLabel');
    var bannerClear = document.getElementById('networkFilterClear');

    function applyFilter(filter) {
        activeFilter = filter || null;
        document.querySelectorAll('.tier-filter-btn').forEach(function (b) {
            b.classList.toggle('active', b.dataset.filter === activeFilter);
        });
        document.querySelectorAll('.network-item').forEach(function (item) {
            var tier = (item.getAttribute('data-tier') || '').toLowerCase();
            if (!activeFilter) {
                item.style.display = '';
            } else if (activeFilter === 'Family') {
                item.style.display = (tier === 'family' || tier === 'relativefamily') ? '' : 'none';
            } else {
                item.style.display = (tier === activeFilter.toLowerCase()) ? '' : 'none';
            }
        });
        if (banner && bannerLabel) {
            if (activeFilter) {
                bannerLabel.textContent = FILTER_LABELS[activeFilter] || activeFilter;
                banner.classList.remove('d-none');
            } else {
                banner.classList.add('d-none');
            }
        }
    }
    document.querySelectorAll('.tier-filter-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var filter = btn.dataset.filter;
            applyFilter(activeFilter === filter ? null : filter);
        });
    });
    if (bannerClear) {
        bannerClear.addEventListener('click', function () {
            applyFilter(null);
            // Drop the ?tier= from the URL so a refresh doesn't re-apply.
            if (history.replaceState) history.replaceState({}, '', window.location.pathname);
        });
    }

    // Honor ?tier= from the My Network sidebar links and scroll the network
    // section into view so the user actually SEES the result of their click.
    var params = new URLSearchParams(window.location.search);
    var initial = params.get('tier');
    if (initial && FILTER_LABELS[initial]) {
        applyFilter(initial);
        var section = document.getElementById('networkSection');
        if (section) {
            // Defer one tick so the layout is settled before scrolling.
            setTimeout(function () { section.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 50);
        }
    }
})();
</script>
}
