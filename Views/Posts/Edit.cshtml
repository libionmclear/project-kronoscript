@model MyStoryTold.Models.ViewModels.EditPostViewModel
@{
    ViewData["Title"] = "Edit Life Event";
    var currentTagged = ViewBag.CurrentTagged as List<MyStoryTold.Models.ViewModels.TaggableFriendViewModel>
                        ?? Model.TaggableFriends
                               .Where(f => Model.TaggedUserIds != null && Model.TaggedUserIds.Contains(f.UserId))
                               .ToList();
}

<div class="row g-3">
    <div class="col-md-2">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="mb-4" style="color: var(--mst-primary);">✏️ Edit Life Event</h2>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="PostId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title (optional)</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Body" class="form-label">Your Story <small class="text-muted">(you can paste images directly)</small></label>
                        <textarea asp-for="Body" id="storyBody" class="form-control" rows="8"></textarea>
                        <div id="pastedImagesPreview" class="mt-2"></div>
                        <span asp-validation-for="Body" class="text-danger"></span>
                    </div>

                    <div class="card bg-light border-0 p-3 mb-3">
                        <h6 class="mb-3">When did this happen?</h6>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label asp-for="EventYear" class="form-label">Year *</label>
                                <input asp-for="EventYear" class="form-control" type="number" max="2100" placeholder="e.g. -44 for 44 BC" />
                                <span asp-validation-for="EventYear" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EventMonth" class="form-label">Month</label>
                                <select asp-for="EventMonth" class="form-select">
                                    <option value="">-- Optional --</option>
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EventDay" class="form-label">Day</label>
                                <input asp-for="EventDay" class="form-control" type="number" min="1" max="31" />
                            </div>
                        </div>
                        <div class="form-check mt-2">
                            <input asp-for="EventDateIsEstimated" class="form-check-input" />
                            <label asp-for="EventDateIsEstimated" class="form-check-label">This date is estimated</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Images" class="form-label">Add More Images</label>
                        <input asp-for="Images" class="form-control" type="file" multiple accept="image/*" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Video" class="form-label">Add Video</label>
                        <input asp-for="Video" class="form-control" type="file" accept="video/*" />
                    </div>

                    <!-- Tag People -->
                    @await Html.PartialAsync("_TagWidget", new MyStoryTold.Models.ViewModels.TagWidgetViewModel
                    {
                        Friends = Model.TaggableFriends,
                        Selected = currentTagged
                    })

                    <div class="alert alert-info">
                        <small>📘 Changes will be highlighted in dark blue so readers can see what was updated.</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Detail" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var textarea = document.getElementById('storyBody');
        var preview  = document.getElementById('pastedImagesPreview');
        if (!textarea) return;

        textarea.addEventListener('paste', function (e) {
            var items = (e.clipboardData || e.originalEvent.clipboardData).items;
            for (var i = 0; i < items.length; i++) {
                if (items[i].type.indexOf('image') !== -1) {
                    e.preventDefault();
                    var blob = items[i].getAsFile();
                    var fd = new FormData();
                    fd.append('file', blob, 'pasted-image.png');
                    fetch('/Posts/UploadPastedImage', { method: 'POST', body: fd })
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            if (data.url) {
                                var pos = textarea.selectionStart;
                                var before = textarea.value.substring(0, pos);
                                var after  = textarea.value.substring(pos);
                                textarea.value = before + '\n[image: ' + data.url + ']\n' + after;
                                var img = document.createElement('img');
                                img.src = data.url;
                                img.className = 'pasted-img-preview';
                                img.title = data.url;
                                preview.appendChild(img);
                            }
                        })
                        .catch(function () {});
                }
            }
        });
    })();
    </script>
}
