@model MyStoryTold.Models.ViewModels.EditPostViewModel
@inject MyStoryTold.Services.IPremiumService _premium
@inject Microsoft.AspNetCore.Identity.UserManager<MyStoryTold.Models.ApplicationUser> _editUserManager
@{
    ViewData["Title"] = "Edit Story";
    var currentTagged = ViewBag.CurrentTagged as List<MyStoryTold.Models.ViewModels.TaggableFriendViewModel>
                        ?? Model.TaggableFriends
                               .Where(f => Model.TaggedUserIds != null && Model.TaggedUserIds.Contains(f.UserId))
                               .ToList();
    // Photo positioning is a premium-tagged feature. While
    // PremiumEnforcementActive is off the call always returns true,
    // so behavior matches today's "free for everyone." Once
    // enforcement flips on, non-subscribers see the placeholder gate
    // instead of the grid — no code change here required.
    var editCurrentUser = await _editUserManager.GetUserAsync(User);
    var photoPositioningOn = await _premium.IsAvailableAsync(editCurrentUser, MyStoryTold.Models.PremiumFeature.PhotoPositioning);
}

<div class="row g-3">
    <div class="col-md-2">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3">
                <h5 class="mb-3" style="color:var(--mst-primary);">✏️ Edit Story</h5>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="PostId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    <!-- Title -->
                    <div class="mb-2">
                        <input asp-for="Title" class="form-control form-control-sm" placeholder="Title (optional)" />
                    </div>

                    <!-- Body -->
                    <div class="mb-2">
                        <textarea asp-for="Body" id="storyBody" class="form-control form-control-sm" rows="6"
                                  placeholder="Tell us what happened… (paste images directly)"></textarea>
                        <div id="pastedImagesPreview" class="mt-1 d-flex flex-wrap gap-2"></div>
                        <div id="pastedImageInputs"></div>
                        <span asp-validation-for="Body" class="text-danger small"></span>
                    </div>

                    <!-- Date + Estimated — single compact row -->
                    <div class="row g-1 mb-2 align-items-center">
                        <div class="col-auto">
                            <input asp-for="EventYear" class="form-control form-control-sm" type="number" max="2100"
                                   placeholder="Year (-=BC)" style="width:110px;" />
                            <span asp-validation-for="EventYear" class="text-danger small"></span>
                        </div>
                        <div class="col-auto">
                            <select asp-for="EventMonth" class="form-select form-select-sm" style="width:110px;">
                                <option value="">Month</option>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)</option>
                                }
                            </select>
                        </div>
                        <div class="col-auto">
                            <input asp-for="EventDay" class="form-control form-control-sm" type="number" min="1" max="31"
                                   placeholder="Day" style="width:68px;" />
                        </div>
                        <div class="col-auto">
                            <div class="form-check mb-0">
                                <input asp-for="EventDateIsEstimated" class="form-check-input" />
                                <label asp-for="EventDateIsEstimated" class="form-check-label small text-muted">Estimated</label>
                            </div>
                        </div>
                    </div>

                    <!-- Visibility + Location — same row -->
                    <div class="row g-1 mb-2">
                        <div class="col-md-5">
                            <select asp-for="Visibility" class="form-select form-select-sm visibility-select">
                                <option value="Public">● Public</option>
                                <option value="Acquaintances">● Acquaintances</option>
                                <option value="Friends">● Friends</option>
                                <option value="Family">● Family</option>
                                <option value="Private">🔒 Only Me</option>
                            </select>
                        </div>
                        <div class="col-md-7">
                            <input asp-for="Location" class="form-control form-control-sm" placeholder="📍 Location (optional)" />
                        </div>
                    </div>

                    <!-- Layout style: Standard / Newspaper / Book. Channel
                         posts default to Newspaper and biographical posts to
                         Book on first edit; any post can be flipped here. -->
                    <div class="row g-1 mb-2 align-items-center">
                        <div class="col-auto">
                            <label asp-for="LayoutStyle" class="form-label small fw-semibold mb-0 me-1" style="color:var(--mst-muted);">Layout:</label>
                        </div>
                        <div class="col-auto">
                            <select asp-for="LayoutStyle" class="form-select form-select-sm" style="width:auto;">
                                <option value="0">Standard</option>
                                <option value="1">📰 Newspaper</option>
                                <option value="2">📖 Book chapter</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <small class="text-muted">
                                Newspaper = serif headline, two columns, drop-cap. Book = italic title, single wider column, chapter feel.
                                Photo positions in the layout are set on the 3×3 grid in each thumbnail tile below.
                            </small>
                        </div>
                    </div>

                    @{
                        var existingMedia = ViewBag.ExistingMedia as List<MyStoryTold.Models.PostMedia> ?? new List<MyStoryTold.Models.PostMedia>();
                    }
                    @if (existingMedia.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label small text-muted mb-1">Photos &amp; videos on this story</label>
                            <div class="media-reorder-grid" id="mediaReorderGrid">
                                @{
                                    // 4×8 grid — 4 columns wide × 8 rows tall.
                                    // Two grid columns = one article column (newspaper has 2 article cols
                                    // so 4 grid cols = full spread; book has 1 article col so 4 grid cols
                                    // = full chapter width). More cells = bigger photo.
                                    const int GRID_COLS = 4;
                                    const int GRID_ROWS = 8;
                                    // Legacy 3-cell codes → 4×8 grid mapping for posts saved before
                                    // the finer grid landed. New posts have explicit Col/Row.
                                    (int col, int row) LegacyToGrid(string p) => p switch
                                    {
                                        "top-left"     => (0, 0), "top"        => (1, 0), "top-right"    => (3, 0),
                                        "left"         => (0, 3), "center"     => (1, 3), "right"        => (3, 3),
                                        "bottom-left"  => (0, 6), "bottom"     => (1, 6), "bottom-right" => (3, 6),
                                        _ => (-1, -1)
                                    };
                                }
                                @foreach (var m in existingMedia)
                                {
                                    var w = Math.Clamp(m.LayoutWidth < 1 ? 1 : m.LayoutWidth, 1, GRID_COLS);
                                    var h = Math.Clamp(m.LayoutHeight < 1 ? 1 : m.LayoutHeight, 1, GRID_ROWS);
                                    var col = m.LayoutCol;
                                    var row = m.LayoutRow;
                                    if (col < 0 || row < 0)
                                    {
                                        var legacy = LegacyToGrid(m.LayoutPosition ?? "");
                                        col = legacy.col;
                                        row = legacy.row;
                                        // If still unset (no legacy either), leave as -1 = no placement.
                                    }
                                    string CellsLabel(int width, int height)
                                    {
                                        var n = width * height;
                                        if (n == 1) return "1 cell";
                                        return n + " cells (" + width + "×" + height + ")";
                                    }
                                    <div class="media-tile-row">
                                        <div class="media-reorder-tile" draggable="true"
                                             data-media-id="@m.Id"
                                             data-focus-x="@m.FocusX" data-focus-y="@m.FocusY"
                                             style="--focus-x:@(m.FocusX)%;--focus-y:@(m.FocusY)%;">
                                            <input type="hidden" name="MediaOrder" value="@m.Id" />
                                            <input type="hidden" name="MediaFocusX" value="@m.FocusX" class="media-focus-x-input" />
                                            <input type="hidden" name="MediaFocusY" value="@m.FocusY" class="media-focus-y-input" />
                                            <input type="hidden" name="MediaLayoutPositions" value="@(m.LayoutPosition ?? "")" class="media-layout-input" />
                                            <input type="hidden" name="MediaLayoutWidths" value="@w" class="media-layout-w-input" />
                                            <input type="hidden" name="MediaLayoutHeights" value="@h" class="media-layout-h-input" />
                                            <input type="hidden" name="MediaLayoutCols" value="@col" class="media-layout-col-input" />
                                            <input type="hidden" name="MediaLayoutRows" value="@row" class="media-layout-row-input" />
                                            @if (m.MediaType == MyStoryTold.Models.MediaType.Video)
                                            {
                                                <video src="@m.Url" muted playsinline preload="metadata"
                                                       style="object-position:@(m.FocusX)% @(m.FocusY)%;"></video>
                                                <span class="media-reorder-badge">video</span>
                                            }
                                            else
                                            {
                                                <img src="@m.Url" alt=""
                                                     style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                            }
                                            <span class="media-focus-dot" aria-hidden="true"></span>
                                            <span class="media-reorder-grip" aria-hidden="true">⋮⋮</span>
                                        </div>
                                        @{
                                            // Per-image position + size grid is the
                                            // PremiumFeature.PhotoPositioning capability —
                                            // article-style posts (Newspaper/Book) always need
                                            // it to be usable; Standard personal posts gate
                                            // through the PremiumService (today: open to all,
                                            // tomorrow: subscribers only when enforcement
                                            // flips on).
                                            var allowLayout = Model.LayoutStyle != MyStoryTold.Models.PostLayoutStyle.Standard
                                                              || photoPositioningOn;
                                        }
                                        @if (allowLayout)
                                        {
                                            <div class="media-layout-panel">
                                                <div class="media-layout-panel-label">
                                                    Position &amp; size
                                                    @if (Model.LayoutStyle == MyStoryTold.Models.PostLayoutStyle.Standard)
                                                    {
                                                        <partial name="_PremiumBadge" model="@MyStoryTold.Models.PremiumFeature.PhotoPositioning" />
                                                    }
                                                </div>
                                                <div class="media-layout-panel-grid layout-grid-fine"
                                                     data-cols="@GRID_COLS" data-rows="@GRID_ROWS"
                                                     title="Click a cell to place. Shift-click another cell to span more cells (bigger photo).">
                                                    @for (int r = 0; r < GRID_ROWS; r++)
                                                    {
                                                        for (int c = 0; c < GRID_COLS; c++)
                                                        {
                                                            var inRect = col >= 0 && r >= row && r < row + h && c >= col && c < col + w;
                                                            <button type="button" class="media-layout-cell @(inRect ? "active" : "")"
                                                                    data-row="@r" data-col="@c"
                                                                    aria-label="Row @(r+1), column @(c+1)"></button>
                                                        }
                                                    }
                                                </div>
                                                <div class="media-layout-panel-current">@(col < 0 ? "Auto" : CellsLabel(w, h))</div>
                                                <div class="media-layout-panel-hint">Shift-click to span. 2 grid cols = 1 article col.</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <partial name="_PremiumGate" model="@MyStoryTold.Models.PremiumFeature.PhotoPositioning" />
                                        }
                                    </div>
                                }
                            </div>
                            <small class="text-muted">
                                Drag tiles to reorder. <strong>Click</strong> a thumbnail to set its focus point (white dot = where the crop will center).
                                The <strong>3×3 grid beside each photo</strong> picks where it floats inside <em>newspaper</em> and <em>book</em> layouts.
                            </small>
                        </div>
                    }

                    <!-- Media — single combined input -->
                    <div class="mb-2">
                        <label class="form-label small text-muted mb-0">Add Media</label>
                        <input asp-for="Images" class="form-control form-control-sm" type="file" multiple accept="image/*,video/*" />
                        <small class="text-muted">Photos or videos — select multiple if you like.</small>
                    </div>

                    <!-- Tag People -->
                    @{
                        var currentTaggedProfiles = ViewBag.CurrentTaggedProfiles as List<MyStoryTold.Models.ViewModels.TaggableProfileViewModel>
                            ?? Model.TaggableProfiles
                                   .Where(p => Model.TaggedProfileIds != null && Model.TaggedProfileIds.Contains(p.ProfileId))
                                   .ToList();
                    }
                    @await Html.PartialAsync("_TagWidget", new MyStoryTold.Models.ViewModels.TagWidgetViewModel
                    {
                        Friends = Model.TaggableFriends,
                        Selected = currentTagged,
                        Profiles = Model.TaggableProfiles,
                        SelectedProfiles = currentTaggedProfiles
                    })

                    <input asp-for="IsDraft" type="hidden" id="editIsDraft" />

                    @if (Model.IsDraft)
                    {
                        <div class="alert alert-warning py-2 mb-2 small">
                            This post is currently a <strong>draft</strong> — only you can see it. Click <em>Publish</em> to make it visible.
                        </div>
                    }

                    <div class="d-flex gap-2 flex-wrap">
                        @if (Model.IsDraft)
                        {
                            <button type="submit" class="btn btn-sm btn-primary" id="editPublishBtn">Publish</button>
                            <button type="submit" class="btn btn-sm btn-outline-warning" id="editKeepDraftBtn">Save draft</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-sm btn-primary" id="editSaveBtn">Save Changes</button>
                            <button type="submit" class="btn btn-sm btn-outline-warning" id="editToDraftBtn">Move to drafts</button>
                        }
                        <a asp-action="Detail" asp-route-id="@Model.PostId" class="btn btn-sm btn-outline-secondary ms-auto">Cancel</a>
                    </div>
                </form>

                @{
                    var mediaList = ViewBag.ExistingMedia as List<MyStoryTold.Models.PostMedia> ?? new();
                    var mediaTags = ViewBag.MediaPersonTags as Dictionary<int, List<MyStoryTold.Models.MediaPersonTag>>
                                    ?? new Dictionary<int, List<MyStoryTold.Models.MediaPersonTag>>();
                    var imageMedia = mediaList.Where(m => m.MediaType == MyStoryTold.Models.MediaType.Image).ToList();
                    var pickerFriends = (Model.TaggableFriends ?? new())
                        .Select(f => new { type = "u", id = f.UserId, name = f.DisplayName }).ToList();
                    // Profiles first, newest-first by id, so a just-created NPC
                    // shows at the top of the picker without the user searching.
                    var pickerProfiles = (Model.TaggableProfiles ?? new())
                        .OrderByDescending(p => p.ProfileId)
                        .Select(p => new { type = "p", id = p.ProfileId.ToString(), name = p.DisplayName }).ToList();
                    var pickerJson = System.Text.Json.JsonSerializer.Serialize(
                        pickerProfiles.Cast<object>().Concat(pickerFriends));
                }
                @if (imageMedia.Count > 0)
                {
                    <div class="mt-4 photo-tags-section">
                        <h5 class="fw-bold mb-1">Tag people on photos</h5>
                        <div class="text-muted small mb-3">Click on a face to add a name tag. Tags also surface on the home feed and detail page.</div>

                        <div class="row g-3">
                            @foreach (var m in imageMedia)
                            {
                                var existing = mediaTags.TryGetValue(m.Id, out var tt) ? tt : new List<MyStoryTold.Models.MediaPersonTag>();
                                <div class="col-md-6 col-lg-4">
                                    <div class="card border-0 shadow-sm">
                                        <div class="photo-tag-canvas" data-media-id="@m.Id"
                                             style="position:relative;background:#000;overflow:hidden;cursor:crosshair;aspect-ratio:1/1;">
                                            <img src="@m.Url" alt=""
                                                 style="width:100%;height:100%;object-fit:cover;object-position:@(m.FocusX)% @(m.FocusY)%;pointer-events:none;user-select:none;" />
                                            @foreach (var t in existing)
                                            {
                                                var label = t.TargetUser != null
                                                    ? (t.TargetUser.DisplayName ?? t.TargetUser.UserName ?? "?")
                                                    : (t.TargetProfile?.DisplayName ?? "?");
                                                var prefix = t.TargetProfileId.HasValue ? "🕊 " : "";
                                                <div class="photo-tag-overlay" data-tag-id="@t.Id"
                                                     style="position:absolute;left:@(t.X.ToString(System.Globalization.CultureInfo.InvariantCulture))%;top:@(t.Y.ToString(System.Globalization.CultureInfo.InvariantCulture))%;transform:translate(-50%,-50%);pointer-events:auto;">
                                                    <span style="display:block;width:14px;height:14px;border-radius:50%;background:#fff;border:2px solid #1e7e34;box-shadow:0 0 0 2px rgba(0,0,0,0.35);"></span>
                                                    <span class="photo-tag-label"
                                                          style="position:absolute;top:18px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.75);color:#fff;padding:2px 8px;border-radius:4px;font-size:0.75rem;white-space:nowrap;">
                                                        @prefix@label
                                                        <button type="button" class="photo-tag-remove ms-1"
                                                                data-tag-id="@t.Id"
                                                                style="background:transparent;border:none;color:#fff;padding:0 0 0 4px;line-height:1;cursor:pointer;">✕</button>
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                        <div class="card-body py-2 small text-muted">
                                            @(existing.Count == 0 ? "No tags yet — click a face above." : existing.Count + " tag" + (existing.Count == 1 ? "" : "s"))
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div id="photoTagPicker"
                         style="display:none;position:fixed;z-index:2000;background:#fff;border:1px solid #d8c69c;border-radius:8px;box-shadow:0 6px 20px rgba(0,0,0,0.2);width:260px;max-height:320px;overflow:hidden;">
                        <div class="p-2 border-bottom">
                            <input type="text" id="photoTagSearch" class="form-control form-control-sm" placeholder="Search a person…" autocomplete="off" />
                        </div>
                        <div id="photoTagOptions" style="max-height:260px;overflow-y:auto;"></div>
                    </div>
                    <script>
                    (function () {
                        var anti = document.querySelector('input[name="__RequestVerificationToken"]');
                        var token = anti ? anti.value : '';
                        var people = @Html.Raw(pickerJson);
                        var picker = document.getElementById('photoTagPicker');
                        var search = document.getElementById('photoTagSearch');
                        var opts   = document.getElementById('photoTagOptions');
                        var pending = null; // { canvas, mediaId, x, y }

                        function renderOptions(filter) {
                            var f = (filter || '').toLowerCase().trim();
                            var matches = people.filter(function (p) {
                                return !f || (p.name || '').toLowerCase().indexOf(f) !== -1;
                            }).slice(0, 200);
                            if (matches.length === 0) {
                                opts.innerHTML = '<div class="p-2 small text-muted">No matches.</div>';
                                return;
                            }
                            opts.innerHTML = matches.map(function (p) {
                                var prefix = p.type === 'p' ? '🕊 ' : '';
                                return '<button type="button" class="list-group-item list-group-item-action py-2"'
                                     + ' data-type="' + p.type + '" data-id="' + p.id + '" data-name="'
                                     + escapeAttr(p.name) + '">'
                                     + prefix + escapeText(p.name) + '</button>';
                            }).join('');
                        }
                        function escapeText(s) { var d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }
                        function escapeAttr(s) { return (s||'').replace(/"/g,'&quot;'); }

                        function closePicker() { picker.style.display = 'none'; pending = null; }
                        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closePicker(); });
                        document.addEventListener('click', function (e) {
                            if (picker.style.display === 'none') return;
                            if (picker.contains(e.target)) return;
                            // Click outside picker also closes — unless it was a tag click.
                            if (!e.target.closest('.photo-tag-canvas')) closePicker();
                        });

                        search.addEventListener('input', function () { renderOptions(search.value); });
                        opts.addEventListener('click', function (e) {
                            var btn = e.target.closest('button[data-type]');
                            if (!btn || !pending) return;
                            var fd = new FormData();
                            fd.append('__RequestVerificationToken', token);
                            fd.append('mediaId', pending.mediaId);
                            fd.append('x', pending.x);
                            fd.append('y', pending.y);
                            if (btn.dataset.type === 'u') fd.append('targetUserId', btn.dataset.id);
                            else fd.append('targetProfileId', btn.dataset.id);
                            fetch('/Media/AddPersonTag', { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': token } })
                                .then(function (r) { if (!r.ok) throw new Error('Tag failed'); return r.json(); })
                                .then(function (data) {
                                    // Insert the overlay inline so we don't need a reload.
                                    var canvas = pending.canvas;
                                    var ov = document.createElement('div');
                                    ov.className = 'photo-tag-overlay';
                                    ov.dataset.tagId = data.id;
                                    ov.style.cssText = 'position:absolute;left:' + data.x + '%;top:' + data.y + '%;transform:translate(-50%,-50%);pointer-events:auto;';
                                    ov.innerHTML = '<span style="display:block;width:14px;height:14px;border-radius:50%;background:#fff;border:2px solid #1e7e34;box-shadow:0 0 0 2px rgba(0,0,0,0.35);"></span>'
                                                 + '<span class="photo-tag-label" style="position:absolute;top:18px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.75);color:#fff;padding:2px 8px;border-radius:4px;font-size:0.75rem;white-space:nowrap;">'
                                                 + (data.isProfile ? '🕊 ' : '') + escapeText(data.label || '?')
                                                 + ' <button type="button" class="photo-tag-remove" data-tag-id="' + data.id + '" style="background:transparent;border:none;color:#fff;padding:0 0 0 4px;line-height:1;cursor:pointer;">✕</button>'
                                                 + '</span>';
                                    canvas.appendChild(ov);
                                    closePicker();
                                })
                                .catch(function () { closePicker(); alert('Could not save the tag.'); });
                        });

                        document.querySelectorAll('.photo-tag-canvas').forEach(function (canvas) {
                            canvas.addEventListener('click', function (e) {
                                // Don't trigger when clicking an existing overlay's controls.
                                if (e.target.closest('.photo-tag-overlay')) return;
                                var rect = canvas.getBoundingClientRect();
                                var x = ((e.clientX - rect.left) / rect.width) * 100;
                                var y = ((e.clientY - rect.top)  / rect.height) * 100;
                                pending = { canvas: canvas, mediaId: parseInt(canvas.dataset.mediaId, 10), x: x, y: y };
                                search.value = '';
                                renderOptions('');
                                // Position the picker near the click, but keep on-screen.
                                var px = Math.min(window.innerWidth  - 280, e.clientX);
                                var py = Math.min(window.innerHeight - 340, e.clientY);
                                picker.style.left = px + 'px';
                                picker.style.top  = py + 'px';
                                picker.style.display = 'block';
                                setTimeout(function () { search.focus(); }, 0);
                            });
                        });

                        // Remove a tag.
                        document.body.addEventListener('click', function (e) {
                            var btn = e.target.closest('.photo-tag-remove');
                            if (!btn) return;
                            e.stopPropagation();
                            var tagId = btn.dataset.tagId;
                            if (!tagId) return;
                            var fd = new FormData();
                            fd.append('__RequestVerificationToken', token);
                            fetch('/Media/RemovePersonTag/' + tagId, { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': token } })
                                .then(function (r) {
                                    if (r.ok) {
                                        var overlay = btn.closest('.photo-tag-overlay');
                                        if (overlay) overlay.remove();
                                    }
                                });
                        });
                    })();
                    </script>
                }

                <script>
                (function () {
                    var draftFlag = document.getElementById('editIsDraft');
                    if (!draftFlag) return;
                    var publishBtn  = document.getElementById('editPublishBtn');
                    var keepDraftBtn = document.getElementById('editKeepDraftBtn');
                    var saveBtn     = document.getElementById('editSaveBtn');
                    var toDraftBtn  = document.getElementById('editToDraftBtn');
                    if (publishBtn)   publishBtn.addEventListener('click', function () { draftFlag.value = 'False'; });
                    if (keepDraftBtn) keepDraftBtn.addEventListener('click', function () { draftFlag.value = 'True'; });
                    if (saveBtn)      saveBtn.addEventListener('click', function () { draftFlag.value = 'False'; });
                    if (toDraftBtn)   toDraftBtn.addEventListener('click', function () { draftFlag.value = 'True'; });
                })();
                </script>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var textarea = document.getElementById('storyBody');
        var preview  = document.getElementById('pastedImagesPreview');
        var hiddenInputs = document.getElementById('pastedImageInputs');
        if (!textarea || !preview || !hiddenInputs) return;

        function collectImageBlobs(e) {
            var blobs = [];
            var cd = e.clipboardData || (e.originalEvent && e.originalEvent.clipboardData);
            if (!cd) return blobs;
            if (cd.items && cd.items.length) {
                for (var i = 0; i < cd.items.length; i++) {
                    var it = cd.items[i];
                    if (it.kind === 'file' && it.type && it.type.indexOf('image') === 0) {
                        var b = it.getAsFile();
                        if (b) blobs.push(b);
                    }
                }
            }
            if (!blobs.length && cd.files && cd.files.length) {
                for (var j = 0; j < cd.files.length; j++) {
                    var f = cd.files[j];
                    if (f.type && f.type.indexOf('image') === 0) blobs.push(f);
                }
            }
            return blobs;
        }

        function uploadAndAttach(blob) {
            var fd = new FormData();
            var name = blob.name || 'pasted-image.png';
            fd.append('file', blob, name);
            fetch('/Posts/UploadPastedImage', { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function (r) {
                    if (!r.ok) throw new Error('Upload failed: ' + r.status);
                    return r.json();
                })
                .then(function (data) {
                    if (!data || !data.url) throw new Error('No URL returned');
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'PastedImageUrls';
                    input.value = data.url;
                    hiddenInputs.appendChild(input);
                    var wrap = document.createElement('div');
                    wrap.style.cssText = 'position:relative;display:inline-block;';
                    var img = document.createElement('img');
                    img.src = data.url;
                    img.style.cssText = 'height:80px;border-radius:6px;object-fit:cover;';
                    var rm = document.createElement('button');
                    rm.type = 'button';
                    rm.innerHTML = '✕';
                    rm.style.cssText = 'position:absolute;top:2px;right:2px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:18px;height:18px;font-size:10px;cursor:pointer;line-height:1;padding:0;';
                    rm.addEventListener('click', function () { wrap.remove(); input.remove(); });
                    wrap.appendChild(img);
                    wrap.appendChild(rm);
                    preview.appendChild(wrap);
                })
                .catch(function (err) {
                    console.error('Pasted-image upload failed', err);
                    var msg = document.createElement('div');
                    msg.className = 'text-danger small';
                    msg.textContent = 'Could not upload pasted image (' + (err && err.message || 'unknown') + ')';
                    preview.appendChild(msg);
                });
        }

        textarea.addEventListener('paste', function (e) {
            var blobs = collectImageBlobs(e);
            if (!blobs.length) return; // not an image — let default text-paste happen
            e.preventDefault();
            blobs.forEach(uploadAndAttach);
        });
    })();

    // Media reorder + click-to-focus — HTML5 drag-and-drop on the existing
    // media tiles, plus a click that sets a per-image focal point used as
    // CSS object-position so the cover-cropped thumb shows the right part
    // of the picture. We discriminate click vs drag by tracking whether the
    // pointer actually moved more than 4px between mousedown and mouseup.
    (function () {
        var grid = document.getElementById('mediaReorderGrid');
        if (!grid) return;
        var src = null;
        function tiles() { return grid.querySelectorAll('.media-reorder-tile'); }
        // Each draggable tile is now wrapped in a .media-tile-row alongside
        // its layout-position panel. We swap rows on drop so the layout
        // panel travels with the photo.
        function rowOf(tile) { return tile.closest('.media-tile-row') || tile; }

        function applyFocus(tile, xPct, yPct) {
            xPct = Math.max(0, Math.min(100, Math.round(xPct)));
            yPct = Math.max(0, Math.min(100, Math.round(yPct)));
            tile.dataset.focusX = String(xPct);
            tile.dataset.focusY = String(yPct);
            tile.style.setProperty('--focus-x', xPct + '%');
            tile.style.setProperty('--focus-y', yPct + '%');
            var pos = xPct + '% ' + yPct + '%';
            tile.querySelectorAll('img,video').forEach(function (el) { el.style.objectPosition = pos; });
            var xi = tile.querySelector('.media-focus-x-input');
            var yi = tile.querySelector('.media-focus-y-input');
            if (xi) xi.value = String(xPct);
            if (yi) yi.value = String(yPct);
        }

        tiles().forEach(function (tile) {
            // Track pointer travel so a tiny mouse twitch doesn't count as a drag.
            var downX = 0, downY = 0, moved = false;
            tile.addEventListener('mousedown', function (e) {
                downX = e.clientX; downY = e.clientY; moved = false;
            });
            tile.addEventListener('mousemove', function (e) {
                if (Math.abs(e.clientX - downX) > 4 || Math.abs(e.clientY - downY) > 4) moved = true;
            });
            tile.addEventListener('click', function (e) {
                if (moved) return; // it was a drag, not a click
                if (e.target.closest('.media-reorder-remove')) return;
                if (e.target.closest('.media-layout-grid')) return; // layout cells handled below
                var rect = tile.getBoundingClientRect();
                var x = ((e.clientX - rect.left) / rect.width) * 100;
                var y = ((e.clientY - rect.top) / rect.height) * 100;
                applyFocus(tile, x, y);
            });

            // 4×8 layout-position picker — click a cell to place; shift-click
            // another cell to span (2 cells, 4 cells, up to all 32). Click
            // the same single active cell again to clear back to Auto.
            var rowEl = tile.parentElement; // .media-tile-row
            var anchor = null;
            (function () {
                var firstActive = (rowEl || tile).querySelector('.media-layout-cell.active');
                if (firstActive) {
                    anchor = { r: parseInt(firstActive.dataset.row, 10), c: parseInt(firstActive.dataset.col, 10) };
                }
            })();

            function refreshActive(r0, c0, r1, c1) {
                var rMin = Math.min(r0, r1), rMax = Math.max(r0, r1);
                var cMin = Math.min(c0, c1), cMax = Math.max(c0, c1);
                (rowEl || tile).querySelectorAll('.media-layout-cell').forEach(function (c) {
                    var r = parseInt(c.dataset.row, 10);
                    var col = parseInt(c.dataset.col, 10);
                    c.classList.toggle('active', r >= rMin && r <= rMax && col >= cMin && col <= cMax);
                });
                var w = (cMax - cMin) + 1;
                var h = (rMax - rMin) + 1;
                tile.querySelector('.media-layout-w-input').value = String(w);
                tile.querySelector('.media-layout-h-input').value = String(h);
                tile.querySelector('.media-layout-col-input').value = String(cMin);
                tile.querySelector('.media-layout-row-input').value = String(rMin);
                // Clear the legacy 9-cell string — the col/row pair is the
                // source of truth now. Server handles either.
                tile.querySelector('.media-layout-input').value = '';
                var n = w * h;
                var label = n === 1 ? '1 cell' : (n + ' cells (' + w + '×' + h + ')');
                var labelEl = (rowEl || tile).querySelector('.media-layout-panel-current');
                if (labelEl) labelEl.textContent = label;
            }

            function clearActive() {
                (rowEl || tile).querySelectorAll('.media-layout-cell').forEach(function (c) { c.classList.remove('active'); });
                tile.querySelector('.media-layout-input').value = '';
                tile.querySelector('.media-layout-w-input').value = '1';
                tile.querySelector('.media-layout-h-input').value = '1';
                tile.querySelector('.media-layout-col-input').value = '-1';
                tile.querySelector('.media-layout-row-input').value = '-1';
                var labelEl = (rowEl || tile).querySelector('.media-layout-panel-current');
                if (labelEl) labelEl.textContent = 'Auto';
                anchor = null;
            }

            (rowEl || tile).querySelectorAll('.media-layout-cell').forEach(function (cell) {
                cell.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var r = parseInt(cell.dataset.row, 10);
                    var c = parseInt(cell.dataset.col, 10);
                    if (e.shiftKey && anchor) {
                        refreshActive(anchor.r, anchor.c, r, c);
                        return;
                    }
                    if (cell.classList.contains('active')
                        && (rowEl || tile).querySelectorAll('.media-layout-cell.active').length === 1) {
                        clearActive();
                        return;
                    }
                    anchor = { r: r, c: c };
                    refreshActive(r, c, r, c);
                });
            });

            tile.addEventListener('dragstart', function (e) {
                src = tile;
                tile.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
                try { e.dataTransfer.setData('text/plain', tile.dataset.mediaId || ''); } catch (_) {}
            });
            tile.addEventListener('dragend', function () {
                tile.classList.remove('dragging');
                tiles().forEach(function (t) { t.classList.remove('drag-over'); });
                src = null;
            });
            tile.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                if (src && tile !== src) tile.classList.add('drag-over');
            });
            tile.addEventListener('dragleave', function () { tile.classList.remove('drag-over'); });
            tile.addEventListener('drop', function (e) {
                e.preventDefault();
                tile.classList.remove('drag-over');
                if (!src || tile === src) return;
                var rect = tile.getBoundingClientRect();
                var midX = rect.left + rect.width / 2;
                var midY = rect.top + rect.height / 2;
                var before = (e.clientY < midY) || (e.clientY < rect.top + rect.height && e.clientX < midX);
                // Move the whole row (tile + its layout panel) so the
                // photo and its position picker stay together.
                var srcRow = rowOf(src);
                var destRow = rowOf(tile);
                grid.insertBefore(srcRow, before ? destRow : destRow.nextSibling);
            });
        });
    })();
    </script>
}
