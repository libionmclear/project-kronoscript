@model MyStoryTold.Models.ViewModels.FeedViewModel
@{
    ViewData["Title"] = "Story Feed";
}

<div class="row g-3">

    <!-- LEFT: Network Sidebar -->
    <div class="col-md-3 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <!-- CENTER: Feed -->
    <div class="col-md-6">
        <h5 class="mb-3 fw-bold" style="color: var(--mst-primary);">📖 Story Feed</h5>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Quick Post Box -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-3">
                <form asp-controller="Posts" asp-action="QuickPost" method="post">
                    @Html.AntiForgeryToken()
                    <textarea name="body" class="form-control border-0 bg-light mb-2"
                              rows="3" placeholder="Share a life story or memory..."
                              required style="resize:none;"></textarea>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <input type="number" name="eventYear" class="form-control form-control-sm"
                               style="width:90px;" placeholder="Year" min="1" max="2100" required />
                        <input type="number" name="eventMonth" class="form-control form-control-sm"
                               style="width:75px;" placeholder="Month" min="1" max="12" />
                        <input type="number" name="eventDay" class="form-control form-control-sm"
                               style="width:70px;" placeholder="Day" min="1" max="31" />
                        <select name="visibility" class="form-select form-select-sm" style="width:auto;">
                            <option value="Public">🔴 Public</option>
                            <option value="Acquaintances">🟡 Acquaintances</option>
                            <option value="Friends" selected>🟢 Friends</option>
                            <option value="Family">🔵 Family</option>
                            <option value="Private">🔒 Only Me</option>
                        </select>
                        <button type="submit" class="btn btn-sm ms-auto" style="background-color:var(--mst-primary);color:white;">
                            + Add Event
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @if (!Model.Posts.Any())
        {
            <div class="text-center py-5 text-muted">
                <h4>Your feed is empty</h4>
                <p>Connect with friends and family to see their life events here.</p>
                <a asp-controller="Friends" asp-action="Index" class="btn btn-primary">Find Friends</a>
            </div>
        }

        @foreach (var item in Model.Posts)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = item.Post.Owner, Size = 36 })
                        <div>
                            <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@item.Post.OwnerUserId" class="fw-semibold text-decoration-none">
                                @(item.Post.Owner.DisplayName ?? item.Post.Owner.UserName)
                            </a>
                            <span class="small text-muted d-flex align-items-center gap-1">@await Html.PartialAsync("_VisibilityDot", item.Post.Visibility) @item.Post.CreatedAt.ToString("MMM d, yyyy")</span>
                        </div>
                    </div>

                    <span class="badge bg-success-subtle text-success mb-2">@item.Post.EventDateDisplay</span>

                    @if (!string.IsNullOrWhiteSpace(item.Post.Title))
                    {
                        <h5>@item.Post.Title</h5>
                    }

                    @if (item.TaggedUsers.Any())
                    {
                        <small class="text-muted">with @string.Join(", ", item.TaggedUsers.Select(t => t.DisplayName))</small>
                    }

                    <p class="mt-2">@(item.Post.Body.Length > 300 ? item.Post.Body[..300] + "..." : item.Post.Body)</p>

                    @if (item.Post.Media.Any())
                    {
                        var firstMedia = item.Post.Media.First();
                        if (firstMedia.MediaType == MyStoryTold.Models.MediaType.Image)
                        {
                            <div class="post-media-wrap mb-2"><img src="@firstMedia.Url" alt="" /></div>
                        }
                    }

                    <div class="d-flex align-items-center gap-3 border-top pt-2">
                        <form asp-controller="Posts" asp-action="ToggleLike" asp-route-id="@item.Post.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm @(item.CurrentUserLiked ? "btn-danger" : "btn-outline-secondary")">
                                ❤ @item.LikeCount
                            </button>
                        </form>
                        <a asp-controller="Posts" asp-action="Detail" asp-route-id="@item.Post.Id" class="btn btn-sm btn-outline-secondary">
                            💬 @item.Post.Comments.Count
                        </a>
                    </div>
                </div>
            </div>
        }

    </div>

    <!-- RIGHT: Quick Links -->
    <div class="col-md-3 col-sidebar">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>

</div>
