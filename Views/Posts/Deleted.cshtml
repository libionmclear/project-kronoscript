@model List<MyStoryTold.Models.LifeEventPost>
@{
    ViewData["Title"] = "Deleted Stories";
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">🗑️ Deleted Stories</h2>
            <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
               class="btn btn-sm btn-outline-secondary">← Back to My Story</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <div class="alert alert-warning small mb-4">
            Stories here are <strong>not visible to anyone</strong> — not on your timeline, not on the feed,
            not on shared links. You can <strong>restore</strong> them or <strong>delete them permanently</strong>.
            Permanent deletion is irreversible — there is no second archive.
        </div>

        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center text-muted p-4">
                    Your archive is empty.
                </div>
            </div>
        }
        else
        {
            foreach (var p in Model)
            {
                <div class="card border-0 shadow-sm mb-2">
                    <div class="card-body p-3 d-flex align-items-start gap-3">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                @if (!string.IsNullOrWhiteSpace(p.Title))
                                {
                                    <span class="fw-semibold">@p.Title</span>
                                }
                                else
                                {
                                    <span class="fw-semibold text-muted">(untitled)</span>
                                }
                                <span class="badge bg-light text-dark small">@p.EventDateDisplay</span>
                            </div>
                            <small class="text-muted">
                                Deleted @p.DeletedAt!.Value.ToString("MMM d, yyyy h:mm tt")
                            </small>
                            @if (!string.IsNullOrWhiteSpace(p.Body))
                            {
                                <div class="text-muted small mt-1" style="white-space:pre-wrap;">
                                    @MyStoryTold.Helpers.BodyRenderer.TextPreview(p.Body, 200)
                                </div>
                            }
                        </div>
                        <div class="d-flex flex-column gap-1">
                            <form asp-action="Restore" asp-route-id="@p.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Restore</button>
                            </form>
                            <form asp-action="DeleteForever" asp-route-id="@p.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this story PERMANENTLY? This cannot be undone — there is no second archive. Type to confirm? (Click OK to permanently delete.)');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Delete forever</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
