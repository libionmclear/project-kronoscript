@model MyStoryTold.Models.ViewModels.PostDetailViewModel
@using MyStoryTold.Helpers
@{
    ViewData["Title"] = Model.Post.Title ?? "Life Event";
    var ogTitle = !string.IsNullOrWhiteSpace(Model.Post.Title) ? Model.Post.Title : "A memory on Kronoscript";
    var ogDesc = BodyRenderer.TextPreview(Model.Post.Body, 200);
    var firstMedia = Model.Post.Media == null ? null
        : Model.Post.Media.OrderBy(m => m.SortOrder).ThenBy(m => m.Id)
            .FirstOrDefault(m => m.MediaType == MyStoryTold.Models.MediaType.Image);
    var ogImage = firstMedia?.Url;
    if (!string.IsNullOrEmpty(ogImage) && ogImage.StartsWith("/"))
    {
        ogImage = $"{Context.Request.Scheme}://{Context.Request.Host}{ogImage}";
    }
    var ogUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
    // Only public posts get social meta — non-public links shouldn't be previewed by anyone receiving the URL.
    var sharePublicly = Model.Post.Visibility == MyStoryTold.Models.PostVisibility.Public;
}
@Html.AntiForgeryToken()

@section Head {
    @if (sharePublicly)
    {
        <meta property="og:type" content="article" />
        <meta property="og:title" content="@ogTitle" />
        <meta property="og:description" content="@ogDesc" />
        <meta property="og:url" content="@ogUrl" />
        <meta property="og:site_name" content="Kronoscript" />
        @if (!string.IsNullOrEmpty(ogImage))
        {
            <meta property="og:image" content="@ogImage" />
            <meta name="twitter:card" content="summary_large_image" />
        }
        else
        {
            <meta name="twitter:card" content="summary" />
        }
        <meta name="twitter:title" content="@ogTitle" />
        <meta name="twitter:description" content="@ogDesc" />
    }
    else
    {
        <!-- Private/Family/Friends-only post: don't expose preview to link recipients. -->
        <meta name="robots" content="noindex,nofollow" />
    }
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">
        @{
            var detailIsChannel = Model.Post.Channel != null;
            var detailIsBio = Model.Post.Owner?.IsBiographical == true;
            // Treat both as "editorial / timeless" — owner is shown for bio
            // (it's the byline) but the posted-on timestamp is hidden so the
            // post reads as evergreen.
            var detailHidePostedAt = detailIsChannel || detailIsBio;
        }

        <!-- Back link: channel posts back out to the home feed (no personal
             timeline context); regular posts back to the writer's timeline. -->
        @if (detailIsChannel)
        {
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none mb-3 d-block">
                ← Back to Home
            </a>
        }
        else
        {
            <a asp-action="Timeline" asp-route-id="@Model.Post.OwnerUserId" class="text-decoration-none mb-3 d-block">
                ← Back to Timeline
            </a>
        }

        @{
            // Pre-decide article layout so the wrapper can swap skins. The
            // full decision logic runs again later for the actual rendering.
            var preNewspaper = Model.Post.LayoutStyle == MyStoryTold.Models.PostLayoutStyle.Newspaper
                || (Model.Post.LayoutStyle == MyStoryTold.Models.PostLayoutStyle.Standard && detailIsChannel);
            var preBook = Model.Post.LayoutStyle == MyStoryTold.Models.PostLayoutStyle.Book
                || (Model.Post.LayoutStyle == MyStoryTold.Models.PostLayoutStyle.Standard && detailIsBio);
            var articleSkin = preNewspaper ? "post-skin-newspaper"
                            : preBook ? "post-skin-book"
                            : "";
        }
        <!-- Post Card -->
        <div class="card border-0 shadow-sm mb-4 @articleSkin">
            <div class="card-body">
                <!-- Author row. Channel posts read as editorial content and
                     intentionally hide both the writer and the posted-on
                     timestamp — the channel badge IS the byline. -->
                <div class="d-flex align-items-center gap-2 mb-3">
                    @if (!detailIsChannel)
                    {
                        @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.Post.Owner, Size = 40 })
                    }
                    <div class="flex-grow-1">
                        @if (!detailIsChannel)
                        {
                            <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Post.OwnerUserId"
                               class="fw-semibold text-decoration-none d-block lh-1">
                                @(Model.Post.Owner.DisplayName ?? Model.Post.Owner.UserName)
                            </a>
                            <small class="text-muted d-inline-flex align-items-center gap-2">
                                @if (!detailHidePostedAt)
                                {
                                    <span>Posted @Model.Post.CreatedAt.ToString("MMM d, yyyy h:mm tt")</span>
                                }
                                @if (Model.CanManage)
                                {
                                    <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="icon-action py-0" title="Edit" aria-label="Edit">
                                        @await Html.PartialAsync("_Icon", "edit")
                                    </a>
                                }
                            </small>
                        }
                        else if (Model.CanManage)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="icon-action py-0" title="Edit" aria-label="Edit">
                                @await Html.PartialAsync("_Icon", "edit")
                            </a>
                        }
                    </div>
                    @{
                        var visibilityLabel = Model.Post.Visibility switch {
                            MyStoryTold.Models.PostVisibility.Public => "🌍 Public",
                            MyStoryTold.Models.PostVisibility.Acquaintances => "👋 Acquaintances",
                            MyStoryTold.Models.PostVisibility.Friends => "👥 Friends",
                            MyStoryTold.Models.PostVisibility.Family => "👨‍👩‍👧 Family",
                            MyStoryTold.Models.PostVisibility.Private => "🔒 Private",
                            _ => ""
                        };
                    }
                    <span class="badge bg-secondary ms-auto">@visibilityLabel</span>
                    @if (Model.CanManage)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="btn btn-sm btn-outline-secondary ms-2" title="Edit story">Edit</a>
                        <form asp-action="Delete" asp-route-id="@Model.Post.Id" method="post" class="d-inline ms-1"
                              onsubmit="return confirm('Move this story to your Deleted Stories archive? It will be hidden from everyone, but you can restore it from there. To delete permanently, open the archive and confirm again.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Move to Deleted Stories">Delete</button>
                        </form>
                    }
                </div>
                <!-- Date / title -->
                <div class="@(string.IsNullOrWhiteSpace(Model.Post.Title) ? "mb-2" : "mb-0")">
                    <span class="badge bg-success-subtle text-success fs-6">@Model.Post.EventDateDisplay</span>
                    @if (!string.IsNullOrEmpty(Model.Post.Location))
                    {
                        <span class="badge bg-light text-dark ms-1">📍 @Model.Post.Location</span>
                    }
                </div>
                @if (Model.Post.Owner?.IsBiographical == true)
                {
                    <a asp-controller="Posts" asp-action="Biographies"
                       class="post-bio-strip post-bio-strip-detail mt-2 text-decoration-none"
                       style="color:inherit;">
                        <span class="post-bio-icon">📜</span>
                        <span class="post-bio-name">Biographical</span>
                        @if (!string.IsNullOrEmpty(Model.Post.Owner.BiographicalEra))
                        {
                            <span class="post-bio-era">@Model.Post.Owner.BiographicalEra</span>
                        }
                        <span class="post-bio-tag">profile</span>
                    </a>
                }
                @if (Model.Post.Channel != null)
                {
                    <a asp-controller="Channel" asp-action="Show" asp-route-slug="@Model.Post.Channel.Slug"
                       class="post-channel-strip post-channel-strip-detail mt-2 text-decoration-none"
                       style="color:inherit;">
                        <span class="post-channel-icon">@(Model.Post.Channel.IconEmoji ?? "📚")</span>
                        <span class="post-channel-name">@Model.Post.Channel.Name</span>
                        <span class="post-channel-tag">channel</span>
                    </a>
                }
                @if (Model.MemoryOf != null)
                {
                    <a asp-action="Detail" asp-route-id="@Model.MemoryOf.Id"
                       class="memory-of-chip mt-2 text-decoration-none"
                       title="The article that inspired this memory">
                        <span class="memory-of-chip-icon">🔗</span>
                        <span class="memory-of-chip-label">Inspired by</span>
                        <span class="memory-of-chip-name">@(string.IsNullOrWhiteSpace(Model.MemoryOf.Title) ? (Model.MemoryOf.Channel?.Name ?? "this story") : Model.MemoryOf.Title)</span>
                    </a>
                }
                @{
                    // Layout decision: prefer the explicit LayoutStyle stamped
                    // on the post (admin/owner-set in Edit). For posts saved
                    // before LayoutStyle existed (Standard default), fall back
                    // to the old heuristic — channel → newspaper, bio → book.
                    var explicitLayout = Model.Post.LayoutStyle;
                    var newspaper = explicitLayout == MyStoryTold.Models.PostLayoutStyle.Newspaper
                        || (explicitLayout == MyStoryTold.Models.PostLayoutStyle.Standard && detailIsChannel);
                    var book = explicitLayout == MyStoryTold.Models.PostLayoutStyle.Book
                        || (explicitLayout == MyStoryTold.Models.PostLayoutStyle.Standard && detailIsBio);
                    var useArticleLayout = newspaper || book;
                    string ByLineEra(MyStoryTold.Models.LifeEventPost p)
                    {
                        // Channel posts say "Channel · date"; biographical or
                        // owner-driven posts use the display name.
                        var src = p.Channel != null
                            ? p.Channel.Name
                            : (p.Owner?.DisplayName ?? p.Owner?.UserName ?? "");
                        var date = p.EventDateDisplay;
                        return string.IsNullOrEmpty(src) ? date : (src + " · " + date);
                    }
                    // Each placed photo lives at a (col,row) on a 4×8 layout
                    // grid with explicit (width,height) span. We compute the
                    // *effective* col/row at render time so legacy 9-cell
                    // codes still work — they map to the same grid origin.
                    (int col, int row) MapLegacy(string p) => p switch
                    {
                        "top-left"     => (0, 0), "top"        => (1, 0), "top-right"    => (3, 0),
                        "left"         => (0, 3), "center"     => (1, 3), "right"        => (3, 3),
                        "bottom-left"  => (0, 6), "bottom"     => (1, 6), "bottom-right" => (3, 6),
                        _ => (-1, -1)
                    };
                    int EffectiveCol(MyStoryTold.Models.PostMedia m) =>
                        m.LayoutCol >= 0 ? m.LayoutCol : MapLegacy(m.LayoutPosition ?? "").col;
                    int EffectiveRow(MyStoryTold.Models.PostMedia m) =>
                        m.LayoutRow >= 0 ? m.LayoutRow : MapLegacy(m.LayoutPosition ?? "").row;
                    bool IsPlaced(MyStoryTold.Models.PostMedia m) => EffectiveRow(m) >= 0;

                    // Top band = rows 0–2; middle band = rows 3–5; bottom band = rows 6–7.
                    var topImages = useArticleLayout
                        ? Model.Post.Media.Where(m => IsPlaced(m) && EffectiveRow(m) <= 2)
                              .OrderBy(m => m.SortOrder).ThenBy(m => m.Id).ToList()
                        : new List<MyStoryTold.Models.PostMedia>();
                    var midImages = useArticleLayout
                        ? Model.Post.Media.Where(m => IsPlaced(m) && EffectiveRow(m) >= 3 && EffectiveRow(m) <= 5)
                              .OrderBy(m => m.SortOrder).ThenBy(m => m.Id).ToList()
                        : new List<MyStoryTold.Models.PostMedia>();
                    var bottomImages = useArticleLayout
                        ? Model.Post.Media.Where(m => IsPlaced(m) && EffectiveRow(m) >= 6)
                              .OrderBy(m => m.SortOrder).ThenBy(m => m.Id).ToList()
                        : new List<MyStoryTold.Models.PostMedia>();
                    var positionedIds = topImages.Concat(midImages).Concat(bottomImages).Select(m => m.Id).ToHashSet();

                    // Float / size class for an image given its (col,width) on
                    // the 4-col grid: col 0 → left float; col+w == 4 → right
                    // float; spans all 4 cols → block hero; otherwise centered
                    // block at the % width matching the span.
                    string SideClass(MyStoryTold.Models.PostMedia m)
                    {
                        var c = EffectiveCol(m);
                        var w = Math.Clamp(m.LayoutWidth < 1 ? 1 : m.LayoutWidth, 1, 4);
                        if (w >= 4) return "art-img-hero";
                        if (c == 0) return "art-img-left";
                        if (c + w >= 4) return "art-img-right";
                        return "art-img-center";
                    }
                    int WidthSpan(MyStoryTold.Models.PostMedia m) =>
                        Math.Clamp(m.LayoutWidth < 1 ? 1 : m.LayoutWidth, 1, 4);
                    int HeightSpan(MyStoryTold.Models.PostMedia m) =>
                        Math.Clamp(m.LayoutHeight < 1 ? 1 : m.LayoutHeight, 1, 8);
                }

                @{
                    // Newspaper layout uses an explicit 2-column CSS *grid* —
                    // not multicol — so every figure can be deterministically
                    // placed in a journal column. The grid splits the 4×8
                    // placement grid down the middle: cols 0-1 → first journal
                    // column, cols 2-3 → second. Width-3+ images become
                    // heroes and live outside the grid.
                    bool IsHero(MyStoryTold.Models.PostMedia m) => WidthSpan(m) >= 3;
                    int JournalCol(MyStoryTold.Models.PostMedia m)
                    {
                        if (IsHero(m)) return -1;
                        var c = EffectiveCol(m);
                        var w = WidthSpan(m);
                        // Center of the image in grid units; left of center
                        // → first journal col, otherwise second.
                        return (c + w / 2.0) <= 2.0 ? 0 : 1;
                    }
                    // Float / size class re-computed *within* a journal col:
                    // alignment to the left edge of journal col → left float;
                    // right edge → right float; full-col width → block.
                    string SideClassInCol(MyStoryTold.Models.PostMedia m, int journalCol)
                    {
                        if (IsHero(m)) return "art-img-hero";
                        var c = EffectiveCol(m);
                        var w = WidthSpan(m);
                        if (w >= 2)
                        {
                            // Spans the full journal col → treat as block.
                            return "art-img-fill";
                        }
                        if (journalCol == 0)
                        {
                            if (c == 0) return "art-img-left";
                            if (c + w == 2) return "art-img-right";
                            return "art-img-center";
                        }
                        if (journalCol == 1)
                        {
                            if (c == 2) return "art-img-left";
                            if (c + w == 4) return "art-img-right";
                            return "art-img-center";
                        }
                        return "art-img-center";
                    }

                    var allPlaced = topImages.Concat(midImages).Concat(bottomImages).ToList();
                    var topHeroes = allPlaced.Where(m => IsHero(m) && EffectiveRow(m) <= 4)
                                             .OrderBy(m => EffectiveRow(m)).ToList();
                    var bottomHeroes = allPlaced.Where(m => IsHero(m) && EffectiveRow(m) >= 5)
                                                .OrderBy(m => EffectiveRow(m)).ToList();

                    // Approximate how many *characters of body text* an image
                    // displaces inside its journal column. Used to balance
                    // the two-column split — without this, a column with a
                    // big top picture ends up shorter than the other.
                    int CharDisplacement(MyStoryTold.Models.PostMedia m)
                    {
                        if (IsHero(m)) return 0;
                        var w = WidthSpan(m);
                        var h = HeightSpan(m);
                        // Aspect ratio = height / width, mirroring the CSS:
                        //   h-1 → ~auto (assume 3/4); h-2 → 3/4; h-3 → 4/3;
                        //   h-4/5 → 3/2; h-6/7/8 → 16/9.
                        double aspect = h switch
                        {
                            2 => 0.75,
                            3 => 1.333,
                            4 or 5 => 1.5,
                            6 or 7 or 8 => 1.778,
                            _ => 0.667
                        };
                        // ~10 lines of text per "column-width" of vertical space
                        // (line-height ≈ 28px, journal-col width ≈ 280px).
                        double widthFraction = w >= 2 ? 1.0 : 0.5;
                        double lines = widthFraction * aspect * 10.0;
                        const int charsPerLine = 50;
                        // Float (w=1): text wraps around it — only half the
                        // adjacent line-chars are eaten. Block (w>=2): text
                        // starts under the picture, so the full count is eaten.
                        return w >= 2
                            ? (int)(lines * charsPerLine)
                            : (int)(lines * charsPerLine * 0.5);
                    }

                    // Map a non-hero image's row to a paragraph-anchor index
                    // within its column. -1 = before all paragraphs;
                    // [0..N-1] = "after paragraph i". Top rows (0-2) anchor
                    // before the first paragraph so the picture sits at the
                    // top of its column with text flowing under it.
                    Dictionary<int, List<MyStoryTold.Models.PostMedia>> BuildRowMap(
                        IEnumerable<MyStoryTold.Models.PostMedia> imgs, int paraInCol)
                    {
                        var map = new Dictionary<int, List<MyStoryTold.Models.PostMedia>>();
                        foreach (var m in imgs)
                        {
                            int idx;
                            var row = EffectiveRow(m);
                            if (paraInCol == 0) idx = -1;
                            else if (row <= 2) idx = -1;
                            else if (row >= 6) idx = paraInCol - 1;
                            else
                            {
                                var rowFrac = (row - 3) / 3.0;
                                idx = (int)Math.Round(rowFrac * (paraInCol - 1));
                                idx = Math.Clamp(idx, 0, paraInCol - 1);
                            }
                            if (!map.TryGetValue(idx, out var list))
                            {
                                list = new List<MyStoryTold.Models.PostMedia>();
                                map[idx] = list;
                            }
                            list.Add(m);
                        }
                        return map;
                    }

                    // Classify non-hero images by journal column up-front so we
                    // can compute their displacement before deciding the text
                    // split.
                    var leftImgs = newspaper
                        ? allPlaced.Where(m => !IsHero(m) && JournalCol(m) == 0).OrderBy(m => EffectiveRow(m)).ToList()
                        : allPlaced.Where(m => !IsHero(m)).OrderBy(m => EffectiveRow(m)).ToList();
                    var rightImgs = newspaper
                        ? allPlaced.Where(m => !IsHero(m) && JournalCol(m) == 1).OrderBy(m => EffectiveRow(m)).ToList()
                        : new List<MyStoryTold.Models.PostMedia>();

                    // Newspaper: distribute body text across two journal cols
                    // so each column reads to roughly the same vertical
                    // height. Body is broken into "atoms" — paragraphs, but
                    // any single paragraph that's more than ~40% of the full
                    // column-equivalent height gets split at the sentence
                    // boundary closest to its midpoint, so a body that's just
                    // one giant paragraph can still balance.
                    List<Microsoft.AspNetCore.Html.IHtmlContent> leftPars;
                    List<Microsoft.AspNetCore.Html.IHtmlContent> rightPars = new();
                    if (newspaper)
                    {
                        var rawTexts = string.IsNullOrEmpty(Model.Post.Body)
                            ? new List<string>()
                            : Model.Post.Body.Replace("\r\n", "\n")
                                .Split("\n\n", StringSplitOptions.None)
                                .Select(s => s.Trim('\n'))
                                .Where(s => !string.IsNullOrWhiteSpace(s))
                                .ToList();

                        int leftDisp = leftImgs.Sum(CharDisplacement);
                        int rightDisp = rightImgs.Sum(CharDisplacement);
                        int totalChars = rawTexts.Sum(s => s.Length);
                        int splitThreshold = Math.Max(600, (totalChars + leftDisp + rightDisp) * 2 / 5);

                        var atoms = new List<string>();
                        foreach (var p in rawTexts)
                        {
                            if (p.Length <= splitThreshold)
                            {
                                atoms.Add(p);
                                continue;
                            }
                            // Split a too-long paragraph at the sentence break
                            // closest to its midpoint. Stay inside the middle
                            // 2/3 so we don't end up with a single-sentence
                            // sliver hanging off either edge.
                            var matches = System.Text.RegularExpressions.Regex
                                .Matches(p, @"(?<=[.!?])\s+");
                            int target = p.Length / 2;
                            int bestPos = -1;
                            int bestDist = int.MaxValue;
                            foreach (System.Text.RegularExpressions.Match mm in matches)
                            {
                                int pos = mm.Index + mm.Length;
                                if (pos <= p.Length / 6 || pos >= p.Length * 5 / 6) continue;
                                int dist = Math.Abs(pos - target);
                                if (dist < bestDist) { bestDist = dist; bestPos = pos; }
                            }
                            if (bestPos < 0)
                            {
                                atoms.Add(p);
                            }
                            else
                            {
                                atoms.Add(p.Substring(0, bestPos).TrimEnd());
                                atoms.Add(p.Substring(bestPos).TrimStart());
                            }
                        }

                        // Re-render through the body pipeline by joining the
                        // atoms with blank lines (so RenderBodyParagraphs
                        // produces one IHtmlContent per atom).
                        var atomsBody = string.Join("\n\n", atoms);
                        var atomParas = BodyRenderer.RenderBodyParagraphs(atomsBody);

                        // Find the atom split index that puts us closest to
                        // visual height parity:
                        //   textL + leftDisp ≈ textR + rightDisp
                        //   textL = (totalText - leftDisp + rightDisp) / 2
                        int textTotal = atoms.Sum(a => a.Length);
                        int targetLeft = (textTotal - leftDisp + rightDisp) / 2;
                        int splitIdx;
                        if (atomParas.Count <= 1)
                        {
                            splitIdx = atomParas.Count;
                        }
                        else
                        {
                            int bestSplit = 1;
                            int bestSplitDist = int.MaxValue;
                            int running = 0;
                            for (int i = 0; i < atoms.Count; i++)
                            {
                                running += atoms[i].Length;
                                int d = Math.Abs(running - targetLeft);
                                if (d < bestSplitDist) { bestSplitDist = d; bestSplit = i + 1; }
                            }
                            splitIdx = Math.Clamp(bestSplit, 1, atomParas.Count - 1);
                        }
                        leftPars = atomParas.Take(splitIdx).ToList();
                        rightPars = atomParas.Skip(splitIdx).ToList();
                    }
                    else
                    {
                        leftPars = BodyRenderer.RenderBodyParagraphs(Model.Post.Body);
                    }

                    var leftMap = BuildRowMap(leftImgs, leftPars.Count);
                    var rightMap = BuildRowMap(rightImgs, rightPars.Count);
                }

                @if (useArticleLayout)
                {
                    <article class="article-layout @(newspaper ? "article-newspaper" : "article-book")">
                        <header class="article-head">
                            @if (!string.IsNullOrWhiteSpace(Model.Post.Title))
                            {
                                <h1 class="article-headline" data-translate-title="@Model.Post.Id">@Model.Post.Title</h1>
                            }
                            <div class="article-byline">@ByLineEra(Model.Post)</div>
                            @if (Model.TaggedUsers.Any())
                            {
                                <div class="article-tagged">with
                                    @foreach (var tag in Model.TaggedUsers)
                                    {
                                        <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@tag.UserId" class="fw-semibold text-decoration-none">@tag.DisplayName</a>
                                        if (tag != Model.TaggedUsers.Last()) { <text>, </text> }
                                    }
                                </div>
                            }
                        </header>

                        @if (!string.IsNullOrWhiteSpace(Model.Post.MusicUrl))
                        {
                            <a href="@Model.Post.MusicUrl" target="_blank" rel="noopener" class="post-music-chip mb-2">
                                🎵 Memory Music
                            </a>
                        }

                        @* Heroes (width-3+ images) span the article width and
                           are rendered outside the column grid. Top heroes sit
                           above the prose; bottom heroes below. *@
                        @foreach (var m in topHeroes)
                        {
                            <figure class="article-image art-img-hero art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                @if (!string.IsNullOrWhiteSpace(m.Caption))
                                {
                                    <figcaption>@m.Caption</figcaption>
                                }
                            </figure>
                        }

                        @if (newspaper)
                        {
                            <div class="article-prose article-news-grid" data-translate-body="@Model.Post.Id">
                                <div class="article-news-col article-news-col-1">
                                    @if (leftMap.TryGetValue(-1, out var lpre))
                                    {
                                        foreach (var m in lpre)
                                        {
                                            <figure class="article-image @SideClassInCol(m, 0) art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                                <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                                @if (!string.IsNullOrWhiteSpace(m.Caption)) { <figcaption>@m.Caption</figcaption> }
                                            </figure>
                                        }
                                    }
                                    @for (int pi = 0; pi < leftPars.Count; pi++)
                                    {
                                        <p>@leftPars[pi]</p>
                                        if (leftMap.TryGetValue(pi, out var figs))
                                        {
                                            foreach (var m in figs)
                                            {
                                                <figure class="article-image @SideClassInCol(m, 0) art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                                    <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                                    @if (!string.IsNullOrWhiteSpace(m.Caption)) { <figcaption>@m.Caption</figcaption> }
                                                </figure>
                                            }
                                        }
                                    }
                                </div>
                                <div class="article-news-col article-news-col-2">
                                    @if (rightMap.TryGetValue(-1, out var rpre))
                                    {
                                        foreach (var m in rpre)
                                        {
                                            <figure class="article-image @SideClassInCol(m, 1) art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                                <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                                @if (!string.IsNullOrWhiteSpace(m.Caption)) { <figcaption>@m.Caption</figcaption> }
                                            </figure>
                                        }
                                    }
                                    @for (int pi = 0; pi < rightPars.Count; pi++)
                                    {
                                        <p>@rightPars[pi]</p>
                                        if (rightMap.TryGetValue(pi, out var figs))
                                        {
                                            foreach (var m in figs)
                                            {
                                                <figure class="article-image @SideClassInCol(m, 1) art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                                    <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                                    @if (!string.IsNullOrWhiteSpace(m.Caption)) { <figcaption>@m.Caption</figcaption> }
                                                </figure>
                                            }
                                        }
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="article-prose" data-translate-body="@Model.Post.Id">
                                @if (leftMap.TryGetValue(-1, out var bpre))
                                {
                                    foreach (var m in bpre)
                                    {
                                        <figure class="article-image @SideClass(m) art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                            <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                            @if (!string.IsNullOrWhiteSpace(m.Caption)) { <figcaption>@m.Caption</figcaption> }
                                        </figure>
                                    }
                                }
                                @for (int pi = 0; pi < leftPars.Count; pi++)
                                {
                                    <p>@leftPars[pi]</p>
                                    if (leftMap.TryGetValue(pi, out var figs))
                                    {
                                        foreach (var m in figs)
                                        {
                                            <figure class="article-image @SideClass(m) art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                                <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                                @if (!string.IsNullOrWhiteSpace(m.Caption)) { <figcaption>@m.Caption</figcaption> }
                                            </figure>
                                        }
                                    }
                                }
                            </div>
                        }

                        @foreach (var m in bottomHeroes)
                        {
                            <figure class="article-image art-img-hero art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                @if (!string.IsNullOrWhiteSpace(m.Caption))
                                {
                                    <figcaption>@m.Caption</figcaption>
                                }
                            </figure>
                        }

                        @if (Model.Post.LastEditedAt != null)
                        {
                            <div class="post-edited-note mt-3">
                                edited @Model.Post.LastEditedAt.Value.ToString("MMM d, yyyy h:mm tt")
                            </div>
                        }

                        @* "Connect your memory" — invites readers to write
                           their own personal recollection of this event.
                           Only on channel posts (where it makes sense as a
                           shared moment) and never on the writer's own draft
                           or on a private/family post the reader can't see. *@
                        @if (detailIsChannel && User.Identity?.IsAuthenticated == true)
                        {
                            <div class="connect-memory-bar mt-4">
                                <a asp-action="Create" asp-route-memoryOfId="@Model.Post.Id"
                                   class="connect-memory-btn">
                                    <span class="connect-memory-icon">🔗</span>
                                    <span class="connect-memory-label">
                                        <span class="connect-memory-title">Connect your memory to this story</span>
                                        <span class="connect-memory-sub">Write where you were, what you remember — your version goes on your timeline.</span>
                                    </span>
                                </a>
                                @if (Model.ConnectedMemoryCount > 0)
                                {
                                    <a asp-action="Memories" asp-route-id="@Model.Post.Id" class="connect-memory-count">
                                        @Model.ConnectedMemoryCount @(Model.ConnectedMemoryCount == 1 ? "memory" : "memories") connected →
                                    </a>
                                }
                            </div>
                        }
                        else if (detailIsChannel && Model.ConnectedMemoryCount > 0)
                        {
                            <div class="connect-memory-bar mt-4">
                                <a asp-action="Memories" asp-route-id="@Model.Post.Id" class="connect-memory-count">
                                    @Model.ConnectedMemoryCount @(Model.ConnectedMemoryCount == 1 ? "memory" : "memories") connected →
                                </a>
                            </div>
                        }
                    </article>
                }
                else
                {
                @if (!string.IsNullOrWhiteSpace(Model.Post.Title))
                {
                    <h5 class="mt-1 mb-0 fw-semibold" data-translate-title="@Model.Post.Id">@Model.Post.Title</h5>
                }

                <!-- Tags -->
                @if (Model.TaggedUsers.Any())
                {
                    <div class="mb-3">
                        <small class="text-muted">with
                            @foreach (var tag in Model.TaggedUsers)
                            {
                                <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@tag.UserId" class="fw-semibold text-decoration-none">@tag.DisplayName</a>
                                if (tag != Model.TaggedUsers.Last()) { <text>, </text> }
                            }
                        </small>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Post.MusicUrl))
                {
                    <a href="@Model.Post.MusicUrl" target="_blank" rel="noopener" class="post-music-chip mb-2">
                        🎵 Memory Music
                    </a>
                }
                <!-- Body -->
                <div class="post-body mb-2 mt-0" data-translate-body="@Model.Post.Id" style="white-space: pre-wrap; line-height: 1.6;">
                    @BodyRenderer.RenderBody(Model.Post.Body)
                </div>
                @if (Model.Post.LastEditedAt != null)
                {
                    <div class="post-edited-note mb-3">
                        edited @Model.Post.LastEditedAt.Value.ToString("MMM d, yyyy h:mm tt")
                    </div>
                }
                }

                <!-- Media — for personal posts, render ALL media here. For
                     article-layout posts, only the unpositioned media falls
                     through to this grid. -->
                @if (Model.Post.Media.Any() && !(useArticleLayout && positionedIds.Count == Model.Post.Media.Count))
                {
                    var dMedia = (useArticleLayout
                            ? Model.Post.Media.Where(m => !positionedIds.Contains(m.Id))
                            : Model.Post.Media)
                        .OrderBy(m => m.SortOrder).ThenBy(m => m.Id).ToList();
                    var dJson = System.Text.Json.JsonSerializer.Serialize(
                        dMedia.Select(m => new { id = m.Id, url = m.Url, type = m.MediaType.ToString() }));
                    var dShow = Math.Min(4, dMedia.Count);
                    var dExtra = dMedia.Count - dShow;
                    <div class="feed-media-grid feed-media-grid-@dShow mb-3"
                         data-media='@Html.Raw(dJson)'>
                        @for (int i = 0; i < dShow; i++)
                        {
                            var media = dMedia[i];
                            var isLast = i == dShow - 1;
                            <button type="button" class="feed-media-thumb-btn" data-index="@i">
                                @if (media.MediaType == MyStoryTold.Models.MediaType.Image)
                                {
                                    <img src="@media.Url" alt="@media.Caption" class="feed-media-thumb"
                                         style="object-position:@(media.FocusX)% @(media.FocusY)%;" />
                                }
                                else
                                {
                                    <video src="@media.Url" class="feed-media-thumb" preload="metadata" muted
                                           style="object-position:@(media.FocusX)% @(media.FocusY)%;"></video>
                                }
                                @if (isLast && dExtra > 0)
                                {
                                    <span class="feed-media-more">+@dExtra</span>
                                }
                            </button>
                        }
                    </div>
                }

                <!-- Actions -->
                <div class="d-flex align-items-center gap-3 border-top pt-3 flex-wrap">
                    @await Html.PartialAsync("_ReactionWidget",
                        (Model.Post.Id, (int?)(Model.CurrentUserReaction.HasValue ? (int)Model.CurrentUserReaction.Value : (int?)null), Model.LikeCount, ReactionTooltip.Build(Model.Post.Likes)))
                    <span class="icon-action" style="cursor:default;">
                        @await Html.PartialAsync("_Icon", "message") @Model.Comments.Count
                    </span>
                    <button type="button" class="icon-action btn-share-post" data-post-id="@Model.Post.Id" title="Copy link to this story">
                        @await Html.PartialAsync("_Icon", "share")
                    </button>
                    <partial name="_TranslateButton" model="@Model.Post.Id" />
                    @if (!Model.IsOwner)
                    {
                        <form asp-controller="Reports" asp-action="Create" method="post" class="m-0 ms-auto"
                              onsubmit="var r = prompt('Why are you reporting this story? (Optional context for the admins.)'); if (r === null) return false; this.elements.reason.value = r || ''; return confirm('Send this report to the admins?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="targetType" value="Post" />
                            <input type="hidden" name="targetId" value="@Model.Post.Id" />
                            <input type="hidden" name="reason" value="" />
                            <input type="hidden" name="returnUrl" value="@Url.Action("Detail", new { id = Model.Post.Id })" />
                            <button type="submit" class="icon-action" title="Report this story" style="color: #dc3545;">
                                🚩
                            </button>
                        </form>
                    }
                </div>

                <!-- Comments (merged into same card, threaded one level) -->
                @{
                    var repliesByParent = Model.Comments
                        .Where(c => c.ParentCommentId != null)
                        .GroupBy(c => c.ParentCommentId!.Value)
                        .ToDictionary(g => g.Key, g => g.OrderBy(c => c.CreatedAt).ToList());
                    var topLevel = Model.Comments.Where(c => c.ParentCommentId == null).OrderBy(c => c.CreatedAt).ToList();

                    string RenderBodyWithMentions(MyStoryTold.Models.Comment c)
                    {
                        var html = BodyRenderer.RenderBody(c.Body).ToString()!;
                        if (Model.CommentMentions.TryGetValue(c.Id, out var mentions))
                        {
                            foreach (var m in mentions)
                            {
                                var url = $"/Posts/Timeline/{m.UserId}";
                                html = html.Replace($"@{m.UserName}", $"<a href='{url}' class='fw-semibold text-decoration-none'>@{m.DisplayName}</a>");
                            }
                        }
                        return html;
                    }
                }

                @{
                    var meId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                }
                @foreach (var comment in topLevel)
                {
                    var isAuthor = comment.AuthorUserId == meId;
                    var canDelete = isAuthor || Model.CanManage;
                    <div class="comment-row" id="comment-@comment.Id" data-comment-id="@comment.Id">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = comment.Author, Size = 28 })
                            <div class="flex-grow-1 d-flex justify-content-between align-items-center flex-wrap gap-1">
                                <strong class="small">@(comment.Author.DisplayName ?? comment.Author.UserName)</strong>
                                <small class="text-muted">@comment.CreatedAt.ToString("MMM d, yyyy h:mm tt")</small>
                            </div>
                        </div>
                        <div class="mb-1 mt-1 comment-body" data-translate-comment-body="@comment.Id">@Html.Raw(RenderBodyWithMentions(comment))</div>
                        <div class="comment-edit-form mt-1" style="display:none;">
                            <textarea class="form-control form-control-sm comment-edit-input" rows="2" maxlength="2000">@comment.Body</textarea>
                            <div class="d-flex gap-2 mt-1">
                                <button type="button" class="btn btn-sm btn-primary comment-edit-save">Save</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary comment-edit-cancel">Cancel</button>
                            </div>
                        </div>
                        @{
                            var cLike = Model.CommentLikes.TryGetValue(comment.Id, out var ci) ? ci : (Count: 0, LikedByMe: false);
                        }
                        <div class="d-flex align-items-center gap-3 mt-1 comment-actions">
                            <button type="button" class="btn-comment-like @(cLike.LikedByMe ? "is-liked" : "")"
                                    data-comment-id="@comment.Id" aria-label="@(cLike.LikedByMe ? "Unlike comment" : "Like comment")">
                                @await Html.PartialAsync("_Icon", "heart")
                                <span class="comment-like-count">@(cLike.Count > 0 ? cLike.Count.ToString() : "")</span>
                            </button>
                            @if (Model.CanComment)
                            {
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted reply-toggle"
                                        data-target="reply-form-@comment.Id"
                                        data-bs-toggle="tooltip" data-bs-title="Reply"
                                        aria-label="Reply"
                                        style="font-size:0.95rem;text-decoration:none;line-height:1;">↪</button>
                            }
                            @if (isAuthor)
                            {
                                <button type="button" class="btn btn-link btn-sm p-0 text-muted comment-edit-toggle"
                                        data-bs-toggle="tooltip" data-bs-title="Edit"
                                        aria-label="Edit"
                                        style="font-size:0.85rem;text-decoration:none;line-height:1;">✎</button>
                            }
                            @if (canDelete)
                            {
                                <button type="button" class="btn btn-link btn-sm p-0 comment-delete"
                                        data-bs-toggle="tooltip" data-bs-title="Delete comment"
                                        aria-label="Delete comment"
                                        style="font-size:0.85rem;color:#dc3545 !important;text-decoration:none;line-height:1;">✕</button>
                            }
                        </div>

                        @if (repliesByParent.TryGetValue(comment.Id, out var replies))
                        {
                            foreach (var reply in replies)
                            {
                                <div class="comment-reply mt-2">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = reply.Author, Size = 24 })
                                        <div class="flex-grow-1 d-flex justify-content-between align-items-center flex-wrap gap-1">
                                            <strong class="small">@(reply.Author.DisplayName ?? reply.Author.UserName)</strong>
                                            <small class="text-muted">@reply.CreatedAt.ToString("MMM d, yyyy h:mm tt")</small>
                                        </div>
                                    </div>
                                    <div class="mb-0 mt-1" data-translate-comment-body="@reply.Id">@Html.Raw(RenderBodyWithMentions(reply))</div>
                                    @{
                                        var rLike = Model.CommentLikes.TryGetValue(reply.Id, out var ri) ? ri : (Count: 0, LikedByMe: false);
                                    }
                                    <button type="button" class="btn-comment-like mt-1 @(rLike.LikedByMe ? "is-liked" : "")"
                                            data-comment-id="@reply.Id" aria-label="@(rLike.LikedByMe ? "Unlike reply" : "Like reply")">
                                        @await Html.PartialAsync("_Icon", "heart")
                                        <span class="comment-like-count">@(rLike.Count > 0 ? rLike.Count.ToString() : "")</span>
                                    </button>
                                </div>
                            }
                        }

                        @if (Model.CanComment)
                        {
                            <div class="reply-form comment-reply mt-2" id="reply-form-@comment.Id" style="display:none;">
                                <form asp-action="AddComment" method="post">
                                    <input type="hidden" name="PostId" value="@Model.Post.Id" />
                                    <input type="hidden" name="ParentCommentId" value="@comment.Id" />
                                    <textarea name="Body" class="form-control form-control-sm mb-1" rows="1" placeholder="Write a reply..." required></textarea>
                                    <div class="d-flex justify-content-end">
                                        <button type="submit" class="btn btn-sm btn-primary">Reply</button>
                                    </div>
                                </form>
                            </div>
                        }
                    </div>
                }

                <!-- Add Comment -->
                @if (Model.CanComment)
                {
                    var friendsJson = System.Text.Json.JsonSerializer.Serialize(
                        Model.TaggableFriends.Select(f => new { userName = f.DisplayName, displayName = f.DisplayName })
                    );
                    <div class="border-top pt-3 mt-3">
                        <form asp-action="AddComment" method="post">
                            <input type="hidden" name="PostId" value="@Model.Post.Id" />
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            <div class="position-relative mb-2">
                                <textarea id="commentBody" name="Body" class="form-control" rows="2"
                                          placeholder="Write a comment... type @@ to mention a friend" required
                                          data-friends='@Html.Raw(friendsJson)'></textarea>
                                <div id="mentionDropdown" class="list-group position-absolute shadow" style="z-index:1000;display:none;max-width:250px;"></div>
                            </div>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-sm btn-primary">Comment</button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3 border-top mt-3">
                        <em>Only friends and family can comment on this post.</em>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.reply-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var target = document.getElementById(btn.dataset.target);
            if (!target) return;
            target.style.display = (target.style.display === 'none' || !target.style.display) ? 'block' : 'none';
            var ta = target.querySelector('textarea');
            if (ta && target.style.display === 'block') ta.focus();
        });
    });
});
</script>
<script>
(function () {
    const textarea = document.getElementById('commentBody');
    if (!textarea) return;

    const dropdown = document.getElementById('mentionDropdown');
    const friends = JSON.parse(textarea.dataset.friends || '[]');
    let mentionStart = -1;

    textarea.addEventListener('input', function () {
        const val = textarea.value;
        const cursor = textarea.selectionStart;
        const textUpToCursor = val.substring(0, cursor);
        const atIndex = textUpToCursor.lastIndexOf('@@');

        if (atIndex === -1) { hideDropdown(); return; }

        const query = textUpToCursor.substring(atIndex + 1).toLowerCase();
        if (query.includes(' ')) { hideDropdown(); return; }

        mentionStart = atIndex;
        const filtered = friends.filter(f => f.displayName.toLowerCase().startsWith(query));

        if (filtered.length === 0) { hideDropdown(); return; }

        dropdown.innerHTML = '';
        filtered.slice(0, 6).forEach(f => {
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'list-group-item list-group-item-action py-1 px-2';
            item.textContent = '@@' + f.displayName;
            item.addEventListener('mousedown', function (e) {
                e.preventDefault();
                const before = textarea.value.substring(0, mentionStart);
                const after = textarea.value.substring(cursor);
                textarea.value = before + '@@' + f.userName + ' ' + after;
                hideDropdown();
                textarea.focus();
            });
            dropdown.appendChild(item);
        });
        dropdown.style.display = 'block';
    });

    textarea.addEventListener('blur', function () {
        setTimeout(hideDropdown, 150);
    });

    function hideDropdown() { dropdown.style.display = 'none'; }
})();
</script>
}
