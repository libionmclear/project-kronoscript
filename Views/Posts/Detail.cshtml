                                    @{
                                        var rLike = Model.CommentLikes.TryGetValue(reply.Id, out var ri) ? ri : (Count: 0, LikedByMe: false);
                                    }
                                    <button type="button" class="btn-comment-like mt-1 @(rLike.LikedByMe ? "is-liked" : "")"
                                            data-comment-id="@reply.Id" aria-label="@(rLike.LikedByMe ? "Unlike reply" : "Like reply")">
                                        @await Html.PartialAsync("_Icon", "heart")
                                        <span class="comment-like-count">@(rLike.Count > 0 ? rLike.Count.ToString() : "")</span>
                                    </button>
                                </div>
                            }
                        }

                        @if (Model.CanComment)
                        {
                            <div class="reply-form comment-reply mt-2" id="reply-form-@comment.Id" style="display:none;">
                                <form asp-action="AddComment" method="post">
                                    <input type="hidden" name="PostId" value="@Model.Post.Id" />
                                    <input type="hidden" name="ParentCommentId" value="@comment.Id" />
