                            <figure class="article-image art-img-hero art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
