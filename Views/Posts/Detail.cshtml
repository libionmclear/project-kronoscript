@model MyStoryTold.Models.ViewModels.PostDetailViewModel
@{
    ViewData["Title"] = Model.Post.Title ?? "Life Event";
}

<div class="row g-3">
    <div class="col-md-3">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-6">
        <!-- Back link -->
        <a asp-action="Timeline" asp-route-id="@Model.Post.OwnerUserId" class="text-decoration-none mb-3 d-block">
            ← Back to Timeline
        </a>

        <!-- Post Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <span class="badge bg-success-subtle text-success fs-6">@Model.Post.EventDateDisplay</span>
                        @{
                            var visibilityLabel = Model.Post.Visibility switch {
                                MyStoryTold.Models.PostVisibility.Public => "🌍 Public",
                                MyStoryTold.Models.PostVisibility.Acquaintances => "👋 Acquaintances",
                                MyStoryTold.Models.PostVisibility.Friends => "👥 Friends",
                                MyStoryTold.Models.PostVisibility.Family => "👨‍👩‍👧 Family",
                                MyStoryTold.Models.PostVisibility.Private => "🔒 Private",
                                _ => ""
                            };
                        }
                        <span class="badge bg-secondary ms-1">@visibilityLabel</span>
                        @if (!string.IsNullOrEmpty(Model.Post.Location))
                        {
                            <span class="badge bg-light text-dark ms-1">📍 @Model.Post.Location</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Post.Title))
                        {
                            <h3 class="mt-2 mb-0">@Model.Post.Title</h3>
                        }
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block">by @(Model.Post.Owner.DisplayName ?? Model.Post.Owner.UserName)</small>
                        <small class="text-muted">Posted @Model.Post.CreatedAt.ToString("MMM d, yyyy h:mm tt")</small>
                    </div>
                </div>

                <!-- Tags -->
                @if (Model.TaggedUsers.Any())
                {
                    <div class="mb-3">
                        <small class="text-muted">🏷️ Tagged:
                            @foreach (var tag in Model.TaggedUsers)
                            {
                                <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@tag.UserId" class="fw-semibold text-decoration-none">@tag.DisplayName</a>
                                if (tag != Model.TaggedUsers.Last()) { <text>, </text> }
                            }
                        </small>
                    </div>
                }

                <!-- Body with diff -->
                <div class="post-body mb-3" style="white-space: pre-wrap; line-height: 1.8;">
                    @if (Model.DiffHtml != null && Model.Post.LastEditedAt != null)
                    {
                        @Html.Raw(Model.DiffHtml)
                        <div class="mt-2">
                            <small class="text-muted fst-italic">Edited on @Model.Post.LastEditedAt?.ToString("MMM d, yyyy h:mm tt")</small>
                        </div>
                    }
                    else
                    {
                        @Model.Post.Body
                    }
                </div>

                <!-- Media -->
                @if (Model.Post.Media.Any())
                {
                    <div class="mb-3">
                        @foreach (var media in Model.Post.Media)
                        {
                            <div class="post-media-wrap mb-2">
                                @if (media.MediaType == MyStoryTold.Models.MediaType.Image)
                                {
                                    <img src="@media.Url" alt="@media.Caption" />
                                }
                                else
                                {
                                    <video src="@media.Url" controls></video>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Actions -->
                <div class="d-flex align-items-center gap-3 border-top pt-3">
                    <form asp-action="ToggleLike" asp-route-id="@Model.Post.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm @(Model.CurrentUserLiked ? "btn-danger" : "btn-outline-secondary")">
                            ❤ @Model.LikeCount
                        </button>
                    </form>

                    @if (Model.IsOwner)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="btn btn-sm btn-outline-primary ms-auto">
                            ✏️ Edit
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Comments Section -->
        <h5 class="mb-3">💬 Memories & Comments (@Model.Comments.Count)</h5>

        @foreach (var comment in Model.Comments)
        {
            <div class="card border-0 bg-light mb-2">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between">
                        <strong>@(comment.Author.DisplayName ?? comment.Author.UserName)</strong>
                        <small class="text-muted">@comment.EventDateDisplay · @comment.CreatedAt.ToString("MMM d, yyyy")</small>
                    </div>
                    <p class="mb-0 mt-1">
                        @{
                            var bodyHtml = System.Web.HttpUtility.HtmlEncode(comment.Body);
                            if (Model.CommentMentions.TryGetValue(comment.Id, out var mentions))
                            {
                                foreach (var m in mentions)
                                {
                                    var timelineUrl = Url.Action("Timeline", "Posts", new { id = m.UserId });
                                    bodyHtml = bodyHtml.Replace(
                                        $"@{m.UserName}",
                                        $"<a href='{timelineUrl}' class='fw-semibold text-decoration-none'>@{m.DisplayName}</a>"
                                    );
                                }
                            }
                        }
                        @Html.Raw(bodyHtml)
                    </p>
                </div>
            </div>
        }

        <!-- Add Comment -->
        @if (Model.CanComment)
        {
            var friendsJson = System.Text.Json.JsonSerializer.Serialize(
                Model.TaggableFriends.Select(f => new { userName = f.DisplayName, displayName = f.DisplayName })
            );
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h6>Add a Memory</h6>
                    <form asp-action="AddComment" method="post">
                        <input type="hidden" name="PostId" value="@Model.Post.Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-2 position-relative">
                            <textarea id="commentBody" name="Body" class="form-control" rows="3"
                                placeholder="Share your memory... type @@ to mention a friend" required
                                data-friends='@Html.Raw(friendsJson)'></textarea>
                            <div id="mentionDropdown" class="list-group position-absolute shadow" style="z-index:1000;display:none;max-width:250px;"></div>
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-4">
                                <input name="EventYear" type="number" class="form-control form-control-sm" placeholder="Year (neg=BC)" max="2100" value="@Model.Post.EventYear" />
                            </div>
                            <div class="col-4">
                                <select name="EventMonth" class="form-select form-select-sm">
                                    <option value="">Month</option>
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        <option value="@m" selected="@(m == Model.Post.EventMonth)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-4">
                                <input name="EventDay" type="number" class="form-control form-control-sm" placeholder="Day" min="1" max="31" value="@Model.Post.EventDay" />
                            </div>
                        </div>

                        <div class="form-check mb-2">
                            <input name="EventDateIsEstimated" type="checkbox" class="form-check-input" value="true" id="commentEstimated" />
                            <label class="form-check-label" for="commentEstimated">Date is estimated</label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-sm">Add Memory</button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-3">
                <em>Only friends and family can add memories to this post.</em>
            </div>
        }
    </div>
    <div class="col-md-3">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>
</div>

@section Scripts {
<script>
(function () {
    const textarea = document.getElementById('commentBody');
    if (!textarea) return;

    const dropdown = document.getElementById('mentionDropdown');
    const friends = JSON.parse(textarea.dataset.friends || '[]');
    let mentionStart = -1;

    textarea.addEventListener('input', function () {
        const val = textarea.value;
        const cursor = textarea.selectionStart;
        const textUpToCursor = val.substring(0, cursor);
        const atIndex = textUpToCursor.lastIndexOf('@@');

        if (atIndex === -1) { hideDropdown(); return; }

        const query = textUpToCursor.substring(atIndex + 1).toLowerCase();
        if (query.includes(' ')) { hideDropdown(); return; }

        mentionStart = atIndex;
        const filtered = friends.filter(f => f.displayName.toLowerCase().startsWith(query));

        if (filtered.length === 0) { hideDropdown(); return; }

        dropdown.innerHTML = '';
        filtered.slice(0, 6).forEach(f => {
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'list-group-item list-group-item-action py-1 px-2';
            item.textContent = '@@' + f.displayName;
            item.addEventListener('mousedown', function (e) {
                e.preventDefault();
                const before = textarea.value.substring(0, mentionStart);
                const after = textarea.value.substring(cursor);
                textarea.value = before + '@@' + f.userName + ' ' + after;
                hideDropdown();
                textarea.focus();
            });
            dropdown.appendChild(item);
        });
        dropdown.style.display = 'block';
    });

    textarea.addEventListener('blur', function () {
        setTimeout(hideDropdown, 150);
    });

    function hideDropdown() { dropdown.style.display = 'none'; }
})();
</script>
}
