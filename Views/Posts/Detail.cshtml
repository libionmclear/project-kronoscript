                                }
                                else
                                {
                                    <a asp-controller="PersonProfiles" asp-action="Details" asp-route-id="@pp.ProfileId" class="fw-semibold text-decoration-none" title="People profile"><span aria-hidden="true">🕊</span> @pp.DisplayName</a>
