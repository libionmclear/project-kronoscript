@{
    // Photo person-tags grouped by media URL, projected to a JSON-safe shape.
    var mediaTagPayload = new Dictionary<string, object>();
    foreach (var tagList in Model.MediaPersonTags.Values)
    {
        foreach (var t in tagList)
        {
            var url = t.Media?.Url;
            if (string.IsNullOrEmpty(url)) continue;
            if (!mediaTagPayload.ContainsKey(url))
            {
                mediaTagPayload[url] = new List<object>();
            }
            string href;
            if (t.TargetUser != null)
            {
                href = Url.Action("Timeline", "Posts", new { id = t.TargetUserId }) ?? "#";
            }
            else if (t.TargetProfile?.LinkedUserId != null)
            {
                href = Url.Action("Index", "Profile", new { id = t.TargetProfile.LinkedUserId }) ?? "#";
            }
            else
            {
                href = Url.Action("Details", "PersonProfiles", new { id = t.TargetProfileId }) ?? "#";
            }
            ((List<object>)mediaTagPayload[url]).Add(new
            {
                id = t.Id,
                x = t.X,
                y = t.Y,
                label = t.TargetUser != null
                    ? (t.TargetUser.DisplayName ?? t.TargetUser.UserName ?? "?")
                    : (t.TargetProfile?.DisplayName ?? "?"),
                isProfile = t.TargetProfileId.HasValue,
                href = href
            });
        }
    }
    var mediaTagPayloadJson = System.Text.Json.JsonSerializer.Serialize(mediaTagPayload);
}
@if (Model.CanTagPhotos)
{
    @* Tag-mode toggle and picker. The toggle attaches data-mode="tagging"
       to the article wrapper; the JS uses that as the cue to capture
       clicks and open the picker. *@
    <div class="container my-2" style="max-width:920px;">
        <button type="button" id="ftFaceTagToggle" class="btn btn-sm btn-outline-primary">🏷 Tag a face</button>
        <span id="ftFaceTagHint" class="small text-muted ms-2" style="display:none;">Click any photo to drop a name label.</span>
    </div>
    <div id="ftFaceTagPicker"
         style="display:none;position:fixed;z-index:2000;background:#fff;border:1px solid #d8c69c;border-radius:8px;box-shadow:0 6px 20px rgba(0,0,0,0.2);width:280px;max-height:340px;overflow:hidden;">
        <div class="p-2 border-bottom">
            <input type="text" id="ftFaceTagSearch" class="form-control form-control-sm" placeholder="Search a person…" autocomplete="off" />
        </div>
        <div id="ftFaceTagOptions" style="max-height:280px;overflow-y:auto;"></div>
    </div>
}
@section Scripts {
<script>
// Photo person-tags: server emits a {url: [tags...]} map; on load, find
// every <figure class="article-image"> and inject overlay labels whose
// img.src matches a key. The label is hidden by default and revealed on
// hover (see <style> at top of page). Family-tier viewers also see a
// "Tag a face" toggle — see the second IIFE below.
(function () {
    var tagMap = @Html.Raw(mediaTagPayloadJson);
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('figure.article-image').forEach(function (fig) {
            var img = fig.querySelector('img');
            if (!img) return;
            var tags = tagMap[img.getAttribute('src')];
            if (!tags || !tags.length) return;
            fig.style.position = fig.style.position || 'relative';
            tags.forEach(function (t) {
                var ov = document.createElement('a');
                ov.href = t.href || '#';
                ov.title = (t.isProfile ? '🕊 ' : '') + t.label;
                ov.className = 'photo-tag-overlay';
                // 28px transparent square so the hover target is easy to land
                // on — the pin is centred inside via flexbox.
                ov.style.cssText = 'position:absolute;left:' + t.x + '%;top:' + t.y + '%;transform:translate(-50%,-50%);z-index:5;text-decoration:none;color:inherit;';
                ov.innerHTML = '<span class="photo-tag-pin" style="display:block;width:14px;height:14px;border-radius:50%;background:#fff;border:2px solid #1e7e34;box-shadow:0 0 0 2px rgba(0,0,0,0.35);"></span>'
                             + '<span class="photo-tag-label" style="position:absolute;top:30px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.78);color:#fff;padding:2px 8px;border-radius:4px;font-size:0.75rem;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .15s ease;">'
                             + (t.isProfile ? '🕊 ' : '') + escapeText(t.label) + '</span>';
                // Tap-toggle so touch users (no :hover) can still see the
                // label. Tapping a second time, or tapping elsewhere, hides it.
                ov.addEventListener('click', function (e) {
                    // Let actual link clicks proceed normally on desktop;
                    // on touch, the click fires before any hover. We toggle
                    // the label and only navigate on a second tap.
                    if (window.matchMedia && window.matchMedia('(hover: hover)').matches) return;
                    if (!ov.classList.contains('is-active')) {
                        document.querySelectorAll('.photo-tag-overlay.is-active').forEach(function (o) { o.classList.remove('is-active'); });
                        ov.classList.add('is-active');
                        e.preventDefault();
                    }
                });
                fig.appendChild(ov);
            });
        });
    });
    function escapeText(s) { var d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }
})();
</script>

@if (Model.CanTagPhotos)
{
    <script>
    // "Tag a face" mode — enabled for owner/admin/family-tier viewers on Detail.
    // Toggling enters a state where clicking any article-image figure opens a
    // floating people picker; selecting a person POSTs to /Media/AddPersonTag
    // with the click % and the chosen target. New tag appears inline.
    (function () {
        var toggle = document.getElementById('ftFaceTagToggle');
        var hint = document.getElementById('ftFaceTagHint');
        var picker = document.getElementById('ftFaceTagPicker');
        var searchInput = document.getElementById('ftFaceTagSearch');
        var optionsEl = document.getElementById('ftFaceTagOptions');
        var anti = document.querySelector('input[name="__RequestVerificationToken"]');
        var token = anti ? anti.value : '';
        var tagging = false;
        var pending = null; // { figure, mediaUrl, x, y }

        // People pool — viewer's friend list + viewer's own profiles + family-shared profiles.
        var people = [
            @foreach (var f in Model.TaggableFriends)
            {
                <text>{ type:'u', id:'@f.UserId', name:@Json.Serialize(f.DisplayName) },</text>
            }
            @foreach (var p in Model.TaggableProfiles)
            {
                <text>{ type:'p', id:'@p.ProfileId', name:@Json.Serialize(p.DisplayName + (string.IsNullOrEmpty(p.Relation) ? "" : " · " + p.Relation)) },</text>
            }
        ];

        function escapeText(s) { var d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }
        function renderOptions(filter) {
            var f = (filter || '').toLowerCase().trim();
            var matches = people.filter(function (p) {
                return !f || (p.name || '').toLowerCase().indexOf(f) !== -1;
            }).slice(0, 16);
            if (matches.length === 0) {
                optionsEl.innerHTML = '<div class="p-2 small text-muted">No one to tag — invite a friend or create a People Profile first.</div>';
                return;
            }
            optionsEl.innerHTML = matches.map(function (p) {
                var prefix = p.type === 'p' ? '🕊 ' : '👤 ';
                return '<button type="button" class="list-group-item list-group-item-action py-2 px-2 small" data-type="' + p.type + '" data-id="' + p.id + '">'
                     + prefix + escapeText(p.name) + '</button>';
            }).join('');
        }
        function closePicker() { picker.style.display = 'none'; pending = null; }
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                if (picker.style.display === 'block') { closePicker(); }
                else if (tagging) { setTagging(false); }
            }
        });
        document.addEventListener('click', function (e) {
            if (picker.style.display !== 'block') return;
            if (picker.contains(e.target)) return;
            if (e.target.closest('figure.article-image')) return;
            closePicker();
        });

        function setTagging(on) {
            tagging = on;
            toggle.classList.toggle('btn-primary', on);
            toggle.classList.toggle('btn-outline-primary', !on);
            toggle.textContent = on ? '✓ Tagging — click any photo' : '🏷 Tag a face';
            hint.style.display = on ? '' : 'none';
            document.querySelectorAll('figure.article-image').forEach(function (fig) {
                fig.style.cursor = on ? 'crosshair' : '';
            });
        }
        toggle.addEventListener('click', function () { setTagging(!tagging); });

        document.querySelectorAll('figure.article-image').forEach(function (fig) {
            fig.addEventListener('click', function (e) {
                if (!tagging) return;
                // Don't trigger when clicking an existing overlay's controls.
                if (e.target.closest('.photo-tag-overlay')) return;
                var img = fig.querySelector('img');
                if (!img) return;
                var rect = img.getBoundingClientRect();
                var x = ((e.clientX - rect.left) / rect.width) * 100;
                var y = ((e.clientY - rect.top)  / rect.height) * 100;
                if (x < 0 || x > 100 || y < 0 || y > 100) return;
                // Resolve the media id by matching the img src against the
                // payload map we already emit for read-only overlays —
                // ALL keys are media URLs so we can ask the controller via
                // the URL too, but it's cleaner to send the media id.
                // Detail.cshtml's article doesn't render data-media-id, so
                // we POST the URL and let the server find it.
                pending = { figure: fig, mediaUrl: img.getAttribute('src'), x: x, y: y };
                searchInput.value = '';
                renderOptions('');
                var px = Math.min(window.innerWidth  - 300, e.clientX);
                var py = Math.min(window.innerHeight - 360, e.clientY);
                picker.style.left = px + 'px';
                picker.style.top  = py + 'px';
                picker.style.display = 'block';
                setTimeout(function () { searchInput.focus(); }, 0);
            });
        });

        searchInput.addEventListener('input', function () { renderOptions(searchInput.value); });
        optionsEl.addEventListener('click', function (e) {
            var btn = e.target.closest('button[data-type]');
            if (!btn || !pending) return;
            var fd = new FormData();
            fd.append('__RequestVerificationToken', token);
            // Server needs the mediaId; we resolve it via mediaUrl below.
            fd.append('mediaUrl', pending.mediaUrl);
            fd.append('x', pending.x);
            fd.append('y', pending.y);
            if (btn.dataset.type === 'u') fd.append('targetUserId', btn.dataset.id);
            else fd.append('targetProfileId', btn.dataset.id);
            fetch('/Media/AddPersonTagByUrl', { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': token } })
                .then(function (r) { if (!r.ok) throw new Error('tag failed'); return r.json(); })
                .then(function (data) {
                    // Build overlay matching the read-only renderer's shape.
                    var ov = document.createElement('a');
                    ov.href = data.href || '#';
                    ov.title = (data.isProfile ? '🕊 ' : '') + (data.label || '?');
                    ov.className = 'photo-tag-overlay';
                    ov.style.cssText = 'position:absolute;left:' + data.x + '%;top:' + data.y + '%;transform:translate(-50%,-50%);z-index:5;text-decoration:none;color:inherit;';
                    ov.innerHTML = '<span class="photo-tag-pin" style="display:block;width:14px;height:14px;border-radius:50%;background:#fff;border:2px solid #1e7e34;box-shadow:0 0 0 2px rgba(0,0,0,0.35);"></span>'
                                 + '<span class="photo-tag-label" style="position:absolute;top:30px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.78);color:#fff;padding:2px 8px;border-radius:4px;font-size:0.75rem;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .15s ease;">'
                                 + (data.isProfile ? '🕊 ' : '') + escapeText(data.label || '?') + '</span>';
                    pending.figure.appendChild(ov);
                    closePicker();
                })
                .catch(function () { closePicker(); alert('Could not save the tag.'); });
        });
    })();
    </script>
}

<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.reply-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var target = document.getElementById(btn.dataset.target);
            if (!target) return;
            target.style.display = (target.style.display === 'none' || !target.style.display) ? 'block' : 'none';
            var ta = target.querySelector('textarea');
            if (ta && target.style.display === 'block') ta.focus();
        });
    });
});
</script>
<script>
(function () {
    const textarea = document.getElementById('commentBody');
    if (!textarea) return;

    const dropdown = document.getElementById('mentionDropdown');
    const friends = JSON.parse(textarea.dataset.friends || '[]');
    let mentionStart = -1;

    textarea.addEventListener('input', function () {
        const val = textarea.value;
        const cursor = textarea.selectionStart;
        const textUpToCursor = val.substring(0, cursor);
        const atIndex = textUpToCursor.lastIndexOf('@@');

        if (atIndex === -1) { hideDropdown(); return; }

        const query = textUpToCursor.substring(atIndex + 1).toLowerCase();
        if (query.includes(' ')) { hideDropdown(); return; }

        mentionStart = atIndex;
        const filtered = friends.filter(f => f.displayName.toLowerCase().startsWith(query));

        if (filtered.length === 0) { hideDropdown(); return; }

        dropdown.innerHTML = '';
        filtered.slice(0, 6).forEach(f => {
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'list-group-item list-group-item-action py-1 px-2';
            item.textContent = '@@' + f.displayName;
            item.addEventListener('mousedown', function (e) {
                e.preventDefault();
                const before = textarea.value.substring(0, mentionStart);
                const after = textarea.value.substring(cursor);
                textarea.value = before + '@@' + f.userName + ' ' + after;
                hideDropdown();
                textarea.focus();
            });
            dropdown.appendChild(item);
        });
        dropdown.style.display = 'block';
    });

    textarea.addEventListener('blur', function () {
        setTimeout(hideDropdown, 150);
    });

    function hideDropdown() { dropdown.style.display = 'none'; }
})();
</script>
}
