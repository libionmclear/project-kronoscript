@model MyStoryTold.Models.ViewModels.PostDetailViewModel
@using MyStoryTold.Helpers
@{
    ViewData["Title"] = Model.Post.Title ?? "Life Event";
}

<div class="row g-3">
    <div class="col-md-2">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <!-- Back link -->
        <a asp-action="Timeline" asp-route-id="@Model.Post.OwnerUserId" class="text-decoration-none mb-3 d-block">
            ← Back to Timeline
        </a>

        <!-- Post Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <!-- Author row -->
                <div class="d-flex align-items-center gap-2 mb-3">
                    @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = Model.Post.Owner, Size = 40 })
                    <div class="flex-grow-1">
                        <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@Model.Post.OwnerUserId"
                           class="fw-semibold text-decoration-none d-block lh-1">
                            @(Model.Post.Owner.DisplayName ?? Model.Post.Owner.UserName)
                        </a>
                        <small class="text-muted">Posted @Model.Post.CreatedAt.ToString("MMM d, yyyy h:mm tt")</small>
                    </div>
                    @{
                        var visibilityLabel = Model.Post.Visibility switch {
                            MyStoryTold.Models.PostVisibility.Public => "🌍 Public",
                            MyStoryTold.Models.PostVisibility.Acquaintances => "👋 Acquaintances",
                            MyStoryTold.Models.PostVisibility.Friends => "👥 Friends",
                            MyStoryTold.Models.PostVisibility.Family => "👨‍👩‍👧 Family",
                            MyStoryTold.Models.PostVisibility.Private => "🔒 Private",
                            _ => ""
                        };
                    }
                    <span class="badge bg-secondary ms-auto">@visibilityLabel</span>
                </div>
                <!-- Date / title -->
                <div class="mb-2">
                    <span class="badge bg-success-subtle text-success fs-6">@Model.Post.EventDateDisplay</span>
                    @if (!string.IsNullOrEmpty(Model.Post.Location))
                    {
                        <span class="badge bg-light text-dark ms-1">📍 @Model.Post.Location</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Post.Title))
                    {
                        <h3 class="mt-1 mb-0">@Model.Post.Title</h3>
                    }
                </div>

                <!-- Tags -->
                @if (Model.TaggedUsers.Any())
                {
                    <div class="mb-3">
                        <small class="text-muted">🏷️ Tagged:
                            @foreach (var tag in Model.TaggedUsers)
                            {
                                <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@tag.UserId" class="fw-semibold text-decoration-none">@tag.DisplayName</a>
                                if (tag != Model.TaggedUsers.Last()) { <text>, </text> }
                            }
                        </small>
                    </div>
                }

                <!-- Body with diff -->
                <div class="post-body mb-3 mt-1" style="white-space: pre-wrap; line-height: 1.6;">
                    @if (Model.DiffHtml != null && Model.Post.LastEditedAt != null)
                    {
                        @Html.Raw(Model.DiffHtml)
                    }
                    else
                    {
                        @BodyRenderer.RenderBody(Model.Post.Body)
                    }
                </div>

                <!-- Media -->
                @if (Model.Post.Media.Any())
                {
                    <div class="mb-3">
                        @foreach (var media in Model.Post.Media)
                        {
                            <div class="post-media-wrap mb-2">
                                @if (media.MediaType == MyStoryTold.Models.MediaType.Image)
                                {
                                    <img src="@media.Url" alt="@media.Caption" />
                                }
                                else
                                {
                                    <video src="@media.Url" controls></video>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Actions -->
                <div class="d-flex align-items-center gap-3 border-top pt-3">
                    <form asp-action="ToggleLike" asp-route-id="@Model.Post.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="icon-action @(Model.CurrentUserLiked ? "liked" : "")">
                            <span class="icon-heart">❤</span> @Model.LikeCount
                        </button>
                    </form>
                    <span class="icon-action" style="cursor:default;">💬 @Model.Comments.Count</span>

                    @if (Model.IsOwner)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="icon-action ms-auto">
                            ✏️ Edit
                        </a>
                    }
                </div>

                <!-- Comments (merged into same card, threaded one level) -->
                @{
                    var repliesByParent = Model.Comments
                        .Where(c => c.ParentCommentId != null)
                        .GroupBy(c => c.ParentCommentId!.Value)
                        .ToDictionary(g => g.Key, g => g.OrderBy(c => c.CreatedAt).ToList());
                    var topLevel = Model.Comments.Where(c => c.ParentCommentId == null).OrderBy(c => c.CreatedAt).ToList();

                    string RenderBodyWithMentions(MyStoryTold.Models.Comment c)
                    {
                        var html = BodyRenderer.RenderBody(c.Body).ToString()!;
                        if (Model.CommentMentions.TryGetValue(c.Id, out var mentions))
                        {
                            foreach (var m in mentions)
                            {
                                var url = $"/Posts/Timeline/{m.UserId}";
                                html = html.Replace($"@{m.UserName}", $"<a href='{url}' class='fw-semibold text-decoration-none'>@{m.DisplayName}</a>");
                            }
                        }
                        return html;
                    }
                }

                @foreach (var comment in topLevel)
                {
                    <div class="comment-row border-top pt-3 mt-3" id="comment-@comment.Id">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = comment.Author, Size = 28 })
                            <div class="flex-grow-1 d-flex justify-content-between align-items-center flex-wrap gap-1">
                                <strong class="small">@(comment.Author.DisplayName ?? comment.Author.UserName)</strong>
                                <small class="text-muted">@comment.CreatedAt.ToString("MMM d, yyyy h:mm tt")</small>
                            </div>
                        </div>
                        <div class="mb-1 mt-1">@Html.Raw(RenderBodyWithMentions(comment))</div>
                        @if (Model.CanComment)
                        {
                            <button type="button" class="btn btn-link btn-sm p-0 text-muted reply-toggle" data-target="reply-form-@comment.Id" style="font-size:0.75rem;">↪ Reply</button>
                        }

                        @if (repliesByParent.TryGetValue(comment.Id, out var replies))
                        {
                            foreach (var reply in replies)
                            {
                                <div class="comment-reply mt-2">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        @await Html.PartialAsync("_UserAvatar", new MyStoryTold.Models.ViewModels.UserAvatarViewModel { User = reply.Author, Size = 24 })
                                        <div class="flex-grow-1 d-flex justify-content-between align-items-center flex-wrap gap-1">
                                            <strong class="small">@(reply.Author.DisplayName ?? reply.Author.UserName)</strong>
                                            <small class="text-muted">@reply.CreatedAt.ToString("MMM d, yyyy h:mm tt")</small>
                                        </div>
                                    </div>
                                    <div class="mb-0 mt-1">@Html.Raw(RenderBodyWithMentions(reply))</div>
                                </div>
                            }
                        }

                        @if (Model.CanComment)
                        {
                            <div class="reply-form comment-reply mt-2" id="reply-form-@comment.Id" style="display:none;">
                                <form asp-action="AddComment" method="post">
                                    <input type="hidden" name="PostId" value="@Model.Post.Id" />
                                    <input type="hidden" name="ParentCommentId" value="@comment.Id" />
                                    <textarea name="Body" class="form-control form-control-sm mb-1" rows="1" placeholder="Write a reply..." required></textarea>
                                    <div class="d-flex justify-content-end">
                                        <button type="submit" class="btn btn-sm btn-primary">Reply</button>
                                    </div>
                                </form>
                            </div>
                        }
                    </div>
                }

                <!-- Add Comment -->
                @if (Model.CanComment)
                {
                    var friendsJson = System.Text.Json.JsonSerializer.Serialize(
                        Model.TaggableFriends.Select(f => new { userName = f.DisplayName, displayName = f.DisplayName })
                    );
                    <div class="border-top pt-3 mt-3">
                        <form asp-action="AddComment" method="post">
                            <input type="hidden" name="PostId" value="@Model.Post.Id" />
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            <div class="position-relative mb-2">
                                <textarea id="commentBody" name="Body" class="form-control" rows="2"
                                          placeholder="Write a comment... type @@ to mention a friend" required
                                          data-friends='@Html.Raw(friendsJson)'></textarea>
                                <div id="mentionDropdown" class="list-group position-absolute shadow" style="z-index:1000;display:none;max-width:250px;"></div>
                            </div>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-sm btn-primary">Comment</button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3 border-top mt-3">
                        <em>Only friends and family can comment on this post.</em>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-2">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.reply-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var target = document.getElementById(btn.dataset.target);
            if (!target) return;
            target.style.display = (target.style.display === 'none' || !target.style.display) ? 'block' : 'none';
            var ta = target.querySelector('textarea');
            if (ta && target.style.display === 'block') ta.focus();
        });
    });
});
</script>
<script>
(function () {
    const textarea = document.getElementById('commentBody');
    if (!textarea) return;

    const dropdown = document.getElementById('mentionDropdown');
    const friends = JSON.parse(textarea.dataset.friends || '[]');
    let mentionStart = -1;

    textarea.addEventListener('input', function () {
        const val = textarea.value;
        const cursor = textarea.selectionStart;
        const textUpToCursor = val.substring(0, cursor);
        const atIndex = textUpToCursor.lastIndexOf('@@');

        if (atIndex === -1) { hideDropdown(); return; }

        const query = textUpToCursor.substring(atIndex + 1).toLowerCase();
        if (query.includes(' ')) { hideDropdown(); return; }

        mentionStart = atIndex;
        const filtered = friends.filter(f => f.displayName.toLowerCase().startsWith(query));

        if (filtered.length === 0) { hideDropdown(); return; }

        dropdown.innerHTML = '';
        filtered.slice(0, 6).forEach(f => {
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'list-group-item list-group-item-action py-1 px-2';
            item.textContent = '@@' + f.displayName;
            item.addEventListener('mousedown', function (e) {
                e.preventDefault();
                const before = textarea.value.substring(0, mentionStart);
                const after = textarea.value.substring(cursor);
                textarea.value = before + '@@' + f.userName + ' ' + after;
                hideDropdown();
                textarea.focus();
            });
            dropdown.appendChild(item);
        });
        dropdown.style.display = 'block';
    });

    textarea.addEventListener('blur', function () {
        setTimeout(hideDropdown, 150);
    });

    function hideDropdown() { dropdown.style.display = 'none'; }
})();
</script>
}
