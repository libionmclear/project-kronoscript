                                        }
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="article-prose" data-translate-body="@Model.Post.Id">
                                @if (leftMap.TryGetValue(-1, out var bpre))
                                {
                                    foreach (var m in bpre)
                                    {
                                        <figure class="article-image @SideClass(m) art-img-w-@WidthSpan(m) art-img-h-@HeightSpan(m)">
                                            <img src="@m.Url" alt="@m.Caption" style="object-position:@(m.FocusX)% @(m.FocusY)%;" />
                                            @if (!string.IsNullOrWhiteSpace(m.Caption)) { <figcaption>@m.Caption</figcaption> }
                                        </figure>
