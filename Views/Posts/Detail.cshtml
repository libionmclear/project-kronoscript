                                        aria-label="Edit"
                                        style="font-size:0.85rem;text-decoration:none;line-height:1;">✎</button>
                            }
                            @if (canDelete)
                            {
                                <button type="button" class="btn btn-link btn-sm p-0 comment-delete"
