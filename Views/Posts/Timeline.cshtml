@model MyStoryTold.Models.ViewModels.TimelineViewModel
@using MyStoryTold.Helpers
@{
    ViewData["Title"] = Model.IsOwner ? "My Timeline" : $"{Model.ProfileUser.DisplayName ?? Model.ProfileUser.UserName}'s Timeline";
}

<div class="row g-3">

    <!-- LEFT: Network Sidebar -->
    <div class="col-md-3 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <!-- CENTER: Timeline -->
    <div class="col-md-6">

        <!-- Profile Header -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body d-flex align-items-center gap-3">
                @if (!string.IsNullOrEmpty(Model.ProfileUser.ProfilePhotoUrl))
                {
                    <img src="@Model.ProfileUser.ProfilePhotoUrl" alt="Profile" class="rounded-circle" style="width:64px;height:64px;object-fit:cover;" />
                }
                else
                {
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:64px;height:64px;background:var(--mst-light);color:var(--mst-primary);font-size:1.5rem;font-weight:bold;">
                        @(Model.ProfileUser.DisplayName?[0] ?? Model.ProfileUser.UserName![0])
                    </div>
                }
                <div>
                    <h3 class="mb-0">@(Model.ProfileUser.DisplayName ?? Model.ProfileUser.UserName)</h3>
                    @if (!string.IsNullOrEmpty(Model.ProfileUser.CurrentLocation))
                    {
                        <small class="text-muted">📍 @Model.ProfileUser.CurrentLocation</small>
                    }
                </div>
                <div class="ms-auto d-flex gap-2">
                    @if (Model.IsOwner)
                    {
                        <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">
                            + New Event
                        </a>
                        <a asp-controller="Export" asp-action="Index" class="btn btn-outline-secondary">
                            📥 Export
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Inbox" asp-action="Conversation" asp-route-id="@Model.ProfileUser.Id"
                           class="btn btn-outline-primary" title="Send a message">
                            ✉️ Message
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Sort Toggle -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">
                @if (Model.SortBy == "event")
                {
                    <span>📅 Chronological Story</span>
                }
                else
                {
                    <span>🕐 Recent Posts</span>
                }
            </h5>
            <div class="btn-group btn-group-sm">
                <a asp-action="Timeline" asp-route-id="@Model.ProfileUser.Id" asp-route-sort="created"
                   class="btn @(Model.SortBy != "event" ? "btn-primary" : "btn-outline-primary")">
                    Recent
                </a>
                <a asp-action="Timeline" asp-route-id="@Model.ProfileUser.Id" asp-route-sort="event"
                   class="btn @(Model.SortBy == "event" ? "btn-primary" : "btn-outline-primary")">
                    Chronological
                </a>
            </div>
        </div>

        <!-- Posts -->
        @if (Model.Posts.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <h4>No life events yet</h4>
                @if (Model.IsOwner)
                {
                    <p>Begin documenting your story by creating your first life event.</p>
                    <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">Create First Event</a>
                }
            </div>
        }

        @{
            int? lastYear = null;
        }
        @foreach (var card in Model.Posts)
        {
            @if (Model.SortBy == "event" && card.Post.EventYear != lastYear)
            {
                lastYear = card.Post.EventYear;
                <div class="timeline-year-divider">
                    <div class="timeline-line-segment"></div>
                    <span class="timeline-year-badge">@(card.Post.EventYear < 0 ? $"{Math.Abs(card.Post.EventYear)} BC" : card.Post.EventYear.ToString())</span>
                    <div class="timeline-line-segment"></div>
                </div>
            }

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <!-- Date Header -->
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <span class="badge bg-success-subtle text-success fs-6">@card.Post.EventDateDisplay</span>
                            @if (!string.IsNullOrWhiteSpace(card.Post.Title))
                            {
                                <h5 class="mt-2 mb-0">@card.Post.Title</h5>
                            }
                        </div>
                        <span class="small text-muted d-inline-flex align-items-center gap-1">@await Html.PartialAsync("_VisibilityDot", card.Post.Visibility) Posted @card.Post.CreatedAt.ToString("MMM d, yyyy")</span>
                    </div>

                    <!-- Tags -->
                    @if (card.TaggedUsers.Any())
                    {
                        <div class="mb-2">
                            <small class="text-muted">with
                                @foreach (var tag in card.TaggedUsers)
                                {
                                    <a asp-controller="Posts" asp-action="Timeline" asp-route-id="@tag.UserId" class="text-decoration-none fw-semibold">@tag.DisplayName</a>
                                    if (tag != card.TaggedUsers.Last()) { <text>, </text> }
                                }
                            </small>
                        </div>
                    }

                    <!-- Body -->
                    <div class="post-body mb-2">
                        @if (card.DiffHtml != null && card.Post.LastEditedAt != null)
                        {
                            @Html.Raw(card.DiffHtml)
                        }
                        else
                        {
                            @BodyRenderer.RenderBody(card.Post.Body)
                        }
                    </div>
                    @if (card.DiffHtml != null && card.Post.LastEditedAt != null)
                    {
                        <small class="text-muted fst-italic d-block mb-2">Edited on @card.Post.LastEditedAt?.ToString("MMM d, yyyy")</small>
                    }

                    <!-- Media -->
                    @if (card.Post.Media.Any())
                    {
                        <div class="mb-3">
                            @foreach (var media in card.Post.Media)
                            {
                                <div class="post-media-wrap mb-2">
                                    @if (media.MediaType == MyStoryTold.Models.MediaType.Image)
                                    {
                                        <img src="@media.Url" alt="@media.Caption" />
                                    }
                                    else
                                    {
                                        <video src="@media.Url" controls></video>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <!-- Actions -->
                    <div class="d-flex align-items-center gap-3 border-top pt-2">
                        <form asp-controller="Posts" asp-action="ToggleLike" asp-route-id="@card.Post.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm @(card.CurrentUserLiked ? "btn-danger" : "btn-outline-secondary")">
                                ❤ @card.LikeCount
                            </button>
                        </form>

                        <a asp-controller="Posts" asp-action="Detail" asp-route-id="@card.Post.Id" class="btn btn-sm btn-outline-secondary">
                            💬 @card.Post.Comments.Count Comments
                        </a>

                        @if (Model.IsOwner)
                        {
                            <a asp-controller="Posts" asp-action="Edit" asp-route-id="@card.Post.Id" class="btn btn-sm btn-outline-primary ms-auto">
                                ✏️ Edit
                            </a>
                        }
                    </div>
                </div>
            </div>
        }

    </div>

    <!-- RIGHT: Quick Links -->
    <div class="col-md-3 col-sidebar">
        @await Html.PartialAsync("_QuickLinksSidebar")
    </div>

</div>
