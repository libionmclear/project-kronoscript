@model MyStoryTold.Models.ViewModels.CreatePostViewModel
@inject Microsoft.AspNetCore.Identity.UserManager<MyStoryTold.Models.ApplicationUser> _userManagerCh
@inject MyStoryTold.Data.ApplicationDbContext _dbCh
@inject MyStoryTold.Services.ILocalizer _t
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = "New Full Story";
    var taggable = ViewBag.TaggableFriends as List<MyStoryTold.Models.ViewModels.TaggableFriendViewModel> ?? new();
    var taggableProfiles = ViewBag.TaggableProfiles as List<MyStoryTold.Models.ViewModels.TaggableProfileViewModel> ?? new();

    // Channels this user can publish into. Empty list = no channel selector shown.
    var meIdCh = _userManagerCh.GetUserId(User);

    // Biographical/managed profiles this admin owns — drives the "Post as" picker.
    // Also collect channels the managed accounts can publish into so the channel
    // dropdown stays usable when posting as one of them.
    var myManagedUsers = string.IsNullOrEmpty(meIdCh) || !User.IsInRole("Admin")
        ? new List<MyStoryTold.Models.ApplicationUser>()
        : await _dbCh.Users
            .Where(u => u.ManagedByUserId == meIdCh && u.IsBiographical)
            .OrderBy(u => u.DisplayName)
            .ToListAsync();
    var managedIds = myManagedUsers.Select(u => u.Id).ToList();

    var myChannels = string.IsNullOrEmpty(meIdCh)
        ? new List<MyStoryTold.Models.Channel>()
        : await _dbCh.Channels
            .Where(c => c.AdminUserId == meIdCh || (c.AdminUserId != null && managedIds.Contains(c.AdminUserId)))
            .OrderBy(c => c.Name)
            .ToListAsync();
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">

        <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="mb-0">@(Model.MemoryOfPostId.HasValue ? _t["Connect your memory"] : _t["New full story"])</h3>
            <a asp-action="Timeline" asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
               class="btn btn-sm btn-outline-secondary">@_t["Cancel"]</a>
        </div>

        @if (Model.MemoryOfPostId.HasValue)
        {
            <div class="memory-of-banner mb-3">
                <span class="memory-of-icon">🔗</span>
                <div class="memory-of-text">
                    <div class="small text-muted">You're writing your personal memory of</div>
                    <a asp-action="Detail" asp-route-id="@Model.MemoryOfPostId" class="fw-semibold text-decoration-none">
                        @Model.MemoryOfPostTitle
                    </a>
                    <div class="small text-muted mt-1">
                        It will live on your timeline like any other story, with a small chip linking back to the article.
                    </div>
                </div>
            </div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data" id="fullStoryForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>
            <input type="hidden" asp-for="MemoryOfPostId" />
            <input type="hidden" asp-for="MemoryOfPostTitle" />
            @* Crowdsource-a-memory: when the composer was opened with
               ?attachToGroupId=N, carry it through so the saved post
               auto-attaches to the group's feed in one click. *@
            @if (ViewBag.AttachToGroupId is int aGid)
            {
                <input type="hidden" name="AttachToGroupId" value="@aGid" />
            }

            <!-- The page itself -->
            <div class="story-page">
                <input asp-for="Title" class="story-title-input" placeholder="@(_t["Title (optional)"])" />

                @{
                    // Premium gate for the inline-images toggle. We render
                    // the toggle for everyone; non-premium users see it
                    // disabled with a small "Premium" badge so they know
                    // the feature exists.
                    var meUserForInline = await _userManagerCh.GetUserAsync(User);
                    var inlinePhotosAvailable = await ((MyStoryTold.Services.IPremiumService)Context.RequestServices.GetService(typeof(MyStoryTold.Services.IPremiumService))!).IsAvailableAsync(meUserForInline, MyStoryTold.Models.PremiumFeature.InlinePhotos);
                }
                <!-- Editorial toolbar -->
                <div class="story-toolbar story-toolbar-sticky" role="toolbar" aria-label="Formatting">
                    <button type="button" class="story-tool" data-cmd="bold" title="Bold (Ctrl+B)"><strong>B</strong></button>
                    <button type="button" class="story-tool" data-cmd="italic" title="Italic (Ctrl+I)"><em>I</em></button>
                    <button type="button" class="story-tool" data-cmd="underline" title="Underline (Ctrl+U)"><u>U</u></button>
                    <span class="story-tool-sep"></span>
                    <button type="button" class="story-tool" data-cmd="formatBlock" data-arg="H2" title="Heading">H</button>
                    <button type="button" class="story-tool" data-cmd="formatBlock" data-arg="BLOCKQUOTE" title="Quote">&ldquo; &rdquo;</button>
                    <span class="story-tool-sep"></span>
                    <button type="button" class="story-tool" data-cmd="insertUnorderedList" title="Bullet list">&bull;</button>
                    <button type="button" class="story-tool" data-cmd="formatBlock" data-arg="P" title="Plain paragraph">¶</button>
                    <span class="story-tool-sep"></span>
                    <button type="button" class="story-tool" id="storyInsertImageBtn" title="Insert image">🖼</button>
                    <input type="file" id="storyInsertImageInput" accept="image/*" class="d-none" />
                    @* Inline-image position picker — only meaningful when
                       a photo is selected in inline mode. 2×3 grid lets
                       the writer place the photo top-left / top-center /
                       top-right / bottom-left / bottom-center / bottom-right
                       within its paragraph, with text wrapping around it. *@
                    <span class="story-img-pos-grid story-img-float-btn d-none" id="storyImgPosGrid"
                          title="Place the selected photo">
                        <button type="button" class="story-img-pos-cell" data-pos="img-pos-top-left"      title="Top-left, wrap right">↖</button>
                        <button type="button" class="story-img-pos-cell" data-pos="img-pos-top-center"    title="Top-center, no wrap">↑</button>
                        <button type="button" class="story-img-pos-cell" data-pos="img-pos-top-right"     title="Top-right, wrap left">↗</button>
                        <button type="button" class="story-img-pos-cell" data-pos="img-pos-bottom-left"   title="Bottom-left, wrap right">↙</button>
                        <button type="button" class="story-img-pos-cell" data-pos="img-pos-bottom-center" title="Bottom-center, no wrap">↓</button>
                        <button type="button" class="story-img-pos-cell" data-pos="img-pos-bottom-right"  title="Bottom-right, wrap left">↘</button>
                    </span>
                    @* Wrap the meta cluster onto its own line so the
                       formatting buttons stay uncluttered on top. *@
                    <span class="story-toolbar-break"></span>
                    @{
                        var inlineToggleClass = inlinePhotosAvailable ? "story-inline-toggle" : "story-inline-toggle is-gated";
                        var inlineToggleTitle = inlinePhotosAvailable
                            ? "Photos sit inside the prose where you put them. Click a photo to pick where text wraps."
                            : "Premium feature — upgrade to place photos in the prose";
                    }
                    <label class="@inlineToggleClass" title="@inlineToggleTitle">
                        @if (inlinePhotosAvailable)
                        {
                            <input type="checkbox" asp-for="UseInlineImages" id="storyUseInlineImages" />
                        }
                        else
                        {
                            <input type="checkbox" asp-for="UseInlineImages" id="storyUseInlineImages" disabled />
                        }
                        <span class="story-inline-toggle-label">📍 Place photos in the story</span>
                        @if (!inlinePhotosAvailable)
                        {
                            <span class="story-inline-toggle-badge">Premium</span>
                        }
                    </label>
                    <span class="story-stats" id="storyStats" title="Word count and reading time">
                        <span id="storyWordCount">0</span> words · <span id="storyReadMin">0</span> min read
                    </span>
                    <span class="story-autosave" id="storyAutosave" aria-live="polite"></span>
                </div>

                <div id="storyEditor" class="story-editor" contenteditable="true"
                     data-placeholder="@(_t["Start telling your story… you can paste or drop images directly. Take your time."])"></div>
                <textarea asp-for="Body" id="storyBody" class="d-none"></textarea>
                <p id="storyInlineHint" class="story-inline-hint small text-muted mb-0" style="display:none;">
                    📍 Photos you paste, drop, or insert stay where you put them in the prose.
                    Click any photo and use the 2×3 arrow picker in the toolbar to pick where text wraps around it.
                </p>

                <!-- Floating action icons (live on the page edge) -->
                <div class="story-page-actions">
                    <button type="button" class="story-action-btn" data-bs-toggle="modal" data-bs-target="#fullStoryMediaModal" title="Attach photos or videos" aria-label="Attach media">
                        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="11" r="2"/><path d="M21 15l-5-5L6 19"/></svg>
                        <span class="story-action-badge media-count-badge d-none"></span>
                    </button>
                    <button type="button" class="story-action-btn" data-bs-toggle="modal" data-bs-target="#fullStoryMusicModal" title="Memory Music link" aria-label="Memory Music">
                        <svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                        <span class="story-action-badge music-set-badge d-none"></span>
                    </button>
                </div>
            </div>

            <!-- Compact metadata row -->
            <div class="story-meta mt-3">
                <div class="row g-2 align-items-center">
                    <div class="col-auto">
                        <label class="form-label small fw-semibold mb-0 me-1" style="color:var(--mst-muted);">@_t["Story Date:"]</label>
                    </div>
                    <div class="col-auto">
                        <input asp-for="EventYear" class="form-control form-control-sm" type="number" max="2100"
                               placeholder="@(_t["Year"]) (-=BC)" style="width:120px;" />
                    </div>
                    <div class="col-auto">
                        @{
                            var monthCulture = System.Globalization.CultureInfo.CurrentUICulture;
                            var capMonths = monthCulture.TwoLetterISOLanguageName == "it";
                        }
                        <select asp-for="EventMonth" class="form-select form-select-sm" style="width:120px;">
                            <option value="">@_t["Month"]</option>
                            @for (int m = 1; m <= 12; m++)
                            {
                                var monthName = monthCulture.DateTimeFormat.GetAbbreviatedMonthName(m);
                                if (capMonths && monthName.Length > 0)
                                {
                                    monthName = char.ToUpper(monthName[0]) + monthName[1..];
                                }
                                <option value="@m">@monthName</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <input asp-for="EventDay" class="form-control form-control-sm" type="number" min="1" max="31"
                               placeholder="@(_t["Day"])" style="width:74px;" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-0">
                            <input asp-for="EventDateIsEstimated" class="form-check-input" />
                            <label asp-for="EventDateIsEstimated" class="form-check-label small text-muted">@_t["Estimated"]</label>
                        </div>
                    </div>
                </div>

                @if (myManagedUsers.Any())
                {
                    <div class="alert mb-2 py-2" style="background: rgba(160,110,60,0.10); border:1px solid rgba(160,110,60,0.4);">
                        <label asp-for="PostAsUserId" class="form-label small fw-semibold mb-1">Post as (optional)</label>
                        <select asp-for="PostAsUserId" class="form-select form-select-sm" style="max-width:360px;">
                            <option value="">— Yourself —</option>
                            @foreach (var u in myManagedUsers)
                            {
                                <option value="@u.Id">📜 @(u.DisplayName ?? u.UserName)@(string.IsNullOrEmpty(u.BiographicalEra) ? "" : $" ({u.BiographicalEra})")</option>
                            }
                        </select>
                        <small class="text-muted d-block mt-1">
                            Publishing on behalf of a biographical profile. Their post will get a sepia accent on the feed.
                        </small>
                    </div>
                }

                @if (myChannels.Any())
                {
                    <div class="alert mb-2 py-2" style="background: rgba(240,192,64,0.10); border:1px solid rgba(240,192,64,0.4);">
                        <label asp-for="ChannelId" class="form-label small fw-semibold mb-1">Publish to channel (optional)</label>
                        <select asp-for="ChannelId" class="form-select form-select-sm" id="channelSelect" style="max-width:360px;">
                            <option value="">— Personal post (no channel) —</option>
                            @foreach (var ch in myChannels)
                            {
                                <option value="@ch.Id" data-default-layout="@((int)ch.DefaultLayoutStyle)">@(ch.IconEmoji ?? "📚") @ch.Name</option>
                            }
                        </select>
                        <small class="text-muted d-block mt-1">
                            Channel posts pick up the channel's default layout (Journal or Book).
                        </small>
                    </div>
                }

                <!-- Layout style picker — controls how this post renders on
                     the Detail page (and the feed card). Channels seed it
                     to their default; biographical posts seed to Book. The
                     writer can still flip it before publishing. -->
                <div class="row g-1 mb-2 align-items-center">
                    <div class="col-auto">
                        <label asp-for="LayoutStyle" class="form-label small fw-semibold mb-0 me-1" style="color:var(--mst-muted);">Layout:</label>
                    </div>
                    <div class="col-auto">
                        @{
                            // Newspaper / Book layouts on personal posts are
                            // a premium typographic upgrade. Channel articles
                            // and bio posts still auto-apply them regardless
                            // of subscription (those features are themselves
                            // premium-gated upstream).
                            var createMeUser = await _userManagerCh.GetUserAsync(User);
                            var layoutPremium = MyStoryTold.Helpers.PremiumUserExtensions.HasPremium(createMeUser);
                            var fancySuffix = layoutPremium ? "" : " — Premium";
                        }
                        <select asp-for="LayoutStyle" id="layoutStyleSelect" class="form-select form-select-sm" style="width:auto;">
                            <option value="0">Standard (memoir card)</option>
                            @if (layoutPremium)
                            {
                                <option value="1">📰 Journal (newspaper)</option>
                                <option value="2">📖 Book chapter</option>
                            }
                            else
                            {
                                <option value="1" disabled>📰 Journal (newspaper) — Premium</option>
                                <option value="2" disabled>📖 Book chapter — Premium</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <small class="text-muted">
                            Journal = serif headline, two-column body, drop cap. Book = italic title, single chapter column.
                            @(layoutPremium ? "After publishing, you'll be taken to Edit to position photos on the layout grid." : "Upgrade to use these layouts on your personal posts.")
                        </small>
                    </div>
                </div>

                <div class="row g-2 mt-2">
                    <div class="col-md-5">
                        <select asp-for="Visibility" class="form-select form-select-sm visibility-select">
                            <option value="Public">@_t["● Public"]</option>
                            <option value="Acquaintances">@_t["● Acquaintances"]</option>
                            <option value="Friends" selected>@_t["● Friends"]</option>
                            <option value="Family">@_t["● Family"]</option>
                            <option value="Private">@_t["🔒 Only Me"]</option>
                        </select>
                    </div>
                    <div class="col-md-7">
                        <input asp-for="Location" class="form-control form-control-sm" placeholder="@("📍 " + _t["Location (optional)"])" />
                    </div>
                </div>
            </div>

            <input type="hidden" name="MusicUrl" id="fullStoryMusicUrl" />
            <!-- Pasted-image preview tiles. Each tile holds a hidden
                 PastedImageUrls input plus the visible thumbnail; drag to
                 reorder and the inputs ride along, so submit order matches
                 what the writer sees. Empty by default; tiles are added by
                 the paste handler in the script section below. -->
            <div id="mediaReorderGrid" class="media-reorder-grid mt-2 d-none"></div>
            <div id="pastedImagesPreview" class="d-none"></div>

            <!-- Tag People -->
            <div class="mt-3">
                @await Html.PartialAsync("_TagWidget", new MyStoryTold.Models.ViewModels.TagWidgetViewModel
                {
                    Friends = taggable,
                    Selected = new List<MyStoryTold.Models.ViewModels.TaggableFriendViewModel>(),
                    Profiles = taggableProfiles,
                    SelectedProfiles = new List<MyStoryTold.Models.ViewModels.TaggableProfileViewModel>()
                })
            </div>

            <input type="hidden" name="IsDraft" id="fullStoryIsDraft" value="false" />
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary" id="fullStoryPublishBtn">@_t["Publish Story"]</button>
                <button type="submit" class="btn btn-outline-warning" id="fullStorySaveDraftBtn">@_t["Save as Draft"]</button>
                <a asp-controller="Posts" asp-action="Drafts" class="btn btn-outline-secondary">@_t["My Drafts"]</a>
                <a asp-action="Timeline" asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
                   class="btn btn-outline-secondary ms-auto">@_t["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

<!-- Memory Music modal -->
<div class="modal fade" id="fullStoryMusicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">🎵 @_t["Memory Music"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@(_t["Close"])"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">Paste a YouTube, Spotify, Apple Music or any link to a song that takes you back to this memory.</p>
                <input type="url" class="form-control music-url-input-fs" placeholder="https://www.youtube.com/watch?v=..." />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">@_t["Cancel"]</button>
                <button type="button" class="btn btn-primary btn-sm" id="fullStoryMusicSave" data-bs-dismiss="modal">@_t["Save"]</button>
            </div>
        </div>
    </div>
</div>

<!-- Media attach modal -->
<div class="modal fade" id="fullStoryMediaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@_t["Attach media"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@(_t["Close"])"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small fw-semibold">@_t["Photos or videos"]</label>
                <input type="file" class="form-control" id="fullStoryMediaInput" name="Images" accept="image/*,video/*" multiple form="fullStoryForm" />
                <p class="text-muted small mt-2 mb-0">@_t["Select multiple if you like — they'll be saved with the story."]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">@_t["Cancel"]</button>
                <button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="modal">@_t["Done"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        // Sync contenteditable → hidden textarea on every keystroke and on submit
        var editor = document.getElementById('storyEditor');
        var hidden = document.getElementById('storyBody');
        var form = document.getElementById('fullStoryForm');
        if (!editor || !hidden || !form) return;

        // Pasted images render as <img> inline so the writer sees them. In
        // the default (free / gallery) mode we strip them before save so
        // the published body stays pure text and the photos route to the
        // gallery via PastedImageUrls. In inline-images premium mode we
        // KEEP them — server-side Sanitize will verify each src is from
        // our storage and drop unsafe markup.
        function stripImgs(html) {
            return (html || '').replace(/<img\b[^>]*>/gi, '');
        }
        var inlineToggle = document.getElementById('storyUseInlineImages');
        function inlineMode() { return !!(inlineToggle && inlineToggle.checked); }

        // Initialize from any existing model value
        if (hidden.value) editor.innerHTML = hidden.value;

        function sync() {
            hidden.value = inlineMode() ? (editor.innerHTML || '') : stripImgs(editor.innerHTML);
        }
        editor.addEventListener('input', sync);
        form.addEventListener('submit', sync);
        var inlineHint = document.getElementById('storyInlineHint');
        function reflectInlineMode() {
            var on = inlineMode();
            editor.classList.toggle('story-editor-inline-mode', on);
            if (inlineHint) inlineHint.style.display = on ? '' : 'none';
        }
        if (inlineToggle) {
            inlineToggle.addEventListener('change', function () {
                reflectInlineMode();
                sync();
            });
            // Set initial state on load (handles ModelState round-trip).
            reflectInlineMode();
        }

        // 2×3 image-position picker — visible only when an inline <img>
        // is the current selection / click target. Clicking a cell
        // applies one of the six img-pos-* classes and triggers sync.
        var floatBtns = document.querySelectorAll('.story-img-float-btn');
        var posCells  = document.querySelectorAll('.story-img-pos-cell');
        var selectedImg = null;
        var POS_CLASSES = [
            'img-pos-top-left', 'img-pos-top-center', 'img-pos-top-right',
            'img-pos-bottom-left', 'img-pos-bottom-center', 'img-pos-bottom-right',
            // legacy aliases — preserved so older posts opened in the
            // editor don't lose their float when the writer re-clicks
            'img-float-left', 'img-float-right', 'img-block'
        ];
        function setSelectedImg(img) {
            if (selectedImg) selectedImg.classList.remove('story-img-selected');
            selectedImg = img;
            if (img) img.classList.add('story-img-selected');
            floatBtns.forEach(function (b) { b.classList.toggle('d-none', !img || !inlineMode()); });
            // Light up the cell that matches the current class so the
            // writer can see at-a-glance where this image already sits.
            if (img) {
                posCells.forEach(function (c) {
                    c.classList.toggle('is-active', img.classList.contains(c.dataset.pos));
                });
            }
        }
        editor.addEventListener('click', function (e) {
            if (e.target && e.target.tagName === 'IMG') setSelectedImg(e.target);
            else setSelectedImg(null);
        });
        posCells.forEach(function (btn) {
            btn.addEventListener('mousedown', function (e) { e.preventDefault(); });
            btn.addEventListener('click', function () {
                if (!selectedImg) return;
                POS_CLASSES.forEach(function (c) { selectedImg.classList.remove(c); });
                selectedImg.classList.add(btn.dataset.pos);
                posCells.forEach(function (c) {
                    c.classList.toggle('is-active', c.dataset.pos === btn.dataset.pos);
                });
                sync();
            });
        });

        // Toolbar (uses execCommand — old API but fine for this lightweight editor)
        document.querySelectorAll('.story-tool').forEach(function (btn) {
            btn.addEventListener('mousedown', function (e) { e.preventDefault(); }); // keep selection
            btn.addEventListener('click', function () {
                var cmd = btn.dataset.cmd;
                var arg = btn.dataset.arg || null;
                editor.focus();
                document.execCommand(cmd, false, arg);
                sync();
            });
        });

        // ── Pasted-image reorder grid ─────────────────────────────────────
        // Each pasted image becomes a draggable tile holding the visible
        // thumbnail AND the hidden PastedImageUrls input. Drag rearranges DOM
        // so form submit picks up the new order; the first tile becomes the
        // home-feed cover.
        var reorderGrid = document.getElementById('mediaReorderGrid');
        function addReorderTile(url) {
            if (!reorderGrid) return;
            reorderGrid.classList.remove('d-none');

            var tile = document.createElement('div');
            tile.className = 'media-reorder-tile';
            tile.draggable = true;

            var hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = 'PastedImageUrls';
            hidden.value = url;
            tile.appendChild(hidden);

            var img = document.createElement('img');
            img.src = url;
            img.alt = '';
            tile.appendChild(img);

            var grip = document.createElement('span');
            grip.className = 'media-reorder-grip';
            grip.setAttribute('aria-hidden', 'true');
            grip.textContent = '⋮⋮';
            tile.appendChild(grip);

            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'media-reorder-remove';
            rm.title = 'Remove';
            rm.setAttribute('aria-label', 'Remove image');
            rm.textContent = '✕';
            rm.addEventListener('click', function () {
                tile.remove();
                if (!reorderGrid.querySelector('.media-reorder-tile')) reorderGrid.classList.add('d-none');
                sync();
            });
            tile.appendChild(rm);

            wireTileDrag(tile);
            reorderGrid.appendChild(tile);
        }

        var dragSrc = null;
        function wireTileDrag(tile) {
            tile.addEventListener('dragstart', function (e) {
                dragSrc = tile;
                tile.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
                try { e.dataTransfer.setData('text/plain', tile.querySelector('input')?.value || ''); } catch (_) {}
            });
            tile.addEventListener('dragend', function () {
                tile.classList.remove('dragging');
                reorderGrid.querySelectorAll('.media-reorder-tile').forEach(function (t) { t.classList.remove('drag-over'); });
                dragSrc = null;
            });
            tile.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                if (dragSrc && tile !== dragSrc) tile.classList.add('drag-over');
            });
            tile.addEventListener('dragleave', function () { tile.classList.remove('drag-over'); });
            tile.addEventListener('drop', function (e) {
                e.preventDefault();
                tile.classList.remove('drag-over');
                if (!dragSrc || tile === dragSrc) return;
                var rect = tile.getBoundingClientRect();
                var midX = rect.left + rect.width / 2;
                var midY = rect.top + rect.height / 2;
                var before = (e.clientY < midY) || (e.clientY < rect.top + rect.height && e.clientX < midX);
                reorderGrid.insertBefore(dragSrc, before ? tile : tile.nextSibling);
            });
        }

        // Strip pasted HTML down to the editor's own typography. Word/Docs/web
        // pastes carry inline style, font-family, color, and span/div noise
        // that visually clashes with the page; we keep only basic semantic
        // tags (b/i/u, headings, blockquote, lists, links, line breaks).
        // Note: BLOCKQUOTE is intentionally NOT here — pasting an article's
        // quoted paragraph used to drop the writer's text into an indented
        // quote block, which doesn't match the editor's typography. The "
        // toolbar button can still apply a quote when the writer wants one.
        var ALLOWED_TAGS = ['B','STRONG','I','EM','U','BR','P','H2','H3','UL','OL','LI','A'];
        function cleanPastedHtml(html) {
            var doc = new DOMParser().parseFromString('<div id="root">' + html + '</div>', 'text/html');
            var root = doc.getElementById('root');
            // Drop entire <style>/<script>/<meta>/<link>/<head> subtrees first.
            ['style','script','meta','link','head'].forEach(function (tag) {
                root.querySelectorAll(tag).forEach(function (el) { el.remove(); });
            });
            (function walk(node) {
                var i = node.childNodes.length;
                while (i--) {
                    var c = node.childNodes[i];
                    if (c.nodeType === 1) {
                        walk(c);
                        if (ALLOWED_TAGS.indexOf(c.nodeName) === -1) {
                            // Unwrap: replace the disallowed element with its children.
                            var parent = c.parentNode;
                            while (c.firstChild) parent.insertBefore(c.firstChild, c);
                            parent.removeChild(c);
                        } else {
                            // Strip every attribute (style/class/font/color/etc.).
                            // Preserve only href on <a>; force safe target/rel.
                            for (var j = c.attributes.length - 1; j >= 0; j--) {
                                c.removeAttribute(c.attributes[j].name);
                            }
                            if (c.nodeName === 'A') {
                                // Re-read href from the original (we just stripped it) — fall back to text.
                            }
                        }
                    } else if (c.nodeType === 8) {
                        c.remove(); // comments
                    }
                }
            })(root);
            // Re-extract hrefs from the original HTML and re-stitch onto <a> tags
            // matching by text content. Cheap heuristic: just keep any href that
            // survived because we only stripped after walking — but we just
            // stripped them above. Re-parse to keep hrefs:
            var doc2 = new DOMParser().parseFromString('<div id="root">' + html + '</div>', 'text/html');
            var origLinks = Array.from(doc2.querySelectorAll('a[href]'));
            var newLinks = root.querySelectorAll('a');
            for (var k = 0; k < newLinks.length && k < origLinks.length; k++) {
                var href = origLinks[k].getAttribute('href') || '';
                if (/^(https?:|mailto:|\/)/i.test(href)) {
                    newLinks[k].setAttribute('href', href);
                    newLinks[k].setAttribute('target', '_blank');
                    newLinks[k].setAttribute('rel', 'noopener noreferrer');
                }
            }
            return root.innerHTML;
        }

        function escapeHtml(text) {
            return (text || '').replace(/[&<>"']/g, function (c) {
                return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]);
            }).replace(/\r\n|\r|\n/g, '<br>');
        }

        // Shared: upload a single image blob to the server, then drop a
        // tile in the reorder grid AND a preview <img> at the cursor.
        function uploadAndInsertImage(blob) {
            if (!blob) return Promise.resolve();
            var fd = new FormData();
            fd.append('file', blob, blob.name || 'image.png');
            return fetch('/Posts/UploadPastedImage', { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data || !data.url) return;
                    addReorderTile(data.url);
                    editor.focus();
                    document.execCommand('insertHTML', false,
                        '<img src="' + data.url + '" style="max-width:100%;border-radius:8px;margin:8px 0;" />');
                    sync();
                })
                .catch(function () {});
        }

        // Paste handler: images upload via /Posts/UploadPastedImage; text/HTML
        // is normalized to the editor's typography before insertion.
        editor.addEventListener('paste', function (e) {
            var cd = e.clipboardData || e.originalEvent.clipboardData;
            if (!cd) return;

            // 1) Image paste — upload + insert <img>.
            var items = cd.items || [];
            var hasImage = false;
            for (var i = 0; i < items.length; i++) {
                if (items[i].kind === 'file' && items[i].type && items[i].type.indexOf('image') === 0) {
                    hasImage = true;
                    e.preventDefault();
                    uploadAndInsertImage(items[i].getAsFile());
                }
            }
            if (hasImage) return;

            // 2) Rich/plain text paste — sanitize before insert.
            var html = cd.getData('text/html');
            var text = cd.getData('text/plain');
            if (!html && !text) return; // unknown type — let browser do its thing
            e.preventDefault();
            var insert = html ? cleanPastedHtml(html) : escapeHtml(text);
            document.execCommand('insertHTML', false, insert);
            sync();
        });

        // Drag-and-drop: drop image files onto the editor to upload.
        editor.addEventListener('dragover', function (e) {
            if (e.dataTransfer && Array.prototype.indexOf.call(e.dataTransfer.types || [], 'Files') !== -1) {
                e.preventDefault();
                editor.classList.add('story-editor-drag-over');
            }
        });
        editor.addEventListener('dragleave', function () {
            editor.classList.remove('story-editor-drag-over');
        });
        editor.addEventListener('drop', function (e) {
            editor.classList.remove('story-editor-drag-over');
            if (!e.dataTransfer || !e.dataTransfer.files || !e.dataTransfer.files.length) return;
            var any = false;
            for (var i = 0; i < e.dataTransfer.files.length; i++) {
                var f = e.dataTransfer.files[i];
                if (f && f.type && f.type.indexOf('image/') === 0) { any = true; uploadAndInsertImage(f); }
            }
            if (any) e.preventDefault();
        });

        // "+ Image" toolbar button → hidden file input → upload.
        var insertImageBtn = document.getElementById('storyInsertImageBtn');
        var insertImageInput = document.getElementById('storyInsertImageInput');
        if (insertImageBtn && insertImageInput) {
            insertImageBtn.addEventListener('mousedown', function (e) { e.preventDefault(); });
            insertImageBtn.addEventListener('click', function () { insertImageInput.click(); });
            insertImageInput.addEventListener('change', function () {
                if (!insertImageInput.files || !insertImageInput.files.length) return;
                for (var i = 0; i < insertImageInput.files.length; i++) {
                    uploadAndInsertImage(insertImageInput.files[i]);
                }
                insertImageInput.value = '';
            });
        }

        // Word count + reading time. ~225 wpm for memoir prose feels honest.
        var wordCountEl = document.getElementById('storyWordCount');
        var readMinEl   = document.getElementById('storyReadMin');
        function updateStats() {
            var text = editor.innerText || '';
            var words = text.trim() ? text.trim().split(/\s+/).length : 0;
            if (wordCountEl) wordCountEl.textContent = words;
            if (readMinEl)   readMinEl.textContent = Math.max(1, Math.round(words / 225));
        }
        editor.addEventListener('input', updateStats);
        updateStats();

        // localStorage autosave. New stories get a stable per-tab key
        // so a different draft each time the page is opened doesn't
        // collide; on submit we clear the key so the next new story
        // starts fresh. Restore on load if the editor is empty (i.e.
        // server didn't pre-fill from a draft model).
        var draftKey = 'mst:story-draft:create';
        var autosaveEl = document.getElementById('storyAutosave');
        var titleInput = document.querySelector('.story-title-input');
        var lastSavedAt = 0;
        function setAutosaveStatus(text) {
            if (autosaveEl) autosaveEl.textContent = text;
        }
        function tickStatus() {
            if (!lastSavedAt) return;
            var sec = Math.round((Date.now() - lastSavedAt) / 1000);
            if (sec < 5) setAutosaveStatus('Saved just now');
            else if (sec < 60) setAutosaveStatus('Saved ' + sec + 's ago');
            else setAutosaveStatus('Saved ' + Math.round(sec / 60) + 'm ago');
        }
        setInterval(tickStatus, 5000);

        var autosaveTimer = null;
        function saveDraft() {
            try {
                var snapshot = {
                    title: titleInput ? titleInput.value : '',
                    // Mirror the sync rule so the autosave snapshot matches
                    // what would be persisted on submit (inline keeps imgs).
                    body:  inlineMode() ? (editor.innerHTML || '') : stripImgs(editor.innerHTML),
                    inline: inlineMode(),
                    at:    Date.now()
                };
                if (!snapshot.title && !snapshot.body) return;
                localStorage.setItem(draftKey, JSON.stringify(snapshot));
                lastSavedAt = snapshot.at;
                tickStatus();
            } catch (_) { /* storage full / disabled — ignore */ }
        }
        editor.addEventListener('input', function () {
            clearTimeout(autosaveTimer);
            autosaveTimer = setTimeout(saveDraft, 4000);
        });
        if (titleInput) {
            titleInput.addEventListener('input', function () {
                clearTimeout(autosaveTimer);
                autosaveTimer = setTimeout(saveDraft, 4000);
            });
        }

        // Restore: only if the server didn't pre-fill body, AND there's
        // a saved snapshot from this browser. Ask before overwriting an
        // empty editor — surprise restoration would be confusing.
        (function tryRestore() {
            if (hidden.value) return; // server already loaded something
            try {
                var raw = localStorage.getItem(draftKey);
                if (!raw) return;
                var snap = JSON.parse(raw);
                if (!snap || (!snap.title && !snap.body)) return;
                var ageMin = (Date.now() - (snap.at || 0)) / 60000;
                var label = (snap.body || '').replace(/<[^>]*>/g, ' ').trim().slice(0, 60);
                var msg = 'You have an unsaved draft from this browser';
                if (ageMin >= 1) msg += ' (' + Math.round(ageMin) + ' min ago)';
                msg += '. Restore it?';
                if (label) msg += '\n\n"' + label + '..."';
                if (window.confirm(msg)) {
                    if (titleInput && snap.title) titleInput.value = snap.title;
                    if (snap.body) {
                        editor.innerHTML = snap.body;
                        sync();
                        updateStats();
                    }
                    setAutosaveStatus('Restored from your last session');
                } else {
                    localStorage.removeItem(draftKey);
                }
            } catch (_) { /* parse / storage error — ignore */ }
        })();

        // Clear the localStorage draft once the post is submitted (either
        // path — Save as draft or Publish). The server-side draft / post
        // is the source of truth from that point on.
        form.addEventListener('submit', function () {
            try { localStorage.removeItem(draftKey); } catch (_) {}
        });

        // Auto-pick the layout style from the channel's default whenever
        // the writer changes the channel selection. They can still flip
        // the layout manually after.
        var channelSelect = document.getElementById('channelSelect');
        var layoutStyleSelect = document.getElementById('layoutStyleSelect');
        if (channelSelect && layoutStyleSelect) {
            channelSelect.addEventListener('change', function () {
                var opt = channelSelect.options[channelSelect.selectedIndex];
                var defaultLayout = opt && opt.dataset.defaultLayout;
                if (defaultLayout != null && defaultLayout !== '') {
                    layoutStyleSelect.value = defaultLayout;
                }
            });
        }

        // Music modal save → write to hidden input + show badge
        var musicSave = document.getElementById('fullStoryMusicSave');
        var musicInput = document.querySelector('.music-url-input-fs');
        var musicHidden = document.getElementById('fullStoryMusicUrl');
        var musicBadge = document.querySelector('.story-action-btn[data-bs-target="#fullStoryMusicModal"] .music-set-badge');
        if (musicSave) {
            musicSave.addEventListener('click', function () {
                var v = (musicInput.value || '').trim();
                musicHidden.value = v;
                if (musicBadge) {
                    if (v) { musicBadge.textContent = '•'; musicBadge.classList.remove('d-none'); }
                    else   { musicBadge.classList.add('d-none'); }
                }
            });
        }

        // Save-as-draft button → flips hidden IsDraft before submit
        var draftBtn = document.getElementById('fullStorySaveDraftBtn');
        var publishBtn = document.getElementById('fullStoryPublishBtn');
        var draftFlag = document.getElementById('fullStoryIsDraft');
        if (draftBtn && draftFlag) {
            draftBtn.addEventListener('click', function () { draftFlag.value = 'true'; });
        }
        if (publishBtn && draftFlag) {
            publishBtn.addEventListener('click', function () { draftFlag.value = 'false'; });
        }

        // Media count badge
        var mediaInput = document.getElementById('fullStoryMediaInput');
        var mediaBadge = document.querySelector('.story-action-btn[data-bs-target="#fullStoryMediaModal"] .media-count-badge');
        if (mediaInput && mediaBadge) {
            mediaInput.addEventListener('change', function () {
                var n = mediaInput.files ? mediaInput.files.length : 0;
                if (n > 0) { mediaBadge.textContent = String(n); mediaBadge.classList.remove('d-none'); }
                else       { mediaBadge.classList.add('d-none'); }
            });
        }
    })();
    </script>
}
