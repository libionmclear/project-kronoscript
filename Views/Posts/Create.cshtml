@model MyStoryTold.Models.ViewModels.CreatePostViewModel
@inject Microsoft.AspNetCore.Identity.UserManager<MyStoryTold.Models.ApplicationUser> _userManagerCh
@inject MyStoryTold.Data.ApplicationDbContext _dbCh
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = "New Full Story";
    var taggable = ViewBag.TaggableFriends as List<MyStoryTold.Models.ViewModels.TaggableFriendViewModel> ?? new();

    // Channels this user can publish into. Empty list = no channel selector shown.
    var meIdCh = _userManagerCh.GetUserId(User);

    // Biographical/managed profiles this admin owns — drives the "Post as" picker.
    // Also collect channels the managed accounts can publish into so the channel
    // dropdown stays usable when posting as one of them.
    var myManagedUsers = string.IsNullOrEmpty(meIdCh) || !User.IsInRole("Admin")
        ? new List<MyStoryTold.Models.ApplicationUser>()
        : await _dbCh.Users
            .Where(u => u.ManagedByUserId == meIdCh && u.IsBiographical)
            .OrderBy(u => u.DisplayName)
            .ToListAsync();
    var managedIds = myManagedUsers.Select(u => u.Id).ToList();

    var myChannels = string.IsNullOrEmpty(meIdCh)
        ? new List<MyStoryTold.Models.Channel>()
        : await _dbCh.Channels
            .Where(c => c.AdminUserId == meIdCh || (c.AdminUserId != null && managedIds.Contains(c.AdminUserId)))
            .OrderBy(c => c.Name)
            .ToListAsync();
}

<div class="row g-4">
    <div class="col-md-3 col-sidebar sticky-rail d-none d-md-block">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-9 col-main">

        <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="mb-0">@(Model.MemoryOfPostId.HasValue ? "Connect your memory" : "New Full Story")</h3>
            <a asp-action="Timeline" asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
               class="btn btn-sm btn-outline-secondary">Cancel</a>
        </div>

        @if (Model.MemoryOfPostId.HasValue)
        {
            <div class="memory-of-banner mb-3">
                <span class="memory-of-icon">🔗</span>
                <div class="memory-of-text">
                    <div class="small text-muted">You're writing your personal memory of</div>
                    <a asp-action="Detail" asp-route-id="@Model.MemoryOfPostId" class="fw-semibold text-decoration-none">
                        @Model.MemoryOfPostTitle
                    </a>
                    <div class="small text-muted mt-1">
                        It will live on your timeline like any other story, with a small chip linking back to the article.
                    </div>
                </div>
            </div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data" id="fullStoryForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>
            <input type="hidden" asp-for="MemoryOfPostId" />
            <input type="hidden" asp-for="MemoryOfPostTitle" />

            <!-- The page itself -->
            <div class="story-page">
                <input asp-for="Title" class="story-title-input" placeholder="Title (optional)" />

                <!-- Editorial toolbar -->
                <div class="story-toolbar" role="toolbar" aria-label="Formatting">
                    <button type="button" class="story-tool" data-cmd="bold" title="Bold (Ctrl+B)"><strong>B</strong></button>
                    <button type="button" class="story-tool" data-cmd="italic" title="Italic (Ctrl+I)"><em>I</em></button>
                    <button type="button" class="story-tool" data-cmd="underline" title="Underline (Ctrl+U)"><u>U</u></button>
                    <span class="story-tool-sep"></span>
                    <button type="button" class="story-tool" data-cmd="formatBlock" data-arg="H2" title="Heading">H</button>
                    <button type="button" class="story-tool" data-cmd="formatBlock" data-arg="BLOCKQUOTE" title="Quote">&ldquo; &rdquo;</button>
                    <span class="story-tool-sep"></span>
                    <button type="button" class="story-tool" data-cmd="insertUnorderedList" title="Bullet list">&bull;</button>
                    <button type="button" class="story-tool" data-cmd="formatBlock" data-arg="P" title="Plain paragraph">¶</button>
                </div>

                <div id="storyEditor" class="story-editor" contenteditable="true"
                     data-placeholder="Start telling your story… you can paste images directly. Take your time."></div>
                <textarea asp-for="Body" id="storyBody" class="d-none"></textarea>

                <!-- Floating action icons (live on the page edge) -->
                <div class="story-page-actions">
                    <button type="button" class="story-action-btn" data-bs-toggle="modal" data-bs-target="#fullStoryMediaModal" title="Attach photos or videos" aria-label="Attach media">
                        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="11" r="2"/><path d="M21 15l-5-5L6 19"/></svg>
                        <span class="story-action-badge media-count-badge d-none"></span>
                    </button>
                    <button type="button" class="story-action-btn" data-bs-toggle="modal" data-bs-target="#fullStoryMusicModal" title="Memory Music link" aria-label="Memory Music">
                        <svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                        <span class="story-action-badge music-set-badge d-none"></span>
                    </button>
                </div>
            </div>

            <!-- Compact metadata row -->
            <div class="story-meta mt-3">
                <div class="row g-2 align-items-center">
                    <div class="col-auto">
                        <label class="form-label small fw-semibold mb-0 me-1" style="color:var(--mst-muted);">Story Date:</label>
                    </div>
                    <div class="col-auto">
                        <input asp-for="EventYear" class="form-control form-control-sm" type="number" max="2100"
                               placeholder="Year (-=BC)" style="width:120px;" />
                    </div>
                    <div class="col-auto">
                        <select asp-for="EventMonth" class="form-select form-select-sm" style="width:120px;">
                            <option value="">Month</option>
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <input asp-for="EventDay" class="form-control form-control-sm" type="number" min="1" max="31"
                               placeholder="Day" style="width:74px;" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-0">
                            <input asp-for="EventDateIsEstimated" class="form-check-input" />
                            <label asp-for="EventDateIsEstimated" class="form-check-label small text-muted">Estimated</label>
                        </div>
                    </div>
                </div>

                @if (myManagedUsers.Any())
                {
                    <div class="alert mb-2 py-2" style="background: rgba(160,110,60,0.10); border:1px solid rgba(160,110,60,0.4);">
                        <label asp-for="PostAsUserId" class="form-label small fw-semibold mb-1">Post as (optional)</label>
                        <select asp-for="PostAsUserId" class="form-select form-select-sm" style="max-width:360px;">
                            <option value="">— Yourself —</option>
                            @foreach (var u in myManagedUsers)
                            {
                                <option value="@u.Id">📜 @(u.DisplayName ?? u.UserName)@(string.IsNullOrEmpty(u.BiographicalEra) ? "" : $" ({u.BiographicalEra})")</option>
                            }
                        </select>
                        <small class="text-muted d-block mt-1">
                            Publishing on behalf of a biographical profile. Their post will get a sepia accent on the feed.
                        </small>
                    </div>
                }

                @if (myChannels.Any())
                {
                    <div class="alert mb-2 py-2" style="background: rgba(240,192,64,0.10); border:1px solid rgba(240,192,64,0.4);">
                        <label asp-for="ChannelId" class="form-label small fw-semibold mb-1">Publish to channel (optional)</label>
                        <select asp-for="ChannelId" class="form-select form-select-sm" id="channelSelect" style="max-width:360px;">
                            <option value="">— Personal post (no channel) —</option>
                            @foreach (var ch in myChannels)
                            {
                                <option value="@ch.Id" data-default-layout="@((int)ch.DefaultLayoutStyle)">@(ch.IconEmoji ?? "📚") @ch.Name</option>
                            }
                        </select>
                        <small class="text-muted d-block mt-1">
                            Channel posts pick up the channel's default layout (Journal or Book).
                        </small>
                    </div>
                }

                <!-- Layout style picker — controls how this post renders on
                     the Detail page (and the feed card). Channels seed it
                     to their default; biographical posts seed to Book. The
                     writer can still flip it before publishing. -->
                <div class="row g-1 mb-2 align-items-center">
                    <div class="col-auto">
                        <label asp-for="LayoutStyle" class="form-label small fw-semibold mb-0 me-1" style="color:var(--mst-muted);">Layout:</label>
                    </div>
                    <div class="col-auto">
                        <select asp-for="LayoutStyle" id="layoutStyleSelect" class="form-select form-select-sm" style="width:auto;">
                            <option value="0">Standard (memoir card)</option>
                            <option value="1">📰 Journal (newspaper)</option>
                            <option value="2">📖 Book chapter</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <small class="text-muted">
                            Journal = serif headline, two-column body, drop cap. Book = italic title, single chapter column.
                            After publishing, you'll be taken to Edit to position photos on the layout grid.
                        </small>
                    </div>
                </div>

                <div class="row g-2 mt-2">
                    <div class="col-md-5">
                        <select asp-for="Visibility" class="form-select form-select-sm visibility-select">
                            <option value="Public">● Public</option>
                            <option value="Acquaintances">● Acquaintances</option>
                            <option value="Friends" selected>● Friends</option>
                            <option value="Family">● Family</option>
                            <option value="Private">🔒 Only Me</option>
                        </select>
                    </div>
                    <div class="col-md-7">
                        <input asp-for="Location" class="form-control form-control-sm" placeholder="📍 Location (optional)" />
                    </div>
                </div>
            </div>

            <input type="hidden" name="MusicUrl" id="fullStoryMusicUrl" />
            <!-- Pasted-image preview tiles. Each tile holds a hidden
                 PastedImageUrls input plus the visible thumbnail; drag to
                 reorder and the inputs ride along, so submit order matches
                 what the writer sees. Empty by default; tiles are added by
                 the paste handler in the script section below. -->
            <div id="mediaReorderGrid" class="media-reorder-grid mt-2 d-none"></div>
            <div id="pastedImagesPreview" class="d-none"></div>

            <!-- Tag People -->
            <div class="mt-3">
                @await Html.PartialAsync("_TagWidget", new MyStoryTold.Models.ViewModels.TagWidgetViewModel
                {
                    Friends = taggable,
                    Selected = new List<MyStoryTold.Models.ViewModels.TaggableFriendViewModel>()
                })
            </div>

            <input type="hidden" name="IsDraft" id="fullStoryIsDraft" value="false" />
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary" id="fullStoryPublishBtn">Publish Story</button>
                <button type="submit" class="btn btn-outline-warning" id="fullStorySaveDraftBtn">Save as Draft</button>
                <a asp-controller="Posts" asp-action="Drafts" class="btn btn-outline-secondary">My Drafts</a>
                <a asp-action="Timeline" asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
                   class="btn btn-outline-secondary ms-auto">Cancel</a>
            </div>
        </form>
    </div>
</div>

<!-- Memory Music modal -->
<div class="modal fade" id="fullStoryMusicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">🎵 Memory Music</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">Paste a YouTube, Spotify, Apple Music or any link to a song that takes you back to this memory.</p>
                <input type="url" class="form-control music-url-input-fs" placeholder="https://www.youtube.com/watch?v=..." />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="fullStoryMusicSave" data-bs-dismiss="modal">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Media attach modal -->
<div class="modal fade" id="fullStoryMediaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Attach media</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small fw-semibold">Photos or videos</label>
                <input type="file" class="form-control" id="fullStoryMediaInput" name="Images" accept="image/*,video/*" multiple form="fullStoryForm" />
                <p class="text-muted small mt-2 mb-0">Select multiple if you like — they'll be saved with the story.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="modal">Done</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        // Sync contenteditable → hidden textarea on every keystroke and on submit
        var editor = document.getElementById('storyEditor');
        var hidden = document.getElementById('storyBody');
        var form = document.getElementById('fullStoryForm');
        if (!editor || !hidden || !form) return;

        // Pasted images render as <img> inline so the writer sees them, but
        // they're saved separately as PostMedia (via the hidden PastedImageUrls
        // inputs) and BodyRenderer html-encodes the body. So strip <img> tags
        // from the body before syncing — otherwise the raw markup leaks into
        // the published post as literal text alongside the proper image.
        function stripImgs(html) {
            return (html || '').replace(/<img\b[^>]*>/gi, '');
        }

        // Initialize from any existing model value
        if (hidden.value) editor.innerHTML = hidden.value;

        function sync() { hidden.value = stripImgs(editor.innerHTML); }
        editor.addEventListener('input', sync);
        form.addEventListener('submit', sync);

        // Toolbar (uses execCommand — old API but fine for this lightweight editor)
        document.querySelectorAll('.story-tool').forEach(function (btn) {
            btn.addEventListener('mousedown', function (e) { e.preventDefault(); }); // keep selection
            btn.addEventListener('click', function () {
                var cmd = btn.dataset.cmd;
                var arg = btn.dataset.arg || null;
                editor.focus();
                document.execCommand(cmd, false, arg);
                sync();
            });
        });

        // ── Pasted-image reorder grid ─────────────────────────────────────
        // Each pasted image becomes a draggable tile holding the visible
        // thumbnail AND the hidden PastedImageUrls input. Drag rearranges DOM
        // so form submit picks up the new order; the first tile becomes the
        // home-feed cover.
        var reorderGrid = document.getElementById('mediaReorderGrid');
        function addReorderTile(url) {
            if (!reorderGrid) return;
            reorderGrid.classList.remove('d-none');

            var tile = document.createElement('div');
            tile.className = 'media-reorder-tile';
            tile.draggable = true;

            var hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = 'PastedImageUrls';
            hidden.value = url;
            tile.appendChild(hidden);

            var img = document.createElement('img');
            img.src = url;
            img.alt = '';
            tile.appendChild(img);

            var grip = document.createElement('span');
            grip.className = 'media-reorder-grip';
            grip.setAttribute('aria-hidden', 'true');
            grip.textContent = '⋮⋮';
            tile.appendChild(grip);

            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'media-reorder-remove';
            rm.title = 'Remove';
            rm.setAttribute('aria-label', 'Remove image');
            rm.textContent = '✕';
            rm.addEventListener('click', function () {
                tile.remove();
                if (!reorderGrid.querySelector('.media-reorder-tile')) reorderGrid.classList.add('d-none');
                sync();
            });
            tile.appendChild(rm);

            wireTileDrag(tile);
            reorderGrid.appendChild(tile);
        }

        var dragSrc = null;
        function wireTileDrag(tile) {
            tile.addEventListener('dragstart', function (e) {
                dragSrc = tile;
                tile.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
                try { e.dataTransfer.setData('text/plain', tile.querySelector('input')?.value || ''); } catch (_) {}
            });
            tile.addEventListener('dragend', function () {
                tile.classList.remove('dragging');
                reorderGrid.querySelectorAll('.media-reorder-tile').forEach(function (t) { t.classList.remove('drag-over'); });
                dragSrc = null;
            });
            tile.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                if (dragSrc && tile !== dragSrc) tile.classList.add('drag-over');
            });
            tile.addEventListener('dragleave', function () { tile.classList.remove('drag-over'); });
            tile.addEventListener('drop', function (e) {
                e.preventDefault();
                tile.classList.remove('drag-over');
                if (!dragSrc || tile === dragSrc) return;
                var rect = tile.getBoundingClientRect();
                var midX = rect.left + rect.width / 2;
                var midY = rect.top + rect.height / 2;
                var before = (e.clientY < midY) || (e.clientY < rect.top + rect.height && e.clientX < midX);
                reorderGrid.insertBefore(dragSrc, before ? tile : tile.nextSibling);
            });
        }

        // Strip pasted HTML down to the editor's own typography. Word/Docs/web
        // pastes carry inline style, font-family, color, and span/div noise
        // that visually clashes with the page; we keep only basic semantic
        // tags (b/i/u, headings, blockquote, lists, links, line breaks).
        // Note: BLOCKQUOTE is intentionally NOT here — pasting an article's
        // quoted paragraph used to drop the writer's text into an indented
        // quote block, which doesn't match the editor's typography. The "
        // toolbar button can still apply a quote when the writer wants one.
        var ALLOWED_TAGS = ['B','STRONG','I','EM','U','BR','P','H2','H3','UL','OL','LI','A'];
        function cleanPastedHtml(html) {
            var doc = new DOMParser().parseFromString('<div id="root">' + html + '</div>', 'text/html');
            var root = doc.getElementById('root');
            // Drop entire <style>/<script>/<meta>/<link>/<head> subtrees first.
            ['style','script','meta','link','head'].forEach(function (tag) {
                root.querySelectorAll(tag).forEach(function (el) { el.remove(); });
            });
            (function walk(node) {
                var i = node.childNodes.length;
                while (i--) {
                    var c = node.childNodes[i];
                    if (c.nodeType === 1) {
                        walk(c);
                        if (ALLOWED_TAGS.indexOf(c.nodeName) === -1) {
                            // Unwrap: replace the disallowed element with its children.
                            var parent = c.parentNode;
                            while (c.firstChild) parent.insertBefore(c.firstChild, c);
                            parent.removeChild(c);
                        } else {
                            // Strip every attribute (style/class/font/color/etc.).
                            // Preserve only href on <a>; force safe target/rel.
                            for (var j = c.attributes.length - 1; j >= 0; j--) {
                                c.removeAttribute(c.attributes[j].name);
                            }
                            if (c.nodeName === 'A') {
                                // Re-read href from the original (we just stripped it) — fall back to text.
                            }
                        }
                    } else if (c.nodeType === 8) {
                        c.remove(); // comments
                    }
                }
            })(root);
            // Re-extract hrefs from the original HTML and re-stitch onto <a> tags
            // matching by text content. Cheap heuristic: just keep any href that
            // survived because we only stripped after walking — but we just
            // stripped them above. Re-parse to keep hrefs:
            var doc2 = new DOMParser().parseFromString('<div id="root">' + html + '</div>', 'text/html');
            var origLinks = Array.from(doc2.querySelectorAll('a[href]'));
            var newLinks = root.querySelectorAll('a');
            for (var k = 0; k < newLinks.length && k < origLinks.length; k++) {
                var href = origLinks[k].getAttribute('href') || '';
                if (/^(https?:|mailto:|\/)/i.test(href)) {
                    newLinks[k].setAttribute('href', href);
                    newLinks[k].setAttribute('target', '_blank');
                    newLinks[k].setAttribute('rel', 'noopener noreferrer');
                }
            }
            return root.innerHTML;
        }

        function escapeHtml(text) {
            return (text || '').replace(/[&<>"']/g, function (c) {
                return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]);
            }).replace(/\r\n|\r|\n/g, '<br>');
        }

        // Paste handler: images upload via /Posts/UploadPastedImage; text/HTML
        // is normalized to the editor's typography before insertion.
        editor.addEventListener('paste', function (e) {
            var cd = e.clipboardData || e.originalEvent.clipboardData;
            if (!cd) return;

            // 1) Image paste — upload + insert <img>.
            var items = cd.items || [];
            var hasImage = false;
            for (var i = 0; i < items.length; i++) {
                if (items[i].kind === 'file' && items[i].type && items[i].type.indexOf('image') === 0) {
                    hasImage = true;
                    e.preventDefault();
                    var blob = items[i].getAsFile();
                    if (!blob) continue;
                    var fd = new FormData();
                    fd.append('file', blob, blob.name || 'pasted-image.png');
                    fetch('/Posts/UploadPastedImage', { method: 'POST', body: fd, credentials: 'same-origin' })
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            if (!data || !data.url) return;
                            addReorderTile(data.url);
                            document.execCommand('insertHTML', false,
                                '<img src="' + data.url + '" style="max-width:100%;border-radius:8px;margin:8px 0;" />');
                            sync();
                        })
                        .catch(function () {});
                }
            }
            if (hasImage) return;

            // 2) Rich/plain text paste — sanitize before insert.
            var html = cd.getData('text/html');
            var text = cd.getData('text/plain');
            if (!html && !text) return; // unknown type — let browser do its thing
            e.preventDefault();
            var insert = html ? cleanPastedHtml(html) : escapeHtml(text);
            document.execCommand('insertHTML', false, insert);
            sync();
        });

        // Auto-pick the layout style from the channel's default whenever
        // the writer changes the channel selection. They can still flip
        // the layout manually after.
        var channelSelect = document.getElementById('channelSelect');
        var layoutStyleSelect = document.getElementById('layoutStyleSelect');
        if (channelSelect && layoutStyleSelect) {
            channelSelect.addEventListener('change', function () {
                var opt = channelSelect.options[channelSelect.selectedIndex];
                var defaultLayout = opt && opt.dataset.defaultLayout;
                if (defaultLayout != null && defaultLayout !== '') {
                    layoutStyleSelect.value = defaultLayout;
                }
            });
        }

        // Music modal save → write to hidden input + show badge
        var musicSave = document.getElementById('fullStoryMusicSave');
        var musicInput = document.querySelector('.music-url-input-fs');
        var musicHidden = document.getElementById('fullStoryMusicUrl');
        var musicBadge = document.querySelector('.story-action-btn[data-bs-target="#fullStoryMusicModal"] .music-set-badge');
        if (musicSave) {
            musicSave.addEventListener('click', function () {
                var v = (musicInput.value || '').trim();
                musicHidden.value = v;
                if (musicBadge) {
                    if (v) { musicBadge.textContent = '•'; musicBadge.classList.remove('d-none'); }
                    else   { musicBadge.classList.add('d-none'); }
                }
            });
        }

        // Save-as-draft button → flips hidden IsDraft before submit
        var draftBtn = document.getElementById('fullStorySaveDraftBtn');
        var publishBtn = document.getElementById('fullStoryPublishBtn');
        var draftFlag = document.getElementById('fullStoryIsDraft');
        if (draftBtn && draftFlag) {
            draftBtn.addEventListener('click', function () { draftFlag.value = 'true'; });
        }
        if (publishBtn && draftFlag) {
            publishBtn.addEventListener('click', function () { draftFlag.value = 'false'; });
        }

        // Media count badge
        var mediaInput = document.getElementById('fullStoryMediaInput');
        var mediaBadge = document.querySelector('.story-action-btn[data-bs-target="#fullStoryMediaModal"] .media-count-badge');
        if (mediaInput && mediaBadge) {
            mediaInput.addEventListener('change', function () {
                var n = mediaInput.files ? mediaInput.files.length : 0;
                if (n > 0) { mediaBadge.textContent = String(n); mediaBadge.classList.remove('d-none'); }
                else       { mediaBadge.classList.add('d-none'); }
            });
        }
    })();
    </script>
}
