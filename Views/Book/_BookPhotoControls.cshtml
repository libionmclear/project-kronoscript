@model MyStoryTold.Models.PostMedia
@{
    var wrap = Model.BookWrap ?? "";
    var size = Model.BookSize ?? "medium";
}
@* Per-photo book-view controls. Owner-only — this view is /Book/Index
   which the controller already scopes to the current user. The menu
   element carries data-media-id so the JS portal can re-locate it
   after moving it to document.body (escapes the page-frame's overflow). *@
<div class="book-photo-controls">
    <button type="button" class="book-photo-grip" title="Drag to reorder" aria-label="Drag">⋮⋮</button>
    <div class="book-photo-menu-wrap">
        <button type="button" class="book-photo-menu-btn" aria-label="Photo options" title="Photo options">···</button>
        <div class="book-photo-menu" data-media-id="@Model.Id" hidden>
            <div class="book-photo-menu-section">
                <div class="book-photo-menu-label">Text wrap</div>
                <div class="book-photo-menu-row book-photo-menu-row-wrap">
                    <button type="button" class="book-photo-opt @(wrap == "" ? "is-on" : "")"
                            data-set-wrap=""
                            title="Photo sits on its own line — text does not flow around it">Don't wrap</button>
                    <button type="button" class="book-photo-opt @(wrap == "left" ? "is-on" : "")"
                            data-set-wrap="left"
                            title="Photo floats left — text wraps around it on the right">Wrap left</button>
                    <button type="button" class="book-photo-opt @(wrap == "right" ? "is-on" : "")"
                            data-set-wrap="right"
                            title="Photo floats right — text wraps around it on the left">Wrap right</button>
                </div>
            </div>
            <div class="book-photo-menu-section">
                <div class="book-photo-menu-label">Size</div>
                <div class="book-photo-menu-row">
                    <button type="button" class="book-photo-opt @(size == "small" ? "is-on" : "")" data-set-size="small">S</button>
                    <button type="button" class="book-photo-opt @(size == "medium" ? "is-on" : "")" data-set-size="medium">M</button>
                    <button type="button" class="book-photo-opt @(size == "large" ? "is-on" : "")" data-set-size="large">L</button>
                </div>
            </div>
            <div class="book-photo-menu-section">
                <div class="book-photo-menu-label">Fit</div>
                <div class="book-photo-menu-row">
                    <button type="button" class="book-photo-opt" data-toggle-crop title="Toggle between full image and square crop">Full / Crop</button>
                </div>
            </div>
            <div class="book-photo-menu-section">
                <button type="button" class="book-photo-hide-btn" data-toggle-hide>Hide from book</button>
            </div>
        </div>
    </div>
</div>
