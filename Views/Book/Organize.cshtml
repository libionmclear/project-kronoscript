@model List<MyStoryTold.Models.LifeEventPost>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Organize my book";
    var chapters = (ViewBag.Chapters as List<MyStoryTold.Models.BookChapter>) ?? new();
    var storyCount = (int)(ViewBag.StoryCount ?? 0);

    // Build chapter parent/child tree, sorted.
    var topChapters = chapters
        .Where(c => c.ParentChapterId == null)
        .OrderBy(c => c.Year).ThenBy(c => c.SortOrder).ThenBy(c => c.Id)
        .ToList();
    var subByParent = chapters
        .Where(c => c.ParentChapterId.HasValue)
        .GroupBy(c => c.ParentChapterId!.Value)
        .ToDictionary(g => g.Key,
            g => g.OrderBy(c => c.SortOrder).ThenBy(c => c.Id).ToList());

    // Available years from existing stories — drive the "year" dropdown
    // on the create-chapter form. Fall back to current year.
    var yearChoices = Model.Select(p => p.EventYear).Distinct().OrderBy(y => y).ToList();
    if (!yearChoices.Any()) yearChoices.Add(DateTime.UtcNow.Year);

    // Group all stories by year for the right column.
    var postsByYear = Model
        .GroupBy(p => p.EventYear)
        .OrderBy(g => g.Key)
        .ToList();

    string Abbreviate(string s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "Untitled";
        return s.Length <= max ? s : s.Substring(0, max - 1).TrimEnd() + "…";
    }

    // ── Local Razor helper to render one chapter box (recursive
    //    via the SubChapter loop). Drop-target dataset.id wires it
    //    up to Sortable.js as a destination for story bubbles. ──
}

@functions {
    string PhotoFor(MyStoryTold.Models.LifeEventPost p)
    {
        var photo = (p.Media ?? new List<MyStoryTold.Models.PostMedia>())
            .FirstOrDefault(m => m.MediaType == MyStoryTold.Models.MediaType.Image
                                 && !string.IsNullOrEmpty(m.Url));
        return photo?.Url ?? "";
    }
}

<div class="organize-shell-v2">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-1">Organize my book</h3>
            <p class="text-muted mb-0" style="font-size:0.92rem;">
                Drag a story bubble from the right into a chapter box on the left.
                Drop a chapter onto another chapter to make it a subchapter.
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary btn-sm">📖 Back to the book</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning py-2">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2">@TempData["Success"]</div>
    }

    @* ── Top: + Create chapter + Auto-by-year ──────────────────── *@
    <div class="organize-top-bar">
        <form asp-action="CreateChapter" method="post" class="organize-create-chapter">
            @Html.AntiForgeryToken()
            <span class="organize-plus">+</span>
            <input type="text" name="title" maxlength="200" required
                   class="form-control form-control-sm"
                   placeholder='New chapter title — e.g. "The big year"' />
            <select name="year" class="form-select form-select-sm year-pick">
                @foreach (var y in yearChoices)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <button type="submit" class="btn btn-primary btn-sm">Create</button>
        </form>
        <form asp-action="AutoCreateYearChapters" method="post" class="organize-auto-year"
              title="Create one chapter per year that doesn't have one yet, named with the year, and auto-assign unassigned stories from that year">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary btn-sm">
                ✨ Auto-create chapters by year
            </button>
        </form>
    </div>

    @if (storyCount == 0)
    {
        <div class="empty-state card border-0 shadow-sm text-center p-5 mt-3">
            <div class="empty-state-mark">📖</div>
            <h4 class="mt-3 mb-2">Nothing to organize yet</h4>
            <p class="text-muted">Publish a story and it'll appear here as a bubble you can drag into a chapter.</p>
        </div>
    }
    else
    {
        <div class="organize-split">
            @* ── LEFT: chapter boxes (drop targets) ────────────────── *@
            <div class="organize-left">
                <h5 class="organize-col-title">📚 Chapters</h5>
                @if (!topChapters.Any())
                {
                    <div class="organize-empty-hint">
                        No chapters yet. Use the form above to create one.
                    </div>
                }
                @foreach (var chapter in topChapters)
                {
                    var inChapter = Model.Where(p => p.BookChapterId == chapter.Id).ToList();
                    var subs = subByParent.GetValueOrDefault(chapter.Id) ?? new List<MyStoryTold.Models.BookChapter>();
                    <div class="organize-chapter-card" data-chapter-id="@chapter.Id">
                        <form asp-action="RenameChapter" asp-route-id="@chapter.Id" method="post"
                              class="organize-chapter-head">
                            @Html.AntiForgeryToken()
                            <span class="organize-chapter-year">@chapter.Year</span>
                            <input type="text" name="title" value="@chapter.Title"
                                   class="form-control form-control-sm organize-chapter-title"
                                   maxlength="200" required />
                            <button type="submit" class="btn btn-sm btn-link p-1" title="Save title">💾</button>
                        </form>
                        <div class="organize-chapter-meta">
                            <span class="text-muted small">
                                @inChapter.Count @(inChapter.Count == 1 ? "story" : "stories")
                            </span>
                            <form asp-action="DeleteChapter" asp-route-id="@chapter.Id" method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Remove this chapter? Stories inside become Unassigned.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-link text-danger p-0">🗑</button>
                            </form>
                        </div>

                        @* Drop zone: bubbles for stories in this chapter *@
                        <div class="organize-drop-zone"
                             data-chapter-id="@chapter.Id"
                             aria-label="Stories in @chapter.Title">
                            @foreach (var p in inChapter)
                            {
                                <span class="organize-bubble organize-bubble-sm"
                                      data-post-id="@p.Id"
                                      title="@p.Title">
                                    @{ var u = PhotoFor(p); }
                                    @if (!string.IsNullOrEmpty(u))
                                    {
                                        <img src="@u" alt="" />
                                    }
                                    else
                                    {
                                        <span class="organize-bubble-icon">📄</span>
                                    }
                                    <span class="organize-bubble-mini-title">@Abbreviate(p.Title ?? "Untitled", 16)</span>
                                </span>
                            }
                        </div>

                        @* Subchapter add form *@
                        <form asp-action="CreateChapter" method="post" class="organize-add-sub">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="year" value="@chapter.Year" />
                            <input type="hidden" name="parentChapterId" value="@chapter.Id" />
                            <input type="text" name="title" maxlength="200" required
                                   class="form-control form-control-sm"
                                   placeholder="+ Add subchapter…" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">+</button>
                        </form>

                        @* Subchapters *@
                        @if (subs.Any())
                        {
                            <div class="organize-subs">
                                @foreach (var sub in subs)
                                {
                                    var subStories = Model.Where(p => p.BookChapterId == sub.Id).ToList();
                                    <div class="organize-chapter-card organize-chapter-sub" data-chapter-id="@sub.Id">
                                        <form asp-action="RenameChapter" asp-route-id="@sub.Id" method="post"
                                              class="organize-chapter-head">
                                            @Html.AntiForgeryToken()
                                            <span class="organize-chapter-year">@sub.Year</span>
                                            <input type="text" name="title" value="@sub.Title"
                                                   class="form-control form-control-sm organize-chapter-title"
                                                   maxlength="200" required />
                                            <button type="submit" class="btn btn-sm btn-link p-1" title="Save">💾</button>
                                        </form>
                                        <div class="organize-chapter-meta">
                                            <span class="text-muted small">
                                                @subStories.Count @(subStories.Count == 1 ? "story" : "stories")
                                            </span>
                                            <form asp-action="DeleteChapter" asp-route-id="@sub.Id" method="post"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Remove this subchapter?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0">🗑</button>
                                            </form>
                                        </div>
                                        <div class="organize-drop-zone"
                                             data-chapter-id="@sub.Id"
                                             aria-label="Stories in @sub.Title">
                                            @foreach (var p in subStories)
                                            {
                                                <span class="organize-bubble organize-bubble-sm"
                                                      data-post-id="@p.Id"
                                                      title="@p.Title">
                                                    @{ var u2 = PhotoFor(p); }
                                                    @if (!string.IsNullOrEmpty(u2))
                                                    {
                                                        <img src="@u2" alt="" />
                                                    }
                                                    else
                                                    {
                                                        <span class="organize-bubble-icon">📄</span>
                                                    }
                                                    <span class="organize-bubble-mini-title">@Abbreviate(p.Title ?? "Untitled", 14)</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @* "Unassigned" drop zone (special chapterId = 0) *@
                <div class="organize-chapter-card organize-unassigned-box">
                    <div class="organize-chapter-head">
                        <span class="organize-unassigned-label">Unassigned</span>
                    </div>
                    <div class="organize-drop-zone"
                         data-chapter-id="0"
                         aria-label="Drop here to unassign">
                        @{
                            var unassignedAll = Model.Where(p => p.BookChapterId == null).ToList();
                        }
                        @if (!unassignedAll.Any())
                        {
                            <span class="text-muted small fst-italic">Drag here to unassign a story.</span>
                        }
                        @foreach (var p in unassignedAll)
                        {
                            <span class="organize-bubble organize-bubble-sm"
                                  data-post-id="@p.Id"
                                  title="@p.Title">
                                @{ var u3 = PhotoFor(p); }
                                @if (!string.IsNullOrEmpty(u3))
                                {
                                    <img src="@u3" alt="" />
                                }
                                else
                                {
                                    <span class="organize-bubble-icon">📄</span>
                                }
                                <span class="organize-bubble-mini-title">@Abbreviate(p.Title ?? "Untitled", 16)</span>
                            </span>
                        }
                    </div>
                </div>
            </div>

            @* ── RIGHT: story library, grouped by year ────────────── *@
            <div class="organize-right">
                <h5 class="organize-col-title">🪶 All my stories</h5>
                <p class="text-muted small mb-2">
                    Each year is a bucket of bubbles you can drag into a chapter on the left.
                </p>
                @foreach (var yearGroup in postsByYear)
                {
                    <div class="organize-year-pile">
                        <h6 class="organize-year-pile-head">
                            @yearGroup.Key
                            <span class="text-muted small fw-normal">· @yearGroup.Count() @(yearGroup.Count() == 1 ? "story" : "stories")</span>
                        </h6>
                        <div class="organize-drop-zone organize-drop-zone-source"
                             data-year="@yearGroup.Key"
                             data-chapter-id="0">
                            @foreach (var p in yearGroup.OrderBy(p => p.EventMonth ?? 0).ThenBy(p => p.EventDay ?? 0))
                            {
                                <span class="organize-bubble @(p.IncludeInBook ? "" : "is-hidden")"
                                      data-post-id="@p.Id"
                                      data-assigned="@(p.BookChapterId.HasValue ? "1" : "0")"
                                      title="@p.Title @(p.IncludeInBook ? "" : "(hidden from book)")">
                                    @{ var url = PhotoFor(p); }
                                    <span class="organize-bubble-art">
                                        @if (!string.IsNullOrEmpty(url))
                                        {
                                            <img src="@url" alt="" />
                                        }
                                        else
                                        {
                                            <span class="organize-bubble-icon">📄</span>
                                        }
                                    </span>
                                    <span class="organize-bubble-title">@Abbreviate(p.Title ?? "Untitled", 22)</span>
                                    @if (p.BookChapterId.HasValue)
                                    {
                                        var chapName = chapters.FirstOrDefault(c => c.Id == p.BookChapterId.Value)?.Title ?? "";
                                        <span class="organize-bubble-badge" title="In: @chapName">✓</span>
                                    }
                                    <form asp-action="ToggleIncludeInBook" asp-route-id="@p.Id" method="post"
                                          class="organize-bubble-hide-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnTo" value="organize" />
                                        <button type="submit"
                                                class="organize-bubble-hide"
                                                title="@(p.IncludeInBook ? "Hide from book" : "Show in book")">
                                            @(p.IncludeInBook ? "🚫" : "👁")
                                        </button>
                                    </form>
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
@if (storyCount > 0)
{
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>
    (function () {
        var antiForgeryToken =
            document.querySelector('input[name="__RequestVerificationToken"]').value;

        function assignStory(postId, chapterId) {
            return fetch('@Url.Action("AssignStoryAjax", "Book")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: 'postId=' + encodeURIComponent(postId) +
                      '&chapterId=' + encodeURIComponent(chapterId) +
                      '&__RequestVerificationToken=' + encodeURIComponent(antiForgeryToken)
            }).then(function (r) { return r.json(); });
        }

        // Wire every drop-zone as a Sortable group. Bubbles can move
        // between zones; the dragged element's data-post-id + the
        // destination's data-chapter-id tell the server what changed.
        document.querySelectorAll('.organize-drop-zone').forEach(function (z) {
            new Sortable(z, {
                group: 'book-stories',
                animation: 150,
                ghostClass: 'organize-bubble-ghost',
                dragClass: 'organize-bubble-dragging',
                onAdd: function (evt) {
                    var bubble = evt.item;
                    var dest   = evt.to;
                    var postId    = bubble.dataset.postId;
                    var chapterId = dest.dataset.chapterId || '0';
                    bubble.classList.add('is-saving');
                    assignStory(postId, chapterId).then(function (res) {
                        bubble.classList.remove('is-saving');
                        if (!res.ok) {
                            alert('Could not move that story: ' + (res.error || 'unknown error'));
                            location.reload();
                        } else {
                            // Update the ✓ badge state on the source-side bubble
                            // (the bubble in the year column). The visually-moved
                            // bubble may BE that one if dragged from the year list.
                            if (chapterId === '0') {
                                bubble.dataset.assigned = '0';
                                var b = bubble.querySelector('.organize-bubble-badge');
                                if (b) b.remove();
                            } else {
                                bubble.dataset.assigned = '1';
                            }
                        }
                    }).catch(function () {
                        bubble.classList.remove('is-saving');
                        alert('Could not move that story (network error).');
                        location.reload();
                    });
                }
            });
        });
    })();
    </script>
}
}
