@model List<MyStoryTold.Models.LifeEventPost>
@{
    Layout = "_Layout";
    ViewData["Title"] = "My book";
    var author = ViewBag.Author as MyStoryTold.Models.ApplicationUser;
    var storyCount = (int)(ViewBag.StoryCount ?? 0);
    var authorName = author?.DisplayName ?? author?.UserName ?? "My";
    var allChapters = (ViewBag.Chapters as List<MyStoryTold.Models.BookChapter>) ?? new();

    int? firstYear = Model.Count > 0 ? Model.Min(p => p.EventYear) : null;
    int? lastYear  = Model.Count > 0 ? Model.Max(p => p.EventYear) : null;

    int DecadeOf(int year) => (int)Math.Floor(year / 10.0) * 10;
    string DecadeLabel(int decade) => decade < 0
        ? $"The {Math.Abs(decade)}s BC"
        : $"The {decade}s";

    var byDecade = Model
        .GroupBy(p => DecadeOf(p.EventYear))
        .OrderBy(g => g.Key)
        .ToList();

    string Slug(int year, int id) => $"story-{year}-{id}";
    string ChapterSlug(int chapterId) => $"chapter-{chapterId}";
    string YearSlug(int year) => $"year-{year}";

    // Word-count helper. Body is HTML so strip tags before counting.
    // 225 wpm matches the editor's reading-time estimate so the numbers
    // tell a consistent story.
    int CountWords(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return 0;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", " ");
        var decoded = System.Net.WebUtility.HtmlDecode(stripped);
        var parts = decoded.Split(new[] { ' ', '\t', '\r', '\n' },
                                  StringSplitOptions.RemoveEmptyEntries);
        return parts.Length;
    }
    string FormatNumber(int n) => n.ToString("N0", System.Globalization.CultureInfo.InvariantCulture);

    // Pre-compute once per post — we use the count in three places
    // (cover total, per-story date line, per-story page footer).
    var wordsByPost = Model.ToDictionary(p => p.Id, p => CountWords(p.Body));
    var totalWords = wordsByPost.Values.Sum();

    // ── Build the linear page sequence. Order:
    //    cover → toc → for each decade: decade-page → for each year:
    //    (year heading? only if multiple chapters or unassigned + chapter)
    //    → for each chapter: chapter-page → stories → unassigned
    //    stories → colophon.
    var pages = new List<(string Kind, object? Payload)>();
    pages.Add(("cover", null));
    var chaptersByOwnerYear = allChapters
        .GroupBy(c => c.Year)
        .ToDictionary(g => g.Key,
            g => g.OrderBy(c => c.SortOrder).ThenBy(c => c.Id).ToList());

    if (storyCount > 0)
    {
        pages.Add(("toc", null));
        foreach (var dec in byDecade)
        {
            pages.Add(("decade", dec.Key));
            var byYear = dec.GroupBy(p => p.EventYear).OrderBy(g => g.Key);
            foreach (var yearGroup in byYear)
            {
                var yearPosts = yearGroup
                    .OrderBy(p => p.EventMonth ?? 0)
                    .ThenBy(p => p.EventDay ?? 0)
                    .ThenBy(p => p.CreatedAt)
                    .ToList();
                var yearChapters = chaptersByOwnerYear.GetValueOrDefault(yearGroup.Key)
                                   ?? new List<MyStoryTold.Models.BookChapter>();
                // Render in chapter order (sorted) then unassigned at end.
                foreach (var chapter in yearChapters)
                {
                    var inChapter = yearPosts.Where(p => p.BookChapterId == chapter.Id).ToList();
                    if (inChapter.Count == 0) continue;
                    pages.Add(("chapter", chapter));
                    foreach (var p in inChapter) pages.Add(("story", p));
                }
                var unassigned = yearPosts.Where(p => p.BookChapterId == null).ToList();
                foreach (var p in unassigned) pages.Add(("story", p));
            }
        }
        pages.Add(("colophon", null));
    }
    int totalPages = pages.Count;

    // Page-number lookups for the TOC.
    var pageOfStory   = new Dictionary<int, int>();
    var pageOfChapter = new Dictionary<int, int>();
    var firstPageOfYear = new Dictionary<int, int>();
    for (int i = 0; i < pages.Count; i++)
    {
        if (pages[i].Kind == "story" && pages[i].Payload is MyStoryTold.Models.LifeEventPost lp)
        {
            pageOfStory[lp.Id] = i + 1;
            if (!firstPageOfYear.ContainsKey(lp.EventYear))
                firstPageOfYear[lp.EventYear] = i + 1;
        }
        else if (pages[i].Kind == "chapter" && pages[i].Payload is MyStoryTold.Models.BookChapter cp)
        {
            pageOfChapter[cp.Id] = i + 1;
            if (!firstPageOfYear.ContainsKey(cp.Year))
                firstPageOfYear[cp.Year] = i + 1;
        }
    }
}

<div class="book-shell">

    @if (storyCount == 0)
    {
        <div class="empty-state card border-0 shadow-sm text-center p-5">
            <div class="empty-state-mark">📖</div>
            <h4 class="mt-3 mb-2">Your book starts here</h4>
            <p class="text-muted mb-3">
                Once you publish a story or two, this page becomes the cover of a
                life story you can read end to end.
            </p>
            <div><a asp-controller="Posts" asp-action="Create" class="btn btn-primary">Write your first story</a></div>
        </div>
    }
    else
    {
        <div class="book-toolbar">
            <button type="button" class="book-nav-btn" data-dir="-1" aria-label="Previous page">‹</button>
            <div class="book-page-readout">
                <span id="bookCurrentPage">1</span> / @totalPages
            </div>
            <button type="button" class="book-nav-btn" data-dir="1" aria-label="Next page">›</button>
            <span class="book-toolbar-spacer"></span>
            <a asp-action="Organize" class="btn btn-outline-secondary btn-sm" title="Organize chapters">🗂 Chapters</a>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print();" title="Print or save as PDF">🖨 Print</button>
        </div>

        @* Large side arrows for page navigation. Click to turn one page;
           subtle 'flip' animation drives the visual feedback. Hidden on
           the first / last page via JS so they don't tease beyond the
           bounds of the book. *@
        <div class="book-arrows">
            <button type="button" class="book-side-arrow book-side-arrow-prev" data-dir="-1" aria-label="Previous page">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 6l-6 6 6 6"/>
                </svg>
            </button>
            <button type="button" class="book-side-arrow book-side-arrow-next" data-dir="1" aria-label="Next page">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 6l6 6-6 6"/>
                </svg>
            </button>
        </div>

        <div class="book-pages" id="bookPages" tabindex="0">
            @for (int i = 0; i < pages.Count; i++)
            {
                var (kind, payload) = pages[i];
                int pageNum = i + 1;
                var pageId = $"page-{pageNum}";
                if (payload is MyStoryTold.Models.LifeEventPost spId) pageId = Slug(spId.EventYear, spId.Id);
                else if (payload is MyStoryTold.Models.BookChapter cpId) pageId = ChapterSlug(cpId.Id);
                // Also tag the first page of the year so the TOC year-row link can target it.
                string? yearAnchor = null;
                if (payload is MyStoryTold.Models.LifeEventPost spY
                    && firstPageOfYear.TryGetValue(spY.EventYear, out var yPg1) && yPg1 == pageNum)
                {
                    yearAnchor = YearSlug(spY.EventYear);
                }
                else if (payload is MyStoryTold.Models.BookChapter cpY
                         && firstPageOfYear.TryGetValue(cpY.Year, out var yPg2) && yPg2 == pageNum)
                {
                    yearAnchor = YearSlug(cpY.Year);
                }
                <article class="book-page book-page-@kind"
                         id="@pageId"
                         data-page="@pageNum">
                    @if (yearAnchor != null)
                    {
                        <span id="@yearAnchor" class="book-anchor"></span>
                    }
                    <div class="book-page-frame">
                        @switch (kind)
                        {
                            case "cover":
                                <div class="book-cover-content">
                                    <div class="book-cover-eyebrow">A life story</div>
                                    <h1 class="book-cover-title">@authorName</h1>
                                    <div class="book-cover-rule"></div>
                                    <div class="book-cover-meta">
                                        @storyCount @(storyCount == 1 ? "story" : "stories")
                                        @if (firstYear.HasValue && lastYear.HasValue && firstYear != lastYear)
                                        {
                                            <span>· @firstYear – @lastYear</span>
                                        }
                                        else if (firstYear.HasValue)
                                        {
                                            <span>· @firstYear</span>
                                        }
                                        @if (totalWords > 0)
                                        {
                                            <span>· @FormatNumber(totalWords) words</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(author?.ProfilePhotoUrl))
                                    {
                                        <img class="book-cover-portrait" src="@author.ProfilePhotoUrl" alt="" />
                                    }
                                </div>
                                break;

                            case "toc":
                                <div class="book-toc-head">
                                    <h2 class="book-section-title mb-0">Contents</h2>
                                    <a asp-action="Organize" class="book-toc-organize-btn">🗂 Organize my chapters</a>
                                </div>
                                <div class="book-toc-body">
                                @foreach (var dec in byDecade)
                                {
                                    <div class="book-toc-decade">
                                        <h3>@DecadeLabel(dec.Key)</h3>
                                        <ol class="book-toc-list">
                                            @foreach (var yg in dec.GroupBy(p => p.EventYear).OrderBy(g => g.Key))
                                            {
                                                var yearChs = chaptersByOwnerYear.GetValueOrDefault(yg.Key)
                                                              ?? new List<MyStoryTold.Models.BookChapter>();
                                                var usedChs = yearChs.Where(c => yg.Any(p => p.BookChapterId == c.Id)).ToList();
                                                var unas    = yg.Where(p => p.BookChapterId == null).ToList();
                                                firstPageOfYear.TryGetValue(yg.Key, out var yPage);
                                                <li class="book-toc-year-row">
                                                    <a href="#@YearSlug(yg.Key)" data-go-page="@yPage">
                                                        <span class="book-toc-year">@yg.Key</span>
                                                        <span class="book-toc-title">
                                                            @if (usedChs.Count == 0 && unas.Count > 0)
                                                            {
                                                                <em class="text-muted">@unas.Count @(unas.Count == 1 ? "story" : "stories")</em>
                                                            }
                                                            else if (usedChs.Count == 1 && unas.Count == 0)
                                                            {
                                                                @usedChs[0].Title
                                                            }
                                                            else if (usedChs.Count > 0)
                                                            {
                                                                @(string.Join(" · ", usedChs.Select(c => c.Title)))
                                                                @if (unas.Count > 0)
                                                                {
                                                                    <span class="text-muted small"> + @unas.Count more</span>
                                                                }
                                                            }
                                                        </span>
                                                        <span class="book-toc-dots"></span>
                                                        <span class="book-toc-pagenum">@yPage</span>
                                                    </a>
                                                    @if (usedChs.Count > 1)
                                                    {
                                                        <ol class="book-toc-sublist">
                                                            @foreach (var ch in usedChs)
                                                            {
                                                                pageOfChapter.TryGetValue(ch.Id, out var cPg);
                                                                <li>
                                                                    <a href="#@ChapterSlug(ch.Id)" data-go-page="@cPg">
                                                                        <span class="book-toc-bullet">›</span>
                                                                        <span class="book-toc-title">@ch.Title</span>
                                                                        <span class="book-toc-dots"></span>
                                                                        <span class="book-toc-pagenum">@cPg</span>
                                                                    </a>
                                                                </li>
                                                            }
                                                        </ol>
                                                    }
                                                </li>
                                            }
                                        </ol>
                                    </div>
                                }
                                </div>
                                break;

                            case "decade":
                                int dec0 = (int)(payload ?? 0);
                                <div class="book-decade-page-content">
                                    <div class="book-decade-rule"></div>
                                    <h2 class="book-decade-title">@DecadeLabel(dec0)</h2>
                                    <div class="book-decade-rule"></div>
                                </div>
                                break;

                            case "chapter":
                                var ch0 = (MyStoryTold.Models.BookChapter)payload!;
                                var chapterWords = Model
                                    .Where(p => p.BookChapterId == ch0.Id)
                                    .Sum(p => wordsByPost.GetValueOrDefault(p.Id));
                                var chapterStoryCount = Model.Count(p => p.BookChapterId == ch0.Id);
                                <div class="book-chapter-page-content">
                                    <div class="book-chapter-eyebrow">@ch0.Year</div>
                                    <h2 class="book-chapter-title">@ch0.Title</h2>
                                    <div class="book-decade-rule"></div>
                                    @if (chapterStoryCount > 0)
                                    {
                                        <div class="book-chapter-meta">
                                            @chapterStoryCount @(chapterStoryCount == 1 ? "story" : "stories")
                                            @if (chapterWords > 0)
                                            {
                                                <span>· @FormatNumber(chapterWords) words</span>
                                            }
                                        </div>
                                    }
                                </div>
                                break;

                            case "story":
                                var p2 = (MyStoryTold.Models.LifeEventPost)payload!;
                                // Book photos: respect HideFromBook (owner-set per photo).
                                // Keep all-media list separately so the owner panel can
                                // surface hidden photos to bring them back.
                                var allPhotos = (p2.Media ?? new List<MyStoryTold.Models.PostMedia>())
                                    .Where(m => m.MediaType == MyStoryTold.Models.MediaType.Image
                                                && !string.IsNullOrEmpty(m.Url))
                                    .OrderBy(m => m.SortOrder).ThenBy(m => m.Id)
                                    .ToList();
                                var photos = allPhotos.Where(m => !m.HideFromBook).ToList();
                                var hiddenPhotos = allPhotos.Where(m => m.HideFromBook).ToList();
                                <div class="book-story-head">
                                    <div class="book-story-head-left">
                                        @if (!string.IsNullOrWhiteSpace(p2.Title))
                                        {
                                            <h3 class="book-story-title">@p2.Title</h3>
                                        }
                                        <div class="book-story-date">
                                            @p2.EventDateDisplay
                                            @if (!string.IsNullOrEmpty(p2.Location))
                                            {
                                                <span> · @p2.Location</span>
                                            }
                                            @{
                                                var w = wordsByPost.GetValueOrDefault(p2.Id);
                                            }
                                            @if (w > 0)
                                            {
                                                var mins = Math.Max(1, (int)Math.Round(w / 225.0));
                                                <span> · @FormatNumber(w) words · @mins min read</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="book-story-actions">
                                        <form asp-action="ToggleFinalised" asp-route-id="@p2.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="book-tick @(p2.IsFinalised ? "is-on" : "")"
                                                    title="@(p2.IsFinalised ? "Marked as final — click to unmark" : "Mark as final for the book")">
                                                @(p2.IsFinalised ? "✓ Final" : "○ Mark final")
                                            </button>
                                        </form>
                                        <form asp-action="ToggleIncludeInBook" asp-route-id="@p2.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="book-hide"
                                                    title="Hide this story from the book"
                                                    onclick="return confirm('Hide this story from your book? You can bring it back from the Organize page.');">
                                                🚫 Hide
                                            </button>
                                        </form>
                                        <a asp-controller="Posts" asp-action="Edit" asp-route-id="@p2.Id"
                                           class="book-edit"
                                           title="Edit this story">✎ Edit</a>
                                    </div>
                                </div>

                                <div class="book-story-body-wrap">
                                    @* Inline-images stories render their body HTML including
                                       <img> tags (already sanitized server-side). The lead
                                       photo + gallery strip are skipped because the writer
                                       chose to weave images into the prose themselves. *@
                                    @if (p2.UseInlineImages)
                                    {
                                        <div class="book-story-body book-story-body-inline">
                                            @MyStoryTold.Helpers.BodyRenderer.RenderBody(p2.Body, null, allowInlineImages: true)
                                        </div>
                                    }
                                    else
                                    {
                                        // Lead = first visible photo without a wrap mode.
                                        // Wrap-flagged photos float inside the body; the
                                        // rest go in the strip below.
                                        var leadCandidate = photos.FirstOrDefault();
                                        var leadIsWrapped = leadCandidate != null
                                            && (leadCandidate.BookWrap == "left" || leadCandidate.BookWrap == "right");
                                        var leadPhoto = leadIsWrapped ? null : leadCandidate;
                                        var rest = leadPhoto == null ? photos : photos.Skip(1).ToList();
                                        var wrapPhotos = (leadIsWrapped ? new[] { leadCandidate! }.Concat(rest) : rest)
                                            .Where(m => m.BookWrap == "left" || m.BookWrap == "right")
                                            .ToList();
                                        var stripPhotos = rest
                                            .Where(m => m.BookWrap != "left" && m.BookWrap != "right")
                                            .ToList();

                                        if (leadPhoto != null)
                                        {
                                            <figure class="book-story-figure-lead book-photo book-photo-size-@(leadPhoto.BookSize ?? "medium")"
                                                    data-media-id="@leadPhoto.Id"
                                                    data-book-wrap=""
                                                    data-book-size="@(leadPhoto.BookSize ?? "medium")">
                                                <img src="@leadPhoto.Url" alt="" />
                                                @await Html.PartialAsync("_BookPhotoControls", leadPhoto)
                                            </figure>
                                        }

                                        <div class="book-story-body" data-post-id="@p2.Id">
                                            @foreach (var wm in wrapPhotos)
                                            {
                                                <figure class="book-photo book-photo-wrap book-photo-wrap-@wm.BookWrap book-photo-size-@(wm.BookSize ?? "medium")"
                                                        data-media-id="@wm.Id"
                                                        data-book-wrap="@wm.BookWrap"
                                                        data-book-size="@(wm.BookSize ?? "medium")">
                                                    <img src="@wm.Url" alt="" />
                                                    @await Html.PartialAsync("_BookPhotoControls", wm)
                                                </figure>
                                            }
                                            @Html.Raw(System.Web.HttpUtility.HtmlEncode(p2.Body).Replace("\n", "<br/>"))
                                        </div>

                                        if (stripPhotos.Count > 0)
                                        {
                                            <div class="book-story-gallery book-photo-strip" data-post-id="@p2.Id">
                                                @foreach (var ph in stripPhotos)
                                                {
                                                    <figure class="book-photo book-photo-size-@(ph.BookSize ?? "medium")"
                                                            data-media-id="@ph.Id"
                                                            data-book-wrap=""
                                                            data-book-size="@(ph.BookSize ?? "medium")">
                                                        <img src="@ph.Url" alt="" />
                                                        @await Html.PartialAsync("_BookPhotoControls", ph)
                                                    </figure>
                                                }
                                            </div>
                                        }

                                        if (hiddenPhotos.Count > 0)
                                        {
                                            <details class="book-photo-hidden-panel">
                                                <summary>@hiddenPhotos.Count hidden from book — show</summary>
                                                <div class="book-photo-hidden-grid">
                                                    @foreach (var h in hiddenPhotos)
                                                    {
                                                        <figure class="book-photo is-hidden" data-media-id="@h.Id">
                                                            <img src="@h.Url" alt="" />
                                                            <form asp-action="ToggleMediaHideFromBook" asp-route-id="@h.Id" method="post" class="book-photo-bring-back-form">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="book-photo-bring-back">Bring back</button>
                                                            </form>
                                                        </figure>
                                                    }
                                                </div>
                                            </details>
                                        }
                                    }
                                </div>
                                break;

                            case "colophon":
                                <div class="book-colophon-content">
                                    <div class="book-rule"></div>
                                    <p>The end — for now. Written by @authorName on Kronoscript.</p>
                                    <p class="book-colophon-tip text-muted small">
                                        Tip: use the Print / Save as PDF button at the top to keep
                                        a copy of your life story as it stands today.
                                    </p>
                                </div>
                                break;
                        }
                        <div class="book-page-footer">
                            @if (kind == "story" && payload is MyStoryTold.Models.LifeEventPost spFoot)
                            {
                                var wFoot = wordsByPost.GetValueOrDefault(spFoot.Id);
                                if (wFoot > 0)
                                {
                                    <span class="book-page-words">@FormatNumber(wFoot) words</span>
                                }
                            }
                            @if (kind != "cover")
                            {
                                <span class="book-page-number">@pageNum</span>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>

@section Scripts {
@if (storyCount > 0)
{
<script>
(function () {
    var pages = document.getElementById('bookPages');
    if (!pages) return;
    var allPages = Array.prototype.slice.call(pages.querySelectorAll('.book-page'));
    var readout = document.getElementById('bookCurrentPage');

    function pageWidth() { return pages.clientWidth; }

    function indexFromScroll() {
        var idx = Math.round(pages.scrollLeft / pageWidth());
        return Math.max(0, Math.min(allPages.length - 1, idx));
    }
    function goTo(idx, smooth) {
        idx = Math.max(0, Math.min(allPages.length - 1, idx));
        pages.scrollTo({
            left: idx * pageWidth(),
            behavior: smooth === false ? 'auto' : 'smooth'
        });
    }
    function updateReadout() {
        if (readout) readout.textContent = (indexFromScroll() + 1);
    }
    pages.addEventListener('scroll', function () {
        // Throttle with rAF — scroll fires fast.
        if (pages._raf) return;
        pages._raf = requestAnimationFrame(function () {
            pages._raf = null;
            updateReadout();
        });
    });

    // Prev / next buttons — both the toolbar (.book-nav-btn) and the
    // big side arrows (.book-side-arrow) share the same data-dir handler.
    document.querySelectorAll('.book-nav-btn, .book-side-arrow').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var dir = parseInt(btn.dataset.dir, 10) || 0;
            playTurnAnimation(dir);
            goTo(indexFromScroll() + dir);
        });
    });

    // Quick visual cue when the page turns. A real 3D book-spine flip is
    // a separate project; this is a subtle 'page leaves stage left/right
    // and the new one settles' transition. CSS handles the keyframes.
    function playTurnAnimation(dir) {
        var current = allPages[indexFromScroll()];
        if (!current) return;
        var cls = dir > 0 ? 'book-page-turning-forward' : 'book-page-turning-back';
        current.classList.remove('book-page-turning-forward', 'book-page-turning-back');
        // Trigger reflow so the class re-add restarts the animation cleanly.
        void current.offsetWidth;
        current.classList.add(cls);
        setTimeout(function () { current.classList.remove(cls); }, 380);
    }

    // Hide prev arrow on first page, next on last. Sync after every
    // scroll so swipe / scroll-snap stays in sync with the buttons.
    var sideArrowPrev = document.querySelector('.book-side-arrow-prev');
    var sideArrowNext = document.querySelector('.book-side-arrow-next');
    function updateSideArrows() {
        var idx = indexFromScroll();
        var last = allPages.length - 1;
        if (sideArrowPrev) sideArrowPrev.hidden = (idx <= 0);
        if (sideArrowNext) sideArrowNext.hidden = (idx >= last);
    }
    pages.addEventListener('scroll', function () {
        requestAnimationFrame(updateSideArrows);
    });
    updateSideArrows();

    // Keyboard nav: left/right while focused on the book.
    pages.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') {
            e.preventDefault();
            goTo(indexFromScroll() + 1);
        } else if (e.key === 'ArrowLeft' || e.key === 'PageUp') {
            e.preventDefault();
            goTo(indexFromScroll() - 1);
        } else if (e.key === 'Home') {
            goTo(0);
        } else if (e.key === 'End') {
            goTo(allPages.length - 1);
        }
    });

    // TOC entries: jump to the right page via JS so we get a smooth
    // animated turn rather than the browser's anchor jump.
    document.querySelectorAll('[data-go-page]').forEach(function (a) {
        a.addEventListener('click', function (e) {
            var n = parseInt(a.dataset.goPage, 10);
            if (!isNaN(n)) {
                e.preventDefault();
                goTo(n - 1);
            }
        });
    });

    // Deep-link via hash on first load (e.g. coming back from
    // Edit / ToggleFinalised).
    if (location.hash) {
        var target = document.querySelector(location.hash);
        if (target) {
            var idx = allPages.indexOf(target);
            if (idx >= 0) {
                // Skip the smooth animation on first paint.
                requestAnimationFrame(function () { goTo(idx, false); });
            }
        }
    }
    updateReadout();
})();

// ── Per-photo book controls (owner-only — the view only renders for
//    the owner's posts). Handles: open menu, set wrap, set size,
//    hide-from-book, drag-and-drop reorder. POSTs to BookController
//    endpoints; on success preserves the current story page via the
//    URL hash so the book doesn't snap back to the cover.
(function () {
    var antiTokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
    var antiToken = antiTokenInput ? antiTokenInput.value : '';

    function post(url, body) {
        var fd = new FormData();
        if (antiToken) fd.append('__RequestVerificationToken', antiToken);
        if (body) {
            Object.keys(body).forEach(function (k) { fd.append(k, body[k]); });
        }
        return fetch(url, { method: 'POST', body: fd, credentials: 'same-origin' });
    }

    // Reload while preserving the user's current story page. Each story
    // figure lives inside an <article class="book-page" id="story-YYYY-XX">;
    // stamping that id into location.hash before reload lets the book's
    // existing hash-restore logic land us back on the same page.
    function reloadPreservingPage(fig) {
        var page = fig && fig.closest && fig.closest('.book-page');
        if (page && page.id) {
            try { history.replaceState(null, '', '#' + page.id); } catch (_) {}
        }
        location.reload();
    }

    // Portal a menu to document.body so it can escape the .book-page's
    // overflow:hidden / .book-page-frame's overflow:auto. Position it
    // under the trigger button via getBoundingClientRect.
    function placeMenuFixed(menu, trigger) {
        var rect = trigger.getBoundingClientRect();
        // Move to body once; subsequent opens just reposition.
        if (menu.parentElement !== document.body) {
            menu.dataset.originalParentId = menu.dataset.originalParentId
                || (menu.parentElement.dataset.menuParent = 'mp-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8));
            document.body.appendChild(menu);
        }
        menu.style.position = 'fixed';
        menu.style.top = (rect.bottom + 6) + 'px';
        // Right-align under the trigger; clamp to viewport.
        var menuWidth = Math.max(menu.offsetWidth, 220);
        var right = window.innerWidth - rect.right;
        if (right + menuWidth > window.innerWidth - 8) right = 8;
        menu.style.right = right + 'px';
        menu.style.left = 'auto';
        menu.style.zIndex = '3000';
    }
    function closeAllMenus() {
        document.querySelectorAll('.book-photo-menu:not([hidden])').forEach(function (m) {
            m.hidden = true;
        });
        document.querySelectorAll('.book-photo.is-menu-open').forEach(function (f) {
            f.classList.remove('is-menu-open');
        });
    }

    // Open / close the per-photo menu.
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.book-photo-menu-btn');
        if (btn) {
            e.preventDefault();
            e.stopPropagation();
            // Find the menu — may already be portalled to body. Track
            // back via the trigger button's mediaId.
            var fig = btn.closest('.book-photo');
            var mediaId = fig && fig.dataset.mediaId;
            if (!mediaId) return;
            var menu = document.querySelector('.book-photo-menu[data-media-id="' + mediaId + '"]')
                    || btn.parentElement.querySelector('.book-photo-menu');
            if (!menu) return;
            var isOpen = !menu.hidden;
            closeAllMenus();
            if (!isOpen) {
                menu.hidden = false;
                if (fig) fig.classList.add('is-menu-open');
                placeMenuFixed(menu, btn);
            }
            return;
        }
        if (!e.target.closest('.book-photo-menu')) {
            closeAllMenus();
        }
    });
    window.addEventListener('scroll', closeAllMenus, true);
    window.addEventListener('resize', closeAllMenus);

    // Wrap setter
    document.addEventListener('click', function (e) {
        var opt = e.target.closest('[data-set-wrap]');
        if (!opt) return;
        e.preventDefault();
        var menu = opt.closest('.book-photo-menu');
        var mediaId = menu && menu.dataset.mediaId;
        var fig = mediaId && document.querySelector('.book-photo[data-media-id="' + mediaId + '"]');
        if (!mediaId) return;
        var mode = opt.dataset.setWrap || '';
        post('/Book/SetMediaBookWrap/' + encodeURIComponent(mediaId), { mode: mode })
            .then(function (r) { if (r.ok) reloadPreservingPage(fig); });
    });

    // Size setter
    document.addEventListener('click', function (e) {
        var opt = e.target.closest('[data-set-size]');
        if (!opt) return;
        e.preventDefault();
        var menu = opt.closest('.book-photo-menu');
        var mediaId = menu && menu.dataset.mediaId;
        var fig = mediaId && document.querySelector('.book-photo[data-media-id="' + mediaId + '"]');
        if (!mediaId) return;
        var size = opt.dataset.setSize || '';
        post('/Book/SetMediaBookSize/' + encodeURIComponent(mediaId), { size: size })
            .then(function (r) { if (r.ok) reloadPreservingPage(fig); });
    });

    // Crop toggle (full-image vs square-crop in the strip)
    document.addEventListener('click', function (e) {
        var opt = e.target.closest('[data-toggle-crop]');
        if (!opt) return;
        e.preventDefault();
        var menu = opt.closest('.book-photo-menu');
        var mediaId = menu && menu.dataset.mediaId;
        var fig = mediaId && document.querySelector('.book-photo[data-media-id="' + mediaId + '"]');
        if (!fig) return;
        // Optimistic toggle so the user sees the result instantly; the
        // crop state is purely a CSS class — no server round-trip.
        fig.classList.toggle('book-photo-crop');
        closeAllMenus();
    });

    // Hide-from-book toggle (top-level menu button)
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-toggle-hide]');
        if (!btn) return;
        e.preventDefault();
        var menu = btn.closest('.book-photo-menu');
        var mediaId = menu && menu.dataset.mediaId;
        var fig = mediaId && document.querySelector('.book-photo[data-media-id="' + mediaId + '"]');
        if (!mediaId) return;
        post('/Book/ToggleMediaHideFromBook/' + encodeURIComponent(mediaId))
            .then(function (r) { if (r.ok) reloadPreservingPage(fig); });
    });

    // ── Drag-and-drop reorder via the grip handle.
    //    HTML5 native drag-and-drop. The grip is the only thing that
    //    can initiate; the figure is the drop target. After the drop
    //    we send the new id order to /Book/ReorderMedia and reload.
    var draggingFig = null;
    document.addEventListener('mousedown', function (e) {
        var grip = e.target.closest('.book-photo-grip');
        if (!grip) return;
        var fig = grip.closest('.book-photo');
        if (fig) fig.setAttribute('draggable', 'true');
    });
    document.addEventListener('dragstart', function (e) {
        var fig = e.target.closest('.book-photo');
        if (!fig) return;
        draggingFig = fig;
        fig.classList.add('is-dragging');
        try { e.dataTransfer.setData('text/plain', fig.dataset.mediaId || ''); } catch (_) {}
    });
    document.addEventListener('dragend', function () {
        if (draggingFig) {
            draggingFig.classList.remove('is-dragging');
            draggingFig.removeAttribute('draggable');
        }
        document.querySelectorAll('.book-photo.is-drag-over').forEach(function (f) {
            f.classList.remove('is-drag-over');
        });
        draggingFig = null;
    });
    document.addEventListener('dragover', function (e) {
        var fig = e.target.closest('.book-photo');
        if (!fig || fig === draggingFig) return;
        e.preventDefault();
        fig.classList.add('is-drag-over');
    });
    document.addEventListener('dragleave', function (e) {
        var fig = e.target.closest('.book-photo');
        if (!fig) return;
        fig.classList.remove('is-drag-over');
    });
    document.addEventListener('drop', function (e) {
        var target = e.target.closest('.book-photo');
        if (!target || !draggingFig || target === draggingFig) return;
        e.preventDefault();
        target.classList.remove('is-drag-over');
        // Must drop between figures in the SAME post — find the post
        // wrapper (.book-story-body[data-post-id] or .book-photo-strip).
        var container = target.closest('[data-post-id]');
        var sourceContainer = draggingFig.closest('[data-post-id]');
        if (!container || container !== sourceContainer) return;
        var postId = container.dataset.postId;
        // Reorder the DOM, then collect the new order
        container.insertBefore(draggingFig, target);
        var ids = Array.prototype.slice.call(
            container.parentElement.querySelectorAll('.book-photo[data-media-id]')
        )
        .filter(function (f) { return !f.classList.contains('is-hidden'); })
        .map(function (f) { return f.dataset.mediaId; })
        .filter(function (id) { return !!id; });
        post('/Book/ReorderMedia', { postId: postId, ids: ids.join(',') })
            .then(function (r) { if (r.ok) location.reload(); });
    });
})();
</script>
}
}
