@model List<MyStoryTold.Models.ViewModels.AdminUserViewModel>
@{
    ViewData["Title"] = "Manage Users";
    var now = DateTime.UtcNow;
    var currentSort   = (ViewBag.Sort   as string ?? "ordinal").ToLowerInvariant();
    var currentDir    = (ViewBag.Dir    as string ?? "desc").ToLowerInvariant();
    var currentFilter = (ViewBag.Filter as string ?? "").ToLowerInvariant();
    var currentSearch = ViewBag.Search as string;
    var filterCounts  = ViewBag.FilterCounts as Dictionary<string, int> ?? new();

    // Render a sortable column header. Clicking flips direction when
    // already sorting on this column; otherwise jumps to desc-first
    // (most-useful first click for numeric columns).
    string SortLink(string key, string label, string align = "")
    {
        var nextDir = (currentSort == key && currentDir == "desc") ? "asc" : "desc";
        var arrow = currentSort == key ? (currentDir == "desc" ? " ▼" : " ▲") : "";
        var qs = $"?sort={key}&dir={nextDir}";
        if (!string.IsNullOrEmpty(currentSearch))  qs += $"&search={Uri.EscapeDataString(currentSearch)}";
        if (!string.IsNullOrEmpty(currentFilter)) qs += $"&filter={currentFilter}";
        var alignCls = align == "end" ? " text-end" : "";
        var activeCls = currentSort == key ? " admin-users-sort-active" : "";
        return $"<a class='admin-users-sort{activeCls}{alignCls}' href='{qs}'>" +
               System.Net.WebUtility.HtmlEncode(label) + arrow + "</a>";
    }

    string FilterUrl(string key)
    {
        var qs = $"?filter={key}";
        if (!string.IsNullOrEmpty(currentSearch)) qs += $"&search={Uri.EscapeDataString(currentSearch)}";
        // Reset sort/dir when changing filter — usually you want default newest-first.
        return qs;
    }

    string PremiumLabel(MyStoryTold.Models.ViewModels.AdminUserViewModel u)
    {
        var live = u.PremiumUntil != null && u.PremiumUntil > now;
        if (!live && u.PremiumSince == null) return "Basic";
        if (!live) return "Lapsed";
        return u.PremiumTier ?? "Personal";
    }
    string PremiumBadgeClass(string s) => s switch
    {
        "Family"   => "admin-status-family",
        "Personal" => "admin-status-personal",
        "Legacy"   => "admin-status-legacy",
        "Lapsed"   => "admin-status-lapsed",
        _ => "admin-status-basic"
    };
    int DaysSince(DateTime d) => Math.Max(1, (int)Math.Floor((now - d).TotalDays) + 1);
    int PctActive(MyStoryTold.Models.ViewModels.AdminUserViewModel u)
    {
        var total = DaysSince(u.CreatedAt);
        return total == 0 ? 0 : (int)Math.Round(100.0 * u.LoginDays / total);
    }
    int MonthsAtPremium(MyStoryTold.Models.ViewModels.AdminUserViewModel u)
    {
        if (u.PremiumSince == null) return 0;
        var endish = (u.PremiumUntil ?? now) > now ? now : (u.PremiumUntil ?? now);
        var days = Math.Max(0, (endish - u.PremiumSince.Value).TotalDays);
        return (int)Math.Round(days / 30.0);
    }
}

<div class="admin-wide">
    <header class="admin-page-header d-flex justify-content-between align-items-end flex-wrap gap-2">
        <div>
            <p class="admin-page-eyebrow">Admin</p>
            <h2 class="admin-page-title">Manage Users</h2>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Dashboard</a>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Users" method="get" class="mb-3">
        <div class="input-group input-group-sm">
            <input type="text" name="search" class="form-control" placeholder="Search by username, email, or name…"
                   value="@currentSearch" />
            @if (!string.IsNullOrEmpty(currentFilter))
            {
                <input type="hidden" name="filter" value="@currentFilter" />
            }
            <button class="btn btn-outline-primary" type="submit">Search</button>
            @if (!string.IsNullOrEmpty(currentSearch))
            {
                <a asp-action="Users" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @* Filter pills — counts come from the unfiltered set so the admin can
       see 'oh I have 3 banned users' before clicking. *@
    <div class="admin-users-filters mb-2">
        <a href="@FilterUrl("")" class="admin-users-filter @(currentFilter == "" ? "is-on" : "")">
            All <span class="admin-users-filter-count">@filterCounts.GetValueOrDefault("all")</span>
        </a>
        <a href="@FilterUrl("admins")" class="admin-users-filter @(currentFilter == "admins" ? "is-on" : "")">
            Admins <span class="admin-users-filter-count">@filterCounts.GetValueOrDefault("admins")</span>
        </a>
        <a href="@FilterUrl("premium")" class="admin-users-filter @(currentFilter == "premium" ? "is-on" : "")">
            Premium <span class="admin-users-filter-count">@filterCounts.GetValueOrDefault("premium")</span>
        </a>
        <a href="@FilterUrl("lapsed")" class="admin-users-filter @(currentFilter == "lapsed" ? "is-on" : "")">
            Lapsed <span class="admin-users-filter-count">@filterCounts.GetValueOrDefault("lapsed")</span>
        </a>
        <a href="@FilterUrl("banned")" class="admin-users-filter @(currentFilter == "banned" ? "is-on" : "")">
            Banned <span class="admin-users-filter-count">@filterCounts.GetValueOrDefault("banned")</span>
        </a>
        <a href="@FilterUrl("unverified")" class="admin-users-filter @(currentFilter == "unverified" ? "is-on" : "")">
            Unverified <span class="admin-users-filter-count">@filterCounts.GetValueOrDefault("unverified")</span>
        </a>
        <a href="@FilterUrl("locked")" class="admin-users-filter @(currentFilter == "locked" ? "is-on" : "")">
            Locked <span class="admin-users-filter-count">@filterCounts.GetValueOrDefault("locked")</span>
        </a>
    </div>

    <div class="small text-muted mb-2">@Model.Count user(s) shown · click any column header to sort · scroll horizontally for more columns →</div>

    <div class="admin-users-scroll">
        <table class="admin-users-table">
            <thead>
                <tr>
                    <th class="admin-users-sticky admin-users-col-num"  scope="col">@Html.Raw(SortLink("ordinal", "#"))</th>
                    <th class="admin-users-sticky admin-users-col-user" scope="col">@Html.Raw(SortLink("username", "Username"))</th>
                    <th class="admin-users-sticky admin-users-col-last" scope="col">@Html.Raw(SortLink("lastname", "Last"))</th>
                    <th class="admin-users-sticky admin-users-col-first" scope="col">@Html.Raw(SortLink("firstname", "First"))</th>
                    <th class="text-end">@Html.Raw(SortLink("joined", "Joined", "end"))</th>
                    <th class="text-end" title="Distinct UTC days the user logged in (login.day events)">@Html.Raw(SortLink("logindays", "Login days", "end"))</th>
                    <th class="text-end" title="LoginDays ÷ days since signup">@Html.Raw(SortLink("pctactive", "% active", "end"))</th>
                    <th class="text-end" title="Avg minutes per session — computed from session.minutes events on login">@Html.Raw(SortLink("minperlogin", "Min/login", "end"))</th>
                    <th class="text-end" title="Non-draft posts owned by this user">@Html.Raw(SortLink("stories", "Stories", "end"))</th>
                    <th>@Html.Raw(SortLink("status", "Status"))</th>
                    <th class="text-end" title="Date of the user's first subscription.started event">@Html.Raw(SortLink("premsince", "Premium since", "end"))</th>
                    <th class="text-end" title="Months since first subscription.started (approx)">@Html.Raw(SortLink("monthsprem", "Months prem.", "end"))</th>
                    <th class="text-end">@Html.Raw(SortLink("connections", "Connections", "end"))</th>
                    <th class="text-end">@Html.Raw(SortLink("invites", "Invites", "end"))</th>
                    <th class="text-end" title="People who actually registered via this user's invite or share link">@Html.Raw(SortLink("completed", "Completed", "end"))</th>
                    <th class="admin-users-col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var banExpiry = u.ActiveBan?.BanExpiry;
                    var isBanned = u.ActiveBan != null;
                    var isPermanentlyBanned = u.ActiveBan?.BanType == MyStoryTold.Models.BanType.Permanent;
                    var isLocked = u.LockoutEnd.HasValue && u.LockoutEnd.Value > DateTimeOffset.UtcNow;
                    var status = PremiumLabel(u);
                    var rowClasses = new List<string>();
                    if (isBanned) rowClasses.Add("admin-users-banned");
                    if (u.IsBiographical) rowClasses.Add("admin-users-bio");
                    <tr class="@string.Join(' ', rowClasses)">
                        <td class="admin-users-sticky admin-users-col-num">
                            <span class="user-ordinal-badge">#@u.Ordinal</span>
                        </td>
                        <td class="admin-users-sticky admin-users-col-user">
                            <div class="admin-users-handle">@@@u.UserName</div>
                            <div class="admin-users-email">@u.Email</div>
                            <div class="admin-users-flags">
                                @if (u.IsSuperAdmin) { <span class="admin-flag admin-flag-super">Super</span> }
                                else if (u.IsAdmin)  { <span class="admin-flag admin-flag-admin">Admin</span> }
                                @if (u.IsBiographical) { <span class="admin-flag admin-flag-bio" title="Biographical / historical-figure account">Bio</span> }
                                @if (isPermanentlyBanned) { <span class="admin-flag admin-flag-banned">Banned</span> }
                                else if (isBanned) { <span class="admin-flag admin-flag-banned-temp">Banned · @banExpiry?.ToString("MMM d")</span> }
                                @if (!u.EmailConfirmed) { <span class="admin-flag admin-flag-unverified">Unverified</span> }
                                @if (isLocked) { <span class="admin-flag admin-flag-locked">Locked</span> }
                            </div>
                        </td>
                        <td class="admin-users-sticky admin-users-col-last"><span class="admin-users-cell-clip" title="@u.LastName">@u.LastName</span></td>
                        <td class="admin-users-sticky admin-users-col-first"><span class="admin-users-cell-clip" title="@u.FirstName">@u.FirstName</span></td>
                        <td class="text-end admin-users-num">@u.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="text-end admin-users-num">@u.LoginDays</td>
                        <td class="text-end admin-users-num">@PctActive(u)%</td>
                        <td class="text-end admin-users-num">
                            @if (u.AvgMinutesPerSession.HasValue) { @($"{u.AvgMinutesPerSession.Value:0}m") }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td class="text-end admin-users-num">@u.PostCount</td>
                        <td><span class="admin-status-pill @PremiumBadgeClass(status)">@status</span></td>
                        <td class="text-end admin-users-num">
                            @if (u.PremiumSince.HasValue) { @u.PremiumSince.Value.ToString("yyyy-MM-dd") } else { <span class="text-muted">—</span> }
                        </td>
                        <td class="text-end admin-users-num">@MonthsAtPremium(u)</td>
                        <td class="text-end admin-users-num">@u.Connections</td>
                        <td class="text-end admin-users-num">@u.InvitesSent</td>
                        <td class="text-end admin-users-num">@u.InvitesCompleted</td>
                        <td class="admin-users-col-actions">
                            <div class="admin-users-actions">
                                <a asp-action="UserFeed" asp-route-id="@u.Id" class="admin-users-btn">Feed</a>
                                <button type="button" class="admin-users-btn" data-bs-toggle="modal" data-bs-target="#resetPwdModal-@u.Id">Reset pwd</button>
                                @if (!u.IsAdmin && !isBanned)
                                {
                                    <button type="button" class="admin-users-btn admin-users-btn-warn" data-bs-toggle="modal" data-bs-target="#banModal-@u.Id">Ban 30d</button>
                                }
                                else if (isBanned)
                                {
                                    <form asp-action="UnbanUser" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="banId" value="@u.ActiveBan!.Id" />
                                        <button type="submit" class="admin-users-btn admin-users-btn-good">Unban</button>
                                    </form>
                                }
                                @if (!u.IsAdmin)
                                {
                                    <button type="button" class="admin-users-btn admin-users-btn-danger" data-bs-toggle="modal" data-bs-target="#removeModal-@u.Id">Remove</button>
                                }
                                @* Premium grant — available on admin rows too, so an admin
                                   can comp themselves or another admin without going
                                   through Stripe. Remove + Ban stay disabled for admins. *@
                                <button type="button" class="admin-users-btn admin-users-btn-premium" data-bs-toggle="modal" data-bs-target="#premiumModal-@u.Id">⭐ Premium</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Modals — one set per user. Outside the scrollable table so they
       overlay the page properly. Existing endpoints reused as-is. *@
    @foreach (var u in Model)
    {
        var isBanned = u.ActiveBan != null;
        <div class="modal fade" id="resetPwdModal-@u.Id" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <form asp-action="ResetUserPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@u.Id" />
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Send reset email to @@@u.UserName</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-2">A password reset email will be sent to <strong>@u.Email</strong>.</p>
                            <small class="text-muted">The user clicks the link and chooses their own new password. Link expires in 24 hours.</small>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Send reset email</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (!u.IsAdmin && !isBanned)
        {
            <div class="modal fade" id="banModal-@u.Id" tabindex="-1">
                <div class="modal-dialog">
                    <form asp-action="BanUser" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@u.Id" />
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Ban @@@u.UserName for 30 days?</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <label class="form-label">Reason (optional)</label>
                                <textarea name="reason" class="form-control" rows="2" maxlength="500"></textarea>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-warning">Confirm Ban</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }

        @if (!u.IsAdmin)
        {
            <div class="modal fade" id="removeModal-@u.Id" tabindex="-1">
                <div class="modal-dialog">
                    <form asp-action="RemoveUser" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@u.Id" />
                        <div class="modal-content">
                            <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title">Permanently Remove @@@u.UserName?</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p class="text-danger fw-semibold">This will permanently delete the account and ban the email address. This cannot be undone.</p>
                                <label class="form-label">Reason (optional)</label>
                                <textarea name="reason" class="form-control" rows="2" maxlength="500"></textarea>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Permanently Remove</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }

        @* Premium grant modal — rendered for every user, admin or not,
           so an admin can comp themselves or another admin. *@
        <div class="modal fade" id="premiumModal-@u.Id" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <form asp-action="SetPremium" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@u.Id" />
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">⭐ Premium for @@@u.UserName</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            @if (u.PremiumUntil != null)
                            {
                                <p class="mb-2">
                                    Currently <strong>@(u.PremiumUntil > now ? "active" : "expired")</strong> —
                                    @u.PremiumUntil.Value.ToString("MMM d, yyyy")
                                    @if (!string.IsNullOrEmpty(u.PremiumTier))
                                    {
                                        <text> · @u.PremiumTier tier</text>
                                    }
                                </p>
                            }
                            <label class="form-label small fw-semibold mb-1">Premium until (UTC date)</label>
                            <input type="date" name="untilUtc" class="form-control"
                                   value="@(u.PremiumUntil?.ToString("yyyy-MM-dd"))"
                                   min="@(DateTime.UtcNow.AddDays(1).ToString("yyyy-MM-dd"))" />
                            <small class="text-muted">Leave blank to clear premium. Use 2099-12-31 for lifetime/Legacy.</small>

                            <label class="form-label small fw-semibold mb-1 mt-3">Tier</label>
                            <select name="tier" class="form-select">
                                @{ var currentTier = u.PremiumTier ?? "Personal"; }
                                <option value="Personal" selected="@(currentTier == "Personal")">Personal — recurring, individual</option>
                                <option value="Family"   selected="@(currentTier == "Family")">Family — recurring, covers up to 6</option>
                                <option value="Legacy"   selected="@(currentTier == "Legacy")">Legacy — one-time, perpetual</option>
                            </select>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-warning">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
