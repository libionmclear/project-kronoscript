@model List<MyStoryTold.Models.ViewModels.AdminUserViewModel>
@{
    ViewData["Title"] = "Manage Users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-4">
    <!-- Left Sidebar -->
    <div class="col-md-2">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <!-- Main Content -->
    <div class="col-md-8 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">Manage Users</h4>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Dashboard</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Search -->
        <form asp-action="Users" method="get" class="mb-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Search by username, email, or name..."
                       value="@ViewBag.Search" />
                <button class="btn" style="background-color: var(--mst-primary); color: white;" type="submit">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                {
                    <a asp-action="Users" class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </form>

        <div class="small text-muted mb-2">@Model.Count user(s) found</div>

        @foreach (var u in Model)
        {
            var banExpiry = u.ActiveBan?.BanExpiry;
            var isBanned = u.ActiveBan != null;
            var isPermanentlyBanned = u.ActiveBan?.BanType == MyStoryTold.Models.BanType.Permanent;

            <div class="card border-0 shadow-sm mb-2 @(isBanned ? "border-start border-danger border-3" : "")">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            @if (u.Ordinal > 0)
                            {
                                <span class="badge me-1 user-ordinal-badge" title="Signup #@u.Ordinal">#@u.Ordinal</span>
                            }
                            <span class="fw-semibold">@@@u.UserName</span>
                            @if (u.IsSuperAdmin)
                            {
                                <span class="badge ms-1" style="background-color: var(--mst-primary); color: #fff;">Super Admin</span>
                            }
                            else if (u.IsAdmin)
                            {
                                <span class="badge ms-1" style="background-color: var(--mst-accent); color: #000;">Admin</span>
                            }
                            @if (isPermanentlyBanned)
                            {
                                <span class="badge bg-danger ms-1">Perm Banned</span>
                            }
                            else if (isBanned)
                            {
                                <span class="badge bg-warning text-dark ms-1">Banned until @banExpiry?.ToString("MMM d, yyyy")</span>
                            }
                            @if (!u.EmailConfirmed)
                            {
                                <span class="badge ms-1" style="background:#f4d35e;color:#5a4520;" title="Hasn't clicked the verification link in their signup email yet — they can't log in until they do, or until an admin marks them confirmed.">⚠ Unverified email</span>
                            }
                            @{
                                var isLocked = u.LockoutEnd.HasValue && u.LockoutEnd.Value > DateTimeOffset.UtcNow;
                            }
                            @if (isLocked)
                            {
                                <span class="badge bg-secondary ms-1" title="Identity locked the account after too many failed logins. Will clear automatically at the time shown.">🔒 Locked until @u.LockoutEnd!.Value.UtcDateTime.ToString("MMM d, HH:mm") UTC</span>
                            }
                            <div class="small text-muted">@u.Email</div>
                            @if (!string.IsNullOrEmpty(u.FirstName) || !string.IsNullOrEmpty(u.LastName))
                            {
                                <div class="small text-muted">@u.FirstName @u.LastName</div>
                            }
                            <div class="small text-muted">
                                Joined @u.CreatedAt.ToString("MMM d, yyyy") &nbsp;|&nbsp;
                                @u.PostCount post(s)
                            </div>
                            @if (isBanned && u.ActiveBan?.Reason != null)
                            {
                                <div class="small text-danger mt-1">Ban reason: @u.ActiveBan.Reason</div>
                            }
                        </div>

                        <div class="d-flex gap-1 flex-wrap">
                            <a asp-action="UserFeed" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">View Feed</a>
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    data-bs-toggle="modal" data-bs-target="#resetPwdModal-@u.Id">
                                Reset Password
                            </button>

                            @if ((bool)(ViewBag.ViewerIsSuperAdmin ?? false) && !u.IsSuperAdmin)
                            {
                                if (u.IsAdmin)
                                {
                                    <form asp-action="DemoteAdmin" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove admin rights from @u.UserName?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Demote Admin</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="PromoteToAdmin" method="post" class="d-inline"
                                          onsubmit="return confirm('Make @u.UserName an assistant admin?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Promote to Admin</button>
                                    </form>
                                }
                                @* Super-admin-only edit of basic identity fields
                                   (name + photo) — useful for fixing bare
                                   biographical accounts the original user
                                   never filled in. *@
                                <a asp-action="EditUser" asp-route-id="@u.Id"
                                   class="btn btn-sm btn-outline-secondary">Edit info</a>
                            }

                            @* Stuck-signup rescue — surfaced only when there's
                               actually a problem to fix, to keep the row tidy
                               for everyone else. *@
                            @if (!u.EmailConfirmed)
                            {
                                <form asp-action="ResendUserConfirmation" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary" title="Send a fresh verification email to this user.">Resend verify</button>
                                </form>
                                <form asp-action="ConfirmUserEmail" method="post" class="d-inline"
                                      onsubmit="return confirm('Manually mark @u.UserName's email as confirmed? Skips the email-ownership check — only do this when you've verified by another channel that this person controls @u.Email.');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Mark this account's email as confirmed without the user clicking the link.">Mark confirmed</button>
                                </form>
                            }
                            @if (isLocked)
                            {
                                <form asp-action="UnlockUser" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Clear LockoutEnd + failed-attempt count.">Unlock</button>
                                </form>
                            }
                        </div>

                        @if (!u.IsAdmin)
                        {
                            <div class="d-flex gap-1 flex-wrap">
                                @if (isBanned)
                                {
                                    <form asp-action="UnbanUser" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="banId" value="@u.ActiveBan!.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Unban</button>
                                    </form>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-warning"
                                            data-bs-toggle="modal" data-bs-target="#banModal-@u.Id">
                                        Ban 30 Days
                                    </button>
                                }

                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal" data-bs-target="#removeModal-@u.Id">
                                    Remove
                                </button>

                                @* Manual premium grant — used during beta to
                                   comp testers before the Stripe flow is
                                   live. The button caption reflects current
                                   state at a glance. *@
                                @{
                                    var hasPremium = u.PremiumUntil != null && u.PremiumUntil > DateTime.UtcNow;
                                    var premiumLabel = hasPremium
                                        ? $"⭐ Premium ({u.PremiumTier ?? "Personal"}) → {u.PremiumUntil:MMM d, yyyy}"
                                        : "⭐ Grant premium";
                                }
                                <button type="button"
                                        class="btn btn-sm @(hasPremium ? "btn-warning" : "btn-outline-warning")"
                                        data-bs-toggle="modal" data-bs-target="#premiumModal-@u.Id">
                                    @premiumLabel
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Premium grant modal — manual, used while subscriptions
                 aren't live (or for comping beta testers afterwards). -->
            <div class="modal fade" id="premiumModal-@u.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <form asp-action="SetPremium" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@u.Id" />
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">⭐ Premium for @@@u.UserName</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                @if (u.PremiumUntil != null)
                                {
                                    <p class="mb-2">
                                        Currently <strong>@(u.PremiumUntil > DateTime.UtcNow ? "active" : "expired")</strong> —
                                        @u.PremiumUntil.Value.ToString("MMM d, yyyy")
                                        @if (!string.IsNullOrEmpty(u.PremiumTier))
                                        {
                                            <text> · @u.PremiumTier tier</text>
                                        }
                                    </p>
                                }
                                <label class="form-label small fw-semibold mb-1">Premium until (UTC date)</label>
                                <input type="date" name="untilUtc" class="form-control"
                                       value="@(u.PremiumUntil?.ToString("yyyy-MM-dd"))"
                                       min="@(DateTime.UtcNow.AddDays(1).ToString("yyyy-MM-dd"))" />
                                <small class="text-muted">Leave blank to clear premium.</small>

                                <label class="form-label small fw-semibold mb-1 mt-3">Tier</label>
                                <select name="tier" class="form-select">
                                    @{ var currentTier = u.PremiumTier ?? "Personal"; }
                                    <option value="Personal" selected="@(currentTier == "Personal")">Personal — recurring, individual</option>
                                    <option value="Family"   selected="@(currentTier == "Family")">Family — recurring, family group</option>
                                    <option value="Legacy"   selected="@(currentTier == "Legacy")">Legacy — one-time, perpetual</option>
                                </select>
                                <small class="text-muted">For lifetime / "Legacy", set the date far in the future (e.g., 2099-12-31).</small>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-warning">Save</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Reset Password Modal — sends an email reset link, not
                 a generated password. Admin no longer ever sees or
                 handles the user's credential. -->
            <div class="modal fade" id="resetPwdModal-@u.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <form asp-action="ResetUserPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@u.Id" />
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Send reset email to @@@u.UserName</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p class="mb-2">A password reset email will be sent to <strong>@u.Email</strong>.</p>
                                <small class="text-muted">The user clicks the link and chooses their own new password. Link expires in 24 hours.</small>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Send reset email</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Ban Modal -->
            @if (!u.IsAdmin && !isBanned)
            {
                <div class="modal fade" id="banModal-@u.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <form asp-action="BanUser" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@u.Id" />
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Ban @@@u.UserName for 30 days?</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <label class="form-label">Reason (optional)</label>
                                    <textarea name="reason" class="form-control" rows="2" maxlength="500"></textarea>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-warning">Confirm Ban</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <!-- Remove Modal -->
            @if (!u.IsAdmin)
            {
                <div class="modal fade" id="removeModal-@u.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <form asp-action="RemoveUser" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@u.Id" />
                            <div class="modal-content">
                                <div class="modal-header bg-danger text-white">
                                    <h5 class="modal-title">Permanently Remove @@@u.UserName?</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <p class="text-danger fw-semibold">This will permanently delete the account and ban the email address. This cannot be undone.</p>
                                    <label class="form-label">Reason (optional)</label>
                                    <textarea name="reason" class="form-control" rows="2" maxlength="500"></textarea>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-danger">Permanently Remove</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

</div>
