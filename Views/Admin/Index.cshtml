@model MyStoryTold.Models.ViewModels.AdminDashboardViewModel
@using Microsoft.EntityFrameworkCore
@inject MyStoryTold.Data.ApplicationDbContext _dbForBadges
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var pendingDeletions = await _dbForBadges.Users.CountAsync(u => u.AccountDeletionRequestedAt != null);
    var pendingReports = await _dbForBadges.Reports.CountAsync(r => r.Status == MyStoryTold.Models.ReportStatus.Pending);
}

<div class="row g-4">
    <!-- Left Sidebar -->
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <!-- Main Content -->
    <div class="col-md-8 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">Admin Dashboard</h4>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- User Stats -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header fw-semibold" style="background-color: var(--mst-primary); color: white;">
                Users
            </div>
            <div class="card-body p-0">
                <div class="row g-0 text-center">
                    <div class="col-6 col-md-3 p-3 border-end border-bottom">
                        <div class="fs-3 fw-bold" style="color: var(--mst-primary);">@Model.TotalUsers</div>
                        <div class="small text-muted">Total Registered</div>
                    </div>
                    <div class="col-6 col-md-3 p-3 border-end border-bottom">
                        <div class="fs-3 fw-bold" style="color: var(--mst-accent);">@Model.NewUsersThisWeek</div>
                        <div class="small text-muted">New This Week</div>
                    </div>
                    <div class="col-6 col-md-3 p-3 border-end border-bottom">
                        <div class="fs-3 fw-bold text-success">@Model.ActiveUsersLast30Days</div>
                        <div class="small text-muted">Active (30 days)</div>
                    </div>
                    <div class="col-6 col-md-3 p-3 border-bottom">
                        <div class="fs-3 fw-bold text-info">@Model.ActiveUsersNow</div>
                        <div class="small text-muted">Online Now</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Content Stats -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header fw-semibold" style="background-color: var(--mst-secondary); color: white;">
                Content
            </div>
            <div class="card-body p-0">
                <div class="row g-0 text-center">
                    <div class="col-4 p-3 border-end">
                        <div class="fs-3 fw-bold" style="color: var(--mst-primary);">@Model.TotalPosts</div>
                        <div class="small text-muted">Total Posts</div>
                    </div>
                    <div class="col-4 p-3 border-end">
                        <div class="fs-3 fw-bold" style="color: var(--mst-secondary);">@Model.TotalComments</div>
                        <div class="small text-muted">Comments</div>
                    </div>
                    <div class="col-4 p-3">
                        <div class="fs-3 fw-bold" style="color: var(--mst-accent);">@Model.TotalLikes</div>
                        <div class="small text-muted">Likes</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ban Stats -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header fw-semibold bg-danger text-white">
                Moderation
            </div>
            <div class="card-body p-0">
                <div class="row g-0 text-center">
                    <div class="col-6 p-3 border-end">
                        <div class="fs-3 fw-bold text-warning">@Model.ActiveBans</div>
                        <div class="small text-muted">Active Temp Bans</div>
                    </div>
                    <div class="col-6 p-3">
                        <div class="fs-3 fw-bold text-danger">@Model.PermanentBans</div>
                        <div class="small text-muted">Permanent Bans</div>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="mt-4 mb-2 fw-semibold" style="color: var(--mst-primary);">Tools</h5>
        <div class="admin-tool-grid">
            <a asp-action="Users" class="admin-tool-card admin-tool-primary">
                <div class="admin-tool-icon">👥</div>
                <div class="admin-tool-name">Users</div>
                <div class="admin-tool-desc">List, ban, unban, role changes.</div>
            </a>
            <a asp-action="Reports" class="admin-tool-card @(pendingReports > 0 ? "admin-tool-attention" : "")">
                <div class="admin-tool-icon">🚩</div>
                <div class="admin-tool-name">
                    Reports
                    @if (pendingReports > 0)
                    {
                        <span class="badge bg-danger ms-1">@pendingReports</span>
                    }
                </div>
                <div class="admin-tool-desc">User-flagged posts, comments, and accounts.</div>
            </a>
            <a asp-action="DeletionRequests" class="admin-tool-card @(pendingDeletions > 0 ? "admin-tool-attention" : "")">
                <div class="admin-tool-icon">🗑️</div>
                <div class="admin-tool-name">
                    Deletion Requests
                    @if (pendingDeletions > 0)
                    {
                        <span class="badge bg-danger ms-1">@pendingDeletions</span>
                    }
                </div>
                <div class="admin-tool-desc">Users who asked an admin to delete their account.</div>
            </a>
            <a asp-action="Channels" class="admin-tool-card">
                <div class="admin-tool-icon">📚</div>
                <div class="admin-tool-name">Channels</div>
                <div class="admin-tool-desc">Topical buckets like History or Family Tales — assign one writer per channel.</div>
            </a>
            <a asp-action="ManagedUsers" class="admin-tool-card">
                <div class="admin-tool-icon">📜</div>
                <div class="admin-tool-name">Biographical Profiles</div>
                <div class="admin-tool-desc">Fictional / historical figures (e.g., Caesar). You post as them; they can't log in.</div>
            </a>
            <a asp-action="Tips" class="admin-tool-card">
                <div class="admin-tool-icon">📣</div>
                <div class="admin-tool-name">Tips &amp; Announcements</div>
                <div class="admin-tool-desc">Tips for the sidebar; broadcast announcements to all users.</div>
            </a>
            <a asp-action="MemoryPrompts" class="admin-tool-card">
                <div class="admin-tool-icon">💭</div>
                <div class="admin-tool-name">Memory Prompts</div>
                <div class="admin-tool-desc">Daily writing prompts surfaced in the rail.</div>
            </a>
            <a asp-action="QuillMessages" class="admin-tool-card">
                <div class="admin-tool-icon">🪶</div>
                <div class="admin-tool-name">Landing-page Quill</div>
                <div class="admin-tool-desc">The rotating taglines on the public landing page.</div>
            </a>
            <a asp-action="SiteSettings" class="admin-tool-card">
                <div class="admin-tool-icon">⚙️</div>
                <div class="admin-tool-name">Site Settings</div>
                <div class="admin-tool-desc">Global toggles: channels, biographical posts, evergreen surfacing.</div>
            </a>
            <a asp-action="EmailTest" class="admin-tool-card">
                <div class="admin-tool-icon">✉️</div>
                <div class="admin-tool-name">Email Test</div>
                <div class="admin-tool-desc">Send a probe email to verify SendGrid wiring.</div>
            </a>
        </div>
    </div>

</div>
