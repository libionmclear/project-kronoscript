@model MyStoryTold.Models.ViewModels.AdminDashboardViewModel
@using Microsoft.EntityFrameworkCore
@inject MyStoryTold.Data.ApplicationDbContext _dbForBadges
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var pendingDeletions = await _dbForBadges.Users.CountAsync(u => u.AccountDeletionRequestedAt != null);
    var pendingReports = await _dbForBadges.Reports.CountAsync(r => r.Status == MyStoryTold.Models.ReportStatus.Pending);
    var nowOffset = DateTimeOffset.UtcNow;
    var pendingSignups = await _dbForBadges.Users.CountAsync(u =>
        !u.EmailConfirmed
        || (u.LockoutEnd != null && u.LockoutEnd > nowOffset && u.EmailConfirmed));

    // Analytics rollup — counts per event type over three windows.
    // Reads the UserEvents append-only log. Cheap query (indexed on
    // EventType + OccurredAt) but only the admin dashboard sees it.
    var nowUtc = DateTime.UtcNow;
    var day1   = nowUtc.AddDays(-1);
    var day7   = nowUtc.AddDays(-7);
    var day30  = nowUtc.AddDays(-30);
    var keyEvents = new[] {
        "register", "post.published", "invite.sent", "login.day",
        "subscription.started", "subscription.renewed", "subscription.cancelled",
        "subscription.payment_failed"
    };
    var eventStats = await _dbForBadges.UserEvents
        .Where(e => keyEvents.Contains(e.EventType))
        .GroupBy(e => e.EventType)
        .Select(g => new
        {
            EventType = g.Key,
            D1  = g.Count(e => e.OccurredAt >= day1),
            D7  = g.Count(e => e.OccurredAt >= day7),
            D30 = g.Count(e => e.OccurredAt >= day30),
            Total = g.Count()
        })
        .ToListAsync();
    int Stat(string key, string window)
    {
        var row = eventStats.FirstOrDefault(s => s.EventType == key);
        if (row == null) return 0;
        return window switch {
            "d1" => row.D1,
            "d7" => row.D7,
            "d30" => row.D30,
            _ => row.Total
        };
    }
    // Referral count — how many users have InvitedByUserId set.
    // d1 is omitted (no signal at a single-day window for a slow signal).
    var referralsD7    = await _dbForBadges.Users.CountAsync(u => u.InvitedByUserId != null && u.CreatedAt >= day7);
    var referralsD30   = await _dbForBadges.Users.CountAsync(u => u.InvitedByUserId != null && u.CreatedAt >= day30);
    var referralsTotal = await _dbForBadges.Users.CountAsync(u => u.InvitedByUserId != null);
}

<div class="admin-wide">
    <header class="admin-page-header">
        <p class="admin-page-eyebrow">Admin</p>
        <h2 class="admin-page-title">Dashboard</h2>
    </header>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- User Stats -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header fw-semibold" style="background-color: var(--mst-primary); color: white;">
                Users
            </div>
            <div class="card-body p-0">
                <div class="row g-0 text-center">
                    <div class="col-6 col-md-3 p-3 border-end border-bottom">
                        <div class="fs-3 fw-bold" style="color: var(--mst-primary);">@Model.TotalUsers</div>
                        <div class="small text-muted">Total Registered</div>
                    </div>
                    <div class="col-6 col-md-3 p-3 border-end border-bottom">
                        <div class="fs-3 fw-bold" style="color: var(--mst-accent);">@Model.NewUsersThisWeek</div>
                        <div class="small text-muted">New This Week</div>
                    </div>
                    <div class="col-6 col-md-3 p-3 border-end border-bottom">
                        <div class="fs-3 fw-bold text-success">@Model.ActiveUsersLast30Days</div>
                        <div class="small text-muted">Active (30 days)</div>
                    </div>
                    <div class="col-6 col-md-3 p-3 border-bottom">
                        <div class="fs-3 fw-bold text-info">@Model.ActiveUsersNow</div>
                        <div class="small text-muted">Online Now</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Content Stats -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header fw-semibold" style="background-color: var(--mst-secondary); color: white;">
                Content
            </div>
            <div class="card-body p-0">
                <div class="row g-0 text-center">
                    <div class="col-4 p-3 border-end">
                        <div class="fs-3 fw-bold" style="color: var(--mst-primary);">@Model.TotalPosts</div>
                        <div class="small text-muted">Total Posts</div>
                    </div>
                    <div class="col-4 p-3 border-end">
                        <div class="fs-3 fw-bold" style="color: var(--mst-secondary);">@Model.TotalComments</div>
                        <div class="small text-muted">Comments</div>
                    </div>
                    <div class="col-4 p-3">
                        <div class="fs-3 fw-bold" style="color: var(--mst-accent);">@Model.TotalLikes</div>
                        <div class="small text-muted">Likes</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Analytics — append-only event log -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header fw-semibold" style="background-color: var(--mst-accent); color: var(--mst-ink);">
                Analytics — last 24h / 7d / 30d / total
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 analytics-table">
                    <thead>
                        <tr class="text-muted small">
                            <th class="ps-3">Event</th>
                            <th class="text-end">24h</th>
                            <th class="text-end">7d</th>
                            <th class="text-end">30d</th>
                            <th class="text-end pe-3">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-3">Signups <span class="text-muted small">(register)</span></td>
                            <td class="text-end">@Stat("register", "d1")</td>
                            <td class="text-end">@Stat("register", "d7")</td>
                            <td class="text-end">@Stat("register", "d30")</td>
                            <td class="text-end pe-3 fw-semibold">@Stat("register", "total")</td>
                        </tr>
                        <tr>
                            <td class="ps-3">Stories published <span class="text-muted small">(post.published)</span></td>
                            <td class="text-end">@Stat("post.published", "d1")</td>
                            <td class="text-end">@Stat("post.published", "d7")</td>
                            <td class="text-end">@Stat("post.published", "d30")</td>
                            <td class="text-end pe-3 fw-semibold">@Stat("post.published", "total")</td>
                        </tr>
                        <tr>
                            <td class="ps-3">Invites sent <span class="text-muted small">(invite.sent)</span></td>
                            <td class="text-end">@Stat("invite.sent", "d1")</td>
                            <td class="text-end">@Stat("invite.sent", "d7")</td>
                            <td class="text-end">@Stat("invite.sent", "d30")</td>
                            <td class="text-end pe-3 fw-semibold">@Stat("invite.sent", "total")</td>
                        </tr>
                        <tr>
                            <td class="ps-3">Login-days <span class="text-muted small">(unique user/day)</span></td>
                            <td class="text-end">@Stat("login.day", "d1")</td>
                            <td class="text-end">@Stat("login.day", "d7")</td>
                            <td class="text-end">@Stat("login.day", "d30")</td>
                            <td class="text-end pe-3 fw-semibold">@Stat("login.day", "total")</td>
                        </tr>
                        <tr class="border-top">
                            <td class="ps-3 fw-semibold">Referral signups <span class="text-muted small">(via invite or ?ref=)</span></td>
                            <td class="text-end text-muted">—</td>
                            <td class="text-end" style="color: var(--mst-primary);">@referralsD7</td>
                            <td class="text-end" style="color: var(--mst-primary);">@referralsD30</td>
                            <td class="text-end pe-3 fw-semibold" style="color: var(--mst-primary);">@referralsTotal</td>
                        </tr>
                        <tr class="border-top">
                            <td class="ps-3 fw-bold" style="color: var(--mst-primary);">New subscriptions <span class="text-muted small fw-normal">(subscription.started)</span></td>
                            <td class="text-end" style="color: var(--mst-primary);">@Stat("subscription.started", "d1")</td>
                            <td class="text-end" style="color: var(--mst-primary);">@Stat("subscription.started", "d7")</td>
                            <td class="text-end" style="color: var(--mst-primary);">@Stat("subscription.started", "d30")</td>
                            <td class="text-end pe-3 fw-bold" style="color: var(--mst-primary);">@Stat("subscription.started", "total")</td>
                        </tr>
                        <tr>
                            <td class="ps-3">Renewals <span class="text-muted small">(subscription.renewed)</span></td>
                            <td class="text-end">@Stat("subscription.renewed", "d1")</td>
                            <td class="text-end">@Stat("subscription.renewed", "d7")</td>
                            <td class="text-end">@Stat("subscription.renewed", "d30")</td>
                            <td class="text-end pe-3 fw-semibold">@Stat("subscription.renewed", "total")</td>
                        </tr>
                        <tr>
                            <td class="ps-3">Cancellations <span class="text-muted small">(subscription.cancelled)</span></td>
                            <td class="text-end">@Stat("subscription.cancelled", "d1")</td>
                            <td class="text-end">@Stat("subscription.cancelled", "d7")</td>
                            <td class="text-end">@Stat("subscription.cancelled", "d30")</td>
                            <td class="text-end pe-3 fw-semibold">@Stat("subscription.cancelled", "total")</td>
                        </tr>
                        <tr>
                            <td class="ps-3">Payment failures <span class="text-muted small">(subscription.payment_failed)</span></td>
                            <td class="text-end @(Stat("subscription.payment_failed", "d1") > 0 ? "text-danger fw-semibold" : "")">@Stat("subscription.payment_failed", "d1")</td>
                            <td class="text-end @(Stat("subscription.payment_failed", "d7") > 0 ? "text-danger fw-semibold" : "")">@Stat("subscription.payment_failed", "d7")</td>
                            <td class="text-end @(Stat("subscription.payment_failed", "d30") > 0 ? "text-danger fw-semibold" : "")">@Stat("subscription.payment_failed", "d30")</td>
                            <td class="text-end pe-3 fw-semibold @(Stat("subscription.payment_failed", "total") > 0 ? "text-danger" : "")">@Stat("subscription.payment_failed", "total")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Ban Stats -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header fw-semibold bg-danger text-white">
                Moderation
            </div>
            <div class="card-body p-0">
                <div class="row g-0 text-center">
                    <div class="col-6 p-3 border-end">
                        <div class="fs-3 fw-bold text-warning">@Model.ActiveBans</div>
                        <div class="small text-muted">Active Temp Bans</div>
                    </div>
                    <div class="col-6 p-3">
                        <div class="fs-3 fw-bold text-danger">@Model.PermanentBans</div>
                        <div class="small text-muted">Permanent Bans</div>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="mt-4 mb-2 fw-semibold" style="color: var(--mst-primary);">Tools</h5>
        <div class="admin-tool-grid">
            <a asp-action="Users" class="admin-tool-card admin-tool-primary">
                <div class="admin-tool-icon">👥</div>
                <div class="admin-tool-name">Users</div>
                <div class="admin-tool-desc">List, ban, unban, role changes.</div>
            </a>
            <a asp-action="PendingSignups" class="admin-tool-card @(pendingSignups > 0 ? "admin-tool-attention" : "")">
                <div class="admin-tool-icon">📨</div>
                <div class="admin-tool-name">
                    Pending Signups
                    @if (pendingSignups > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">@pendingSignups</span>
                    }
                </div>
                <div class="admin-tool-desc">Accounts stuck unverified or locked — approve, resend, unlock.</div>
            </a>
            <a asp-action="Reports" class="admin-tool-card @(pendingReports > 0 ? "admin-tool-attention" : "")">
                <div class="admin-tool-icon">🚩</div>
                <div class="admin-tool-name">
                    Reports
                    @if (pendingReports > 0)
                    {
                        <span class="badge bg-danger ms-1">@pendingReports</span>
                    }
                </div>
                <div class="admin-tool-desc">User-flagged posts, comments, and accounts.</div>
            </a>
            <a asp-action="DeletionRequests" class="admin-tool-card @(pendingDeletions > 0 ? "admin-tool-attention" : "")">
                <div class="admin-tool-icon">🗑️</div>
                <div class="admin-tool-name">
                    Deletion Requests
                    @if (pendingDeletions > 0)
                    {
                        <span class="badge bg-danger ms-1">@pendingDeletions</span>
                    }
                </div>
                <div class="admin-tool-desc">Users who asked an admin to delete their account.</div>
            </a>
            <a asp-action="Channels" class="admin-tool-card">
                <div class="admin-tool-icon">📚</div>
                <div class="admin-tool-name">Channels</div>
                <div class="admin-tool-desc">Topical buckets like History or Family Tales — assign one writer per channel.</div>
            </a>
            <a asp-action="ManagedUsers" class="admin-tool-card">
                <div class="admin-tool-icon">📜</div>
                <div class="admin-tool-name">Biographical Profiles</div>
                <div class="admin-tool-desc">Fictional / historical figures (e.g., Caesar). You post as them; they can't log in.</div>
            </a>
            <a asp-action="Tips" class="admin-tool-card">
                <div class="admin-tool-icon">📣</div>
                <div class="admin-tool-name">Tips &amp; Announcements</div>
                <div class="admin-tool-desc">Tips for the sidebar; broadcast announcements to all users.</div>
            </a>
            <a asp-action="MemoryPrompts" class="admin-tool-card">
                <div class="admin-tool-icon">💭</div>
                <div class="admin-tool-name">Memory Prompts</div>
                <div class="admin-tool-desc">Daily writing prompts surfaced in the rail.</div>
            </a>
            <a asp-action="QuillMessages" class="admin-tool-card">
                <div class="admin-tool-icon">🪶</div>
                <div class="admin-tool-name">Landing-page Quill</div>
                <div class="admin-tool-desc">The rotating taglines on the public landing page.</div>
            </a>
            <a asp-action="SiteSettings" class="admin-tool-card">
                <div class="admin-tool-icon">⚙️</div>
                <div class="admin-tool-name">Site Settings</div>
                <div class="admin-tool-desc">Global toggles: channels, biographical posts, evergreen surfacing.</div>
            </a>
            <a asp-action="CreatorNotes" class="admin-tool-card">
                <div class="admin-tool-icon">📝</div>
                <div class="admin-tool-name">Creator's Notes</div>
                <div class="admin-tool-desc">Private scratchpad. Premium features + services lists.</div>
            </a>
            <a asp-action="PremiumCatalog" class="admin-tool-card">
                <div class="admin-tool-icon">⭐</div>
                <div class="admin-tool-name">Premium Catalog</div>
                <div class="admin-tool-desc">All features tagged premium, grouped by tier. Read-only.</div>
            </a>
            <a asp-action="EmailTest" class="admin-tool-card">
                <div class="admin-tool-icon">✉️</div>
                <div class="admin-tool-name">Email Test</div>
                <div class="admin-tool-desc">Send a probe email to verify SendGrid wiring.</div>
            </a>
        </div>
</div>
