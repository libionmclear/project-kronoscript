@model List<MyStoryTold.Models.Report>
@{
    ViewData["Title"] = "Reported Content";
}

<div class="row g-4">
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>

    <div class="col-md-10 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">Reported Content</h4>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Admin Dashboard</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <div class="alert alert-warning small mb-3">
            Each row links to the reported item. Open it in a new tab, decide if it
            violates the <a asp-controller="Home" asp-action="AcceptableUse">Acceptable Use Policy</a>,
            and either <strong>Dismiss</strong> (no violation) or take action on the content
            (delete / ban) and then <strong>Mark actioned</strong>.
        </div>

        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center text-muted p-4">No pending reports.</div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Reporter</th>
                                <th>Target</th>
                                <th>Reason</th>
                                <th>When</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                var name = r.Reporter?.DisplayName ?? r.Reporter?.UserName ?? r.ReporterUserId;
                                string targetLink;
                                string targetLabel;
                                switch (r.TargetType)
                                {
                                    case MyStoryTold.Models.ReportTargetType.Post:
                                        targetLink = "/Posts/Detail/" + r.TargetId;
                                        targetLabel = "Post #" + r.TargetId;
                                        break;
                                    case MyStoryTold.Models.ReportTargetType.Comment:
                                        targetLink = "/Posts/Detail/?#comment-" + r.TargetId;
                                        targetLabel = "Comment #" + r.TargetId;
                                        break;
                                    default:
                                        targetLink = "/Profile/Index/" + r.TargetId;
                                        targetLabel = "User";
                                        break;
                                }
                                <tr>
                                    <td><small>@name</small></td>
                                    <td>
                                        <span class="badge bg-secondary">@r.TargetType</span>
                                        <a href="@targetLink" target="_blank" rel="noopener">@targetLabel ↗</a>
                                    </td>
                                    <td><small>@(string.IsNullOrEmpty(r.Reason) ? "—" : r.Reason)</small></td>
                                    <td><small class="text-muted">@r.CreatedAt.ToString("MMM d, yyyy h:mm tt") UTC</small></td>
                                    <td class="text-end">
                                        <form asp-action="DismissReport" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Dismiss</button>
                                        </form>
                                        <form asp-action="MarkReportActioned" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Mark actioned</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
