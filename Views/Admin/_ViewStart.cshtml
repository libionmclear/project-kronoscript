@{
    Layout = "_Layout";
    // Admin pages drop the NetworkSidebar (CSS hides .col-sidebar on
    // body.admin-page) but stay bounded by the navbar's container —
    // the right edge sits under the user dropdown, the left under the
    // Kronoscript wordmark. So: same .container as the navbar, not
    // container-fluid.
    ViewData["BodyClass"] = ((ViewData["BodyClass"] as string) ?? "") + " admin-page";
    ViewData["ContainerClass"] = "container mt-3";
}
