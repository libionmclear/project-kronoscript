@{
    ViewData["Title"] = "Site Settings";
    var channelsEnabled = (bool)ViewBag.ChannelsEnabled;
    var biographicalEnabled = (bool)ViewBag.BiographicalEnabled;
    var evergreenSurfacing = (bool)ViewBag.EvergreenSurfacing;

    var evChMax       = (int)ViewBag.EvergreenChannelMaxPerPage;
    var evChPos       = (string)ViewBag.EvergreenChannelPosition;
    var evChOrder     = (string)ViewBag.EvergreenChannelOrder;
    var evChBackToBack= (bool)ViewBag.EvergreenChannelAllowBackToBack;
    var evChDaily     = (bool)ViewBag.EvergreenChannelDailyOnePerSource;
    var evBioMax      = (int)ViewBag.EvergreenBioMaxPerPage;
    var evBioPos      = (string)ViewBag.EvergreenBioPosition;
    var evBioOrder    = (string)ViewBag.EvergreenBioOrder;
    var evBioBackToBack = (bool)ViewBag.EvergreenBioAllowBackToBack;
    var evBioDaily    = (bool)ViewBag.EvergreenBioDailyOnePerSource;

    var bannerEnabled = (bool)ViewBag.BannerEnabled;
    var bannerText = ViewBag.BannerText as string;
    var bannerSeverity = (ViewBag.BannerSeverity as string) ?? "info";
    var bannerLinkUrl = ViewBag.BannerLinkUrl as string;
    var bannerLinkText = ViewBag.BannerLinkText as string;
    var bannerVersion = (int)ViewBag.BannerVersion;

    var whatsNewEnabled = (bool)ViewBag.WhatsNewEnabled;
    var whatsNewTitle = ViewBag.WhatsNewTitle as string;
    var whatsNewBody = ViewBag.WhatsNewBody as string;
    var whatsNewVersion = (int)ViewBag.WhatsNewVersion;
}

<div class="row g-4">
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">Site Settings</h4>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Admin Dashboard</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <form asp-action="SiteSettings" method="post">
            @Html.AntiForgeryToken()

            <!-- ── Feature toggles ─────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2" style="color:var(--mst-primary);">Feed features</h6>
                    <p class="text-muted small mb-3">
                        Global toggles. Individual users can also hide channels or biographies from
                        <em>their</em> feed in Profile → Settings; the toggles below cut at the source.
                    </p>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="channelsEnabled" name="channelsEnabled" value="true" @(channelsEnabled ? "checked" : "") />
                        <label class="form-check-label fw-semibold" for="channelsEnabled">Channel posts enabled</label>
                        <div class="small text-muted">When off, channel posts disappear from every feed and detail view.</div>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="biographicalEnabled" name="biographicalEnabled" value="true" @(biographicalEnabled ? "checked" : "") />
                        <label class="form-check-label fw-semibold" for="biographicalEnabled">Biographical-profile posts enabled</label>
                        <div class="small text-muted">When off, posts authored by biographical / managed accounts (e.g., Caesar) are hidden from feeds.</div>
                    </div>
                    <div class="form-check form-switch mb-1">
                        <input class="form-check-input" type="checkbox" id="evergreenSurfacing" name="evergreenSurfacing" value="true" @(evergreenSurfacing ? "checked" : "") />
                        <label class="form-check-label fw-semibold" for="evergreenSurfacing">Resurface evergreen content</label>
                        <div class="small text-muted">Master switch for the rules below — older channel and biographical posts (>14 days) get re-surfaced into home feeds.</div>
                    </div>
                </div>
            </div>

            <!-- ── Evergreen surfacing rules ────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2" style="color:var(--mst-primary);">📚 Channel post surfacing</h6>
                    <p class="text-muted small mb-3">How often, in what order, and where channel posts re-appear in the home feed.</p>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold mb-1" for="evergreenChannelMaxPerPage">Max per page load</label>
                            <input class="form-control form-control-sm" type="number" min="0" max="10"
                                   id="evergreenChannelMaxPerPage" name="evergreenChannelMaxPerPage" value="@evChMax" />
                            <div class="form-text small">0 disables; typical 1–5.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold mb-1" for="evergreenChannelPosition">Where they land</label>
                            <select class="form-select form-select-sm" id="evergreenChannelPosition" name="evergreenChannelPosition">
                                <option value="random" selected="@(evChPos == "random")">Random spread (default)</option>
                                <option value="top" selected="@(evChPos == "top")">Top of feed</option>
                                <option value="middle" selected="@(evChPos == "middle")">Middle of feed</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold mb-1" for="evergreenChannelOrder">Pick order</label>
                            <select class="form-select form-select-sm" id="evergreenChannelOrder" name="evergreenChannelOrder">
                                <option value="random" selected="@(evChOrder == "random")">Random</option>
                                <option value="recent" selected="@(evChOrder == "recent")">Most recent first</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="evergreenChannelAllowBackToBack" name="evergreenChannelAllowBackToBack" value="true" @(evChBackToBack ? "checked" : "") />
                        <label class="form-check-label small" for="evergreenChannelAllowBackToBack">Allow back-to-back channel posts</label>
                        <div class="small text-muted">When off, surfaced channel posts are spread so two never sit next to each other.</div>
                    </div>
                    <div class="form-check form-switch mb-1">
                        <input class="form-check-input" type="checkbox" id="evergreenChannelDailyOnePerSource" name="evergreenChannelDailyOnePerSource" value="true" @(evChDaily ? "checked" : "") />
                        <label class="form-check-label small" for="evergreenChannelDailyOnePerSource">Show one post per channel per day, per user</label>
                        <div class="small text-muted">Stops a single channel from monopolising the rotation. The pick is stable per user per day.</div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2" style="color:var(--mst-primary);">📜 Biographical post surfacing</h6>
                    <p class="text-muted small mb-3">Same controls, applied to posts authored by biographical / managed accounts.</p>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold mb-1" for="evergreenBioMaxPerPage">Max per page load</label>
                            <input class="form-control form-control-sm" type="number" min="0" max="10"
                                   id="evergreenBioMaxPerPage" name="evergreenBioMaxPerPage" value="@evBioMax" />
                            <div class="form-text small">0 disables; typical 1–3.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold mb-1" for="evergreenBioPosition">Where they land</label>
                            <select class="form-select form-select-sm" id="evergreenBioPosition" name="evergreenBioPosition">
                                <option value="random" selected="@(evBioPos == "random")">Random spread (default)</option>
                                <option value="top" selected="@(evBioPos == "top")">Top of feed</option>
                                <option value="middle" selected="@(evBioPos == "middle")">Middle of feed</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold mb-1" for="evergreenBioOrder">Pick order</label>
                            <select class="form-select form-select-sm" id="evergreenBioOrder" name="evergreenBioOrder">
                                <option value="random" selected="@(evBioOrder == "random")">Random</option>
                                <option value="recent" selected="@(evBioOrder == "recent")">Most recent first</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="evergreenBioAllowBackToBack" name="evergreenBioAllowBackToBack" value="true" @(evBioBackToBack ? "checked" : "") />
                        <label class="form-check-label small" for="evergreenBioAllowBackToBack">Allow back-to-back biographical posts</label>
                    </div>
                    <div class="form-check form-switch mb-1">
                        <input class="form-check-input" type="checkbox" id="evergreenBioDailyOnePerSource" name="evergreenBioDailyOnePerSource" value="true" @(evBioDaily ? "checked" : "") />
                        <label class="form-check-label small" for="evergreenBioDailyOnePerSource">Show one post per biographical account per day, per user</label>
                    </div>
                </div>
            </div>

            <!-- ── Site banner (top-of-page strip) ─────────────────────── -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2" style="color:var(--mst-primary);">Site banner</h6>
                    <p class="text-muted small mb-3">
                        Shows a thin strip at the top of every page until each user dismisses it.
                        Editing the text auto-bumps the version so users see the new copy even if they
                        already dismissed an earlier one. Currently at version <strong>@bannerVersion</strong>.
                    </p>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="bannerEnabled" name="bannerEnabled" value="true" @(bannerEnabled ? "checked" : "") />
                        <label class="form-check-label fw-semibold" for="bannerEnabled">Banner enabled</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message</label>
                        <textarea name="bannerText" class="form-control" rows="2" maxlength="500" placeholder="Heads up: planned downtime Sunday 10–11 UTC for a database upgrade.">@bannerText</textarea>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Severity</label>
                            <select name="bannerSeverity" class="form-select">
                                <option value="info" selected="@(bannerSeverity == "info")">Info (teal)</option>
                                <option value="warning" selected="@(bannerSeverity == "warning")">Warning (gold)</option>
                                <option value="critical" selected="@(bannerSeverity == "critical")">Critical (red)</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Optional link URL</label>
                            <input type="url" name="bannerLinkUrl" value="@bannerLinkUrl" class="form-control" placeholder="https://blog.example.com/post" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Link text</label>
                            <input type="text" name="bannerLinkText" value="@bannerLinkText" class="form-control" placeholder="Read more" maxlength="40" />
                        </div>
                    </div>
                    <div class="form-check small">
                        <input class="form-check-input" type="checkbox" id="bannerForceShowAll" name="bannerForceShowAll" value="true" />
                        <label class="form-check-label" for="bannerForceShowAll">
                            Force-show to everyone (re-prompt users who dismissed the previous version)
                        </label>
                    </div>
                </div>
            </div>

            <!-- ── What's new modal ────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2" style="color:var(--mst-primary);">What's new modal</h6>
                    <p class="text-muted small mb-3">
                        Pops up once per user on the home feed when the version increments. Use this
                        for feature announcements that you want everyone to read once. Currently at
                        version <strong>@whatsNewVersion</strong>.
                    </p>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="whatsNewEnabled" name="whatsNewEnabled" value="true" @(whatsNewEnabled ? "checked" : "") />
                        <label class="form-check-label fw-semibold" for="whatsNewEnabled">What's new modal enabled</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" name="whatsNewTitle" value="@whatsNewTitle" class="form-control" maxlength="120" placeholder="Channels, biographies, and a sleeker feed" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Body</label>
                        <textarea name="whatsNewBody" class="form-control" rows="6" maxlength="2000" placeholder="• Posts can now be focused — click any thumbnail in Edit to set the crop center.&#10;• Settings is reorganized into collapsible sections.&#10;• …">@whatsNewBody</textarea>
                        <small class="text-muted">Plain text. Each line shows on its own row; bullet characters are rendered as-is.</small>
                    </div>
                    <div class="form-check small">
                        <input class="form-check-input" type="checkbox" id="whatsNewForceShowAll" name="whatsNewForceShowAll" value="true" />
                        <label class="form-check-label" for="whatsNewForceShowAll">
                            Force-show to everyone (re-prompt users who saw the previous version)
                        </label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mb-4">
                <button type="submit" class="btn btn-primary">Save settings</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
