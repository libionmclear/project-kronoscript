@{
    ViewData["Title"] = "New biographical profile";
}

<div class="row g-4">
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">New biographical profile</h4>
            <a asp-action="ManagedUsers" class="btn btn-sm btn-outline-secondary">← All profiles</a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger small">@TempData["Error"]</div>
        }

        <div class="alert alert-info small mb-3">
            Biographical profiles are for fictional / historical / public figures. The admin who creates one
            <em>posts as</em> them — the profile itself can't log in. Pick a username carefully; it shows up
            as <code>@@username</code> on every post.
        </div>

        <form asp-action="CreateManagedUser" method="post" class="card border-0 shadow-sm">
            @Html.AntiForgeryToken()
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Username</label>
                        <input type="text" name="userName" class="form-control" placeholder="caesar" required maxlength="60" />
                        <small class="text-muted">URL-friendly: lowercase letters, numbers, underscores.</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Display name</label>
                        <input type="text" name="displayName" class="form-control" placeholder="Gaius Julius Caesar" maxlength="50" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Era</label>
                        <input type="text" name="era" class="form-control" placeholder="100 BC – 44 BC" maxlength="60" />
                        <small class="text-muted">Free-text date span shown on the profile.</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Profile photo URL</label>
                        <input type="url" name="profilePhotoUrl" class="form-control" placeholder="https://..." maxlength="500" />
                        <small class="text-muted">Paste a public image URL (Wikimedia, etc.). You can leave it blank for now.</small>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Summary</label>
                        <textarea name="summary" class="form-control" rows="2" maxlength="500"
                                  placeholder="Roman general and statesman whose conquests and political maneuvering ended the Republic."></textarea>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary">Create profile</button>
                    <a asp-action="ManagedUsers" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
