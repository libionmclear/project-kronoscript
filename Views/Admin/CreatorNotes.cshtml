@{
    ViewData["Title"] = "Creator's Notes";
    var premiumFeatures = ViewBag.CreatorNotesPremiumFeatures as string ?? "";
    var premiumServices = ViewBag.CreatorNotesPremiumServices as string ?? "";
}

<div class="row g-4">
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">📝 Creator's Notes</h4>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Admin Dashboard</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Private scratchpad — only admins can see this. Two free-form lists for what's planned.
                    One item per line. Add, edit, delete, reorder by editing the textareas.
                </p>

                <form asp-action="CreatorNotes" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold mb-1" for="premiumFeatures">
                            ⭐ Premium features <span class="text-muted small fw-normal">(recurring subscription)</span>
                        </label>
                        <textarea class="form-control font-monospace" rows="18"
                                  id="premiumFeatures" name="premiumFeatures"
                                  spellcheck="false">@premiumFeatures</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold mb-1" for="premiumServices">
                            🎁 Premium services <span class="text-muted small fw-normal">(one-off, paid)</span>
                        </label>
                        <textarea class="form-control font-monospace" rows="18"
                                  id="premiumServices" name="premiumServices"
                                  spellcheck="false">@premiumServices</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
