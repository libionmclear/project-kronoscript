@model IReadOnlyList<MyStoryTold.Models.PremiumFeatureInfo>
@using MyStoryTold.Models
@{
    ViewData["Title"] = "Premium Catalog";
    var enforcing = (bool)ViewBag.EnforcementActive;
    var modes = ViewBag.FeatureModes as Dictionary<PremiumFeature, FeatureMode> ?? new();
    var byTier = Model.GroupBy(f => f.Tier).OrderBy(g => g.Key);
}

<div class="row g-4">
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">⭐ Premium Catalog</h4>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Admin Dashboard</a>
        </div>

        <div class="alert @(enforcing ? "alert-warning" : "alert-info") py-2 mb-3">
            <strong>Enforcement is currently @(enforcing ? "ON" : "OFF").</strong>
            @if (enforcing)
            {
                <span>Features below are gated by users' PremiumUntil + tier. Non-subscribers see the upgrade card instead of the feature.</span>
            }
            else
            {
                <span>The catalog is informational only — every premium feature is available to every user. Flip on at <a asp-action="SiteSettings">Site Settings</a> when subscriptions go live.</span>
            }
            <div class="small mt-2">
                The per-row <strong>All / Premium / Off</strong> switch below is independent of global enforcement.
                <strong>All</strong> = everyone sees it. <strong>Premium</strong> = subscribers only (and admins).
                <strong>Off</strong> = hidden from regular users entirely (admins still see it, to keep testing).
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <p class="text-muted small mb-4">
            Single source of truth for what's tagged premium lives in C#
            (<code>PremiumService.Catalog</code>). To add or change anything here, edit the catalog
            and re-deploy — this page just renders it.
        </p>

        @foreach (var tier in byTier)
        {
            <h5 class="mt-4 mb-2" style="color: var(--mst-primary);">
                @switch (tier.Key)
                {
                    case MyStoryTold.Models.PremiumTier.Personal:
                        <span>👤 Personal</span><span class="text-muted small ms-2">recurring subscription</span>
                        break;
                    case MyStoryTold.Models.PremiumTier.Family:
                        <span>👨‍👩‍👧 Family</span><span class="text-muted small ms-2">recurring, family group</span>
                        break;
                    case MyStoryTold.Models.PremiumTier.Legacy:
                        <span>🌳 Legacy</span><span class="text-muted small ms-2">one-time, perpetual</span>
                        break;
                }
            </h5>
            <div class="card border-0 shadow-sm mb-3">
                <ul class="list-group list-group-flush">
                    @foreach (var f in tier.OrderBy(f => !f.Built).ThenBy(f => f.Name))
                    {
                        var mode = modes.TryGetValue(f.Key, out var m) ? m : FeatureMode.All;
                        <li class="list-group-item d-flex align-items-start gap-3 py-3 flex-wrap">
                            <div style="flex:1 1 320px;min-width:260px;">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <strong>@f.Name</strong>
                                    @if (f.Built)
                                    {
                                        <span class="badge bg-success-subtle text-success small">Live</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary small">Coming soon</span>
                                    }
                                    @switch (mode)
                                    {
                                        case FeatureMode.All:
                                            <span class="badge bg-info-subtle text-info small" title="Visible to everyone, regardless of subscription.">🔓 All users</span>
                                            break;
                                        case FeatureMode.Premium:
                                            <span class="badge bg-warning-subtle text-warning small" title="Only premium subscribers see this. Admins also see it.">⭐ Premium only</span>
                                            break;
                                        case FeatureMode.Off:
                                            <span class="badge bg-danger-subtle text-danger small" title="Hidden from everyone except admins.">🚫 Off (admins only)</span>
                                            break;
                                    }
                                </div>
                                <div class="text-muted small mt-1">@f.Description</div>
                                <code class="small text-muted">PremiumFeature.@f.Key</code>
                            </div>
                            <div class="d-flex gap-1 align-items-center" style="flex:0 0 auto;">
                                @foreach (var (label, value, btnClass, title) in new[]
                                {
                                    ("All",     FeatureMode.All,     "btn-outline-info",    "Open this feature to every user."),
                                    ("Premium", FeatureMode.Premium, "btn-outline-warning", "Gate to premium subscribers (admins also pass)."),
                                    ("Off",     FeatureMode.Off,     "btn-outline-danger",  "Hide entirely from users (admins still see it for testing).")
                                })
                                {
                                    var active = mode == value;
                                    <form asp-action="SetFeatureMode" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="feature" value="@f.Key" />
                                        <input type="hidden" name="mode" value="@value" />
                                        <button type="submit"
                                                class="btn btn-sm @(active ? btnClass.Replace("btn-outline-", "btn-") : btnClass)"
                                                @(active ? "disabled" : "")
                                                title="@title">@label</button>
                                    </form>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>
