@model MyStoryTold.Models.Channel
@{
    ViewData["Title"] = "New channel";
}

<div class="row g-4">
    <div class="col-md-2 col-sidebar">
        @await Component.InvokeAsync("NetworkSidebar")
    </div>
    <div class="col-md-8 col-main">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color: var(--mst-primary);">New channel</h4>
            <a asp-action="Channels" class="btn btn-sm btn-outline-secondary">← All channels</a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger small">@TempData["Error"]</div>
        }

        <form asp-action="CreateChannel" method="post" class="card border-0 shadow-sm">
            @Html.AntiForgeryToken()
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Name</label>
                        <input asp-for="Name" class="form-control" placeholder="History" required maxlength="80" />
                        <small class="text-muted">Shown on the channel badge and as a heading.</small>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Icon (emoji)</label>
                        <input asp-for="IconEmoji" class="form-control text-center" placeholder="📚" maxlength="4" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Slug</label>
                        <input asp-for="Slug" class="form-control" placeholder="history" maxlength="80" />
                        <small class="text-muted">URL-friendly identifier. Leave blank and we'll generate one from the name.</small>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" maxlength="500"
                                  placeholder="Tidbits of history. Where were you when X happened?"></textarea>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="DefaultLayoutStyle" class="form-label">Default layout style</label>
                        <select asp-for="DefaultLayoutStyle" class="form-select">
                            <option value="1">📰 Journal (newspaper) — serif headline, two-column body, drop cap</option>
                            <option value="2">📖 Book — italic title, single chapter column, dingbat divider</option>
                            <option value="0">Standard — feed-style card</option>
                        </select>
                        <small class="text-muted">
                            Posts published into this channel pick this style up automatically. The writer
                            can still flip an individual post to a different layout in Edit.
                        </small>
                    </div>
                    <div class="col-md-12 user-typeahead-wrap">
                        <label class="form-label">Assigned writer</label>
                        <input type="text" name="adminEmailOrUsername" class="form-control user-typeahead-input"
                               placeholder="Start typing a username, email, or display name…" autocomplete="off" />
                        <div class="user-typeahead-results list-group shadow"></div>
                        <small class="text-muted d-block mt-1">
                            The one user who can publish into this channel. Leave blank and only app
                            admins will be able to post here.
                        </small>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary">Create channel</button>
                    <a asp-action="Channels" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

<script src="~/js/user-typeahead.js" asp-append-version="true"></script>
